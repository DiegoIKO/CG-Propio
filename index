function printMulticriterioAll() {
  const matrices = state.multiCriteria || [];
  if (matrices.length === 0) { toast('No hay matrices para imprimir'); return; }
  
  const matricesHTML = matrices.map(m => {
    const criteria = m.criteria || [];
    const options = m.options || [];
    
    // Calcular score por opción
    const totalWeight = criteria.reduce((s, c) => s + (c.weight || 1), 0) || 1;
    const scored = options.map(opt => {
      let score = 0;
      criteria.forEach(c => {
        const val = (opt.scores && opt.scores[c.id]) || 0;
        score += val * (c.weight || 1);
      });
      const normalized = score / totalWeight;
      return { name: opt.name, score: normalized, raw: score };
    });
    scored.sort((a, b) => b.score - a.score);
    
    const tableHTML = `<table style="width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 11.5px">
      <thead><tr style="background: #f0ebe0">
        <th style="border: 1px solid #d8d2c4; padding: 8px; text-align: left">Opción</th>
        ${criteria.map(c => `<th style="border: 1px solid #d8d2c4; padding: 8px; text-align: center; font-size: 10.5px">${escapeHtml(c.name)}<br><span style="color:#6b6357; font-weight: normal">peso: ${c.weight || 1}</span></th>`).join('')}
        <th style="border: 1px solid #d8d2c4; padding: 8px; text-align: center; background: #15110d; color: white">Puntaje</th>
      </tr></thead>
      <tbody>
        ${scored.map((s, i) => {
          const opt = options.find(o => o.name === s.name);
          const isTop = i === 0;
          return `<tr style="${isTop ? 'background: #e8f5e8' : ''}">
            <td style="border: 1px solid #d8d2c4; padding: 8px; font-weight: ${isTop ? '600' : '400'}">${isTop ? '★ ' : ''}${escapeHtml(s.name)}</td>
            ${criteria.map(c => `<td style="border: 1px solid #d8d2c4; padding: 8px; text-align: center">${(opt.scores && opt.scores[c.id]) || 0}</td>`).join('')}
            <td style="border: 1px solid #d8d2c4; padding: 8px; text-align: center; font-family: 'JetBrains Mono', monospace; font-weight: 600; ${isTop ? 'color: #4a7c4a' : ''}">${s.score.toFixed(2)}</td>
          </tr>`;
        }).join('')}
      </tbody>
    </table>
    <div style="margin-top: 12px; padding: 12px; background: #f7f4ee; border-radius: 6px; font-size: 12px">
      <strong style="color: #4a7c4a">★ Opción recomendada:</strong> ${scored[0] ? escapeHtml(scored[0].name) : '—'} (puntaje ${scored[0] ? scored[0].score.toFixed(2) : '—'})
    </div>`;
    
    return `<div style="margin-bottom: 32px; page-break-inside: avoid">
      <div style="font-family: 'Instrument Serif', serif; font-size: 20px; margin-bottom: 4px">${escapeHtml(m.name || 'Sin nombre')}</div>
      ${m.description ? `<div style="font-size: 11px; color: #6b6357; font-style: italic; margin-bottom: 8px">${escapeHtml(m.description)}</div>` : ''}
      ${tableHTML}
    </div>`;
  }).join('');
  
  const content = `
    <div style="text-align: center; margin-bottom: 20px">
      <div style="font-size: 11px; color: #6b6357; font-style: italic">Priorización multicriterio · Toma de decisiones con criterios ponderados</div>
    </div>
    ${matricesHTML}
  `;
  
  _printAnalysisShell('Análisis multicriterio', content);
}

