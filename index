function sortTasksList(tasks) {
  const { key, dir } = tareasSort;
  const mult = dir === 'asc' ? 1 : -1;
  return [...tasks].sort((a, b) => {
    let va, vb;
    if (key === 'priority') {
      const ord = { alta: 0, media: 1, baja: 2 };
      va = ord[a.priority] ?? 99; vb = ord[b.priority] ?? 99;
    } else if (key === 'status') {
      const ord = { todo: 0, inProgress: 1, review: 2, done: 3 };
      va = ord[a.status] ?? 99; vb = ord[b.status] ?? 99;
    } else if (key === 'progress') {
      va = a.status === 'done' ? 100 : (a.progress || 0);
      vb = b.status === 'done' ? 100 : (b.progress || 0);
    } else if (key === 'project') {
      const pa = a.projectId ? state.projects.find(p => p.id === a.projectId) : null;
      const pb = b.projectId ? state.projects.find(p => p.id === b.projectId) : null;
      va = pa ? pa.code : ''; vb = pb ? pb.code : '';
    } else {
      va = a[key]; vb = b[key];
    }
    if (va == null && vb == null) return 0;
    if (va == null || va === '') return mult;
    if (vb == null || vb === '') return -mult;
    if (typeof va === 'number' && typeof vb === 'number') return (va - vb) * mult;
    return String(va).localeCompare(String(vb), 'es-CL', { numeric: true }) * mult;
  });
}

function setTareasSort(key) {
  if (tareasSort.key === key) {
    tareasSort.dir = tareasSort.dir === 'asc' ? 'desc' : 'asc';
  } else {
    tareasSort.key = key;
    tareasSort.dir = 'asc';
  }
  renderTareas();
}

function taskSortHeader(key, label) {
  const active = tareasSort.key === key;
  const arrow = active ? (tareasSort.dir === 'asc' ? ' ↑' : ' ↓') : '';
  return `<th onclick="setTareasSort('${key}')" style="cursor: pointer; user-select: none" title="Clic para ordenar">${escapeHtml(label)}${arrow}</th>`;
}

function renderTasksBoard() {
  const filtered = applyTaskFilter(state.tasks);
  return `<div class="tasks-kanban">
    ${TASK_STATUSES.map(s => {
      const items = filtered.filter(t => t.status === s.key);
