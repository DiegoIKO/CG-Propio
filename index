function renderBlockStrategySummary(t) {
  if (!state.objectives.length) return '';
  const byPersp = {};
  PERSPECTIVES.forEach(p => { byPersp[p] = state.objectives.filter(o => o.perspective === p); });
  const totalProgress = state.objectives.reduce((s, o) => s + (o.progress || 0), 0) / state.objectives.length;
  return `<div class="card p-5">
    <div class="flex items-center justify-between mb-4">
      <div><div class="font-serif text-xl">Avance Estratégico</div><div class="text-xs mt-1" style="color:var(--ink-muted)">Por perspectiva del Balanced Scorecard</div></div>
      <div class="text-right"><div class="text-xs" style="color:var(--ink-muted)">Promedio general</div><div class="font-serif" style="font-size: 28px; line-height: 1">${Math.round(totalProgress)}%</div></div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      ${PERSPECTIVES.map(p => {
        const objs = byPersp[p];
        const avg = objs.length ? Math.round(objs.reduce((s, o) => s + (o.progress || 0), 0) / objs.length) : 0;
        return `<div>
          <div class="text-xs mb-1" style="color:var(--ink-muted)">${escapeHtml(p)}</div>
          <div class="flex items-center gap-2 mb-1"><div class="font-serif text-2xl">${avg}%</div><div class="text-xs" style="color:var(--ink-muted)">${objs.length} obj.</div></div>
          <div style="height: 4px; background: var(--bg-sunken); border-radius: 2px; overflow: hidden"><div style="height: 100%; width: ${avg}%; background: var(--ink)"></div></div>
        </div>`;
      }).join('')}
