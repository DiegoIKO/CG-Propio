    };
    if (isEdit) Object.assign(a, payload);
    else m.agreements.push({ id: uid(), ...payload, taskId: null, createdAt: new Date().toISOString() });
    save(); closeModal(); renderReuniones(); toast(isEdit ? 'Acuerdo actualizado' : 'Acuerdo agregado');
  };
}

function removeAgreement(meetingId, agreementId) {
  if (!confirm('¿Eliminar este acuerdo? Si ya fue convertido a tarea, la tarea no se elimina automáticamente.')) return;
  const m = state.meetings.find(x => x.id === meetingId); if (!m) return;
  m.agreements = (m.agreements || []).filter(a => a.id !== agreementId);
  save(); renderReuniones(); toast('Acuerdo eliminado');
}

function convertAgreementToTask(meetingId, agreementId) {
  const m = state.meetings.find(x => x.id === meetingId); if (!m) return;
  const a = (m.agreements || []).find(x => x.id === agreementId); if (!a) return;
  if (!state.tasks) state.tasks = [];
  const newTask = {
    id: uid(),
    code: 'T-' + String(state.tasks.length + 1).padStart(3, '0'),
    title: a.text.slice(0, 100),
    description: `Acuerdo de la reunión "${m.title}" (${m.code}, ${fmtDate(m.date)}).\n\n${a.text.length > 100 ? a.text : ''}`.trim(),
    status: 'todo',
    priority: a.priority || 'media',
    assignee: a.assignee || '',
    dueDate: a.dueDate || '',
    tags: ['acuerdo', m.type.toLowerCase()],
    projectId: null,
    subtasks: [],
    meetingId: m.id,
    agreementId: a.id,
    createdAt: new Date().toISOString()
  };
  state.tasks.push(newTask);
  a.taskId = newTask.id;
  save(); renderReuniones(); toast('Acuerdo convertido en tarea ' + newTask.code);
}

