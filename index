function addPorque(id) {
  const a = state.analyses.find(x => x.id === id);
  const inp = document.getElementById(`porque-input-${id}`);
  const v = inp.value.trim(); if (!v) return;
  if (!a.whys) a.whys = [];
  a.whys.push(v); save(); renderAnalisis();
}
function removePorque(id, idx) { const a = state.analyses.find(x => x.id === id); a.whys.splice(idx, 1); save(); renderAnalisis(); }
function updateRootCause(id, v) { const a = state.analyses.find(x => x.id === id); a.rootCause = v; save(); }
function openPorquesForm() {
  const body = `<div class="space-y-3">${field('Problema a analizar', inputField('f-pq-problem', '', 'text'))}</div>`;
  openModal({ title: 'Nuevo análisis 5 Porqués', body, footer: `<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-save-pq">Crear</button>` });
  document.getElementById('btn-save-pq').onclick = () => {
    const problem = document.getElementById('f-pq-problem').value.trim();
    if (!problem) { toast('Problema obligatorio'); return; }
    const a = { id: uid(), type: 'porques', problem, date: new Date().toISOString(), whys: [], rootCause: '' };
    state.analyses.push(a); analisisSelectedId = a.id;
    save(); closeModal(); renderAnalisis(); toast('Análisis creado');
  };
}

