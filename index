let state = loadState();

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      const parsed = JSON.parse(raw);
      const defaults = seedData();
      Object.keys(defaults).forEach(k => { if (!(k in parsed)) parsed[k] = defaults[k]; });
      // Migración: limpiar nombre placeholder "Servicio Demo" si quedó
      if (parsed.meta && (parsed.meta.institution === 'Servicio Demo' || parsed.meta.institution === 'Mi Institución')) {
        parsed.meta.institution = '';
      }
      return parsed;
    }
    const v1 = localStorage.getItem('gestio_os_data_v1');
    if (v1) {
      const old = JSON.parse(v1);
      const fresh = seedData();
      Object.keys(old).forEach(k => { if (k in fresh) fresh[k] = old[k]; });
      if (fresh.meta && (fresh.meta.institution === 'Servicio Demo' || fresh.meta.institution === 'Mi Institución')) {
        fresh.meta.institution = '';
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(fresh));
      return fresh;
    }
  } catch (e) { console.error(e); }
  const seed = seedData();
  localStorage.setItem(STORAGE_KEY, JSON.stringify(seed));
  return seed;
}
const persist = debounce(() => {
  try { state.meta.lastSaved = new Date().toISOString(); localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }
  catch (e) { toast('Error guardando.'); }
}, 200);
function save() { persist(); }

function toast(msg) {
  const root = document.getElementById('toast-root');
  const el = document.createElement('div');
  el.className = 'toast'; el.textContent = msg;
  root.appendChild(el);
  setTimeout(() => { el.style.opacity = '0'; el.style.transition = 'opacity .3s'; }, 2200);
  setTimeout(() => el.remove(), 2600);
}

function openModal({ title, body, footer, width = 'normal', onClose }) {
  const root = document.getElementById('modal-root');
  root.innerHTML = '';
  const widthCls = width === 'wide' ? 'modal-wide' : width === 'xwide' ? 'modal-xwide' : width === 'narrow' ? 'modal-narrow' : '';
  const wrap = document.createElement('div');
  wrap.className = 'modal-backdrop';
  wrap.innerHTML = `<div class="modal ${widthCls}">
    <div class="modal-header">
      <div class="font-serif text-2xl leading-tight">${escapeHtml(title)}</div>
      <button class="btn btn-ghost btn-icon" data-action="close-modal"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
    </div>
    <div class="modal-body">${body}</div>
    ${footer ? `<div class="modal-footer">${footer}</div>` : ''}
  </div>`;
  wrap.addEventListener('click', e => {
    if (e.target === wrap || e.target.closest('[data-action="close-modal"]')) {
      closeModal(); if (onClose) onClose();
    }
  });
  root.appendChild(wrap);
}
function closeModal() { document.getElementById('modal-root').innerHTML = ''; }

function field(label, html) { return `<div><label class="form-label">${escapeHtml(label)}</label>${html}</div>`; }
function inputField(id, value = '', type = 'text', placeholder = '') {
  return `<input class="input" id="${id}" type="${type}" value="${escapeHtml(value)}" placeholder="${escapeHtml(placeholder)}">`;
}
function textareaField(id, value = '', placeholder = '', rows = 3) {
  return `<textarea class="textarea" id="${id}" rows="${rows}" placeholder="${escapeHtml(placeholder)}">${escapeHtml(value)}</textarea>`;
}
function selectField(id, options, current = '') {
  return `<select class="select" id="${id}">${options.map(o => {
    const v = typeof o === 'object' ? o.value : o;
    const l = typeof o === 'object' ? o.label : o;
    return `<option value="${escapeHtml(v)}" ${current === v ? 'selected' : ''}>${escapeHtml(l)}</option>`;
  }).join('')}</select>`;
}

