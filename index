/* ==================== PROYECTOS ==================== */
// === Estado de Proyectos: vistas y filtros ===
let proyectosTab = 'lista'; // 'lista' | 'tablero' | 'timeline' | 'detail'
let proyectosFilter = { q: '', status: '', priority: '', owner: '', objective: '', overdue: '' };
let selectedProjectId = null; // cuando estamos en vista detalle
let proyectosSort = { key: 'code', dir: 'asc' };

const PROJECT_STATUSES = [
  { key: 'backlog', label: 'Backlog', color: 'gray' },
  { key: 'inProgress', label: 'En curso', color: 'blue' },
  { key: 'review', label: 'En revisión', color: 'yellow' },
