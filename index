/* ==================== BITÁCORA DE AVANCE DE HALLAZGOS ==================== */

function ensureFindingLog(f) {
  if (!f.progressLog) f.progressLog = [];
  if (typeof f.progress !== 'number') f.progress = 0;
}

function computeFindingProgress(f) {
  ensureFindingLog(f);
  // Si el hallazgo está cerrado, siempre 100%
  if (f.status === 'Cerrado') return 100;
  // Si hay log, tomar el % de la última entrada (la más reciente por fecha)
  if (f.progressLog.length > 0) {
    const sorted = [...f.progressLog].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
    const last = sorted[0];
    return typeof last.percent === 'number' ? last.percent : (f.progress || 0);
  }
  return f.progress || 0;
}

function openFindingLog(findingId) {
  const f = state.findings.find(x => x.id === findingId);
  if (!f) return;
  ensureFindingLog(f);
  
  const sortedLog = [...f.progressLog].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
  const currentProgress = computeFindingProgress(f);
  
  const body = `<div class="space-y-4">
    <div class="card-soft p-3" style="background: var(--bg-sunken)">
      <div class="flex items-center gap-3">
        <div style="flex: 1">
