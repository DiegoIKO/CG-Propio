}

function renderBlockUpcoming(t) {
  if (typeof getAllEvents !== 'function') return '';
  const today = new Date(); today.setHours(0,0,0,0);
  const events = getAllEvents().filter(e => new Date(e.date) >= today).sort((a, b) => a.date.localeCompare(b.date)).slice(0, 8);
  if (!events.length) return '';
  const kindLabels = { milestone: 'Hito', project: 'Proyecto', finding: 'Hallazgo', commitment: 'Compromiso', risk: 'Riesgo', task: 'Tarea', meeting: 'Reunión' };
  return `<div class="card p-5">
    <div class="flex items-center justify-between mb-3"><div class="font-serif text-xl">Próximos vencimientos</div><button class="btn btn-ghost text-xs" onclick="navigate('calendario')">Ver calendario →</button></div>
    <div class="space-y-2">${events.map(e => {
      const days = Math.ceil((new Date(e.date) - today) / 86400000);
      const urgency = days <= 3 ? 'red' : days <= 7 ? 'yellow' : 'gray';
      return `<div class="flex items-center gap-3 p-2 rounded cursor-pointer" style="background:var(--bg-sunken)" onclick="calOpenEvent('${e.kind}', '${e.id}')">
        <span class="dot" style="background:var(--${e.color}); width:8px; height:8px; flex-shrink:0"></span>
        <div class="text-xs" style="color:var(--ink-muted); min-width: 90px">${fmtDate(e.date)}</div>
        <span class="badge badge-${urgency}" style="min-width: 60px; text-align: center">${days === 0 ? 'hoy' : days === 1 ? '1 día' : days + ' días'}</span>
        <span class="badge badge-gray">${kindLabels[e.kind] || e.kind}</span>
        <div class="text-sm flex-1 truncate">${escapeHtml(e.title)}</div>
      </div>`;
    }).join('')}</div>
  </div>`;
}

function renderBlockTopRisks(t) {
  if (!state.risks.length) return '';
  const sorted = [...state.risks].sort((a, b) => (b.residualProb * b.residualImpact) - (a.residualProb * a.residualImpact)).slice(0, 5);
  return `<div class="card p-5">
    <div class="flex items-center justify-between mb-3"><div class="font-serif text-xl">Riesgos prioritarios</div><button class="btn btn-ghost text-xs" onclick="navigate('riesgos')">Ver matriz →</button></div>
    <table class="data-table">
      <thead><tr><th>Código</th><th>Riesgo</th><th>Residual</th><th>Categoría</th></tr></thead>
      <tbody>${sorted.map(r => { const score = r.residualProb * r.residualImpact; const cls = score >= 15 ? 'red' : score >= 8 ? 'yellow' : 'green'; return `<tr style="cursor:pointer" onclick="goToRisk('${r.id}')"><td class="font-mono text-xs">${escapeHtml(r.code)}</td><td class="text-sm">${escapeHtml(r.name)}</td><td><span class="badge badge-${cls}">${score}</span></td><td class="text-xs" style="color:var(--ink-muted)">${escapeHtml(r.category)}</td></tr>`; }).join('')}</tbody>
    </table>
  </div>`;
}

