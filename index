function inferColumnType(ds, colIdx) {
  const samples = (ds.rows || []).slice(0, 10).map(r => r[colIdx]).filter(v => v !== '' && v != null);
  if (!samples.length) return 'text';
  // ¿Todos numéricos?
  if (samples.every(v => !isNaN(parseFloat(v)) && isFinite(v))) return 'number';
  // ¿Todos fechas?
  if (samples.every(v => /^\d{4}-\d{2}-\d{2}/.test(String(v)) || /^\d{1,2}\/\d{1,2}\/\d{2,4}/.test(String(v)))) return 'date';
  return 'text';
}

function columnTypeLabel(type) {
  const labels = { text: 'Aa', number: '123', date: '📅' };
  return labels[type] || 'Aa';
}

function cycleColumnType(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId); if (!ds) return;
  const types = ['text', 'number', 'date'];
  const current = ds.columns[colIdx].type || 'text';
  const next = types[(types.indexOf(current) + 1) % types.length];
  ds.columns[colIdx].type = next;
  save();
  renderVisualizaciones();
}

function updateDatasetColumn(datasetId, colIdx, value, field) {
  const ds = state.datasets.find(d => d.id === datasetId); if (!ds) return;
  if (field === 'name') ds.columns[colIdx].name = value;
  save();
  // No re-render para no romper el foco del input
}

function updateDatasetCell(datasetId, ri, ci, value, isLive) {
  const ds = state.datasets.find(d => d.id === datasetId); if (!ds) return;
  if (!ds.rows[ri]) ds.rows[ri] = [];
  ds.rows[ri][ci] = value;
  if (isLive) {
    // Solo guardamos con debounce, no re-render
    if (typeof debouncedSave === 'undefined') window.debouncedSave = debounce(save, 400);
    window.debouncedSave();
  } else {
    save();
  }
}

