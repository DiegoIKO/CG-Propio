/* ==================== FILTROS Y ORDENAMIENTO DE TABLAS ==================== */
const tableState = {}; // { key: { sortBy, sortDir, search, filters: {} } }

function getTableState(key) {
  if (!tableState[key]) tableState[key] = { sortBy: null, sortDir: 'asc', search: '', filters: {} };
  return tableState[key];
}

function sortHeader(tableKey, field, label) {
  const st = getTableState(tableKey);
  const isSorted = st.sortBy === field;
  const ind = isSorted ? (st.sortDir === 'asc' ? '↑' : '↓') : '↕';
  return `<th class="sortable ${isSorted ? 'sorted' : ''}" onclick="setSort('${tableKey}', '${field}')">${escapeHtml(label)}<span class="sort-ind">${ind}</span></th>`;
}

function setSort(tableKey, field) {
  const st = getTableState(tableKey);
  if (st.sortBy === field) st.sortDir = st.sortDir === 'asc' ? 'desc' : 'asc';
  else { st.sortBy = field; st.sortDir = 'asc'; }
  // Re-renderizar la vista actual
  (routes[currentRoute] || routes.inicio)();
}

function applyTableFilters(items, tableKey, getField, searchableFields) {
  const st = getTableState(tableKey);
  let result = items;
  // Búsqueda libre
  if (st.search) {
    const q = st.search.toLowerCase();
    result = result.filter(it => {
      const blob = (searchableFields || []).map(f => getField(it, f)).join(' ').toLowerCase();
      return blob.includes(q);
    });
  }
  // Filtros por campo
  Object.keys(st.filters).forEach(key => {
    const val = st.filters[key];
    if (val !== '' && val !== null && val !== undefined) {
      result = result.filter(it => {
        const v = getField(it, key);
        return v === val;
      });
    }
  });
  // Ordenamiento
  if (st.sortBy) {
    const dir = st.sortDir === 'asc' ? 1 : -1;
    result = [...result].sort((a, b) => {
      const va = getField(a, st.sortBy);
      const vb = getField(b, st.sortBy);
      if (va == null && vb == null) return 0;
      if (va == null) return dir;
      if (vb == null) return -dir;
      if (typeof va === 'number' && typeof vb === 'number') return (va - vb) * dir;
      return String(va).localeCompare(String(vb), 'es-CL', { sensitivity: 'base' }) * dir;
    });
  }
  return result;
}

// Aplica todos los filtros EXCEPTO uno específico (para cálculo jerárquico)
function applyTableFiltersExcept(items, tableKey, getField, searchableFields, excludeFilterKey) {
  const st = getTableState(tableKey);
  let result = items;
  if (st.search) {
    const q = st.search.toLowerCase();
    result = result.filter(it => {
      const blob = (searchableFields || []).map(f => getField(it, f)).join(' ').toLowerCase();
      return blob.includes(q);
    });
  }
  Object.keys(st.filters).forEach(key => {
    if (key === excludeFilterKey) return; // saltar el filtro excluido
    const val = st.filters[key];
    if (val !== '' && val !== null && val !== undefined) {
      result = result.filter(it => {
        const v = getField(it, key);
        return v === val;
      });
    }
  });
  return result;
}

function tableToolbarHTML(tableKey, total, filtered, filterOptions = [], items, getField, searchableFields) {
  const st = getTableState(tableKey);
  const hasFilters = st.search || Object.values(st.filters).some(v => v !== '' && v !== null && v !== undefined);
  
  return `<div class="table-toolbar">
    <input class="input input-sm search-mini" placeholder="Buscar..." value="${escapeHtml(st.search)}" oninput="setTableSearch('${tableKey}', this.value)">
    ${filterOptions.map(f => {
      const current = st.filters[f.key] || '';
      // CÁLCULO JERÁRQUICO: si tenemos items/getField, calcular qué valores tienen datos en el contexto filtrado
      let availableValues = null;
      if (items && getField) {
        const contextItems = applyTableFiltersExcept(items, tableKey, getField, searchableFields, f.key);
        availableValues = new Set();
        contextItems.forEach(it => {
          const v = getField(it, f.key);
          if (v !== null && v !== undefined && v !== '') availableValues.add(String(v));
        });
      }
      
      return `<select class="select input-sm" style="width:auto" onchange="setTableFilter('${tableKey}', '${f.key}', this.value)">
        <option value="">${escapeHtml(f.label)}: todos</option>
        ${f.options.map(o => {
          const v = typeof o === 'object' ? o.value : o;
          const l = typeof o === 'object' ? o.label : o;
          // Si tenemos cálculo jerárquico, anotar count y marcar como vacío si no hay
          let countStr = '';
          let disabledAttr = '';
          if (availableValues && current !== v) {
            const isAvailable = availableValues.has(String(v));
            if (!isAvailable) {
              countStr = ' (0)';
              disabledAttr = ' disabled';
            }
          }
          return `<option value="${escapeHtml(v)}" ${current === v ? 'selected' : ''}${disabledAttr}>${escapeHtml(l)}${countStr}</option>`;
        }).join('')}
      </select>`;
    }).join('')}
    ${hasFilters ? `<button class="btn btn-ghost btn-sm" onclick="clearTableFilters('${tableKey}')">Limpiar</button>` : ''}
    <span class="table-info">${filtered} de ${total}</span>
    <button class="btn btn-ghost btn-sm" onclick="exportTableCSV('${tableKey}')" title="Exportar CSV"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg> CSV</button>
  </div>`;
}

const debouncedTableSearchRerender = debounce(() => (routes[currentRoute] || routes.inicio)(), 220);

function setTableSearch(tableKey, val) {
  getTableState(tableKey).search = val;
  debouncedTableSearchRerender();
}
function setTableFilter(tableKey, key, val) {
  getTableState(tableKey).filters[key] = val;
  (routes[currentRoute] || routes.inicio)();
}
function clearTableFilters(tableKey) {
  tableState[tableKey] = { sortBy: null, sortDir: 'asc', search: '', filters: {} };
  (routes[currentRoute] || routes.inicio)();
}

// Almacena temporalmente los datos visibles de cada tabla para exportar
const tableExportData = {};
function registerTableExport(tableKey, headers, rows) {
  tableExportData[tableKey] = { headers, rows };
}
function exportTableCSV(tableKey) {
  const data = tableExportData[tableKey];
  if (!data) { toast('Datos no disponibles'); return; }
  const csvLine = (arr) => arr.map(v => {
    const s = v === null || v === undefined ? '' : String(v).replace(/<[^>]*>/g, '');
    return /[",\n;]/.test(s) ? `"${s.replace(/"/g, '""')}"` : s;
  }).join(';');
  const csv = [csvLine(data.headers), ...data.rows.map(csvLine)].join('\n');
  const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = `${tableKey}-${new Date().toISOString().slice(0,10)}.csv`; a.click();
  URL.revokeObjectURL(url);
  toast('CSV descargado');
}

