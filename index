function renderMarkdownWithAnchors(md) {
  // Variante de renderMarkdown que añade IDs a los headings
  let html = escapeHtml(md);
  const lines = md.split('\n');
  let headingIdx = 0;
  
  html = html.replace(/^### (.+)$/gm, (match, text) => {
    const line = lines[lines.indexOf('### ' + text)];
    const idx = lines.findIndex((l, i) => l === '### ' + text && i >= headingIdx);
    headingIdx = idx + 1;
    return `<h3 id="wiki-anchor-${slugify(text)}-${idx}">${text}</h3>`;
  });
  headingIdx = 0;
  html = html.replace(/^## (.+)$/gm, (match, text) => {
    const idx = lines.findIndex((l, i) => l === '## ' + text && i >= headingIdx);
    headingIdx = idx + 1;
    return `<h2 id="wiki-anchor-${slugify(text)}-${idx}">${text}</h2>`;
  });
  headingIdx = 0;
  html = html.replace(/^# (.+)$/gm, (match, text) => {
    const idx = lines.findIndex((l, i) => l === '# ' + text && i >= headingIdx);
    headingIdx = idx + 1;
    return `<h1 id="wiki-anchor-${slugify(text)}-${idx}">${text}</h1>`;
  });
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '<em>$1</em>');
  html = html.replace(/`(.+?)`/g, '<code>$1</code>');
  html = html.replace(/^&gt; (.+)$/gm, '<blockquote>$1</blockquote>');
  html = html.replace(/(?:^- .+$\n?)+/gm, m => '<ul>' + m.trim().split('\n').map(l => '<li>' + l.replace(/^- /, '') + '</li>').join('') + '</ul>');
  html = html.replace(/(?:^\d+\. .+$\n?)+/gm, m => '<ol>' + m.trim().split('\n').map(l => '<li>' + l.replace(/^\d+\. /, '') + '</li>').join('') + '</ol>');
  html = html.split(/\n\n+/).map(b => {
    if (b.match(/^<(h\d|ul|ol|blockquote)/)) return b;
    if (!b.trim()) return '';
    return '<p>' + b.replace(/\n/g, '<br>') + '</p>';
  }).join('\n');
  return html;
}

function renderMarkdown(md) {
  // Render mínimo de Markdown
  let html = escapeHtml(md);
  html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '<em>$1</em>');
  html = html.replace(/`(.+?)`/g, '<code>$1</code>');
  html = html.replace(/^&gt; (.+)$/gm, '<blockquote>$1</blockquote>');
  // Listas
  html = html.replace(/(?:^- .+$\n?)+/gm, m => '<ul>' + m.trim().split('\n').map(l => '<li>' + l.replace(/^- /, '') + '</li>').join('') + '</ul>');
  html = html.replace(/(?:^\d+\. .+$\n?)+/gm, m => '<ol>' + m.trim().split('\n').map(l => '<li>' + l.replace(/^\d+\. /, '') + '</li>').join('') + '</ol>');
  // Párrafos: bloques separados por línea vacía
  html = html.split(/\n\n+/).map(b => {
    if (b.match(/^<(h\d|ul|ol|blockquote)/)) return b;
    if (!b.trim()) return '';
    return '<p>' + b.replace(/\n/g, '<br>') + '</p>';
  }).join('\n');
  return html;
}

