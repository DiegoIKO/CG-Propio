        <div class="space-y-2" style="max-height: 320px; overflow-y: auto">
          ${sortedLog.map((entry, displayIdx) => {
            const realIdx = f.progressLog.indexOf(entry);
            const pctColor = entry.percent >= 100 ? 'var(--green)' : entry.percent >= 50 ? 'var(--warm)' : 'var(--red)';
            return `<div class="card-soft p-3" style="background: var(--bg-elevated); border-left: 3px solid ${pctColor}">
              <div class="flex items-start justify-between gap-3">
