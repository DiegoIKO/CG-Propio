/* === GENERADORES DE INFORMES === */

function generateReporteMensual() {
  const today = new Date();
  const monthName = today.toLocaleDateString('es-CL', { month: 'long', year: 'numeric' });
  const t = {
    kpis: state.kpis.length,
    kpisGreen: state.kpis.filter(k => kpiStatus(k) === 'green').length,
    kpisYellow: state.kpis.filter(k => kpiStatus(k) === 'yellow').length,
    kpisRed: state.kpis.filter(k => kpiStatus(k) === 'red').length,
    risksHigh: state.risks.filter(r => (r.probability * r.impact) >= 15).length,
    projectsActive: state.projects.filter(p => p.status === 'inProgress' || p.status === 'review').length,
    findingsOpen: state.findings.filter(f => f.status !== 'Cerrado').length,
    tasksOverdue: (state.tasks || []).filter(t => t.dueDate && new Date(t.dueDate) < new Date() && t.status !== 'done').length
  };
  
  const kpiRows = state.kpis.map(k => {
    const v = kpiCurrentValue(k);
    const s = kpiStatus(k);
    return [
      `<strong>${escapeHtml(k.code)}</strong> ${escapeHtml(k.name)}`,
      v === null ? '—' : `${fmtNumber(v)} ${escapeHtml(k.unit || '')}`,
      `${fmtNumber(k.target)} ${escapeHtml(k.unit || '')}`,
      repTag(s === 'green' ? 'En meta' : s === 'yellow' ? 'En alerta' : s === 'red' ? 'Crítico' : 'Sin datos', kpiTagColor(k))
    ];
  });
  
  const topRisks = [...state.risks].sort((a, b) => (b.probability * b.impact) - (a.probability * a.impact)).slice(0, 5);
  const riskRows = topRisks.map(r => {
    const score = r.probability * r.impact;
    return [
      `<strong>${escapeHtml(r.code)}</strong>`,
      escapeHtml(r.name),
      escapeHtml(r.category),
      repTag(score.toString(), score >= 15 ? 'red' : score >= 8 ? 'yellow' : 'green'),
      escapeHtml(r.owner || '—')
    ];
  });
  
  const openFindings = state.findings.filter(f => f.status !== 'Cerrado');
  const findingRows = openFindings.map(f => [
