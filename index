  } else if (bpmnSelected.kind === 'conn') {
    bpmn.connections = bpmn.connections.filter(c => c.id !== bpmnSelected.id);
  }
  bpmnSelected = null;
  save(); renderProcesos();
}

function bpmnStartDrag(e, pid, nid) {
  if (e.target.classList.contains('bpmn-port')) return;
  const p = state.processes.find(x => x.id === pid);
  const n = p.bpmn.nodes.find(x => x.id === nid); if (!n) return;
  const bpmn = p.bpmn;
  const svg = document.getElementById('bpmn-svg-' + pid); if (!svg) return;
  const rect = svg.getBoundingClientRect();
  const scale = svg.viewBox.baseVal.width / rect.width;
  const startX = (e.clientX - rect.left) * scale;
  const startY = (e.clientY - rect.top) * scale;
  const offsetX = startX - n.x;
  const offsetY = startY - n.y;
  // Calcular límites de arrastre
  const minX = (bpmn.lanes.length || bpmn.phases.length) ? BPMN_HEADER_W + 30 : 30;
  const maxX = bpmn.phases.length ? bpmnContentRight(bpmn) - 30 : svg.viewBox.baseVal.width - 30;
  const minY = bpmn.phases.length ? BPMN_PHASE_H + 30 : 30;
  const maxY = bpmnCanvasHeight(bpmn) - 30;
  
  function onMove(ev) {
    const cx = (ev.clientX - rect.left) * scale;
    const cy = (ev.clientY - rect.top) * scale;
    n.x = Math.max(minX, Math.min(maxX, cx - offsetX));
    n.y = Math.max(minY, Math.min(maxY, cy - offsetY));
    renderProcesos();
  }
  function onUp() {
    document.removeEventListener('mousemove', onMove);
    document.removeEventListener('mouseup', onUp);
    save();
  }
  document.addEventListener('mousemove', onMove);
  document.addEventListener('mouseup', onUp);
}

function bpmnStartConnection(e, pid, fromId) {
  e.preventDefault();
  const svg = document.getElementById('bpmn-svg-' + pid); if (!svg) return;
  const rect = svg.getBoundingClientRect();
  const scale = svg.viewBox.baseVal.width / rect.width;
  const p = state.processes.find(x => x.id === pid);
  const fromNode = p.bpmn.nodes.find(n => n.id === fromId);
  const anchor = getNodeRightAnchor(fromNode);
  // dibujar línea temporal
  const tempLine = document.createElementNS('http://www.w3.org/2000/svg', 'path');
  tempLine.setAttribute('stroke', 'var(--accent)');
  tempLine.setAttribute('stroke-width', '2');
  tempLine.setAttribute('stroke-dasharray', '4,4');
  tempLine.setAttribute('fill', 'none');
  svg.appendChild(tempLine);
  svg.classList.add('connecting');
  
  function onMove(ev) {
    const cx = (ev.clientX - rect.left) * scale;
    const cy = (ev.clientY - rect.top) * scale;
    tempLine.setAttribute('d', `M ${anchor.x} ${anchor.y} L ${cx} ${cy}`);
  }
  function onUp(ev) {
    document.removeEventListener('mousemove', onMove);
    document.removeEventListener('mouseup', onUp);
    svg.classList.remove('connecting');
    // detectar nodo destino
    const target = document.elementFromPoint(ev.clientX, ev.clientY);
    const nodeGroup = target ? target.closest('.bpmn-node') : null;
    if (nodeGroup && nodeGroup.dataset.id && nodeGroup.dataset.id !== fromId) {
      const toId = nodeGroup.dataset.id;
      // verificar que no exista
      if (!p.bpmn.connections.find(c => c.from === fromId && c.to === toId)) {
        p.bpmn.connections.push({ id: uid(), from: fromId, to: toId, label: '' });
        save();
      }
    }
    tempLine.remove();
    renderProcesos();
  }
  document.addEventListener('mousemove', onMove);
  document.addEventListener('mouseup', onUp);
}

function exportBPMNAsImage(pid) {
  const svg = document.getElementById('bpmn-svg-' + pid);
  if (!svg) { toast('Sin diagrama para exportar'); return; }
  const svgData = new XMLSerializer().serializeToString(svg);
  const blob = new Blob([svgData], { type: 'image/svg+xml' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  const p = state.processes.find(x => x.id === pid);
  a.href = url;
  a.download = `bpmn-${(p.code || 'proceso').replace(/[^a-z0-9]/gi, '_')}.svg`;
  a.click();
  URL.revokeObjectURL(url);
  toast('SVG descargado');
}

