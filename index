    ${field('Plan de acción', textareaField('f-h-plan', f?.actionPlan || ''))}
    <div class="grid grid-cols-2 gap-3">
      <div>${field('Plazo de cierre', inputField('f-h-due', fmtDateInput(f?.dueDate), 'date'))}</div>
      <div>${field('Estado', selectField('f-h-status', ['Pendiente', 'En tratamiento', 'Cerrado'], f?.status || 'Pendiente'))}</div>
    </div>
    <div>${field('Proceso afectado (opcional)', relationSelectField('f-h-process', processItems(), f?.processId))}</div>
  </div>`;
  openModal({ title: isEdit ? 'Editar hallazgo' : 'Nuevo hallazgo', body, footer: `<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-save-h">${isEdit ? 'Guardar' : 'Crear'}</button>` });
  document.getElementById('btn-save-h').onclick = () => {
    const payload = { code: document.getElementById('f-h-code').value.trim(), name: document.getElementById('f-h-name').value.trim(), source: document.getElementById('f-h-src').value, severity: document.getElementById('f-h-sev').value, actionPlan: document.getElementById('f-h-plan').value, dueDate: document.getElementById('f-h-due').value, status: document.getElementById('f-h-status').value, processId: document.getElementById('f-h-process').value || null };
