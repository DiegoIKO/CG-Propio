function renderChartInZoom(c) {
  const ctx = document.getElementById('chart-zoom-canvas');
  if (!ctx || !window.Chart) return;
  destroyChart('zoom-chart');
  
  const ds = state.datasets.find(d => d.id === c.datasetId);
  if (!ds) return;
  const xIdx = ds.columns.findIndex(col => col.name === c.xField);
  const yIdxs = (c.yFields || []).map(f => ds.columns.findIndex(col => col.name === f)).filter(i => i >= 0);
  if (xIdx < 0 || !yIdxs.length) return;
  
  const isPieType = c.type === 'pie' || c.type === 'doughnut';
  const isRadar = c.type === 'radar';
  const isArea = c.type === 'area' || c.type === 'stackedArea';
  const isLine = c.type === 'line' || isArea;
  const isStacked = c.type === 'stackedBar' || c.type === 'stackedArea';
  const isScatter = c.type === 'scatter';
  const isMixed = c.type === 'mixed';
  
  // Agregación
  const aggFn = c.aggregation || 'sum';
  const shouldAggregate = !isScatter && aggFn !== 'none';
  
  let labels, ySeriesData;
  if (shouldAggregate) {
    const agg = aggregateChartData(ds, xIdx, yIdxs, aggFn);
    labels = agg.labels;
    ySeriesData = agg.ySeries;
  } else {
    labels = ds.rows.map(r => String(r[xIdx] !== undefined ? r[xIdx] : ''));
    ySeriesData = yIdxs.map(yi => ds.rows.map(r => Number(r[yi]) || 0));
  }
  
  let datasets;
  if (isScatter) {
    datasets = yIdxs.map((yi, i) => {
      const color = CHART_PALETTE[i % CHART_PALETTE.length];
      return {
        label: ds.columns[yi].name,
        data: ds.rows.map(r => ({ x: parseFloat(r[xIdx]) || 0, y: parseFloat(r[yi]) || 0 })),
        backgroundColor: hexToRgba(color, 0.65),
        borderColor: color,
        borderWidth: 2,
        pointRadius: 7,
        pointHoverRadius: 10
      };
    });
  } else {
    datasets = yIdxs.map((yi, i) => {
      const color = CHART_PALETTE[i % CHART_PALETTE.length];
      const base = {
        label: ds.columns[yi].name,
        data: ySeriesData[i],
        borderColor: color,
        borderWidth: isLine ? 3 : 1.5
      };
      if (isPieType) {
        base.backgroundColor = labels.map((_, j) => CHART_PALETTE[j % CHART_PALETTE.length]);
        base.borderColor = '#ffffff';
        base.borderWidth = 3;
        base.hoverOffset = 16;
      } else if (isMixed) {
        if (i === 0) {
          base.type = 'bar';
          base.backgroundColor = hexToRgba(color, 0.75);
          base.borderRadius = 6;
          base.borderSkipped = false;
          base.order = 2;
        } else {
          base.type = 'line';
          base.backgroundColor = hexToRgba(color, 0.4);
          base.tension = 0.3;
          base.fill = false;
          base.pointBackgroundColor = color;
          base.pointBorderColor = '#ffffff';
          base.pointBorderWidth = 2;
