  document.getElementById('btn-save-t').onclick = () => {
    const title = document.getElementById('f-t-title').value.trim();
    if (!title) { toast('Título obligatorio'); return; }
    const payload = {
      code: document.getElementById('f-t-code').value.trim(),
      title,
      description: document.getElementById('f-t-desc').value,
      status: document.getElementById('f-t-status').value,
      priority: document.getElementById('f-t-prio').value,
      assignee: document.getElementById('f-t-assignee').value.trim(),
      dueDate: document.getElementById('f-t-due').value,
      progress: parseInt(document.getElementById('f-t-progress').value) || 0,
      tags: document.getElementById('f-t-tags').value.split(',').map(s => s.trim()).filter(Boolean),
      projectId: document.getElementById('f-t-project').value || null,
