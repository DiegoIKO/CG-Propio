function setAnalisisTab(t) { analisisTab = t; analisisSelectedId = null; analisisShowExplanation = false; renderAnalisis(); }

/* ----- Ishikawa ----- */
function renderIshikawa() {
  const list = state.analyses.filter(a => a.type === 'ishikawa');
  if (analisisSelectedId) {
    const a = list.find(x => x.id === analisisSelectedId);
    if (a) return renderIshikawaDetail(a);
  }
  if (!list.length) return emptyState('Sin análisis Ishikawa', 'Crea el primero con el botón superior');
  return `<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">${list.map(a => `
    <div class="card p-4 cursor-pointer" onclick="selectAnalisis('${a.id}')">
      <div class="meta-label mb-1">Diagrama Ishikawa</div>
      <div class="font-serif text-xl mb-2">${escapeHtml(a.problem)}</div>
      <div class="text-xs" style="color:var(--ink-muted)">${fmtDate(a.date)} · ${Object.values(a.causes || {}).flat().length} causas</div>
    </div>`).join('')}</div>`;
}
function selectAnalisis(id) { analisisSelectedId = id; renderAnalisis(); }

function renderIshikawaDetail(a) {
  return `<div class="space-y-4">
    <div class="flex items-center justify-between">
      <div><div class="meta-label">Problema central</div><div class="font-serif text-3xl">${escapeHtml(a.problem)}</div></div>
      <div class="flex gap-2">
        <button class="btn btn-secondary" onclick="analisisSelectedId=null; renderAnalisis()">← Volver</button>
        <button class="btn btn-primary" onclick="printIshikawa('${a.id}')" title="Imprimir resultado visualmente"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z"/></svg> Imprimir</button>
        <button class="btn btn-danger" onclick="deleteAnalisis('${a.id}')">Eliminar</button>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      ${ISHIKAWA_CATS.map(cat => `<div class="card p-4">
        <div class="font-semibold text-sm mb-3" style="color:var(--accent)">${cat}</div>
        <div>${((a.causes && a.causes[cat]) || []).map((c, i) => `<div class="ishikawa-cause"><span>${escapeHtml(c)}</span><button class="btn btn-ghost btn-icon" onclick="removeIshikawaCause('${a.id}', '${cat}', ${i})"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button></div>`).join('')}</div>
        <input class="input input-sm mt-2" placeholder="Agregar causa..." id="ish-${a.id}-${cat}" onkeydown="if(event.key==='Enter') addIshikawaCause('${a.id}', '${cat}')">
      </div>`).join('')}
    </div>
  </div>`;
}
function addIshikawaCause(id, cat) {
  const a = state.analyses.find(x => x.id === id);
  const inp = document.getElementById(`ish-${id}-${cat}`);
  const v = inp.value.trim(); if (!v) return;
  if (!a.causes) a.causes = {};
  if (!a.causes[cat]) a.causes[cat] = [];
  a.causes[cat].push(v); save(); renderAnalisis();
}
function removeIshikawaCause(id, cat, idx) {
  const a = state.analyses.find(x => x.id === id);
  a.causes[cat].splice(idx, 1); save(); renderAnalisis();
}
function openIshikawaForm() {
  const body = `<div class="space-y-3">${field('Problema a analizar', inputField('f-i-problem', '', 'text', 'Ej: Demora excesiva en respuesta a solicitudes ciudadanas'))}</div>`;
  openModal({ title: 'Nuevo análisis Ishikawa', body, footer: `<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-save-i">Crear</button>` });
  document.getElementById('btn-save-i').onclick = () => {
    const problem = document.getElementById('f-i-problem').value.trim();
    if (!problem) { toast('Problema obligatorio'); return; }
    const a = { id: uid(), type: 'ishikawa', problem, date: new Date().toISOString(), causes: {} };
    state.analyses.push(a); analisisSelectedId = a.id;
    save(); closeModal(); renderAnalisis(); toast('Análisis creado');
  };
}
function deleteAnalisis(id) {
  if (!confirm('¿Eliminar este análisis?')) return;
  state.analyses = state.analyses.filter(a => a.id !== id);
  analisisSelectedId = null; save(); renderAnalisis(); toast('Eliminado');
}

