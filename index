function renderCalendarMonth() {
  const year = calendarioCursor.getFullYear();
  const month = calendarioCursor.getMonth();
  const firstDay = new Date(year, month, 1);
  const startDow = firstDay.getDay(); // 0 = domingo
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const daysPrevMonth = new Date(year, month, 0).getDate();
  const monthName = firstDay.toLocaleDateString('es-CL', { month: 'long', year: 'numeric' });
  const today = new Date(); today.setHours(0, 0, 0, 0);
  const events = getAllEvents();
  // agrupar eventos por fecha YYYY-MM-DD
  const byDate = {};
  events.forEach(e => { const k = e.date.slice(0, 10); if (!byDate[k]) byDate[k] = []; byDate[k].push(e); });

  // construir celdas: 6 semanas x 7 días
  const cells = [];
  // días del mes anterior
  for (let i = startDow - 1; i >= 0; i--) cells.push({ day: daysPrevMonth - i, otherMonth: true, dateObj: new Date(year, month - 1, daysPrevMonth - i) });
  // días del mes
  for (let d = 1; d <= daysInMonth; d++) cells.push({ day: d, otherMonth: false, dateObj: new Date(year, month, d) });
  // completar a múltiplo de 7
  while (cells.length % 7 !== 0) { const last = cells[cells.length - 1]; cells.push({ day: last.dateObj.getDate() + 1, otherMonth: true, dateObj: new Date(last.dateObj.getTime() + 86400000) }); }
  // hasta 6 semanas
  while (cells.length < 42) { const last = cells[cells.length - 1]; cells.push({ day: last.dateObj.getDate() + 1, otherMonth: true, dateObj: new Date(last.dateObj.getTime() + 86400000) }); }

  return `
    <div class="card p-4">
      <div class="flex items-center justify-between mb-4">
        <div class="font-serif text-2xl capitalize">${monthName}</div>
        <div class="flex gap-2">
          <button class="btn btn-secondary btn-sm" onclick="calendarioCursor=new Date(${year}, ${month - 1}, 1); renderCalendario()">← Anterior</button>
          <button class="btn btn-secondary btn-sm" onclick="calendarioCursor=new Date(); renderCalendario()">Hoy</button>
          <button class="btn btn-secondary btn-sm" onclick="calendarioCursor=new Date(${year}, ${month + 1}, 1); renderCalendario()">Siguiente →</button>
        </div>
      </div>
      <div class="cal-grid">
        ${['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'].map(d => `<div class="cal-day-header">${d}</div>`).join('')}
      </div>
      <div class="cal-grid mt-1">
        ${cells.map(c => {
          const dateKey = c.dateObj.toISOString().slice(0, 10);
          const isToday = c.dateObj.toDateString() === today.toDateString();
          const dayEvents = byDate[dateKey] || [];
          return `<div class="cal-cell ${c.otherMonth ? 'other-month' : ''} ${isToday ? 'today' : ''}" style="cursor: ${dayEvents.length ? 'pointer' : 'default'}" ${dayEvents.length ? `onclick="if(event.target.closest('.cal-event'))return; calShowDay('${dateKey}')"` : ''}>
            <div class="cal-day-num">${c.day}</div>
            ${dayEvents.slice(0, 3).map(e => {
              const overdue = c.dateObj < today && (e.status !== 'Cumplido' && e.status !== 'done' && e.status !== 'Cerrado');
              const fullTitle = (e.code ? e.code + ' · ' : '') + e.title;
              return `<div class="cal-event ev-${e.kind} ${overdue ? 'overdue' : ''}" onclick="event.stopPropagation(); calOpenEvent('${e.kind}', '${e.id}')" title="${escapeHtml(fullTitle)} · Clic para abrir">${escapeHtml(e.title.length > 22 ? e.title.slice(0, 22) + '…' : e.title)}</div>`;
            }).join('')}
            ${dayEvents.length > 3 ? `<div class="text-xs" style="color:var(--ink-muted); padding-left:6px; cursor:pointer" onclick="event.stopPropagation(); calShowDay('${dateKey}')">+${dayEvents.length - 3} más</div>` : ''}
          </div>`;
        }).join('')}
      </div>
    </div>
  `;
}

function renderCalendarTimeline() {
  const events = getAllEvents();
  if (!events.length) return emptyState('Sin eventos en el rango', 'Asegúrate de tener fechas registradas en hitos, proyectos, hallazgos o compromisos');
  // Definir rango: 6 meses (3 atrás, 3 adelante) desde hoy
  const today = new Date(); today.setHours(0, 0, 0, 0);
  const start = new Date(today.getFullYear(), today.getMonth() - 2, 1);
  const end = new Date(today.getFullYear(), today.getMonth() + 6, 1);
  const totalDays = Math.round((end - start) / 86400000);
  // Meses para encabezado
  const months = [];
  let cur = new Date(start);
  while (cur < end) { months.push(new Date(cur)); cur = new Date(cur.getFullYear(), cur.getMonth() + 1, 1); }
  
  // Filtrar eventos en rango y ordenar por fecha
  const inRange = events.filter(e => {
    const d = new Date(e.date);
    return d >= start && d <= end;
  }).sort((a, b) => a.date.localeCompare(b.date));
  
  const todayPct = ((today - start) / 86400000 / totalDays) * 100;
  
  return `<div class="timeline-wrap">
    <div class="text-xs mb-3" style="color:var(--ink-muted)">Mostrando ${inRange.length} eventos entre ${fmtDate(start.toISOString())} y ${fmtDate(end.toISOString())}. Cada barra es un vencimiento. La línea vertical es hoy.</div>
    <div class="timeline-header-row">
      <div></div>
      <div class="timeline-months" style="grid-template-columns: repeat(${months.length}, 1fr)">
        ${months.map(m => `<div class="timeline-month">${m.toLocaleDateString('es-CL', { month: 'short', year: '2-digit' })}</div>`).join('')}
      </div>
    </div>
    <div style="position:relative">
      <div class="timeline-today-marker" style="left: calc(220px + 12px + ${todayPct}% * (100% - 220px - 12px) / 100); height:100%"></div>
      ${inRange.map(e => {
        const d = new Date(e.date);
        const dayOffset = Math.round((d - start) / 86400000);
        const pct = (dayOffset / totalDays) * 100;
        const overdue = d < today && (e.status !== 'Cumplido' && e.status !== 'done' && e.status !== 'Cerrado');
        return `<div class="timeline-row">
          <div class="timeline-row-label">
            <span class="meta-code">${escapeHtml(e.code)}</span> · ${escapeHtml(e.title.slice(0, 32))}${e.title.length > 32 ? '…' : ''}
          </div>
          <div class="timeline-track">
            <div class="timeline-bar tl-${e.kind} ${overdue ? 'overdue' : ''}" style="left: ${Math.max(0, pct - 1)}%; width: 60px" onclick="calOpenEvent('${e.kind}', '${e.id}')" title="${escapeHtml(e.title)} · ${fmtDate(e.date)}${overdue ? ' (vencido)' : ''}">
              ${fmtDate(e.date)}
            </div>
          </div>
        </div>`;
      }).join('')}
    </div>
  </div>`;
}

