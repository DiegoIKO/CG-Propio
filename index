function exportDatasetCSV(id) {
  const d = state.datasets.find(x => x.id === id);
  if (!d) return;
  
  const vs = datasetViewState[id];
  let rowsToExport = d.rows;
  let hasSearch = false;
  if (vs && vs.search && vs.search.trim()) {
    const q = vs.search.trim().toLowerCase();
    rowsToExport = d.rows.filter(row => row.some(v => String(v == null ? '' : v).toLowerCase().includes(q)));
    hasSearch = true;
  }
  
  const headers = d.columns.map(c => `"${(c.name || '').replace(/"/g, '""')}"`).join(',');
  const lines = rowsToExport.map(r => r.map(v => {
    const s = v === null || v === undefined ? '' : String(v);
    return /[",\n]/.test(s) ? `"${s.replace(/"/g, '""')}"` : s;
  }).join(','));
  const csv = [headers, ...lines].join('\n');
  const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  const suffix = hasSearch ? '_busqueda' : '';
  a.href = url; a.download = `${d.name.replace(/[^a-z0-9]/gi, '_')}${suffix}.csv`; a.click();
  URL.revokeObjectURL(url);
  toast(hasSearch ? `CSV descargado (${rowsToExport.length} filas)` : 'CSV descargado');
}

function openPasteDataset() {
  const body = `<div class="space-y-3">
    ${field('Nombre del dataset', inputField('f-pst-name', '', 'text', 'Mi dataset'))}
