    h3 { font-size: 12pt; font-weight: bold; margin: 14pt 0 6pt; text-transform: uppercase; letter-spacing: 1pt; }
    p { margin: 6pt 0; font-size: 11pt; }
    table { width: 100%; border-collapse: collapse; margin: 10pt 0; font-size: 10pt; }
    table th { text-align: left; padding: 6pt 8pt; background: #efeae0; font-weight: bold; border-bottom: 2pt solid #15110d; }
