function renderTaskFilters() {
  const tags = getAllTaskTags();
  const assignees = getAllAssignees();
  const allTasks = state.tasks;
  
  // Cálculos jerárquicos: qué valores tienen tareas según los otros filtros
  const ctxStatus = applyTaskFilterExcept(allTasks, 'status');
  const ctxPriority = applyTaskFilterExcept(allTasks, 'priority');
  const ctxAssignee = applyTaskFilterExcept(allTasks, 'assignee');
  const ctxTag = applyTaskFilterExcept(allTasks, 'tag');
  const ctxProject = applyTaskFilterExcept(allTasks, 'project');
  
  const availStatus = new Set(ctxStatus.map(t => t.status));
  const availPriority = new Set(ctxPriority.map(t => t.priority));
  const availAssignee = new Set(ctxAssignee.map(t => t.assignee).filter(Boolean));
  const availTag = new Set();
  ctxTag.forEach(t => (t.tags || []).forEach(tg => availTag.add(tg)));
  const availProject = new Set(ctxProject.map(t => t.projectId).filter(Boolean));
  const hasNoneProject = ctxProject.some(t => !t.projectId);
  
  return `<div class="task-filters">
    <input class="input input-sm search-input" placeholder="Buscar tarea..." value="${escapeHtml(tareasFilter.q)}" oninput="tareasFilter.q=this.value; renderTareasDebounced()">
    <select class="select input-sm" style="width:auto" onchange="tareasFilter.status=this.value; renderTareas()">
      <option value="">Estado: todos</option>
      ${TASK_STATUSES.map(s => {
        const sel = tareasFilter.status === s.key;
        const unavailable = !sel && !availStatus.has(s.key);
        return `<option value="${s.key}" ${sel ? 'selected' : ''}${unavailable ? ' disabled' : ''}>${s.label}${unavailable ? ' (0)' : ''}</option>`;
      }).join('')}
    </select>
    <select class="select input-sm" style="width:auto" onchange="tareasFilter.priority=this.value; renderTareas()">
      <option value="">Prioridad: todas</option>
      ${TASK_PRIORITIES.map(p => {
        const sel = tareasFilter.priority === p.key;
        const unavailable = !sel && !availPriority.has(p.key);
        return `<option value="${p.key}" ${sel ? 'selected' : ''}${unavailable ? ' disabled' : ''}>${p.label}${unavailable ? ' (0)' : ''}</option>`;
      }).join('')}
    </select>
    <select class="select input-sm" style="width:auto" onchange="tareasFilter.assignee=this.value; renderTareas()">
      <option value="">Asignado: todos</option>
      ${assignees.map(a => {
        const sel = tareasFilter.assignee === a;
        const unavailable = !sel && !availAssignee.has(a);
        return `<option value="${escapeHtml(a)}" ${sel ? 'selected' : ''}${unavailable ? ' disabled' : ''}>${escapeHtml(a)}${unavailable ? ' (0)' : ''}</option>`;
      }).join('')}
    </select>
    ${tags.length ? `<select class="select input-sm" style="width:auto" onchange="tareasFilter.tag=this.value; renderTareas()">
      <option value="">Etiqueta: todas</option>
      ${tags.map(t => {
        const sel = tareasFilter.tag === t;
        const unavailable = !sel && !availTag.has(t);
        return `<option value="${escapeHtml(t)}" ${sel ? 'selected' : ''}${unavailable ? ' disabled' : ''}>${escapeHtml(t)}${unavailable ? ' (0)' : ''}</option>`;
      }).join('')}
    </select>` : ''}
    <select class="select input-sm" style="width:auto" onchange="tareasFilter.project=this.value; renderTareas()">
      <option value="">Proyecto: todos</option>
      <option value="__none__" ${tareasFilter.project === '__none__' ? 'selected' : ''}${(tareasFilter.project !== '__none__' && !hasNoneProject) ? ' disabled' : ''}>Sin proyecto${(tareasFilter.project !== '__none__' && !hasNoneProject) ? ' (0)' : ''}</option>
      ${state.projects.map(p => {
        const sel = tareasFilter.project === p.id;
        const unavailable = !sel && !availProject.has(p.id);
        return `<option value="${p.id}" ${sel ? 'selected' : ''}${unavailable ? ' disabled' : ''}>${escapeHtml(p.code + ' · ' + p.name)}${unavailable ? ' (0)' : ''}</option>`;
      }).join('')}
    </select>
    ${(tareasFilter.q || tareasFilter.status || tareasFilter.priority || tareasFilter.assignee || tareasFilter.tag || tareasFilter.project) ? `<button class="btn btn-ghost btn-sm" onclick="tareasFilter={q:'',status:'',assignee:'',priority:'',tag:'',project:''}; renderTareas()">Limpiar filtros</button>` : ''}
  </div>`;
}

const renderTareasDebounced = debounce(renderTareas, 220);

