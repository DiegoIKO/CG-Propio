    el.querySelectorAll('.pivot-table th, .pivot-table td').forEach(c => {
      c.style.border = '1px solid #c9c1b3';
      c.style.padding = '6px 10px';
      c.style.textAlign = c.classList.contains('value-cell') || c.classList.contains('total-cell') ? 'right' : 'left';
    });
    el.querySelectorAll('.pivot-table th').forEach(c => {
      c.style.background = '#ebe4d4';
      c.style.color = '#6b6357';
      c.style.fontSize = '11px';
      c.style.textTransform = 'uppercase';
      c.style.letterSpacing = '.04em';
      c.style.fontWeight = '600';
    });
    el.querySelectorAll('.pivot-table td.value-cell').forEach(c => {
