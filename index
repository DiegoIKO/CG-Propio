function updateWikiTree() {
  const container = document.getElementById('wiki-tree-container');
  if (container) container.innerHTML = renderWikiTree();
}

function renderWikiTree() {
  const q = wikiSearchQuery.trim().toLowerCase();
  
  if (q) {
    // Modo búsqueda: lista plana de coincidencias
    const matches = state.wikiPages.filter(p => 
      (p.title || '').toLowerCase().includes(q) || 
      (p.content || '').toLowerCase().includes(q)
    );
    if (!matches.length) return '<div class="text-sm text-center py-4" style="color:var(--ink-muted)">Sin resultados</div>';
    return matches.map(p => {
      const content = (p.content || '').toLowerCase();
      const titleMatch = (p.title || '').toLowerCase().includes(q);
      let preview = '';
      if (!titleMatch && content.includes(q)) {
        const idx = content.indexOf(q);
        const start = Math.max(0, idx - 25);
        const end = Math.min(content.length, idx + q.length + 25);
        preview = (start > 0 ? '...' : '') + (p.content || '').slice(start, end) + (end < content.length ? '...' : '');
      }
      return `<div class="tree-node ${wikiSelectedId === p.id ? 'selected' : ''}" onclick="selectWiki('${p.id}')" style="padding: 8px 10px; align-items: flex-start; flex-direction: column">
        <div class="flex items-center gap-2 w-full">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
          <span class="flex-1 truncate">${escapeHtml(p.title)}</span>
        </div>
        ${preview ? `<div class="text-xs mt-1" style="color:var(--ink-muted); padding-left: 21px">${escapeHtml(preview)}</div>` : ''}
      </div>`;
