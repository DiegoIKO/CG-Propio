.chart-zoom-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.chart-zoom-actions button { padding: 8px 14px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; color: #f7f4ee; cursor: pointer; font-size: 12.5px; font-family: 'IBM Plex Sans', sans-serif; display: inline-flex; align-items: center; gap: 6px; transition: all .15s; }
