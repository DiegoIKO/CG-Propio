function summarizePivotFilter(ds, f) {
  if (!f) return '';
  const col = ds.columns[f.colIdx];
  if (!col) return '';
  if (f.type === 'text') {
    if (!f.selected || f.selected.length === 0) return '(sin valores)';
    if (f.selected.length === 1) return `= ${f.selected[0]}`;
    if (f.selected.length <= 3) return `∈ {${f.selected.join(', ')}}`;
    return `${f.selected.length} valores`;
  }
  if (f.type === 'number') {
    const parts = [];
    if (f.min !== null && f.min !== undefined && f.min !== '') parts.push(`≥ ${fmtNumber(f.min)}`);
    if (f.max !== null && f.max !== undefined && f.max !== '') parts.push(`≤ ${fmtNumber(f.max)}`);
    return parts.join(' y ') || '(sin rango)';
  }
  if (f.type === 'date') {
    const parts = [];
    if (f.from) parts.push(`desde ${f.from}`);
    if (f.to) parts.push(`hasta ${f.to}`);
    return parts.join(' ') || '(sin rango)';
  }
  return '';
}

function pivotDragStart(e, colIdx) {
  e.dataTransfer.setData('text/plain', String(colIdx));
  e.target.classList.add('dragging');
}

function pivotDragEnd(e) {
  e.target.classList.remove('dragging');
  document.querySelectorAll('.pivot-dropzone').forEach(z => z.classList.remove('drag-over'));
}

function pivotDrop(e, area) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  const colIdx = parseInt(e.dataTransfer.getData('text/plain'));
  if (isNaN(colIdx)) return;
  
  const ds = state.datasets.find(d => d.id === pivotState.datasetId);
  if (!ds || !ds.columns[colIdx]) return;
  
  // Si ya está en otra área, removerlo
  pivotState.rows = pivotState.rows.filter(r => r.colIdx !== colIdx);
  pivotState.cols = pivotState.cols.filter(c => c.colIdx !== colIdx);
  pivotState.values = pivotState.values.filter(v => v.colIdx !== colIdx);
  pivotState.pivotFilters = pivotState.pivotFilters.filter(f => f.colIdx !== colIdx);
  
  // Añadir al área destino
  const col = ds.columns[colIdx];
  if (area === 'values') {
    pivotState.values.push({ colIdx, agg: col.type === 'number' ? 'sum' : 'count' });
  } else if (area === 'pivotFilters') {
    // Inicializar el filtro según tipo
    const filterObj = { colIdx, type: col.type === 'number' ? 'number' : col.type === 'date' ? 'date' : 'text' };
    if (filterObj.type === 'text') {
      // Por defecto, todos los valores seleccionados (filtro inactivo hasta que el usuario quite alguno)
      const allValues = [...new Set(ds.rows.map(r => String(r[colIdx] === null || r[colIdx] === undefined ? '(vacío)' : r[colIdx])))];
      filterObj.selected = allValues;
    } else if (filterObj.type === 'number') {
      filterObj.min = null;
      filterObj.max = null;
    } else {
      filterObj.from = null;
      filterObj.to = null;
    }
    pivotState.pivotFilters.push(filterObj);
    // Abrir el modal de configuración inmediatamente
    setTimeout(() => openPivotFilterConfig(pivotState.pivotFilters.length - 1), 50);
  } else {
    pivotState[area].push({ colIdx });
  }
  
  renderPivotBuilder_refresh();
}

function removePivotField(area, idx) {
  pivotState[area].splice(idx, 1);
  renderPivotBuilder_refresh();
}

function updatePivotAgg(idx, agg) {
  if (pivotState.values[idx]) {
    pivotState.values[idx].agg = agg;
    refreshPivotResult();
  }
}

function refreshPivotResult() {
  const el = document.getElementById('pivot-result');
  if (el) el.innerHTML = renderPivotResult();
}

function renderPivotBuilder_refresh() {
  const container = document.querySelector('.pivot-builder');
  if (container && container.parentElement) {
    const mainBody = document.getElementById('main-content').querySelector('.p-6');
    if (mainBody) {
      mainBody.innerHTML = renderPivotBuilder();
      setTimeout(setupPivotDragDrop, 0);
    }
  }
}

