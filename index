function generateReporteTrimestral() {
  const today = new Date();
  const q = Math.floor(today.getMonth() / 3) + 1;
  const period = `${q}° trimestre ${today.getFullYear()}`;
  
  const objByPersp = {};
  PERSPECTIVES.forEach(p => { objByPersp[p] = state.objectives.filter(o => o.perspective === p); });
  
  const avgProgressByPersp = PERSPECTIVES.map(p => {
    const objs = objByPersp[p];
    if (!objs.length) return { name: p, avg: 0, count: 0 };
    const sum = objs.reduce((s, o) => s + (o.progress || 0), 0);
    return { name: p, avg: Math.round(sum / objs.length), count: objs.length };
  });
  
  const objRows = state.objectives.map(o => [
    `<strong>${escapeHtml(o.code)}</strong>`,
    escapeHtml(o.name),
    escapeHtml(o.perspective),
    `${o.progress || 0}%`,
    repTag(o.status === 'on-track' ? 'En curso' : o.status === 'at-risk' ? 'En riesgo' : o.status === 'off-track' ? 'Fuera meta' : 'Logrado', o.status === 'on-track' ? 'green' : o.status === 'at-risk' ? 'yellow' : o.status === 'off-track' ? 'red' : 'blue')
  ]);
  
  const kpiRows = state.kpis.map(k => {
    const v = kpiCurrentValue(k);
    const progress = kpiProgressVsTarget(k);
