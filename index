let calendarioTab = 'mes';
let calendarioCursor = new Date();
let calendarioFilters = { milestone: true, project: true, finding: true, commitment: true, risk: true, task: true, meeting: true };

function getAllEvents() {
  const evs = [];
  if (calendarioFilters.milestone) state.milestones.forEach(m => { if (m.dueDate) evs.push({ id: m.id, kind: 'milestone', title: m.name, code: m.code, date: m.dueDate, status: m.status, color: 'purple' }); });
  if (calendarioFilters.project) state.projects.forEach(p => { if (p.dueDate) evs.push({ id: p.id, kind: 'project', title: p.name, code: p.code, date: p.dueDate, status: p.status, color: 'blue' }); });
  if (calendarioFilters.finding) state.findings.forEach(f => { if (f.dueDate) evs.push({ id: f.id, kind: 'finding', title: f.name, code: f.code, date: f.dueDate, status: f.status, color: 'red' }); });
  if (calendarioFilters.commitment) state.commitments.forEach(c => { if (c.dueDate) evs.push({ id: c.id, kind: 'commitment', title: c.name, code: c.code, date: c.dueDate, status: c.status, color: 'yellow' }); });
  if (calendarioFilters.risk) state.risks.forEach(r => { if (r.dueDate) evs.push({ id: r.id, kind: 'risk', title: r.name, code: r.code, date: r.dueDate, status: r.status, color: 'warm' }); });
  if (calendarioFilters.task) (state.tasks || []).forEach(t => { if (t.dueDate) evs.push({ id: t.id, kind: 'task', title: t.title, code: t.code, date: t.dueDate, status: t.status, color: 'accent' }); });
  if (calendarioFilters.meeting) (state.meetings || []).forEach(m => { if (m.date) evs.push({ id: m.id, kind: 'meeting', title: m.title, code: m.code, date: m.date.slice(0, 10), status: m.status, color: 'green' }); });
  return evs;
}

// Maneja el clic en un evento del calendario, llevando al elemento correcto
function calOpenEvent(kind, id) {
  if (kind === 'milestone') {
    navigate('estrategia');
    setTimeout(() => { setEstrategiaTab('hitos'); setTimeout(() => openMilestoneForm(id), 80); }, 80);
  } else if (kind === 'project') {
    if (typeof goToProject === 'function') goToProject(id);
    else { selectedProjectId = id; navigate('proyectos'); }
  } else if (kind === 'finding') {
    if (typeof goToFinding === 'function') goToFinding(id);
    else { navigate('hallazgos'); setTimeout(() => openFindingForm(id), 80); }
  } else if (kind === 'commitment') {
    navigate('personas');
    setTimeout(() => { setPersonasTab('compromisos'); setTimeout(() => openCommitmentForm(id), 80); }, 80);
  } else if (kind === 'risk') {
    if (typeof goToRisk === 'function') goToRisk(id);
    else { navigate('riesgos'); setTimeout(() => openRiskForm(id), 80); }
  } else if (kind === 'task') {
    if (typeof goToTask === 'function') goToTask(id);
    else { navigate('tareas'); setTimeout(() => openTaskForm(id), 80); }
  } else if (kind === 'meeting') {
    reunionesSelectedId = id;
    reunionesView = 'detalle';
    navigate('reuniones');
  }
}

