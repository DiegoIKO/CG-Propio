function addFindingLogEntry(findingId) {
  const f = state.findings.find(x => x.id === findingId);
  if (!f) return;
  ensureFindingLog(f);
  
  const date = document.getElementById('f-log-date').value;
  const pct = parseInt(document.getElementById('f-log-pct').value);
  const action = document.getElementById('f-log-action').value.trim();
  const comment = document.getElementById('f-log-comment').value.trim();
  
  if (!date) { toast('La fecha es obligatoria'); return; }
  if (isNaN(pct) || pct < 0 || pct > 100) { toast('El % de avance debe estar entre 0 y 100'); return; }
  if (!action && !comment) { toast('Describe la acción o agrega un comentario'); return; }
  
  f.progressLog.push({ date, percent: pct, action, comment });
  f.progress = pct;
  
  // Sugerir cerrar el hallazgo si llegó a 100%
  if (pct >= 100 && f.status !== 'Cerrado') {
    if (confirm('El avance llegó a 100%. ¿Quieres marcar el hallazgo como "Cerrado"?')) {
      f.status = 'Cerrado';
    }
  } else if (pct > 0 && pct < 100 && f.status === 'Pendiente') {
    f.status = 'En tratamiento';
  }
  
  save();
  closeModal();
  openFindingLog(findingId); // re-abrir para mostrar la nueva entrada
  toast('Entrada agregada a la bitácora');
}

function deleteFindingLogEntry(findingId, idx) {
  const f = state.findings.find(x => x.id === findingId);
  if (!f) return;
  ensureFindingLog(f);
  if (!confirm('¿Eliminar esta entrada de la bitácora?')) return;
  f.progressLog.splice(idx, 1);
  
  // Recalcular progreso al de la entrada más reciente
  if (f.progressLog.length > 0) {
    const sorted = [...f.progressLog].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
    f.progress = sorted[0].percent;
  } else {
    f.progress = 0;
  }
  
  save();
  closeModal();
  openFindingLog(findingId);
}

function openFindingForm(id) {
  const f = id ? state.findings.find(x => x.id === id) : null;
  const isEdit = !!f;
  const yr = new Date().getFullYear();
  const body = `<div class="space-y-3">
    <div class="grid grid-cols-3 gap-3">
      <div>${field('Código', inputField('f-h-code', f?.code || `H-${yr}-${String(state.findings.length + 1).padStart(3, '0')}`))}</div>
      <div>${field('Origen', selectField('f-h-src', ['Auditoría Interna', 'CGR', 'Autoevaluación', 'Denuncia', 'Otro'], f?.source || 'Auditoría Interna'))}</div>
