    <div>${field('Objetivo estratégico (opcional)', selectField('f-kpi-objective', [{value:'',label:'— Ninguno —'}, ...state.objectives.map(o => ({value: o.code, label: o.code + ' · ' + o.name}))], k?.objective || ''))}</div>
    <div>${field('Proceso que mide (opcional)', relationSelectField('f-kpi-process', processItems(), k?.processId))}</div>
  </div>`;
  openModal({ title: isEdit ? 'Editar indicador' : 'Nuevo indicador', body, footer: `<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-save-kpi">${isEdit ? 'Guardar' : 'Crear'}</button>` });
  document.getElementById('btn-save-kpi').onclick = () => {
    const payload = { code: document.getElementById('f-kpi-code').value.trim(), name: document.getElementById('f-kpi-name').value.trim(), unit: document.getElementById('f-kpi-unit').value.trim(), owner: document.getElementById('f-kpi-owner').value.trim(), frequency: document.getElementById('f-kpi-freq').value, target: Number(document.getElementById('f-kpi-target').value), thresholdGreen: Number(document.getElementById('f-kpi-green').value), thresholdYellow: Number(document.getElementById('f-kpi-yellow').value), direction: document.getElementById('f-kpi-direction').value, objective: document.getElementById('f-kpi-objective').value, processId: document.getElementById('f-kpi-process').value || null };
    if (!payload.name) { toast('Nombre obligatorio'); return; }
    if (isEdit) Object.assign(k, payload); else state.kpis.push({ id: uid(), ...payload, measurements: [] });
    save(); closeModal(); renderKPIs(); toast(isEdit ? 'Actualizado' : 'Creado');
