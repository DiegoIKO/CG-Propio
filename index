    pending: 'Pendiente',
    inProgress: 'En curso',
    completed: 'Completada',
    overdue: 'Vencida'
  };
  
  const datesStr = stage.startDate && stage.dueDate
    ? `${fmtDate(stage.startDate)} → ${fmtDate(stage.dueDate)}`
    : stage.dueDate ? `Plazo: ${fmtDate(stage.dueDate)}`
    : 'Sin fechas';
  
  return `<div class="stage-card ${stageStatus}">
    <div class="stage-header ${isExpanded ? 'open' : ''}" onclick="toggleStageExpanded('${project.id}', '${stage.id}')">
