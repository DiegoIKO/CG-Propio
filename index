    `${m.progress || 0}%`,
    fmtDate(m.dueDate),
    repTag(m.status, m.status === 'Cumplido' ? 'green' : m.status === 'En curso' ? 'blue' : 'yellow')
  ]);
  
  return `${repCover('Informe Trimestral de Gestión', `Período: ${period}`)}
    
    <h2>1. Marco Estratégico</h2>
    <h3>Misión</h3>
    <p>${escapeHtml(state.strategy.mission || 'No definida')}</p>
