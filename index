          <button onclick="relZoom(1.2)" title="Acercar">+</button>
          <button onclick="relZoom(0.83)" title="Alejar">−</button>
        </div>
      </div>
      <div class="rel-side-panel" id="rel-side-panel">
        ${renderRelSidePanel()}
      </div>
    </div>
  `;
  
  // Computar grafo y renderizar
  buildRelGraph();
  setTimeout(() => {
    initRelSimulation();
    renderRelSVG();
    updateRelHealth();
  }, 50);
}

function renderRelFilters() {
  const counts = computeRelCounts();
  const filterTypes = ['objective', 'milestone', 'kpi', 'process', 'project', 'risk', 'finding'];
  return filterTypes.map(type => {
    const cfg = REL_NODE_TYPES[type];
    const count = counts[type] || 0;
    const active = relState.filters[type];
    return `<button class="rel-pill ${active ? 'active' : ''}" onclick="toggleRelFilter('${type}')">
      <span class="rel-pill-dot" style="background:${cfg.color}"></span>
      ${cfg.label}s
      <span class="rel-pill-count">${count}</span>
    </button>`;
  }).join('') + `<button class="rel-pill" onclick="relAllFilters(true)" title="Activar todos">Todos</button><button class="rel-pill" onclick="relAllFilters(false)" title="Desactivar todos">Ninguno</button>`;
}

function computeRelCounts() {
  return {
    objective: state.objectives.length,
    milestone: state.milestones.length,
    kpi: state.kpis.length,
    process: state.processes.length,
    project: state.projects.length,
    risk: state.risks.length,
    finding: state.findings.length,
    task: (state.tasks || []).length,
    meeting: (state.meetings || []).length,
    document: state.documents.length,
    commitment: state.commitments.length,
    person: state.people.length,
    unit: state.units.length
  };
}

function renderRelSidePanel() {
  if (!relState.selectedId) {
    return `<div class="rel-side-empty">
      <div class="empty-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><path d="M7 8l4 8M17 8l-4 8"/></svg></div>
      <div style="font-family: 'Instrument Serif', serif; font-size: 22px; color: var(--ink); margin-bottom: 8px">Explora tu red</div>
      <div>Haz clic en cualquier nodo del grafo para ver sus detalles y conexiones. Usa los filtros de arriba para mostrar u ocultar tipos de elementos.</div>
      <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--line); text-align: left; font-size: 12px">
        <div style="font-weight: 600; margin-bottom: 8px; color: var(--ink)">Atajos del grafo</div>
        <div style="line-height: 1.7"><strong>Clic</strong> · selecciona nodo<br><strong>Arrastrar nodo</strong> · reorganizar<br><strong>Arrastrar fondo</strong> · mover vista<br><strong>+ / −</strong> · zoom</div>
      </div>
    </div>`;
  }
  
  const node = relState.nodes.find(n => n.id === relState.selectedId);
  if (!node) return `<div class="rel-side-empty">Nodo no encontrado</div>`;
  
  const cfg = REL_NODE_TYPES[node.type];
  const connections = relState.links.filter(l => l.source.id === node.id || l.target.id === node.id);
  
  // Agrupar conexiones por tipo del nodo del otro lado
  const grouped = {};
  connections.forEach(l => {
    const other = l.source.id === node.id ? l.target : l.source;
    if (!grouped[other.type]) grouped[other.type] = [];
    grouped[other.type].push(other);
  });
  
  // Metadata específica del tipo
  let metaHTML = '';
  if (node.type === 'kpi') {
    const k = state.kpis.find(x => x.id === node.id);
    if (k) {
      const v = kpiCurrentValue(k);
      const s = kpiStatus(k);
      const statusLabel = s === 'green' ? 'En meta' : s === 'yellow' ? 'En alerta' : s === 'red' ? 'Crítico' : 'Sin datos';
      metaHTML = `<div>Valor actual: <strong>${v === null ? '—' : fmtNumber(v)} ${escapeHtml(k.unit || '')}</strong></div>
        <div>Meta: <strong>${fmtNumber(k.target)} ${escapeHtml(k.unit || '')}</strong></div>
        <div>Estado: <span class="badge badge-${s === 'gray' ? 'gray' : s}">${statusLabel}</span></div>
        ${k.owner ? `<div>Responsable: <strong>${escapeHtml(k.owner)}</strong></div>` : ''}`;
    }
  } else if (node.type === 'risk') {
    const r = state.risks.find(x => x.id === node.id);
    if (r) {
      const res = r.residualProb * r.residualImpact;
      const cls = res >= 15 ? 'red' : res >= 8 ? 'yellow' : 'green';
      metaHTML = `<div>P×I residual: <span class="badge badge-${cls}">${res}</span></div>
        <div>Categoría: <strong>${escapeHtml(r.category)}</strong></div>
        <div>Tratamiento: <strong>${escapeHtml(r.treatment)}</strong></div>
        ${r.owner ? `<div>Responsable: <strong>${escapeHtml(r.owner)}</strong></div>` : ''}`;
    }
  } else if (node.type === 'objective') {
    const o = state.objectives.find(x => x.id === node.id);
    if (o) {
      metaHTML = `<div>Perspectiva: <strong>${escapeHtml(o.perspective)}</strong></div>
        <div>Avance: <strong>${o.progress || 0}%</strong></div>
        ${o.owner ? `<div>Responsable: <strong>${escapeHtml(o.owner)}</strong></div>` : ''}`;
    }
  } else if (node.type === 'project') {
    const p = state.projects.find(x => x.id === node.id);
    if (p) {
      const stMap = { backlog: 'Backlog', inProgress: 'En curso', review: 'En revisión', done: 'Completado' };
      metaHTML = `<div>Estado: <strong>${stMap[p.status] || p.status}</strong></div>
        <div>Avance: <strong>${p.progress || 0}%</strong></div>
        ${p.owner ? `<div>Responsable: <strong>${escapeHtml(p.owner)}</strong></div>` : ''}
        ${p.dueDate ? `<div>Plazo: <strong>${fmtDate(p.dueDate)}</strong></div>` : ''}`;
    }
  } else if (node.type === 'process') {
    const p = state.processes.find(x => x.id === node.id);
    if (p) {
      metaHTML = `<div>Tipo: <strong>${escapeHtml(p.type)}</strong></div>
        ${p.owner ? `<div>Dueño: <strong>${escapeHtml(p.owner)}</strong></div>` : ''}
        <div>Versión: <strong>v${escapeHtml(p.version)}</strong></div>
        <div>Salud: <strong>${p.health || 0}%</strong></div>`;
    }
  } else if (node.type === 'finding') {
    const f = state.findings.find(x => x.id === node.id);
    if (f) {
      metaHTML = `<div>Origen: <strong>${escapeHtml(f.source)}</strong></div>
        <div>Severidad: <span class="badge badge-${f.severity === 'Alta' ? 'red' : f.severity === 'Media' ? 'yellow' : 'green'}">${escapeHtml(f.severity)}</span></div>
        <div>Estado: <strong>${escapeHtml(f.status)}</strong></div>
        ${f.dueDate ? `<div>Plazo: <strong>${fmtDate(f.dueDate)}</strong></div>` : ''}`;
    }
  } else if (node.type === 'milestone') {
    const m = state.milestones.find(x => x.id === node.id);
    if (m) {
      metaHTML = `<div>Estado: <strong>${escapeHtml(m.status || 'Pendiente')}</strong></div>
        ${m.dueDate ? `<div>Plazo: <strong>${fmtDate(m.dueDate)}</strong></div>` : ''}
        ${m.owner ? `<div>Responsable: <strong>${escapeHtml(m.owner)}</strong></div>` : ''}`;
    }
  }
  
  // Lista de conexiones
  const connectionsHTML = Object.keys(grouped).length 
    ? Object.entries(grouped).map(([type, nodes]) => {
        const tCfg = REL_NODE_TYPES[type];
        return `<div class="rel-conn-section">
          <div class="rel-conn-title">${tCfg.label}s conectados (${nodes.length})</div>
          ${nodes.map(n => `<div class="rel-conn-item" onclick="selectRelNode('${n.id}')">
            <span class="conn-dot" style="background:${tCfg.color}"></span>
            <span class="conn-text">${n.code ? `<span class="conn-code">${escapeHtml(n.code)}</span> ` : ''}${escapeHtml(n.title)}</span>
          </div>`).join('')}
        </div>`;
      }).join('')
    : `<div class="rel-conn-section">
        <div class="rel-conn-title">Sin conexiones</div>
        <div style="font-size: 12px; color: var(--ink-muted); padding: 8px 0">Este elemento no tiene vínculos con otros elementos del sistema. Considera agregarlos para mejorar la trazabilidad.</div>
      </div>`;
  
  const openRoute = relGetRoute(node.type);
  return `<div class="rel-side-detail">
    <div class="rel-detail-icon" style="background:${cfg.color}">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${cfg.icon}</svg>
    </div>
    <div class="rel-detail-type">${cfg.label}</div>
    ${node.code ? `<div class="rel-detail-code">${escapeHtml(node.code)}</div>` : ''}
    <div class="rel-detail-title">${escapeHtml(node.title)}</div>
    ${node.description ? `<div class="rel-detail-meta">${escapeHtml(node.description)}</div>` : ''}
    ${metaHTML ? `<div class="rel-detail-meta" style="display:flex; flex-direction:column; gap:6px">${metaHTML}</div>` : ''}
    
    ${openRoute ? `<button class="btn btn-primary" style="width:100%; margin-top: 12px" onclick="navigate('${openRoute}')">Abrir en su módulo →</button>` : ''}
    
    ${connectionsHTML}
  </div>`;
}

function relGetRoute(type) {
  const map = { kpi: 'kpis', objective: 'estrategia', milestone: 'estrategia', process: 'procesos', risk: 'riesgos', project: 'proyectos', finding: 'hallazgos', task: 'tareas', meeting: 'reuniones', document: 'documental', commitment: 'personas', person: 'personas', unit: 'personas' };
  return map[type] || null;
}

function buildRelGraph() {
  const nodes = [];
  const links = [];
  const nodesById = {};
  
  function addNode(type, item, titleField = 'name') {
    if (!relState.filters[type]) return null;
    const cfg = REL_NODE_TYPES[type];
    const node = {
      id: type + ':' + item.id,
      rawId: item.id,
      type,
      code: item.code || '',
      title: item[titleField] || item.title || '(sin nombre)',
      description: item.description || '',
      size: cfg.size,
      color: cfg.color,
      x: 0, y: 0, vx: 0, vy: 0,
      fx: null, fy: null
    };
    nodes.push(node);
    nodesById[node.id] = node;
    return node;
  }
  
  function addLink(sourceId, targetId, kind) {
    if (!nodesById[sourceId] || !nodesById[targetId]) return;
    links.push({ source: nodesById[sourceId], target: nodesById[targetId], kind: kind || 'related' });
  }
  
  // Crear nodos
  state.objectives.forEach(o => addNode('objective', o));
  state.milestones.forEach(m => addNode('milestone', m));
  state.kpis.forEach(k => addNode('kpi', k));
  state.processes.forEach(p => addNode('process', p));
  state.risks.forEach(r => addNode('risk', r));
  state.projects.forEach(p => addNode('project', p));
  state.findings.forEach(f => addNode('finding', f));
  (state.tasks || []).forEach(t => addNode('task', t, 'title'));
  (state.meetings || []).forEach(m => addNode('meeting', m, 'title'));
  state.documents.forEach(d => addNode('document', d, 'title'));
  state.commitments.forEach(c => addNode('commitment', c));
  state.people.forEach(p => addNode('person', p));
  state.units.forEach(u => addNode('unit', u));
  
  // Crear enlaces
  // KPI -> Objetivo (por código de objetivo)
  state.kpis.forEach(k => {
    if (k.objective) {
      const obj = state.objectives.find(o => o.code === k.objective);
      if (obj) addLink('kpi:' + k.id, 'objective:' + obj.id, 'kpi-objective');
    }
    if (k.processId) addLink('kpi:' + k.id, 'process:' + k.processId, 'kpi-process');
  });
  
  // Hito -> Objetivo
  state.milestones.forEach(m => {
    if (m.objective) {
      const obj = state.objectives.find(o => o.code === m.objective);
      if (obj) addLink('milestone:' + m.id, 'objective:' + obj.id, 'milestone-objective');
    }
  });
  
  // Proyecto -> Objetivo, Hallazgo
  state.projects.forEach(p => {
    if (p.objectiveCode) {
      const obj = state.objectives.find(o => o.code === p.objectiveCode);
      if (obj) addLink('project:' + p.id, 'objective:' + obj.id, 'project-objective');
    }
    if (p.findingId) addLink('project:' + p.id, 'finding:' + p.findingId, 'project-finding');
  });
  
  // Riesgo -> Procesos (múltiple)
  state.risks.forEach(r => {
    const procIds = r.processIds || (r.processId ? [r.processId] : []);
    procIds.forEach(pid => addLink('risk:' + r.id, 'process:' + pid, 'risk-process'));
  });
  
  // Hallazgo -> Proceso
  state.findings.forEach(f => {
    if (f.processId) addLink('finding:' + f.id, 'process:' + f.processId, 'finding-process');
  });
  
  // Documento -> Proceso
  state.documents.forEach(d => {
    if (d.processId) addLink('document:' + d.id, 'process:' + d.processId, 'document-process');
  });
  
  // Tarea -> Proyecto, Reunión
  (state.tasks || []).forEach(t => {
    if (t.projectId) addLink('task:' + t.id, 'project:' + t.projectId, 'task-project');
    if (t.meetingId) addLink('task:' + t.id, 'meeting:' + t.meetingId, 'task-meeting');
  });
  
  // Persona -> Unidad
  state.people.forEach(p => {
    if (p.unitId) addLink('person:' + p.id, 'unit:' + p.unitId, 'person-unit');
  });
  
  // Compromiso -> Persona (por owner si coincide con persona registrada)
  state.commitments.forEach(c => {
    if (c.owner) {
      const person = state.people.find(p => p.name === c.owner);
      if (person) addLink('commitment:' + c.id, 'person:' + person.id, 'commitment-person');
    }
  });
  
  // Filtrar huérfanos si está activado
  if (relState.showOrphans) {
    const connectedIds = new Set();
    links.forEach(l => { connectedIds.add(l.source.id); connectedIds.add(l.target.id); });
    relState.nodes = nodes.filter(n => !connectedIds.has(n.id));
    relState.links = [];
  } else {
    relState.nodes = nodes;
    relState.links = links;
  }
  
  // Posicionar inicialmente en círculo según tipo
  const W = 900, H = 600;
  const centerX = W / 2, centerY = H / 2;
  const typeAngles = {};
  const typeKeys = Object.keys(REL_NODE_TYPES);
  typeKeys.forEach((t, i) => { typeAngles[t] = (i / typeKeys.length) * Math.PI * 2; });
  
  relState.nodes.forEach((n, i) => {
    const typeRadius = 200;
    const angleBase = typeAngles[n.type];
    const sameTypeCount = relState.nodes.filter(x => x.type === n.type).length;
    const idxInType = relState.nodes.filter(x => x.type === n.type).indexOf(n);
    const spread = (idxInType - sameTypeCount / 2) * 0.15;
    n.x = centerX + Math.cos(angleBase + spread) * typeRadius;
    n.y = centerY + Math.sin(angleBase + spread) * typeRadius;
  });
}

// Simulación de fuerzas simple (force-directed layout)
function initRelSimulation() {
  if (relState.simulationFrame) cancelAnimationFrame(relState.simulationFrame);
  relState.simulationRunning = true;
  let iterations = 0;
  const MAX_ITERATIONS = 350;
  
  function step() {
    if (!relState.simulationRunning || iterations >= MAX_ITERATIONS) {
      relState.simulationRunning = false;
      renderRelSVG();
      return;
    }
    
    const cooling = Math.max(0.05, 1 - (iterations / MAX_ITERATIONS) * 0.95);
    
    // Repulsión entre todos los pares
    for (let i = 0; i < relState.nodes.length; i++) {
      const a = relState.nodes[i];
      if (a.fx !== null) continue;
      for (let j = i + 1; j < relState.nodes.length; j++) {
        const b = relState.nodes[j];
        const dx = b.x - a.x, dy = b.y - a.y;
        const dist2 = dx * dx + dy * dy + 0.01;
        const dist = Math.sqrt(dist2);
        const repulsion = 2200 / dist2;
        const fx = (dx / dist) * repulsion;
        const fy = (dy / dist) * repulsion;
        if (a.fx === null) { a.vx -= fx; a.vy -= fy; }
        if (b.fx === null) { b.vx += fx; b.vy += fy; }
      }
    }
    
    // Atracción por enlaces
    relState.links.forEach(l => {
      const dx = l.target.x - l.source.x;
      const dy = l.target.y - l.source.y;
      const dist = Math.sqrt(dx * dx + dy * dy + 0.01);
      const idealDist = 110;
      const force = (dist - idealDist) * 0.04;
      const fx = (dx / dist) * force;
      const fy = (dy / dist) * force;
      if (l.source.fx === null) { l.source.vx += fx; l.source.vy += fy; }
      if (l.target.fx === null) { l.target.vx -= fx; l.target.vy -= fy; }
    });
    
    // Centrado leve hacia el centro del canvas
    const centerX = 450, centerY = 300;
    relState.nodes.forEach(n => {
      if (n.fx !== null) return;
      n.vx += (centerX - n.x) * 0.005;
      n.vy += (centerY - n.y) * 0.005;
    });
    
    // Aplicar velocidades con amortiguación
    relState.nodes.forEach(n => {
      if (n.fx !== null) { n.x = n.fx; n.y = n.fy; return; }
      n.vx *= 0.85 * cooling;
      n.vy *= 0.85 * cooling;
      n.x += n.vx;
      n.y += n.vy;
    });
    
    iterations++;
    if (iterations % 3 === 0) renderRelSVG();
    relState.simulationFrame = requestAnimationFrame(step);
  }
  
  step();
}

function renderRelSVG() {
  const svg = document.getElementById('rel-svg');
  if (!svg) return;
  
  // Determinar viewBox dinámico basado en posiciones
  if (relState.nodes.length === 0) {
    svg.innerHTML = '<text x="50%" y="50%" text-anchor="middle" fill="#a39684" font-family="Instrument Serif, serif" font-size="20">Sin elementos para mostrar con los filtros actuales</text>';
    svg.setAttribute('viewBox', '0 0 900 600');
    return;
  }
  
  const xs = relState.nodes.map(n => n.x);
  const ys = relState.nodes.map(n => n.y);
  const minX = Math.min(...xs) - 80, maxX = Math.max(...xs) + 80;
  const minY = Math.min(...ys) - 80, maxY = Math.max(...ys) + 80;
  const w = maxX - minX, h = maxY - minY;
  
  // Centrar la vista
  svg.setAttribute('viewBox', `${minX - relState.panX} ${minY - relState.panY} ${w / relState.zoom} ${h / relState.zoom}`);
  
  const selectedNode = relState.selectedId ? relState.nodes.find(n => n.id === relState.selectedId) : null;
  const connectedIds = new Set();
  if (selectedNode) {
    connectedIds.add(selectedNode.id);
    relState.links.forEach(l => {
      if (l.source.id === selectedNode.id) connectedIds.add(l.target.id);
      if (l.target.id === selectedNode.id) connectedIds.add(l.source.id);
    });
  }
  
  // Construir SVG
  let html = '<defs><marker id="rel-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="rgba(120, 110, 100, 0.5)"/></marker></defs>';
  
  // Links primero (debajo)
  relState.links.forEach(l => {
    const isHighlighted = selectedNode && (l.source.id === selectedNode.id || l.target.id === selectedNode.id);
    const isFaded = selectedNode && !isHighlighted;
    const cls = `rel-link ${isHighlighted ? 'highlighted' : ''} ${isFaded ? 'faded' : ''}`;
    // Curva bezier
    const dx = l.target.x - l.source.x;
    const dy = l.target.y - l.source.y;
    const dr = Math.sqrt(dx * dx + dy * dy) * 0.8;
    html += `<path d="M${l.source.x},${l.source.y} A${dr},${dr} 0 0,1 ${l.target.x},${l.target.y}" class="${cls}"/>`;
  });
  
  // Nodos (encima)
  relState.nodes.forEach(n => {
    const isSelected = n.id === relState.selectedId;
    const isFaded = selectedNode && !connectedIds.has(n.id);
    const cls = `rel-node-circle ${isSelected ? 'selected' : ''} ${isFaded ? 'faded' : ''}`;
    const labelCls = `rel-node-label ${isFaded ? 'faded' : ''}`;
    
    html += `<g data-node-id="${escapeHtml(n.id)}" onmousedown="relNodeMouseDown(event, '${escapeHtml(n.id)}')" style="cursor:pointer">
      <circle cx="${n.x}" cy="${n.y}" r="${n.size}" fill="${n.color}" class="${cls}"/>
      <text x="${n.x}" y="${n.y + n.size + 14}" class="${labelCls}">${escapeHtml(n.title.length > 24 ? n.title.slice(0, 22) + '…' : n.title)}</text>
    </g>`;
  });
  
  svg.innerHTML = html;
  
  // Event handlers para pan del canvas
  if (!svg.dataset.panInit) {
    svg.dataset.panInit = '1';
    setupRelCanvasPan();
  }
}

let relDragNode = null;
let relDragStart = { x: 0, y: 0 };
let relCanvasPan = { active: false, startX: 0, startY: 0, baseX: 0, baseY: 0 };

function relNodeMouseDown(e, nodeId) {
  e.stopPropagation();
  const node = relState.nodes.find(n => n.id === nodeId);
  if (!node) return;
  
  selectRelNode(nodeId);
  
  relDragNode = node;
  const svg = document.getElementById('rel-svg');
  const rect = svg.getBoundingClientRect();
  const vb = svg.viewBox.baseVal;
  const startSvgX = vb.x + (e.clientX - rect.left) / rect.width * vb.width;
  const startSvgY = vb.y + (e.clientY - rect.top) / rect.height * vb.height;
  relDragStart = { x: startSvgX - node.x, y: startSvgY - node.y };
  
  node.fx = node.x;
  node.fy = node.y;
  
  document.addEventListener('mousemove', relNodeMouseMove);
  document.addEventListener('mouseup', relNodeMouseUp);
}

function relNodeMouseMove(e) {
  if (!relDragNode) return;
  const svg = document.getElementById('rel-svg');
  const rect = svg.getBoundingClientRect();
  const vb = svg.viewBox.baseVal;
  const svgX = vb.x + (e.clientX - rect.left) / rect.width * vb.width;
  const svgY = vb.y + (e.clientY - rect.top) / rect.height * vb.height;
  relDragNode.fx = svgX - relDragStart.x;
  relDragNode.fy = svgY - relDragStart.y;
  renderRelSVG();
}

function relNodeMouseUp() {
  if (relDragNode) {
    // Mantener fijada la posición tras arrastrar
    relDragNode = null;
  }
  document.removeEventListener('mousemove', relNodeMouseMove);
  document.removeEventListener('mouseup', relNodeMouseUp);
}

function setupRelCanvasPan() {
  const wrap = document.getElementById('rel-canvas-wrap');
  if (!wrap) return;
  
  wrap.addEventListener('mousedown', (e) => {
    if (e.target.closest('[data-node-id]')) return;
    if (e.target.closest('.rel-toolbar') || e.target.closest('.rel-health-bar') || e.target.closest('.rel-zoom-controls')) return;
    relCanvasPan.active = true;
    relCanvasPan.startX = e.clientX;
    relCanvasPan.startY = e.clientY;
    relCanvasPan.baseX = relState.panX;
    relCanvasPan.baseY = relState.panY;
    wrap.classList.add('dragging');
  });
  
  document.addEventListener('mousemove', (e) => {
    if (!relCanvasPan.active) return;
    relState.panX = relCanvasPan.baseX + (e.clientX - relCanvasPan.startX);
    relState.panY = relCanvasPan.baseY + (e.clientY - relCanvasPan.startY);
    renderRelSVG();
  });
  
  document.addEventListener('mouseup', () => {
    if (relCanvasPan.active) {
      relCanvasPan.active = false;
      wrap.classList.remove('dragging');
    }
  });
  
  // Click vacío deselecciona
  wrap.addEventListener('click', (e) => {
    if (e.target.closest('[data-node-id]') || e.target.closest('.rel-toolbar') || e.target.closest('.rel-health-bar') || e.target.closest('.rel-zoom-controls')) return;
    if (relState.selectedId) {
      relState.selectedId = null;
      document.getElementById('rel-side-panel').innerHTML = renderRelSidePanel();
      renderRelSVG();
    }
  });
}

function selectRelNode(nodeId) {
  relState.selectedId = nodeId;
  document.getElementById('rel-side-panel').innerHTML = renderRelSidePanel();
  renderRelSVG();
}

function toggleRelFilter(type) {
  relState.filters[type] = !relState.filters[type];
  document.getElementById('rel-filters').innerHTML = renderRelFilters();
  buildRelGraph();
  initRelSimulation();
  renderRelSVG();
  updateRelHealth();
}

function relAllFilters(value) {
  Object.keys(relState.filters).forEach(k => relState.filters[k] = value);
  // Asegurar al menos los principales
  if (!value) { ['kpi', 'objective', 'process'].forEach(k => relState.filters[k] = true); }
  document.getElementById('rel-filters').innerHTML = renderRelFilters();
  buildRelGraph();
  initRelSimulation();
  renderRelSVG();
  updateRelHealth();
}

function toggleOrphansView() {
  relState.showOrphans = !relState.showOrphans;
  relState.selectedId = null;
  renderRelaciones();
}

function relSearch(query) {
  relState.searchQuery = query;
  const q = query.trim().toLowerCase();
  if (!q) {
    relState.selectedId = null;
    renderRelSVG();
    document.getElementById('rel-side-panel').innerHTML = renderRelSidePanel();
    return;
  }
  const match = relState.nodes.find(n => 
    n.title.toLowerCase().includes(q) || (n.code || '').toLowerCase().includes(q)
  );
  if (match) {
    selectRelNode(match.id);
  }
}

function resetRelView() {
  relState.filters = { ...{ kpi: true, objective: true, milestone: true, process: true, risk: true, project: true, finding: true } };
  relState.selectedId = null;
  relState.searchQuery = '';
  relState.showOrphans = false;
  relState.zoom = 1;
  relState.panX = 0;
  relState.panY = 0;
  // Liberar nodos fijados
  relState.nodes.forEach(n => { n.fx = null; n.fy = null; });
  renderRelaciones();
}

function centerRelGraph() {
  relState.panX = 0;
  relState.panY = 0;
  relState.zoom = 1;
  // Liberar nodos fijados para que se reorganicen
  relState.nodes.forEach(n => { n.fx = null; n.fy = null; });
  initRelSimulation();
  renderRelSVG();
}

function relZoom(factor) {
  relState.zoom = Math.max(0.3, Math.min(3, relState.zoom * factor));
  renderRelSVG();
}

function updateRelHealth() {
  const el = document.getElementById('rel-health');
  if (!el) return;
  
  // Calcular indicadores de salud de la red
  const total = relState.nodes.length;
  const connectedIds = new Set();
  relState.links.forEach(l => { connectedIds.add(l.source.id); connectedIds.add(l.target.id); });
  const orphans = total - connectedIds.size;
  const orphanPct = total ? Math.round(((total - orphans) / total) * 100) : 0;
  
  // KPIs sin objetivo
  const kpisWithoutObj = state.kpis.filter(k => !k.objective || !state.objectives.find(o => o.code === k.objective)).length;
  // Objetivos sin KPIs
  const objsWithoutKpi = state.objectives.filter(o => !state.kpis.some(k => k.objective === o.code)).length;
  // Riesgos sin proceso
  const risksWithoutProc = state.risks.filter(r => !(r.processIds || []).length && !r.processId).length;
  
  el.innerHTML = `
    <div><div style="font-size: 10px; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .06em">Conectividad</div><strong>${orphanPct}%</strong></div>
    <div style="border-left: 1px solid var(--line); padding-left: 14px"><div style="font-size: 10px; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .06em">Nodos</div><strong>${total}</strong></div>
    <div style="border-left: 1px solid var(--line); padding-left: 14px"><div style="font-size: 10px; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .06em">Conexiones</div><strong>${relState.links.length}</strong></div>
    ${orphans > 0 ? `<div style="border-left: 1px solid var(--line); padding-left: 14px; color: var(--red)"><div style="font-size: 10px; text-transform: uppercase; letter-spacing: .06em">Huérfanos</div><strong>${orphans}</strong></div>` : ''}
    ${(kpisWithoutObj + objsWithoutKpi + risksWithoutProc) > 0 ? `<div style="border-left: 1px solid var(--line); padding-left: 14px; color: var(--warm)" title="${kpisWithoutObj} KPIs sin objetivo, ${objsWithoutKpi} objetivos sin KPIs, ${risksWithoutProc} riesgos sin proceso"><div style="font-size: 10px; text-transform: uppercase; letter-spacing: .06em">Vínculos faltantes</div><strong>${kpisWithoutObj + objsWithoutKpi + risksWithoutProc}</strong></div>` : ''}
  `;
}

function exportRelaciones() {
  const svg = document.getElementById('rel-svg');
  if (!svg) return;
  
  // Crear copia con estilos en línea
  const clone = svg.cloneNode(true);
  clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
  clone.setAttribute('style', 'background: #faf7ef');
  
  // Aplicar estilos inline
  clone.querySelectorAll('.rel-link').forEach(el => {
    el.setAttribute('stroke', 'rgba(120, 110, 100, 0.4)');
    el.setAttribute('fill', 'none');
  });
  clone.querySelectorAll('.rel-link.highlighted').forEach(el => {
    el.setAttribute('stroke', 'rgba(21, 17, 13, 0.85)');
    el.setAttribute('stroke-width', '2');
  });
  clone.querySelectorAll('.rel-node-label').forEach(el => {
    el.setAttribute('font-family', "'IBM Plex Sans', sans-serif");
    el.setAttribute('font-size', '10.5');
    el.setAttribute('fill', '#15110d');
    el.setAttribute('font-weight', '500');
    el.setAttribute('text-anchor', 'middle');
  });
  clone.querySelectorAll('.rel-node-circle').forEach(el => {
    el.setAttribute('stroke', 'white');
    el.setAttribute('stroke-width', '2');
  });
  
  const svgString = new XMLSerializer().serializeToString(clone);
  const blob = new Blob([svgString], { type: 'image/svg+xml' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'red-institucional-' + new Date().toISOString().slice(0,10) + '.svg';
  a.click();
  URL.revokeObjectURL(url);
  toast('Red exportada como SVG');
}

