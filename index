      v === null ? '—' : `${fmtNumber(v)} ${escapeHtml(k.unit || '')}`,
      `${fmtNumber(k.target)} ${escapeHtml(k.unit || '')}`,
      `${Math.round(progress)}%`,
      repTag(s === 'green' ? 'En meta' : s === 'yellow' ? 'Alerta' : s === 'red' ? 'Crítico' : 'Sin datos', kpiTagColor(k)),
      escapeHtml(k.owner || '—'),
      obj ? escapeHtml(obj.code) : '—'
    ];
  });
  return `${repCover('Reporte de Indicadores', 'Catálogo institucional de KPIs con semaforización')}
    
    <h2>Resumen</h2>
    ${repSummary(`Se monitorean <strong>${state.kpis.length} indicadores</strong>. Estado actual: ${state.kpis.filter(k => kpiStatus(k) === 'green').length} en meta · ${state.kpis.filter(k => kpiStatus(k) === 'yellow').length} en alerta · ${state.kpis.filter(k => kpiStatus(k) === 'red').length} críticos · ${state.kpis.filter(k => kpiStatus(k) === 'gray').length} sin datos suficientes.`)}
    
    <h2>Catálogo de Indicadores</h2>
