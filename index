function computeSearchResults(query) {
  const results = [];
  const q = query.trim().toLowerCase();
  
  // Búsqueda de rutas siempre disponible
  GS_ROUTES.forEach(r => {
    if (!q || r.name.toLowerCase().includes(q) || r.keywords.toLowerCase().includes(q)) {
      results.push({ kind: 'route', title: r.name, code: '', meta: '', action: () => navigate(r.id) });
    }
  });
  
  if (!q) {
    // Sin búsqueda, solo mostramos rutas
    return results.slice(0, 8);
  }
  
  const match = (str) => (str || '').toLowerCase().includes(q);
  
  state.kpis.forEach(k => {
    if (match(k.code) || match(k.name) || match(k.owner)) {
      const s = kpiStatus(k);
      const v = kpiCurrentValue(k);
      results.push({ kind: 'kpi', code: k.code, title: k.name, meta: `${v === null ? 'Sin datos' : fmtNumber(v) + ' ' + (k.unit || '')} · ${s === 'green' ? 'En meta' : s === 'yellow' ? 'En alerta' : s === 'red' ? 'Crítico' : 'Sin datos'}`, action: () => goToKPI(k.id) });
    }
  });
  
  state.objectives.forEach(o => {
    if (match(o.code) || match(o.name) || match(o.owner) || match(o.perspective)) {
      results.push({ kind: 'objective', code: o.code, title: o.name, meta: `${o.perspective} · ${o.progress || 0}% avance`, action: () => { navigate('estrategia'); setTimeout(() => openObjectiveForm(o.id), 100); } });
    }
  });
  
  state.milestones.forEach(m => {
    if (match(m.code) || match(m.name) || match(m.owner)) {
      results.push({ kind: 'milestone', code: m.code, title: m.name, meta: `${m.status} · plazo ${fmtDate(m.dueDate)}`, action: () => { navigate('estrategia'); setTimeout(() => { setEstrategiaTab('hitos'); setTimeout(() => openMilestoneForm(m.id), 50); }, 100); } });
    }
  });
  
  state.projects.forEach(p => {
    if (match(p.code) || match(p.name) || match(p.owner) || match(p.description)) {
      results.push({ kind: 'project', code: p.code, title: p.name, meta: `${p.owner || '—'} · ${p.progress || 0}% · ${p.status === 'inProgress' ? 'En curso' : p.status === 'review' ? 'En revisión' : p.status === 'done' ? 'Completado' : 'Backlog'}`, action: () => goToProject(p.id) });
    }
  });
  
  (state.tasks || []).forEach(t => {
    if (match(t.code) || match(t.title) || match(t.description) || match(t.assignee) || (t.tags || []).some(tg => match(tg))) {
      const status = t.status === 'done' ? 'Completada' : t.status === 'inProgress' ? 'En curso' : t.status === 'review' ? 'En revisión' : 'Por hacer';
      results.push({ kind: 'task', code: t.code, title: t.title, meta: `${t.assignee || '—'} · ${status}${t.dueDate ? ' · plazo ' + fmtDate(t.dueDate) : ''}`, action: () => goToTask(t.id) });
    }
  });
  
  state.processes.forEach(p => {
    if (match(p.code) || match(p.name) || match(p.description) || match(p.owner)) {
      results.push({ kind: 'process', code: p.code, title: p.name, meta: `${p.type} · v${p.version} · ${p.status}`, action: () => goToProcess(p.id) });
    }
  });
  
  state.risks.forEach(r => {
    if (match(r.code) || match(r.name) || match(r.category) || match(r.owner) || match(r.controls)) {
      const score = r.probability * r.impact;
      results.push({ kind: 'risk', code: r.code, title: r.name, meta: `${r.category} · P×I=${score} · ${r.treatment}`, action: () => goToRisk(r.id) });
    }
  });
  
  state.findings.forEach(f => {
    if (match(f.code) || match(f.name) || match(f.source) || match(f.actionPlan)) {
      results.push({ kind: 'finding', code: f.code, title: f.name, meta: `${f.source} · ${f.severity} · ${f.status}`, action: () => goToFinding(f.id) });
    }
  });
  
  state.commitments.forEach(c => {
    if (match(c.code) || match(c.name) || match(c.description) || match(c.owner)) {
      results.push({ kind: 'commitment', code: c.code, title: c.name, meta: `${c.owner || '—'} · ${c.status} · ${c.progress || 0}%`, action: () => { navigate('personas'); setTimeout(() => { setPersonasTab('compromisos'); setTimeout(() => openCommitmentForm(c.id), 50); }, 100); } });
    }
  });
  
  (state.meetings || []).forEach(m => {
    if (match(m.code) || match(m.title) || match(m.summary) || match(m.minutes) || match(m.type) || (m.attendees || []).some(a => match(a)) || (m.agreements || []).some(a => match(a.text))) {
      results.push({ kind: 'meeting', code: m.code, title: m.title, meta: `${m.type} · ${fmtDate(m.date)} · ${MEETING_STATUS_LABELS[m.status] || m.status}`, action: () => { reunionesSelectedId = m.id; reunionesView = 'detalle'; navigate('reuniones'); } });
    }
  });
  
  state.documents.forEach(d => {
    if (match(d.code) || match(d.title) || match(d.description) || match(d.tags) || match(d.type) || match(d.owner)) {
      results.push({ kind: 'document', code: d.code, title: d.title, meta: `${d.type} · v${d.version} · ${d.status}`, action: () => goToDocument(d.id) });
    }
  });
  
  state.wikiPages.forEach(w => {
    if (match(w.title) || match(w.content)) {
      const preview = (w.content || '').replace(/[#*`_>-]/g, '').trim().slice(0, 80);
      results.push({ kind: 'wiki', title: w.title, meta: preview, action: () => { wikiSelectedId = w.id; documentalTab = 'wiki'; navigate('documental'); } });
    }
  });
  
  state.people.forEach(p => {
    if (match(p.code) || match(p.name) || match(p.position) || match(p.email)) {
      const u = state.units.find(x => x.id === p.unitId);
      results.push({ kind: 'person', code: p.code, title: p.name, meta: `${p.position || '—'}${u ? ' · ' + u.name : ''}`, action: () => { navigate('personas'); setTimeout(() => { setPersonasTab('personas'); setTimeout(() => openPersonForm(p.id), 50); }, 100); } });
    }
  });
  
  state.units.forEach(u => {
    if (match(u.code) || match(u.name) || match(u.head)) {
      results.push({ kind: 'unit', code: u.code, title: u.name, meta: u.head || '—', action: () => { navigate('personas'); setTimeout(() => { setPersonasTab('organigrama'); setTimeout(() => openUnitForm(u.id), 50); }, 100); } });
    }
  });
  
  state.datasets.forEach(d => {
    if (match(d.name) || match(d.description)) {
      results.push({ kind: 'dataset', title: d.name, meta: `${(d.columns || []).length} columnas · ${(d.rows || []).length} filas`, action: () => { vizSelectedDatasetId = d.id; vizTab = 'datasets'; navigate('visualizaciones'); } });
    }
  });
  
  state.charts.forEach(c => {
    if (match(c.name)) {
      results.push({ kind: 'chart', title: c.name, meta: `Tipo: ${c.type}`, action: () => { vizTab = 'charts'; navigate('visualizaciones'); } });
    }
  });
  
  return results.slice(0, 50);
}

function globalSearchSelectAt(idx) {
  const r = globalSearchResults[idx];
  if (!r) return;
  closeGlobalSearch();
  r.action();
}

function globalSearchHandleKey(e) {
  if (!globalSearchActive) return;
  if (e.key === 'Escape') { e.preventDefault(); closeGlobalSearch(); return; }
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    if (globalSearchSelected < globalSearchResults.length - 1) {
      globalSearchSelected++;
      updateGlobalSearchResults();
      setTimeout(() => { const el = document.querySelector('.gs-item.active'); if (el) el.scrollIntoView({ block: 'nearest' }); }, 0);
    }
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (globalSearchSelected > 0) {
      globalSearchSelected--;
      updateGlobalSearchResults();
      setTimeout(() => { const el = document.querySelector('.gs-item.active'); if (el) el.scrollIntoView({ block: 'nearest' }); }, 0);
    }
  } else if (e.key === 'Enter') {
    e.preventDefault();
    globalSearchSelectAt(globalSearchSelected);
  }
}

