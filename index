function renderBlockBriefing(t) {
  const today = new Date();
  const hour = today.getHours();
  const greeting = hour < 12 ? 'Buenos días' : hour < 19 ? 'Buenas tardes' : 'Buenas noches';
  const dateStr = today.toLocaleDateString('es-CL', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
  const parts = [];
  if (t.kpisRed > 0) parts.push(`${t.kpisRed} indicador${t.kpisRed > 1 ? 'es' : ''} crítico${t.kpisRed > 1 ? 's' : ''}`);
  else if (t.kpisYellow > 0) parts.push(`${t.kpisYellow} indicador${t.kpisYellow > 1 ? 'es' : ''} en alerta`);
  if (t.risksHigh > 0) parts.push(`${t.risksHigh} riesgo${t.risksHigh > 1 ? 's' : ''} crítico${t.risksHigh > 1 ? 's' : ''}`);
  if (t.tasksOverdue > 0) parts.push(`${t.tasksOverdue} tarea${t.tasksOverdue > 1 ? 's' : ''} vencida${t.tasksOverdue > 1 ? 's' : ''}`);
  if (t.findingsOpen > 0) parts.push(`${t.findingsOpen} hallazgo${t.findingsOpen > 1 ? 's' : ''} abierto${t.findingsOpen > 1 ? 's' : ''}`);
  const briefing = parts.length ? `Requieren tu atención: ${parts.join(' · ')}` : 'Todo bajo control. Sin alertas críticas en este momento.';
  return `<div class="card p-5" style="background:linear-gradient(135deg, #15110d 0%, #1e3a3a 100%); color:#f7f4ee">
    <div class="meta-label mb-1" style="color:#a39a8c">${escapeHtml(dateStr)}</div>
    <div class="font-serif text-2xl leading-snug mb-2">${greeting}</div>
    <div class="text-sm" style="color:#d4ccba; line-height:1.55">${briefing}</div>
  </div>`;
}

function renderBlockAlerts(t) {
  const alerts = generateAlerts();
  return `<div class="card p-5">
    <div class="flex items-center justify-between mb-3"><div class="font-serif text-xl">Alertas</div><span class="badge badge-${alerts.filter(a => a.level === 'red').length ? 'red' : 'yellow'}">${alerts.length}</span></div>
    <div class="space-y-2 scroll-area" style="max-height:280px; overflow-y:auto">
