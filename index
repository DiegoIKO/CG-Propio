function renderBPMNLanes(p, bpmn, w, h) {
  if (!bpmn.lanes.length) {
    // Sin carriles: solo un fondo claro
    return `<rect x="0" y="0" width="${w}" height="${h}" fill="white"/>`;
  }
  let html = '';
  let y = BPMN_PHASE_H;
  bpmn.lanes.forEach((lane, idx) => {
    const laneH = lane.height || BPMN_LANE_DEFAULT_H;
    const altClass = idx % 2 === 1 ? 'alt' : '';
    // Fondo del carril completo
    html += `<rect class="bpmn-lane-bg ${altClass}" x="0" y="${y}" width="${w}" height="${laneH}"/>`;
    // Encabezado del carril (lado izquierdo, texto rotado)
    html += `<rect class="bpmn-lane-header-bg" x="0" y="${y}" width="${BPMN_HEADER_W}" height="${laneH}"/>`;
    const labelLines = wrapText(lane.label || `Carril ${idx + 1}`, 18);
    const cx = BPMN_HEADER_W / 2;
    const cy = y + laneH / 2;
    html += `<g transform="translate(${cx} ${cy}) rotate(-90)" style="cursor:pointer" onclick="event.stopPropagation(); bpmnRenameLane('${p.id}', '${lane.id}')">`;
    labelLines.forEach((l, i) => {
      html += `<text class="bpmn-lane-label" x="0" y="${(i - (labelLines.length - 1) / 2) * 14}" text-anchor="middle">${escapeHtml(l)}</text>`;
    });
    html += '</g>';
    // Pequeña X para eliminar el carril (arriba a la derecha del header)
    html += `<g style="cursor:pointer" onclick="event.stopPropagation(); deleteBPMNLane('${p.id}', '${lane.id}')">
      <circle cx="${BPMN_HEADER_W - 12}" cy="${y + 12}" r="9" fill="white" stroke="var(--line-strong)" stroke-width="1"/>
      <path d="M ${BPMN_HEADER_W - 16} ${y + 8} L ${BPMN_HEADER_W - 8} ${y + 16} M ${BPMN_HEADER_W - 8} ${y + 8} L ${BPMN_HEADER_W - 16} ${y + 16}" stroke="var(--ink-muted)" stroke-width="1.5" stroke-linecap="round"/>
    </g>`;
    // Botón redimensionar el carril (debajo de la X)
    html += `<g style="cursor:pointer" onclick="event.stopPropagation(); bpmnResizeLane('${p.id}', '${lane.id}')" title="Cambiar alto del carril">
      <circle cx="${BPMN_HEADER_W - 12}" cy="${y + 32}" r="9" fill="white" stroke="var(--line-strong)" stroke-width="1"/>
      <path d="M ${BPMN_HEADER_W - 16} ${y + 30} L ${BPMN_HEADER_W - 8} ${y + 30} M ${BPMN_HEADER_W - 16} ${y + 34} L ${BPMN_HEADER_W - 8} ${y + 34}" stroke="var(--ink-muted)" stroke-width="1.5" stroke-linecap="round"/>
    </g>`;
    y += laneH;
    // Divider entre carriles (excepto el último)
    if (idx < bpmn.lanes.length - 1) {
      html += `<line class="bpmn-lane-divider" x1="${BPMN_HEADER_W}" y1="${y}" x2="${w}" y2="${y}"/>`;
    }
  });
  return html;
}

function renderBPMNPhases(p, bpmn, w, h) {
  if (!bpmn.phases.length) return '';
  let html = '';
  // Banda superior con encabezados de fases
  html += `<rect x="${BPMN_HEADER_W}" y="0" width="${bpmnContentRight(bpmn) - BPMN_HEADER_W}" height="${BPMN_PHASE_H}" fill="var(--bg-sunken)" stroke="var(--line-strong)" stroke-width="1"/>`;
  let x = BPMN_HEADER_W;
  bpmn.phases.forEach((ph, idx) => {
    const phW = ph.width || 240;
    // Divisor vertical entre fases (línea desde abajo del header hasta el final del canvas)
    if (idx > 0) {
      html += `<line class="bpmn-lane-divider" x1="${x}" y1="${BPMN_PHASE_H}" x2="${x}" y2="${h}"/>`;
    }
    // Borde de la celda de fase
    html += `<rect x="${x}" y="0" width="${phW}" height="${BPMN_PHASE_H}" fill="none" stroke="var(--line-strong)" stroke-width="1"/>`;
    // Texto del nombre
    html += `<text class="bpmn-lane-label" x="${x + phW/2}" y="${BPMN_PHASE_H/2 + 4}" text-anchor="middle" style="cursor:pointer" onclick="event.stopPropagation(); bpmnRenamePhase('${p.id}', '${ph.id}')">${escapeHtml(ph.label || `Fase ${idx + 1}`)}</text>`;
    // X para eliminar la fase
    html += `<g style="cursor:pointer" onclick="event.stopPropagation(); deleteBPMNPhase('${p.id}', '${ph.id}')" title="Eliminar fase">
      <circle cx="${x + phW - 14}" cy="${BPMN_PHASE_H/2}" r="8" fill="white" stroke="var(--line-strong)" stroke-width="1"/>
      <path d="M ${x + phW - 17} ${BPMN_PHASE_H/2 - 3} L ${x + phW - 11} ${BPMN_PHASE_H/2 + 3} M ${x + phW - 11} ${BPMN_PHASE_H/2 - 3} L ${x + phW - 17} ${BPMN_PHASE_H/2 + 3}" stroke="var(--ink-muted)" stroke-width="1.5" stroke-linecap="round"/>
    </g>`;
    // Botón redimensionar fase (al lado izquierdo de la X)
    html += `<g style="cursor:pointer" onclick="event.stopPropagation(); bpmnResizePhase('${p.id}', '${ph.id}')" title="Cambiar ancho de la fase">
      <circle cx="${x + phW - 32}" cy="${BPMN_PHASE_H/2}" r="8" fill="white" stroke="var(--line-strong)" stroke-width="1"/>
      <path d="M ${x + phW - 35} ${BPMN_PHASE_H/2} L ${x + phW - 29} ${BPMN_PHASE_H/2}" stroke="var(--ink-muted)" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M ${x + phW - 35} ${BPMN_PHASE_H/2 - 3} L ${x + phW - 35} ${BPMN_PHASE_H/2 + 3} M ${x + phW - 29} ${BPMN_PHASE_H/2 - 3} L ${x + phW - 29} ${BPMN_PHASE_H/2 + 3}" stroke="var(--ink-muted)" stroke-width="1.5" stroke-linecap="round"/>
    </g>`;
    x += phW;
  });
  return html;
}

