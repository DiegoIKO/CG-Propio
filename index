function navigate(route) {
  destroyAllCharts();
  // Limpiar overlays residuales que pudieran quedar atrapados
  const residualOverlays = ['chart-zoom-overlay', 'pivot-zoom-overlay', 'col-profile-panel'];
  residualOverlays.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.remove();
  });
  document.removeEventListener('click', closeColumnProfileOnOutsideClick);
  
  currentRoute = route;
  document.querySelectorAll('.nav-item').forEach(el => el.classList.toggle('active', el.dataset.route === route));
  (routes[route] || routes.inicio)();
  document.getElementById('main-content').scrollTop = 0;
}

function kpiCurrentValue(kpi) { if (!kpi.measurements || !kpi.measurements.length) return null; return kpi.measurements[kpi.measurements.length - 1].value; }
function kpiStatus(kpi) {
  const v = kpiCurrentValue(kpi); if (v === null) return 'gray';
  const g = Number(kpi.thresholdGreen); const y = Number(kpi.thresholdYellow);
  if (kpi.direction === 'up') { if (v >= g) return 'green'; if (v >= y) return 'yellow'; return 'red'; }
  if (v <= g) return 'green'; if (v <= y) return 'yellow'; return 'red';
}
function kpiProgressVsTarget(kpi) {
  const v = kpiCurrentValue(kpi); if (v === null) return 0;
  const t = Number(kpi.target);
  if (kpi.direction === 'up') return Math.min(100, (v / t) * 100);
  return Math.min(100, (t / Math.max(v, 0.0001)) * 100);
}


