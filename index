];
const PROJECT_PRIORITIES = [
  { key: 'alta', label: 'Alta', color: 'red' },
  { key: 'media', label: 'Media', color: 'yellow' },
  { key: 'baja', label: 'Baja', color: 'gray' }
];

/* ==================== SISTEMA DE ETAPAS Y AVANCE AUTOMÁTICO ==================== */

// Asegurar que cada proyecto tenga la estructura de etapas
function ensureProjectStages(p) {
  if (!p.stages) p.stages = [];
  if (!p.progressComment) p.progressComment = '';
  if (typeof p.useAutoProgress === 'undefined') p.useAutoProgress = true;
}

// Calcular el estado de una etapa según sus tareas y plazo
function computeStageStatus(stage, stageTasks) {
  const today = new Date().toISOString().slice(0, 10);
  const hasAllDone = stageTasks.length > 0 && stageTasks.every(t => t.status === 'done');
  if (hasAllDone) return 'completed';
  const isOverdue = stage.dueDate && stage.dueDate < today;
  if (isOverdue && stageTasks.some(t => t.status !== 'done')) return 'overdue';
  const hasStarted = stage.startDate && stage.startDate <= today;
  const hasInProgress = stageTasks.some(t => t.status !== 'todo');
  if (hasStarted || hasInProgress) return 'inProgress';
  return 'pending';
}

// Calcular el % de avance de una etapa
function computeStageProgress(stage, stageTasks) {
  // Si hay tareas vinculadas, promedio de su progreso
  if (stageTasks.length > 0) {
    const sum = stageTasks.reduce((acc, t) => {
      // Si la tarea está done, contamos 100% aunque el progress sea menor
      if (t.status === 'done') return acc + 100;
      return acc + (typeof t.progress === 'number' ? t.progress : 0);
    }, 0);
    return Math.round(sum / stageTasks.length);
  }
  
  // Sin tareas: calcular por plazo (basado en posición temporal)
  if (stage.startDate && stage.dueDate) {
    const today = new Date();
    const start = new Date(stage.startDate);
    const end = new Date(stage.dueDate);
    if (today < start) return 0;
    if (today > end) return 0; // No completada y vencida = 0% (queda pendiente)
    const totalMs = end - start;
    if (totalMs <= 0) return 0;
    const elapsed = today - start;
    // Si tiene un status manual de "completed", honrarlo
    if (stage.manualStatus === 'completed') return 100;
    // Si no, retornar 0 hasta que tenga tareas (las etapas sin tareas requieren confirmación manual)
    return 0;
  }
  
  return 0;
}

// Calcular el avance del proyecto entero (promedio ponderado de etapas)
function computeProjectProgress(project) {
  ensureProjectStages(project);
  
  // Si el usuario desactivó auto, usar el progress manual
  if (project.useAutoProgress === false) {
    return typeof project.progress === 'number' ? project.progress : 0;
  }
  
  const stages = project.stages || [];
  
  // Si no hay etapas, calcular por tareas vinculadas directamente al proyecto
  if (stages.length === 0) {
    const projectTasks = state.tasks.filter(t => t.projectId === project.id);
    if (projectTasks.length === 0) {
      // Sin etapas y sin tareas: progreso manual viejo (compatibilidad)
      return typeof project.progress === 'number' ? project.progress : 0;
    }
    const sum = projectTasks.reduce((acc, t) => {
      if (t.status === 'done') return acc + 100;
      return acc + (typeof t.progress === 'number' ? t.progress : 0);
    }, 0);
    return Math.round(sum / projectTasks.length);
  }
  
  // Con etapas: promedio ponderado
  let totalWeight = 0;
  let weightedSum = 0;
  
  stages.forEach(stage => {
    const stageTasks = state.tasks.filter(t => t.projectId === project.id && t.stageId === stage.id);
    const stageProgress = computeStageProgress(stage, stageTasks);
    const weight = stage.weight || 1;
    weightedSum += stageProgress * weight;
    totalWeight += weight;
  });
  
  if (totalWeight === 0) return 0;
  return Math.round(weightedSum / totalWeight);
}

// Sincroniza el campo project.progress con el valor calculado (para que las vistas Lista/Tablero existentes lo respeten)
function syncProjectProgress(project) {
  ensureProjectStages(project);
  if (project.useAutoProgress !== false) {
    project.progress = computeProjectProgress(project);
  }
}

// Sincroniza TODOS los proyectos (llamar después de cambios masivos)
function syncAllProjectsProgress() {
  state.projects.forEach(p => syncProjectProgress(p));
}

// Obtener tareas de una etapa específica
function getStageTasks(projectId, stageId) {
  return state.tasks.filter(t => t.projectId === projectId && t.stageId === stageId);
}

// Obtener tareas "sueltas" del proyecto (sin etapa asignada)
function getProjectLooseTasks(projectId) {
  const project = state.projects.find(p => p.id === projectId);
  if (!project) return [];
  const stageIds = new Set((project.stages || []).map(s => s.id));
  return state.tasks.filter(t => t.projectId === projectId && (!t.stageId || !stageIds.has(t.stageId)));
}

function applyProjectFilter(projects) {
  const f = proyectosFilter;
  return projects.filter(p => {
    if (f.status && p.status !== f.status) return false;
    if (f.priority && p.priority !== f.priority) return false;
    if (f.owner && p.owner !== f.owner) return false;
    if (f.objective === '__none__' && p.objectiveCode) return false;
    if (f.objective && f.objective !== '__none__' && p.objectiveCode !== f.objective) return false;
    if (f.overdue === 'yes') {
      const isOverdue = p.dueDate && new Date(p.dueDate) < new Date() && p.status !== 'done';
      if (!isOverdue) return false;
    }
    if (f.overdue === 'no') {
      const isOverdue = p.dueDate && new Date(p.dueDate) < new Date() && p.status !== 'done';
      if (isOverdue) return false;
    }
    if (f.q) {
      const q = f.q.toLowerCase();
      const blob = (p.code + ' ' + p.name + ' ' + (p.description || '') + ' ' + (p.owner || '')).toLowerCase();
      if (!blob.includes(q)) return false;
    }
    return true;
  });
}

function applyProjectFilterExcept(projects, excludeKey) {
  const f = proyectosFilter;
  return projects.filter(p => {
    if (excludeKey !== 'status' && f.status && p.status !== f.status) return false;
    if (excludeKey !== 'priority' && f.priority && p.priority !== f.priority) return false;
    if (excludeKey !== 'owner' && f.owner && p.owner !== f.owner) return false;
    if (excludeKey !== 'objective') {
      if (f.objective === '__none__' && p.objectiveCode) return false;
      if (f.objective && f.objective !== '__none__' && p.objectiveCode !== f.objective) return false;
    }
    if (excludeKey !== 'overdue') {
      if (f.overdue === 'yes') {
        const isOverdue = p.dueDate && new Date(p.dueDate) < new Date() && p.status !== 'done';
        if (!isOverdue) return false;
      }
      if (f.overdue === 'no') {
        const isOverdue = p.dueDate && new Date(p.dueDate) < new Date() && p.status !== 'done';
        if (isOverdue) return false;
      }
    }
    if (f.q) {
      const q = f.q.toLowerCase();
      const blob = (p.code + ' ' + p.name + ' ' + (p.description || '') + ' ' + (p.owner || '')).toLowerCase();
      if (!blob.includes(q)) return false;
    }
    return true;
  });
}

