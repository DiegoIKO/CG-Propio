}
function openMeasureForm(kpiId) { return openKPIMeasureForm(kpiId); }

function openKPIMeasureForm(kpiId, measureIdx) {
  const k = state.kpis.find(x => x.id === kpiId); if (!k) return;
  const isEdit = typeof measureIdx === 'number' && measureIdx >= 0;
  const m = isEdit && k.measurements ? k.measurements[measureIdx] : null;
  
  const body = `<div class="text-sm mb-3" style="color:var(--ink-muted)">${escapeHtml(k.code)} · ${escapeHtml(k.name)}</div>
    <div class="grid grid-cols-2 gap-3">
      <div>${field('Fecha', `<input type="date" class="input" id="f-m-date" value="${m ? m.date : new Date().toISOString().slice(0,10)}">`)}</div>
      <div>${field('Valor (' + (k.unit || '') + ')', `<input type="number" step="any" class="input" id="f-m-value" value="${m ? m.value : ''}">`)}</div>
    </div>
    <div class="mt-3">${field('Comentario (opcional)', `<textarea class="textarea" id="f-m-note" rows="3" placeholder="Contexto, explicación de la variación, observaciones...">${m ? escapeHtml(m.comment || m.note || '') : ''}</textarea>`)}</div>`;
  
  openModal({
    title: isEdit ? 'Editar medición' : 'Registrar medición',
    body,
    footer: `${isEdit ? '<button class="btn btn-danger mr-auto" id="btn-del-m">Eliminar</button>' : ''}<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-save-m">${isEdit ? 'Guardar cambios' : 'Registrar'}</button>`,
    width: 'narrow'
  });
  setTimeout(() => document.getElementById('f-m-value').focus(), 100);
  
  document.getElementById('btn-save-m').onclick = () => {
    const date = document.getElementById('f-m-date').value;
    const value = Number(document.getElementById('f-m-value').value);
    const comment = document.getElementById('f-m-note').value.trim();
    if (!date || isNaN(value)) { toast('Fecha y valor obligatorios'); return; }
    if (!k.measurements) k.measurements = [];
    
    if (isEdit) {
      k.measurements[measureIdx] = { date, value, comment };
    } else {
      k.measurements.push({ date, value, comment });
    }
    k.measurements.sort((a, b) => (a.date || '').localeCompare(b.date || ''));
    save();
    closeModal();
    
    // Si el zoom está abierto sobre este KPI, refrescarlo
    if (kpiZoomId === kpiId) {
      closeKpiZoom();
      openKpiZoom(kpiId);
    } else {
      renderKPIs();
    }
    toast(isEdit ? 'Medición actualizada' : 'Medición registrada');
  };
  
  if (isEdit) {
    document.getElementById('btn-del-m').onclick = () => {
      if (!confirm('¿Eliminar esta medición?')) return;
      k.measurements.splice(measureIdx, 1);
      save();
      closeModal();
      if (kpiZoomId === kpiId) {
        closeKpiZoom();
        openKpiZoom(kpiId);
      } else {
        renderKPIs();
      }
      toast('Medición eliminada');
    };
  }
}
function deleteKPI(id) { if (!confirm('¿Eliminar?')) return; state.kpis = state.kpis.filter(k => k.id !== id); save(); renderKPIs(); toast('Eliminado'); }
function deleteMeasure(kpiId, idx) {
  const k = state.kpis.find(x => x.id === kpiId);
  if (!k || !k.measurements) return;
  if (!confirm('¿Eliminar esta medición?')) return;
  k.measurements.splice(idx, 1);
  save();
  if (kpiZoomId === kpiId) {
    closeKpiZoom();
    openKpiZoom(kpiId);
  } else {
    renderKPIs();
  }
}

/* ==================== PROCESOS ==================== */
let procesoSelectedId = null;
let procesoTab = 'sipoc';
let procesoFullscreen = null; // 'bpmn' | 'sipoc' | 'raci' | null

function renderProcesos() {
  if (!procesoSelectedId && state.processes.length) procesoSelectedId = state.processes[0].id;
  
  // Guardar scroll del área de detalle
  const prevScrollDetail = (document.querySelector('.proceso-detail-scroll') || {}).scrollTop || 0;
  const prevScrollTree = (document.querySelector('.proceso-tree-scroll') || {}).scrollTop || 0;
  
  const actions = `${printBtn('printProcesos', 'Imprimir inventario de procesos')}<button class="btn btn-primary" onclick="openProcessForm()">+ Nuevo proceso</button>`;
  const selected = state.processes.find(p => p.id === procesoSelectedId);
  
  // Si está en modo pantalla completa, renderizar solo el componente seleccionado
  if (procesoFullscreen && selected) {
    document.getElementById('main-content').innerHTML = `${headerHTML('Procesos · Modo ampliado', escapeHtml(selected.code + ' · ' + selected.name), `<button class="btn btn-secondary" onclick="exitProcesoFullscreen()"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v3a2 2 0 0 1-2 2H3M21 8h-3a2 2 0 0 1-2-2V3M3 16h3a2 2 0 0 1 2 2v3M16 21v-3a2 2 0 0 1 2-2h3"/></svg> Salir de pantalla completa</button>`)}
      <div class="p-6">
        ${procesoFullscreen === 'bpmn' ? renderBPMN(selected, true) :
          procesoFullscreen === 'sipoc' ? renderSIPOC(selected, true) :
          procesoFullscreen === 'raci' ? renderRACI(selected, true) : ''}
      </div>`;
    return;
  }
  
  document.getElementById('main-content').innerHTML = `${headerHTML('Procesos', 'Inventario institucional con SIPOC y matriz RACI', actions)}
    <div class="flex" style="min-height: calc(100vh - 120px)">
      <div class="w-72 border-r p-4 proceso-tree-scroll overflow-y-auto" style="border-color:var(--line); background:var(--bg-sunken); max-height: calc(100vh - 120px)">
        <div class="font-serif text-lg mb-3">Inventario</div>
        ${renderProcessTree()}
      </div>
      <div class="flex-1 p-6 proceso-detail-scroll overflow-y-auto" style="max-height: calc(100vh - 120px)">
        ${selected ? renderProcessDetail(selected) : emptyState('Selecciona un proceso', 'O crea el primero')}
      </div>
    </div>`;
  
  // Restaurar scroll después de re-render
  setTimeout(() => {
    const newDetail = document.querySelector('.proceso-detail-scroll');
    const newTree = document.querySelector('.proceso-tree-scroll');
    if (newDetail && prevScrollDetail) newDetail.scrollTop = prevScrollDetail;
    if (newTree && prevScrollTree) newTree.scrollTop = prevScrollTree;
  }, 0);
}

function enterProcesoFullscreen(mode) {
  procesoFullscreen = mode;
  renderProcesos();
}

function exitProcesoFullscreen() {
