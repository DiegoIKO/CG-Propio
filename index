function renderRiskMatrix(type) {
  let html = '<div class="risk-matrix">';
  for (let p = 5; p >= 1; p--) {
    html += `<div class="risk-axis-label">P=${p}</div>`;
    for (let i = 1; i <= 5; i++) {
      const score = p * i;
      const bg = score >= 15 ? 'rgba(168, 62, 62, 0.78)' : score >= 8 ? 'rgba(200, 157, 44, 0.72)' : 'rgba(74, 124, 74, 0.72)';
      const risksHere = state.risks.filter(r => type === 'inherent' ? (r.probability === p && r.impact === i) : (r.residualProb === p && r.residualImpact === i));
      html += `<div class="risk-cell" style="background:${bg}" title="P${p}·I${i}=${score}">${risksHere.length ? `<span class="count" title="${risksHere.map(r => r.code).join(', ')}">${risksHere.length}</span>` : `<span style="color:rgba(255,255,255,.7)">${score}</span>`}</div>`;
    }
  }
  html += '<div></div>';
  for (let i = 1; i <= 5; i++) html += `<div class="risk-axis-label">I=${i}</div>`;
  html += '</div><div class="text-xs mt-2 text-center" style="color:var(--ink-muted)">Impacto →</div>';
  return html;
}

/* ==================== BITÁCORA DE MONITOREO DE RIESGOS ==================== */

function ensureRiskMonitoring(r) {
  if (!r.monitoringLog) r.monitoringLog = [];
}

function openRiskMonitoringLog(riskId) {
  const r = state.risks.find(x => x.id === riskId);
  if (!r) return;
  ensureRiskMonitoring(r);
  
  const sortedLog = [...r.monitoringLog].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
  const currentRes = r.residualProb * r.residualImpact;
  const currentCls = currentRes >= 15 ? 'red' : currentRes >= 8 ? 'yellow' : 'green';
  
  // Si hay entradas, mostrar evolución
  const lastEval = sortedLog[0];
  const firstEval = sortedLog[sortedLog.length - 1];
  let evolution = '';
  if (sortedLog.length >= 2) {
    const lastScore = lastEval.probability * lastEval.impact;
    const firstScore = firstEval.probability * firstEval.impact;
    const diff = lastScore - firstScore;
    const arrow = diff < 0 ? '↓' : diff > 0 ? '↑' : '→';
    const color = diff < 0 ? 'var(--green)' : diff > 0 ? 'var(--red)' : 'var(--ink-muted)';
    evolution = `<div style="font-size: 11px; color: ${color}; font-family: 'JetBrains Mono', monospace; margin-top: 4px">Evolución desde primer monitoreo: ${arrow} ${diff > 0 ? '+' : ''}${diff}</div>`;
  }
  
  const body = `<div class="space-y-4">
    <div class="card-soft p-3" style="background: var(--bg-sunken)">
      <div class="flex items-center gap-3">
        <div style="flex: 1">
          <div class="font-mono text-xs" style="color:var(--ink-muted)">${escapeHtml(r.code)} · ${escapeHtml(r.category)}</div>
          <div class="font-medium">${escapeHtml(r.name)}</div>
        </div>
        <div style="text-align: right">
          <div class="text-xs" style="color:var(--ink-muted)">Riesgo residual actual</div>
          <span class="badge badge-${currentCls}" style="font-size: 14px; padding: 4px 10px">${currentRes} · P${r.residualProb}·I${r.residualImpact}</span>
          ${evolution}
        </div>
      </div>
    </div>
    
    <div class="text-xs p-3 rounded" style="background:var(--bg-sunken); color:var(--ink-muted); line-height: 1.5">
      La bitácora de monitoreo permite registrar cómo evoluciona el riesgo en el tiempo después de aplicar el tratamiento. Cada entrada incluye una re-evaluación de probabilidad e impacto, la efectividad del control y observaciones.
    </div>
    
    <div>
      <div class="meta-label mb-2">Nueva evaluación de monitoreo</div>
      <div class="grid grid-cols-4 gap-2 mb-2">
        <div>
          <label class="text-xs" style="color:var(--ink-muted)">Fecha</label>
          <input type="date" class="input input-sm" id="f-mon-date" value="${new Date().toISOString().slice(0,10)}">
        </div>
        <div>
          <label class="text-xs" style="color:var(--ink-muted)">Probabilidad (1-5)</label>
          <select class="select input-sm" id="f-mon-prob">
            ${[1,2,3,4,5].map(n => `<option value="${n}" ${n === r.residualProb ? 'selected' : ''}>${n}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="text-xs" style="color:var(--ink-muted)">Impacto (1-5)</label>
          <select class="select input-sm" id="f-mon-impact">
            ${[1,2,3,4,5].map(n => `<option value="${n}" ${n === r.residualImpact ? 'selected' : ''}>${n}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="text-xs" style="color:var(--ink-muted)">Efectividad control</label>
          <select class="select input-sm" id="f-mon-eff">
            <option value="Efectivo">Efectivo</option>
            <option value="Parcialmente efectivo">Parcialmente efectivo</option>
            <option value="No efectivo">No efectivo</option>
            <option value="No evaluado">No evaluado</option>
          </select>
        </div>
      </div>
      <input type="text" class="input input-sm mb-2" id="f-mon-action" placeholder="Acción de monitoreo ejecutada (ej: Revisión semestral, Auditoría)" style="width:100%">
      <textarea class="input input-sm" id="f-mon-comment" rows="2" placeholder="Observaciones, hallazgos o decisiones de gestión (opcional)" style="width:100%"></textarea>
      <button class="btn btn-primary btn-sm mt-2" onclick="addRiskMonitoringEntry('${riskId}')">+ Registrar evaluación</button>
    </div>
    
    <div>
      <div class="meta-label mb-2">Historial de monitoreo (${sortedLog.length} ${sortedLog.length === 1 ? 'evaluación' : 'evaluaciones'})</div>
      ${sortedLog.length === 0 ? '<div class="text-sm text-center py-6" style="color:var(--ink-muted); font-style: italic">Sin evaluaciones registradas todavía. Registra la primera arriba para empezar a hacer seguimiento.</div>' : `
        <div class="space-y-2" style="max-height: 360px; overflow-y: auto">
          ${sortedLog.map((entry, displayIdx) => {
            const realIdx = r.monitoringLog.indexOf(entry);
            const entryScore = entry.probability * entry.impact;
            const entryCls = entryScore >= 15 ? 'red' : entryScore >= 8 ? 'yellow' : 'green';
            const effIcon = entry.effectiveness === 'Efectivo' ? '✓' : entry.effectiveness === 'No efectivo' ? '✗' : '~';
            const effColor = entry.effectiveness === 'Efectivo' ? 'var(--green)' : entry.effectiveness === 'No efectivo' ? 'var(--red)' : 'var(--warm)';
            return `<div class="card-soft p-3" style="background: var(--bg-elevated); border-left: 3px solid var(--${entryCls === 'red' ? 'red' : entryCls === 'yellow' ? 'warm' : 'green'})">
              <div class="flex items-start justify-between gap-3 mb-2">
                <div class="flex items-center gap-3 flex-wrap">
                  <span class="font-mono text-xs" style="color: var(--ink-muted)">${fmtDate(entry.date)}</span>
                  <span class="badge badge-${entryCls}" style="font-size: 11px">${entryScore} · P${entry.probability}·I${entry.impact}</span>
                  ${entry.effectiveness ? `<span style="font-size: 11px; color: ${effColor}; font-weight: 600">${effIcon} ${escapeHtml(entry.effectiveness)}</span>` : ''}
                </div>
                <button class="btn btn-ghost btn-icon" onclick="deleteRiskMonitoringEntry('${riskId}', ${realIdx})" title="Eliminar"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
              </div>
              ${entry.action ? `<div class="text-sm font-medium">${escapeHtml(entry.action)}</div>` : ''}
              ${entry.comment ? `<div class="text-xs" style="color: var(--ink-muted); font-style: italic; margin-top: 4px; line-height: 1.5">${escapeHtml(entry.comment)}</div>` : ''}
            </div>`;
          }).join('')}
        </div>
      `}
    </div>
  </div>`;
  
  openModal({
    title: `Bitácora de monitoreo: ${r.code}`,
    body,
    footer: `<button class="btn btn-secondary" data-action="close-modal">Cerrar</button>`,
    width: 'wide'
  });
}

function addRiskMonitoringEntry(riskId) {
  const r = state.risks.find(x => x.id === riskId);
  if (!r) return;
  ensureRiskMonitoring(r);
  
  const date = document.getElementById('f-mon-date').value;
  const probability = parseInt(document.getElementById('f-mon-prob').value);
  const impact = parseInt(document.getElementById('f-mon-impact').value);
  const effectiveness = document.getElementById('f-mon-eff').value;
  const action = document.getElementById('f-mon-action').value.trim();
  const comment = document.getElementById('f-mon-comment').value.trim();
  
  if (!date) { toast('La fecha es obligatoria'); return; }
  if (isNaN(probability) || isNaN(impact)) { toast('Probabilidad e impacto son obligatorios'); return; }
  
  r.monitoringLog.push({ date, probability, impact, effectiveness, action, comment });
  
  // Actualizar el riesgo residual con la última evaluación
  r.residualProb = probability;
  r.residualImpact = impact;
  
  save();
  closeModal();
  openRiskMonitoringLog(riskId);
  toast('Evaluación registrada');
}

function deleteRiskMonitoringEntry(riskId, idx) {
  const r = state.risks.find(x => x.id === riskId);
  if (!r) return;
  ensureRiskMonitoring(r);
  if (!confirm('¿Eliminar esta evaluación de monitoreo?')) return;
  r.monitoringLog.splice(idx, 1);
  save();
  closeModal();
  openRiskMonitoringLog(riskId);
}

