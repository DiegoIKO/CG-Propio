.stage-task-row .task-assignee { font-size: 11px; color: var(--ink-muted); flex-shrink: 0; }
.stage-task-row .task-progress { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; color: var(--ink-muted); min-width: 36px; text-align: right; flex-shrink: 0; }
.stage-empty-tasks { font-size: 12px; color: var(--ink-subtle); font-style: italic; padding: 10px; text-align: center; background: var(--bg-elevated); border-radius: 6px; }

.add-stage-btn { background: transparent; border: 1.5px dashed var(--line-strong); border-radius: 10px; padding: 14px; cursor: pointer; color: var(--ink-muted); font-size: 13px; transition: all .15s; display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; }
.add-stage-btn:hover { background: var(--bg-elevated); border-color: var(--ink); color: var(--ink); }

/* === Vista Timeline / Gantt === */
.gantt-container { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 10px; overflow: hidden; }
.gantt-scroll { overflow-x: auto; }
.gantt-header { display: flex; background: var(--bg-sunken); border-bottom: 1px solid var(--line); position: sticky; top: 0; z-index: 2; }
.gantt-side { width: 240px; flex-shrink: 0; padding: 10px 14px; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-muted); font-weight: 600; border-right: 1px solid var(--line); }
.gantt-timeline { flex: 1; display: flex; min-width: 600px; }
.gantt-month { flex: 1; padding: 10px 8px; text-align: center; font-size: 11px; color: var(--ink-muted); border-right: 1px solid var(--line); text-transform: uppercase; letter-spacing: .04em; font-weight: 600; min-width: 80px; }
.gantt-row { display: flex; border-bottom: 1px solid var(--line); min-height: 44px; transition: background .12s; }
.gantt-row:hover { background: rgba(0,0,0,0.015); }
.gantt-row:last-child { border-bottom: none; }
.gantt-row .gantt-side { padding: 10px 14px; border-right: 1px solid var(--line); display: flex; align-items: center; gap: 8px; font-size: 12.5px; cursor: pointer; }
.gantt-row .gantt-side:hover { background: var(--bg); }
.gantt-row .gantt-side .name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.gantt-row .gantt-side .pct { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; color: var(--ink-muted); }
.gantt-row .gantt-timeline { position: relative; min-height: 44px; background-image: linear-gradient(to right, var(--line) 1px, transparent 1px); background-size: calc(100% / var(--gantt-months, 6)) 100%; }
.gantt-bar { position: absolute; top: 10px; height: 24px; background: linear-gradient(90deg, #3d5a80 0%, #5a7d8a 100%); border-radius: 4px; display: flex; align-items: center; padding: 0 8px; font-size: 11px; color: white; cursor: pointer; box-shadow: 0 2px 6px rgba(61, 90, 128, 0.3); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; transition: filter .15s; }
.gantt-bar:hover { filter: brightness(1.1); }
.gantt-bar.completed { background: linear-gradient(90deg, #4a7c4a 0%, #6ba66b 100%); }
.gantt-bar.overdue { background: linear-gradient(90deg, #a83e3e 0%, #c8665a 100%); }
.gantt-bar.pending { background: linear-gradient(90deg, #8a8475 0%, #a39a8c 100%); }
.gantt-bar .gantt-bar-fill { position: absolute; left: 0; top: 0; bottom: 0; background: rgba(255,255,255,0.25); }
.gantt-bar .gantt-bar-text { position: relative; z-index: 1; }
.gantt-today-line { position: absolute; top: 0; bottom: 0; width: 2px; background: var(--red); pointer-events: none; z-index: 3; box-shadow: 0 0 4px rgba(168,62,62,0.4); }
.gantt-today-line::before { content: 'HOY'; position: absolute; top: -16px; left: 50%; transform: translateX(-50%); font-size: 9px; background: var(--red); color: white; padding: 1px 5px; border-radius: 3px; font-family: 'JetBrains Mono', monospace; font-weight: 700; letter-spacing: .05em; }

/* ============ Modal zoom de gráfico (pantalla completa) ============ */
.chart-zoom-overlay { position: fixed; inset: 0; background: rgba(21, 17, 13, 0.85); z-index: 1000; display: flex; flex-direction: column; padding: 24px; animation: fadeIn .2s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.chart-zoom-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; gap: 16px; flex-wrap: wrap; }
.chart-zoom-title-block { color: #f7f4ee; flex: 1; min-width: 0; }
