function printTareas() {
  const byStatus = {
    'Por hacer': (state.tasks || []).filter(t => t.status === 'todo'),
    'En curso': (state.tasks || []).filter(t => t.status === 'inProgress'),
    'En revisión': (state.tasks || []).filter(t => t.status === 'review'),
    'Completada': (state.tasks || []).filter(t => t.status === 'done')
  };
  let html = repSummary(`Total: <strong>${(state.tasks || []).length}</strong> tareas · <strong>${(state.tasks || []).filter(t => t.status !== 'done').length}</strong> activas · <strong>${(state.tasks || []).filter(t => t.dueDate && new Date(t.dueDate) < new Date() && t.status !== 'done').length}</strong> vencidas`);
