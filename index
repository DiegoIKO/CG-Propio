// Estado de paginación y búsqueda por dataset
const datasetViewState = {}; // { datasetId: { page, pageSize, search } }
function getDatasetViewState(dsId) {
  if (!datasetViewState[dsId]) {
    datasetViewState[dsId] = { page: 1, pageSize: 100, search: '' };
  }
  return datasetViewState[dsId];
}

function renderDatasetDetail(ds) {
  // Asegurar que cada columna tenga un tipo
  (ds.columns || []).forEach(c => { if (!c.type) c.type = inferColumnType(ds, ds.columns.indexOf(c)); });
  
  const vs = getDatasetViewState(ds.id);
  
  // Aplicar búsqueda simple sobre todas las columnas
  let filteredRows;
  if (vs.search && vs.search.trim()) {
    const q = vs.search.trim().toLowerCase();
    filteredRows = ds.rows
      .map((row, i) => ({ row, originalIdx: i }))
      .filter(({ row }) => row.some(v => String(v == null ? '' : v).toLowerCase().includes(q)));
  } else {
    filteredRows = ds.rows.map((row, i) => ({ row, originalIdx: i }));
  }
  
  const totalFiltered = filteredRows.length;
  const totalRows = ds.rows.length;
  const hasSearch = !!(vs.search && vs.search.trim());
  
  // Paginación
  const totalPages = Math.max(1, Math.ceil(totalFiltered / vs.pageSize));
  if (vs.page > totalPages) vs.page = totalPages;
  if (vs.page < 1) vs.page = 1;
  const startIdx = (vs.page - 1) * vs.pageSize;
  const endIdx = Math.min(startIdx + vs.pageSize, totalFiltered);
  const visibleRows = filteredRows.slice(startIdx, endIdx);
  
  // Calcular estadísticas (sobre todas las filas filtradas, no solo página)
  const numericCols = (ds.columns || []).filter(c => c.type === 'number');
  const stats = numericCols.map(c => {
    const ci = ds.columns.indexOf(c);
    const values = filteredRows.map(r => parseFloat(r.row[ci])).filter(v => !isNaN(v));
    if (!values.length) return { name: c.name, count: 0 };
    return {
      name: c.name,
      count: values.length,
      sum: values.reduce((a, b) => a + b, 0),
      avg: values.reduce((a, b) => a + b, 0) / values.length,
      min: Math.min(...values),
      max: Math.max(...values)
    };
  });
  
