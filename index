const _origRenderProyectos = renderProyectos;
const _origRenderAnalisis = renderAnalisis;

// Inicialización
document.querySelectorAll('.nav-item').forEach(el => {
  el.addEventListener('click', () => navigate(el.dataset.route));
});

function togglePresentMode() {
  document.body.classList.toggle('present-mode');
  if (document.body.classList.contains('present-mode')) {
    document.getElementById('present-title').textContent = (state.meta.institution || 'Mi Institución') + ' · Dashboard';
    document.getElementById('present-date').textContent = new Date().toLocaleDateString('es-CL', { day: '2-digit', month: 'long', year: 'numeric' });
    // Intentar fullscreen
    if (document.documentElement.requestFullscreen) {
      document.documentElement.requestFullscreen().catch(() => {});
    }
  } else {
    if (document.fullscreenElement && document.exitFullscreen) document.exitFullscreen().catch(() => {});
  }
}

document.addEventListener('keydown', e => {
  // Atajo Ctrl+K / Cmd+K para abrir búsqueda global
  if ((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === 'K')) {
    e.preventDefault();
    if (globalSearchActive) closeGlobalSearch();
    else openGlobalSearch();
    return;
  }
  // Navegación dentro de búsqueda global
  if (globalSearchActive) {
    globalSearchHandleKey(e);
    return;
  }
  // ESC: primero sale del modo presentación, luego cierra modales
  if (e.key === 'Escape') {
    if (document.body.classList.contains('present-mode')) {
      togglePresentMode();
      return;
    }
    closeModal();
  }
});

// Configurar drag para Impacto/Esfuerzo después de cada render del módulo análisis
const _origRenderAnal = renderAnalisis;
renderAnalisis = function() {
  _origRenderAnal();
  if (analisisTab === 'impacto') setTimeout(() => setupImpactoEsfuerzo(), 50);
};

/* ==========================================================================
   HELPERS DE RELACIONES ENTRE MÓDULOS
   ========================================================================== */

function processItems() { return state.processes.map(p => ({ id: p.id, label: p.code + ' · ' + p.name })); }
function objectiveItems() { return state.objectives.map(o => ({ id: o.code, label: o.code + ' · ' + o.name })); }
function projectItems() { return state.projects.map(p => ({ id: p.id, label: p.code + ' · ' + p.name })); }

function relationSelectField(id, items, currentId, placeholder = '— Ninguno —') {
  return selectField(id, [{value:'', label: placeholder}, ...items.map(x => ({value: x.id, label: x.label}))], currentId || '');
}
function relationMultiField(id, items, currentIds = []) {
  if (!items.length) return `<div class="text-xs p-3 rounded" style="background:var(--bg-sunken); color:var(--ink-muted)">No hay opciones disponibles aún</div>`;
  return `<div class="space-y-1 p-2 border rounded" style="border-color:var(--line-strong); max-height:180px; overflow-y:auto">
    ${items.map(x => `<label class="flex items-center gap-2 text-sm py-1"><input type="checkbox" value="${escapeHtml(x.id)}" ${(currentIds || []).includes(x.id) ? 'checked' : ''} class="${id}-check"><span>${escapeHtml(x.label)}</span></label>`).join('')}
  </div>`;
}
function getRelationMultiValues(id) {
  return Array.from(document.querySelectorAll(`.${id}-check:checked`)).map(el => el.value);
}

function getKPIsForProcess(pid) { return state.kpis.filter(k => k.processId === pid); }
function getRisksForProcess(pid) { return state.risks.filter(r => (r.processIds || []).includes(pid)); }
function getFindingsForProcess(pid) { return state.findings.filter(f => f.processId === pid); }
function getDocumentsForProcess(pid) { return state.documents.filter(d => d.processId === pid); }
function getProcessById(pid) { return state.processes.find(p => p.id === pid); }
function getObjectiveByCode(code) { return state.objectives.find(o => o.code === code); }
function getProjectsForObjective(code) { return state.projects.filter(p => p.objectiveCode === code); }
function getProjectsForFinding(fid) { return state.projects.filter(p => p.findingId === fid); }
function getKPIsForObjective(code) { return state.kpis.filter(k => k.objective === code); }

function processBadge(pid) {
  if (!pid) return '';
  const p = getProcessById(pid); if (!p) return '';
  return `<span class="badge badge-gray" style="cursor:pointer" onclick="event.stopPropagation(); goToProcess('${p.id}')" title="Ir al proceso: ${escapeHtml(p.name)}">↗ ${escapeHtml(p.code)}</span>`;
}
function processBadgesMulti(pids) {
  return (pids || []).map(pid => processBadge(pid)).filter(Boolean).join(' ');
}
function objectiveBadge(code) {
  if (!code) return '';
  const o = getObjectiveByCode(code); if (!o) return '';
  return `<span class="badge badge-purple" style="cursor:pointer" onclick="event.stopPropagation(); navigate('estrategia'); setTimeout(() => openObjectiveForm('${o.id}'), 100)" title="Ir al objetivo: ${escapeHtml(o.name)}">↗ ${escapeHtml(o.code)}</span>`;
}

function goToProcess(pid) { procesoSelectedId = pid; procesoTab = 'sipoc'; navigate('procesos'); }
function goToKPI(kid) { navigate('kpis'); setTimeout(() => openKPIForm(kid), 100); }
function goToRisk(rid) { navigate('riesgos'); setTimeout(() => openRiskForm(rid), 100); }
function goToFinding(fid) { navigate('hallazgos'); setTimeout(() => openFindingForm(fid), 100); }
function goToDocument(did) { navigate('documental'); setTimeout(() => openDocumentForm(did), 100); }
function goToProject(pid) { navigate('proyectos'); setTimeout(() => openProjectForm(pid), 100); }

function relationsBlock(title, items, renderItem, emptyMsg) {
  return `<div class="card p-4">
    <div class="flex items-center justify-between mb-3"><div class="font-serif text-lg">${escapeHtml(title)}</div><span class="badge badge-gray">${items.length}</span></div>
    ${items.length ? `<div class="space-y-2">${items.map(renderItem).join('')}</div>` : `<div class="text-sm text-center py-4" style="color:var(--ink-muted)">${escapeHtml(emptyMsg)}</div>`}
  </div>`;
}

function renderProcessRelations(p) {
  const kpis = getKPIsForProcess(p.id);
  const risks = getRisksForProcess(p.id);
  const findings = getFindingsForProcess(p.id);
  const docs = getDocumentsForProcess(p.id);
  return `<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    ${relationsBlock('Indicadores (KPIs)', kpis, k => {
      const s = kpiStatus(k); const cls = s === 'green' ? 'green' : s === 'yellow' ? 'yellow' : s === 'red' ? 'red' : 'gray';
      return `<div class="card-soft p-3 cursor-pointer" onclick="goToKPI('${k.id}')" style="border-left: 3px solid var(--${cls === 'gray' ? 'ink-subtle' : cls})">
        <div class="flex items-center justify-between gap-2"><span class="font-mono text-xs" style="color:var(--ink-muted)">${escapeHtml(k.code)}</span><span class="badge badge-${cls}">${cls === 'gray' ? 'sin datos' : cls}</span></div>
        <div class="text-sm mt-1">${escapeHtml(k.name)}</div>
      </div>`;
    }, 'Sin KPIs vinculados a este proceso')}
    ${relationsBlock('Riesgos asociados', risks, r => {
      const score = r.probability * r.impact;
      const cls = score >= 15 ? 'red' : score >= 8 ? 'yellow' : 'green';
      return `<div class="card-soft p-3 cursor-pointer" onclick="goToRisk('${r.id}')">
        <div class="flex items-center justify-between gap-2"><span class="font-mono text-xs" style="color:var(--ink-muted)">${escapeHtml(r.code)}</span><span class="badge badge-${cls}">P×I=${score}</span></div>
        <div class="text-sm mt-1">${escapeHtml(r.name)}</div>
      </div>`;
    }, 'Sin riesgos vinculados')}
    ${relationsBlock('Hallazgos', findings, f => {
      const sev = f.severity === 'Alta' ? 'red' : f.severity === 'Media' ? 'yellow' : 'green';
      return `<div class="card-soft p-3 cursor-pointer" onclick="goToFinding('${f.id}')">
        <div class="flex items-center justify-between gap-2"><span class="font-mono text-xs" style="color:var(--ink-muted)">${escapeHtml(f.code)}</span><span class="badge badge-${sev}">${escapeHtml(f.severity)}</span></div>
        <div class="text-sm mt-1">${escapeHtml(f.name)}</div>
      </div>`;
    }, 'Sin hallazgos vinculados')}
    ${relationsBlock('Documentos', docs, d => `<div class="card-soft p-3 cursor-pointer" onclick="goToDocument('${d.id}')">
      <div class="flex items-center justify-between gap-2"><span class="font-mono text-xs" style="color:var(--ink-muted)">${escapeHtml(d.code)}</span><span class="badge badge-blue">${escapeHtml(d.type)}</span></div>
      <div class="text-sm mt-1">${escapeHtml(d.title)}</div>
    </div>`, 'Sin documentos vinculados')}
  </div>`;
}

updateSidebarMeta();
navigate('inicio');

</script>
</body>
</html>
