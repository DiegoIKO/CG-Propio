  pivotState.rows = [];
  pivotState.cols = [];
  pivotState.values = [];
  pivotState.pivotFilters = [];
  renderVisualizaciones();
}

function resetPivot() {
  pivotState.rows = [];
  pivotState.cols = [];
  pivotState.values = [];
  pivotState.pivotFilters = [];
  renderVisualizaciones();
}

/* === Modal de configuración de filtro de pivote === */
function openPivotFilterConfig(filterIdx) {
  const f = pivotState.pivotFilters[filterIdx];
  if (!f) return;
  const ds = state.datasets.find(d => d.id === pivotState.datasetId);
  if (!ds) return;
  const col = ds.columns[f.colIdx];
  
  let body = '';
  if (f.type === 'text') {
    // Calcular valores disponibles según los OTROS filtros del pivote (jerárquico interno)
    const otherFilteredIdxs = computePivotFilteredIndices(ds, filterIdx);
    const valueCounts = {};
    const allValues = new Set();
    ds.rows.forEach((row, i) => {
      const v = String(row[f.colIdx] === null || row[f.colIdx] === undefined ? '(vacío)' : row[f.colIdx]);
      allValues.add(v);
      if (otherFilteredIdxs.includes(i)) {
        valueCounts[v] = (valueCounts[v] || 0) + 1;
      }
    });
    const sortedValues = [...allValues].sort((a, b) => a.localeCompare(b, 'es', { numeric: true }));
    
    body = `<div class="space-y-3">
      <div class="text-sm" style="color:var(--ink-muted)">Selecciona los valores que quieres incluir en el análisis</div>
      <input class="input input-sm" id="pf-search" placeholder="Buscar valores..." oninput="filterPivotConfigSearch(this.value)">
      <div class="flex gap-3 text-xs">
        <button class="btn btn-ghost btn-sm" onclick="pivotFilterTextSelectAll(${filterIdx}, true)">Seleccionar todos</button>
        <button class="btn btn-ghost btn-sm" onclick="pivotFilterTextSelectAll(${filterIdx}, false)">Deseleccionar todos</button>
      </div>
      <div id="pf-values-list" style="max-height: 320px; overflow-y: auto; border: 1px solid var(--line); border-radius: 6px; padding: 6px">
        ${sortedValues.map(v => {
          const inContext = valueCounts[v] !== undefined;
          const isSelected = f.selected.includes(v);
          return `<label class="filter-value-row ${!inContext ? 'unavailable' : ''}" data-val="${escapeHtml(v).toLowerCase()}">
            <input type="checkbox" ${isSelected ? 'checked' : ''} onchange="togglePivotFilterValue(${filterIdx}, ${JSON.stringify(v).replace(/"/g, '&quot;')}, this.checked)">
            <span class="val-label" title="${escapeHtml(v)}">${escapeHtml(v)}</span>
            <span class="val-count">${inContext ? valueCounts[v] : 0}</span>
          </label>`;
        }).join('')}
      </div>
    </div>`;
  } else if (f.type === 'number') {
    const otherFilteredIdxs = computePivotFilteredIndices(ds, filterIdx);
    const nums = otherFilteredIdxs.map(i => parseFloat(ds.rows[i][f.colIdx])).filter(v => !isNaN(v));
    const minVal = nums.length ? Math.min(...nums) : 0;
    const maxVal = nums.length ? Math.max(...nums) : 0;
    
    body = `<div class="space-y-3">
      <div class="text-sm" style="color:var(--ink-muted)">Define el rango de valores a incluir</div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="form-label">Mínimo (≥)</label>
          <input type="number" step="any" class="input" id="pf-min" value="${f.min ?? ''}" placeholder="Sin límite">
        </div>
        <div>
          <label class="form-label">Máximo (≤)</label>
          <input type="number" step="any" class="input" id="pf-max" value="${f.max ?? ''}" placeholder="Sin límite">
        </div>
      </div>
      <div class="text-xs" style="color:var(--ink-muted); padding: 8px; background: var(--bg-sunken); border-radius: 6px">
        En los datos disponibles: mínimo <strong>${fmtNumber(minVal)}</strong>, máximo <strong>${fmtNumber(maxVal)}</strong>
      </div>
    </div>`;
  } else if (f.type === 'date') {
    body = `<div class="space-y-3">
      <div class="text-sm" style="color:var(--ink-muted)">Define el rango de fechas a incluir</div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="form-label">Desde</label>
          <input type="date" class="input" id="pf-from" value="${f.from || ''}">
        </div>
        <div>
          <label class="form-label">Hasta</label>
          <input type="date" class="input" id="pf-to" value="${f.to || ''}">
        </div>
      </div>
      <div style="display:flex; gap: 6px; flex-wrap: wrap">
        <button class="btn btn-secondary btn-sm" onclick="applyPivotDatePreset(${filterIdx}, 'last30')">Últ. 30 días</button>
        <button class="btn btn-secondary btn-sm" onclick="applyPivotDatePreset(${filterIdx}, 'last90')">Últ. 90 días</button>
        <button class="btn btn-secondary btn-sm" onclick="applyPivotDatePreset(${filterIdx}, 'thisYear')">Este año</button>
        <button class="btn btn-secondary btn-sm" onclick="applyPivotDatePreset(${filterIdx}, 'lastYear')">Año pasado</button>
      </div>
    </div>`;
  }
  
  openModal({
    title: `Filtro: ${col.name}`,
    body,
    footer: `<button class="btn btn-danger" onclick="removePivotField('pivotFilters', ${filterIdx}); closeModal()">Quitar filtro</button><button class="btn btn-primary" onclick="savePivotFilterConfig(${filterIdx})">Aplicar</button>`,
    width: 'wide'
  });
}

function filterPivotConfigSearch(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('#pf-values-list .filter-value-row').forEach(row => {
    const val = row.dataset.val || '';
    row.style.display = val.includes(q) ? '' : 'none';
  });
}

function togglePivotFilterValue(filterIdx, value, checked) {
  const f = pivotState.pivotFilters[filterIdx];
  if (!f) return;
  if (checked) {
    if (!f.selected.includes(value)) f.selected.push(value);
  } else {
    f.selected = f.selected.filter(v => v !== value);
  }
}

function pivotFilterTextSelectAll(filterIdx, all) {
  const f = pivotState.pivotFilters[filterIdx];
  if (!f) return;
  const ds = state.datasets.find(d => d.id === pivotState.datasetId);
  if (all) {
    const allValues = [...new Set(ds.rows.map(r => String(r[f.colIdx] === null || r[f.colIdx] === undefined ? '(vacío)' : r[f.colIdx])))];
    f.selected = allValues;
  } else {
    f.selected = [];
  }
  // Re-renderizar checkboxes
  document.querySelectorAll('#pf-values-list input[type=checkbox]').forEach(cb => {
    cb.checked = all;
  });
}

function applyPivotDatePreset(filterIdx, preset) {
  const today = new Date();
  const fmt = d => d.toISOString().slice(0, 10);
  let from, to;
  if (preset === 'last30') {
    from = new Date(today); from.setDate(today.getDate() - 30);
    to = today;
  } else if (preset === 'last90') {
    from = new Date(today); from.setDate(today.getDate() - 90);
    to = today;
  } else if (preset === 'thisYear') {
    from = new Date(today.getFullYear(), 0, 1);
    to = new Date(today.getFullYear(), 11, 31);
  } else if (preset === 'lastYear') {
    from = new Date(today.getFullYear() - 1, 0, 1);
    to = new Date(today.getFullYear() - 1, 11, 31);
  }
  document.getElementById('pf-from').value = fmt(from);
  document.getElementById('pf-to').value = fmt(to);
}

function savePivotFilterConfig(filterIdx) {
  const f = pivotState.pivotFilters[filterIdx];
  if (!f) { closeModal(); return; }
  if (f.type === 'number') {
    const minEl = document.getElementById('pf-min');
    const maxEl = document.getElementById('pf-max');
    f.min = minEl && minEl.value !== '' ? parseFloat(minEl.value) : null;
    f.max = maxEl && maxEl.value !== '' ? parseFloat(maxEl.value) : null;
  } else if (f.type === 'date') {
    const fromEl = document.getElementById('pf-from');
    const toEl = document.getElementById('pf-to');
    f.from = fromEl?.value || null;
    f.to = toEl?.value || null;
  }
  // f.selected ya se actualizó en tiempo real para 'text'
  closeModal();
  renderPivotBuilder_refresh();
}

// Devuelve los índices del dataset que pasan los filtros de pivote (excluyendo uno opcional)
function computePivotFilteredIndices(ds, excludeFilterIdx) {
  let baseIndices = ds.rows.map((_, i) => i);
  
  // Aplicar filtros del dataset si está propagado
  const dsFilterState = getFilterState(pivotState.datasetId);
  if (dsFilterState.propagate) {
    baseIndices = getFilteredRowIndices(pivotState.datasetId);
  }
  
  // Aplicar filtros del pivote
  return baseIndices.filter(i => {
    return pivotState.pivotFilters.every((pf, pfIdx) => {
      if (pfIdx === excludeFilterIdx) return true;
      if (!pivotFilterHasValue(pf, ds)) return true;
      return rowMatchesPivotFilter(ds.rows[i][pf.colIdx], pf, ds);
    });
  });
}

function pivotFilterHasValue(f, ds) {
  if (!f) return false;
  if (f.type === 'text') {
    if (!f.selected) return false;
    // Si están todos los valores seleccionados, el filtro está "inactivo"
    const allValues = new Set(ds.rows.map(r => String(r[f.colIdx] === null || r[f.colIdx] === undefined ? '(vacío)' : r[f.colIdx])));
    return f.selected.length < allValues.size;
  }
  if (f.type === 'number') return (f.min !== null && f.min !== undefined && f.min !== '') || (f.max !== null && f.max !== undefined && f.max !== '');
  if (f.type === 'date') return (f.from !== null && f.from !== '') || (f.to !== null && f.to !== '');
  return false;
}

function rowMatchesPivotFilter(value, f, ds) {
  if (f.type === 'text') {
    const v = String(value === null || value === undefined ? '(vacío)' : value);
    return f.selected.includes(v);
  }
  if (f.type === 'number') {
    const n = parseFloat(value);
    if (isNaN(n)) return false;
    if (f.min !== null && f.min !== undefined && f.min !== '' && n < parseFloat(f.min)) return false;
    if (f.max !== null && f.max !== undefined && f.max !== '' && n > parseFloat(f.max)) return false;
    return true;
  }
  if (f.type === 'date') {
    if (!value) return false;
    const v = String(value).slice(0, 10);
    if (f.from && v < f.from) return false;
    if (f.to && v > f.to) return false;
    return true;
  }
  return true;
}

function computePivotData() {
  const ds = state.datasets.find(d => d.id === pivotState.datasetId);
  if (!ds) return null;
  if (pivotState.values.length === 0) return null;
  
  // Obtener filas filtradas (dataset propagado + filtros del pivote)
  const effectiveIndices = computePivotFilteredIndices(ds, -1);
  const effectiveRows = effectiveIndices.map(i => ds.rows[i]);
  
  // Obtener valores únicos para rows y cols
  const getKey = (row, fields) => fields.map(f => String(row[f.colIdx] !== undefined && row[f.colIdx] !== null ? row[f.colIdx] : '(vacío)')).join(' / ');
  
  const rowKeys = new Set();
  const colKeys = new Set();
  
  effectiveRows.forEach(row => {
    if (pivotState.rows.length) rowKeys.add(getKey(row, pivotState.rows));
    if (pivotState.cols.length) colKeys.add(getKey(row, pivotState.cols));
  });
  
  const sortedRowKeys = [...rowKeys].sort((a, b) => a.localeCompare(b, 'es', { numeric: true }));
  const sortedColKeys = [...colKeys].sort((a, b) => a.localeCompare(b, 'es', { numeric: true }));
  
  // Si no hay rows, una fila virtual "Total"
  const effectiveRowKeys = pivotState.rows.length ? sortedRowKeys : ['__total__'];
  const effectiveColKeys = pivotState.cols.length ? sortedColKeys : ['__total__'];
  
  // Construir cubo: rowKey -> colKey -> [valueIdx -> array de valores]
  const cube = {};
  effectiveRowKeys.forEach(rk => {
    cube[rk] = {};
    effectiveColKeys.forEach(ck => {
      cube[rk][ck] = pivotState.values.map(() => []);
    });
  });
  
  effectiveRows.forEach(row => {
    const rk = pivotState.rows.length ? getKey(row, pivotState.rows) : '__total__';
    const ck = pivotState.cols.length ? getKey(row, pivotState.cols) : '__total__';
    pivotState.values.forEach((v, vi) => {
      cube[rk][ck][vi].push(row[v.colIdx]);
    });
  });
  
  // Aplicar agregaciones
  const aggregate = (values, agg) => {
    const nums = values.map(v => parseFloat(v)).filter(v => !isNaN(v));
    const filled = values.filter(v => v !== '' && v != null);
    if (agg === 'count') return filled.length;
    if (agg === 'distinct') return new Set(filled.map(v => String(v))).size;
    if (!nums.length) return 0;
    if (agg === 'sum') return nums.reduce((a, b) => a + b, 0);
    if (agg === 'avg') return nums.reduce((a, b) => a + b, 0) / nums.length;
    if (agg === 'min') return Math.min(...nums);
    if (agg === 'max') return Math.max(...nums);
    return 0;
  };
  
  const result = {};
  effectiveRowKeys.forEach(rk => {
    result[rk] = {};
    effectiveColKeys.forEach(ck => {
      result[rk][ck] = pivotState.values.map((v, vi) => aggregate(cube[rk][ck][vi], v.agg));
    });
  });
  
  return {
    rowKeys: effectiveRowKeys,
    colKeys: effectiveColKeys,
    data: result,
    hasRows: pivotState.rows.length > 0,
    hasCols: pivotState.cols.length > 0,
    ds
  };
}

function renderPivotResult() {
  if (pivotState.values.length === 0) {
    return `<div class="pivot-result-empty">
      <div class="icon-wrap">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 3v18h18M7 14l3-3 3 3 5-5"/></svg>
      </div>
      <div class="empty-title">Construye tu análisis</div>
      <div class="empty-text">Arrastra columnas desde la izquierda al área de <strong>Valores</strong> para empezar. Luego agrega <strong>Filas</strong> para agruparlas y opcionalmente <strong>Columnas</strong> para cruzarlas.</div>
    </div>`;
  }
  
  const pivot = computePivotData();
  if (!pivot) return '<div class="pivot-result-empty">Sin datos</div>';
  
  const ds = pivot.ds;
  
  // Construir tabla HTML
  const rowFieldNames = pivotState.rows.map(r => ds.columns[r.colIdx].name);
  const colFieldNames = pivotState.cols.map(c => ds.columns[c.colIdx].name);
  const valFieldDescs = pivotState.values.map(v => {
    const aggLabel = { sum: 'Σ', count: '#', distinct: 'únicos', avg: '⌀', min: 'min', max: 'max' }[v.agg];
    return `${aggLabel} ${ds.columns[v.colIdx].name}`;
  });
  
  // Calcular totales para mapa de calor
  let allNumValues = [];
  pivot.rowKeys.forEach(rk => {
    pivot.colKeys.forEach(ck => {
      pivot.data[rk][ck].forEach(v => {
        if (typeof v === 'number' && !isNaN(v)) allNumValues.push(v);
      });
    });
  });
  const minV = allNumValues.length ? Math.min(...allNumValues) : 0;
  const maxV = allNumValues.length ? Math.max(...allNumValues) : 0;
  const heatRange = maxV - minV;
  
  const getHeat = (v) => {
    if (!pivotState.showHeatmap || heatRange === 0) return '';
    const normalized = (v - minV) / heatRange;
    if (normalized < 0.2) return 'heat-1';
    if (normalized < 0.4) return 'heat-2';
    if (normalized < 0.6) return 'heat-3';
    if (normalized < 0.8) return 'heat-4';
    return 'heat-5';
  };
  
  // Calcular totales por fila y columna
  const colTotals = {};
  const rowTotals = {};
  pivot.rowKeys.forEach(rk => {
    rowTotals[rk] = pivotState.values.map(() => 0);
    pivot.colKeys.forEach(ck => {
      pivot.data[rk][ck].forEach((v, vi) => {
        if (pivotState.values[vi].agg === 'sum' || pivotState.values[vi].agg === 'count') {
          rowTotals[rk][vi] += v;
        }
      });
    });
  });
  pivot.colKeys.forEach(ck => {
    colTotals[ck] = pivotState.values.map(() => 0);
    pivot.rowKeys.forEach(rk => {
      pivot.data[rk][ck].forEach((v, vi) => {
        if (pivotState.values[vi].agg === 'sum' || pivotState.values[vi].agg === 'count') {
          colTotals[ck][vi] += v;
        }
      });
    });
  });
  
  // HTML de la tabla
  let html = `<div class="pivot-result-header">
    <div>
      <div class="pivot-result-title">Resultado del análisis</div>
      <div class="text-xs" style="color:var(--ink-muted); margin-top: 2px">${pivot.rowKeys.length} ${pivot.rowKeys.length === 1 ? 'grupo' : 'grupos'} × ${pivot.hasCols ? pivot.colKeys.length + ' cruces' : 'sin cruce'} · ${pivotState.values.length} ${pivotState.values.length === 1 ? 'medida' : 'medidas'}</div>
    </div>
  </div>
  <div class="pivot-table-wrap"><table class="pivot-table">`;
  
  // Headers
  if (pivot.hasCols) {
    // Doble header: nombres de columna y valores
    html += '<thead>';
    // Primera fila: encabezados de fila + encabezados de columna (uno por valor)
    html += '<tr>';
    if (pivot.hasRows) html += `<th rowspan="2">${rowFieldNames.join(' / ')}</th>`;
    pivot.colKeys.forEach(ck => {
      const label = ck === '__total__' ? 'Total' : ck;
      html += `<th class="col-header" colspan="${pivotState.values.length}">${escapeHtml(label)}</th>`;
    });
    if (pivot.hasRows) html += `<th class="col-header" colspan="${pivotState.values.length}" style="background: rgba(30,58,58,0.1)">Total</th>`;
    html += '</tr><tr>';
    pivot.colKeys.forEach(() => {
      valFieldDescs.forEach(d => html += `<th class="col-header" style="font-size:10px">${escapeHtml(d)}</th>`);
    });
    if (pivot.hasRows) valFieldDescs.forEach(d => html += `<th class="col-header" style="font-size:10px; background: rgba(30,58,58,0.1)">${escapeHtml(d)}</th>`);
    html += '</tr></thead>';
  } else {
    html += '<thead><tr>';
    if (pivot.hasRows) html += `<th>${rowFieldNames.join(' / ')}</th>`;
    valFieldDescs.forEach(d => html += `<th class="col-header">${escapeHtml(d)}</th>`);
    html += '</tr></thead>';
  }
  
  // Body
  html += '<tbody>';
  pivot.rowKeys.forEach(rk => {
    html += '<tr>';
    if (pivot.hasRows) {
      const label = rk === '__total__' ? 'Total' : rk;
      html += `<td class="row-header">${escapeHtml(label)}</td>`;
    }
    pivot.colKeys.forEach(ck => {
      pivot.data[rk][ck].forEach(v => {
        const heat = getHeat(v);
        html += `<td class="value-cell ${heat}">${typeof v === 'number' ? fmtNumber(v) : v}</td>`;
      });
    });
    // Total de fila
    if (pivot.hasRows && pivot.hasCols) {
      rowTotals[rk].forEach(v => html += `<td class="value-cell total-cell">${fmtNumber(v)}</td>`);
    }
    html += '</tr>';
  });
  
  // Fila de totales
  if (pivot.hasRows && pivot.hasCols) {
    html += '<tr class="total-row"><td class="row-header">Total</td>';
    pivot.colKeys.forEach(ck => {
      colTotals[ck].forEach(v => html += `<td class="value-cell">${fmtNumber(v)}</td>`);
    });
    // Gran total
    pivotState.values.forEach((_, vi) => {
      const grand = pivot.rowKeys.reduce((s, rk) => s + (rowTotals[rk][vi] || 0), 0);
      html += `<td class="value-cell total-cell">${fmtNumber(grand)}</td>`;
    });
    html += '</tr>';
  }
  
  html += '</tbody></table></div>';
  
  return html;
}

function exportPivotXLSX() {
  if (!window.XLSX) return;
  const pivot = computePivotData();
  if (!pivot) return;
  
  // Construir como array of arrays
  const ds = pivot.ds;
  const rowFieldNames = pivotState.rows.map(r => ds.columns[r.colIdx].name);
  const valFieldDescs = pivotState.values.map(v => {
    const aggLabel = { sum: 'Suma', count: 'Conteo', distinct: 'Únicos', avg: 'Promedio', min: 'Mínimo', max: 'Máximo' }[v.agg];
    return `${aggLabel} de ${ds.columns[v.colIdx].name}`;
  });
  
  const aoa = [];
  
  if (pivot.hasCols) {
    // Primer header row
    const h1 = [pivot.hasRows ? rowFieldNames.join(' / ') : ''];
    pivot.colKeys.forEach(ck => {
      const label = ck === '__total__' ? 'Total' : ck;
      h1.push(label);
      for (let i = 1; i < pivotState.values.length; i++) h1.push('');
    });
    aoa.push(h1);
    
    // Segundo header row
    const h2 = [''];
    pivot.colKeys.forEach(() => {
      valFieldDescs.forEach(d => h2.push(d));
    });
    aoa.push(h2);
  } else {
    const h = [];
    if (pivot.hasRows) h.push(rowFieldNames.join(' / '));
    valFieldDescs.forEach(d => h.push(d));
    aoa.push(h);
  }
  
  pivot.rowKeys.forEach(rk => {
    const row = [];
    if (pivot.hasRows) row.push(rk === '__total__' ? 'Total' : rk);
    pivot.colKeys.forEach(ck => {
      pivot.data[rk][ck].forEach(v => row.push(typeof v === 'number' ? Math.round(v * 1000) / 1000 : v));
    });
    aoa.push(row);
  });
  
  const ws = XLSX.utils.aoa_to_sheet(aoa);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Análisis');
  XLSX.writeFile(wb, `analisis_${ds.name.replace(/[^a-zA-Z0-9_\-]/g, '_')}.xlsx`);
  toast('Análisis exportado');
}

function createChartFromPivot() {
  if (pivotState.values.length === 0 || pivotState.rows.length === 0) {
    toast('Necesitas al menos Filas y Valores'); return;
  }
  
  const pivot = computePivotData();
  if (!pivot) return;
  
  const ds = pivot.ds;
  
  // Crear un nuevo dataset con el resultado del pivote
  const rowFieldName = pivotState.rows.map(r => ds.columns[r.colIdx].name).join(' / ');
  const newColumns = [{ name: rowFieldName, type: 'text' }];
  
  if (pivot.hasCols) {
    // Una columna por cada combo colKey × valor
    pivot.colKeys.forEach(ck => {
      pivotState.values.forEach(v => {
        const aggLabel = { sum: 'Σ', count: '#', distinct: 'únicos', avg: '⌀', min: 'min', max: 'max' }[v.agg];
        const label = ck === '__total__' ? `${aggLabel} ${ds.columns[v.colIdx].name}` : `${ck} - ${aggLabel} ${ds.columns[v.colIdx].name}`;
        newColumns.push({ name: label, type: 'number' });
      });
    });
  } else {
    pivotState.values.forEach(v => {
      const aggLabel = { sum: 'Σ', count: '#', distinct: 'únicos', avg: '⌀', min: 'min', max: 'max' }[v.agg];
      newColumns.push({ name: `${aggLabel} ${ds.columns[v.colIdx].name}`, type: 'number' });
    });
  }
  
  const newRows = pivot.rowKeys.map(rk => {
    const row = [rk === '__total__' ? 'Total' : rk];
    pivot.colKeys.forEach(ck => {
      pivot.data[rk][ck].forEach(v => row.push(typeof v === 'number' ? Math.round(v * 100) / 100 : v));
    });
    return row;
  });
  
  const newDs = {
    id: uid(),
    name: 'Análisis de ' + ds.name,
    description: `Tabla pivote generada el ${new Date().toLocaleDateString('es-CL')}`,
    columns: newColumns,
    rows: newRows
  };
  state.datasets.push(newDs);
  
  // Crear gráfico automático
  const yFields = newColumns.slice(1, 6).map(c => c.name); // máximo 5 series
  const newChart = {
    id: uid(),
    name: 'Análisis: ' + ds.name,
    type: 'bar',
    datasetId: newDs.id,
    xField: newColumns[0].name,
    yFields
  };
  state.charts.push(newChart);
  
  save();
  vizTab = 'charts';
  vizSelectedChartId = newChart.id;
  renderVisualizaciones();
  toast('Dataset y gráfico creados');
}

function openPivotZoom() {
  if (pivotState.values.length === 0) { toast('Configura al menos un valor para ver el resultado'); return; }
  
  const ds = state.datasets.find(d => d.id === pivotState.datasetId);
  if (!ds) { toast('Dataset no encontrado'); return; }
  
  const pivot = computePivotData();
  if (!pivot) { toast('No se pudo calcular el análisis'); return; }
  
  // Limpiar TODOS los overlays previos
  ['pivot-zoom-overlay', 'chart-zoom-overlay', 'col-profile-panel'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.remove();
  });
  
  // Construir subtítulo descriptivo
  const rowDesc = pivotState.rows.length ? pivotState.rows.map(r => ds.columns[r.colIdx].name).join(' / ') : 'Total';
  const colDesc = pivotState.cols.length ? pivotState.cols.map(c => ds.columns[c.colIdx].name).join(' / ') : '';
  const valDesc = pivotState.values.map(v => {
    const aggLabel = { sum: 'Σ', count: '#', distinct: 'únicos', avg: '⌀', min: 'min', max: 'max' }[v.agg];
    return `${aggLabel} ${ds.columns[v.colIdx].name}`;
  }).join(', ');
  const activePivotFilters = pivotState.pivotFilters.filter(f => pivotFilterHasValue(f, ds));
  
  const overlay = document.createElement('div');
  overlay.id = 'pivot-zoom-overlay';
  overlay.className = 'chart-zoom-overlay';
  overlay.innerHTML = `
    <div class="chart-zoom-header">
      <div class="chart-zoom-title-block">
        <div class="chart-zoom-title">Análisis: ${escapeHtml(ds.name)}</div>
        <div class="chart-zoom-subtitle">
          <span class="badge-pill">Filas: ${escapeHtml(rowDesc)}</span>
          ${colDesc ? `<span class="badge-pill">Cruce: ${escapeHtml(colDesc)}</span>` : ''}
          <span class="badge-pill">Valores: ${escapeHtml(valDesc)}</span>
          ${activePivotFilters.length ? `<span class="badge-pill" style="background:rgba(200,157,44,0.25)">${activePivotFilters.length} ${activePivotFilters.length === 1 ? 'filtro activo' : 'filtros activos'}</span>` : ''}
          <span>·</span>
          <span>${pivot.rowKeys.length} ${pivot.rowKeys.length === 1 ? 'grupo' : 'grupos'}${colDesc ? ` × ${pivot.colKeys.length} cruces` : ''}</span>
        </div>
      </div>
      <div class="chart-zoom-actions">
        <button onclick="exportPivotXLSX()" title="Descargar como Excel">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          Descargar Excel
        </button>
        <button class="chart-zoom-close" onclick="closePivotZoom()" title="Cerrar (ESC)">×</button>
      </div>
    </div>
    <div class="pivot-zoom-content" id="pivot-zoom-content">
      ${renderPivotResult()}
    </div>
    <div class="chart-zoom-footer">Presiona <kbd>ESC</kbd> para cerrar · Clic en el fondo también cierra</div>
  `;
  
  document.body.appendChild(overlay);
  document.addEventListener('keydown', pivotZoomKeyHandler);
  
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closePivotZoom();
  });
}

function pivotZoomKeyHandler(e) {
  if (e.key === 'Escape') closePivotZoom();
}

function closePivotZoom() {
  const overlay = document.getElementById('pivot-zoom-overlay');
  if (overlay) overlay.remove();
  document.removeEventListener('keydown', pivotZoomKeyHandler);
}

function exportPivotZoomImage() {
  const content = document.getElementById('pivot-zoom-content');
  if (!content) return;
  
  // Clonar el contenido y aplicar estilos inline básicos
  const clone = content.cloneNode(true);
  const rect = content.getBoundingClientRect();
  
  // Calcular dimensiones reales del contenido (scroll)
  const fullWidth = Math.max(content.scrollWidth, rect.width);
  const fullHeight = Math.max(content.scrollHeight, rect.height);
  
  // Aplicar estilos inline esenciales al clon para que se renderice correctamente en SVG
  applyInlineStylesForExport(clone);
  
  // Wrap en SVG con foreignObject
  const svgString = `<svg xmlns="http://www.w3.org/2000/svg" width="${fullWidth}" height="${fullHeight}">
    <foreignObject width="100%" height="100%">
      <div xmlns="http://www.w3.org/1999/xhtml" style="background: #faf7ef; padding: 20px; font-family: 'IBM Plex Sans', sans-serif; color: #15110d; width: ${fullWidth - 40}px;">
        ${new XMLSerializer().serializeToString(clone).replace(/&nbsp;/g, '&#160;')}
      </div>
    </foreignObject>
  </svg>`;
  
  const blob = new Blob([svgString], { type: 'image/svg+xml;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  
  const img = new Image();
  img.onload = function() {
    const canvas = document.createElement('canvas');
    canvas.width = fullWidth;
    canvas.height = fullHeight;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#faf7ef';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(img, 0, 0);
    URL.revokeObjectURL(url);
    
    canvas.toBlob(function(blob) {
      const dlUrl = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = dlUrl;
      a.download = `analisis_${new Date().toISOString().slice(0,10)}.png`;
      a.click();
      URL.revokeObjectURL(dlUrl);
      toast('Imagen descargada');
    }, 'image/png');
  };
  img.onerror = function() {
    URL.revokeObjectURL(url);
    toast('No se pudo generar la imagen. Usa "Excel" o captura de pantalla.');
  };
  img.src = url;
}

function applyInlineStylesForExport(el) {
  // Aplicar algunos estilos básicos en línea para que el SVG renderice
  if (el.querySelectorAll) {
    el.querySelectorAll('.pivot-table').forEach(t => {
      t.style.borderCollapse = 'collapse';
      t.style.width = '100%';
      t.style.fontSize = '12px';
