      <div class="text-xs mb-2" style="color:var(--ink-muted)">La primera fila debe ser los nombres de columna. Soporta separación por tabulaciones (copia desde Excel) o por comas (CSV).</div>
      <textarea class="textarea" id="f-pst-data" rows="10" placeholder="Mes	Ventas	Costos&#10;Enero	1200	800&#10;Febrero	1350	820&#10;Marzo	1500	900" style="font-family: 'JetBrains Mono', monospace; font-size: 12px"></textarea>
    </div>
  </div>`;
  openModal({ title: 'Pegar datos desde Excel/CSV', body, footer: `<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-pst">Importar</button>`, width: 'wide' });
  document.getElementById('btn-pst').onclick = () => {
    const name = document.getElementById('f-pst-name').value.trim() || 'Dataset importado ' + new Date().toLocaleDateString('es-CL');
    const raw = document.getElementById('f-pst-data').value.trim();
    if (!raw) { toast('Pega los datos primero'); return; }
    const lines = raw.split(/\r?\n/);
    // Detectar separador
    const firstLine = lines[0];
    const sep = firstLine.includes('\t') ? '\t' : firstLine.includes(';') ? ';' : ',';
    const parseLine = (l) => {
      // Manejo simple de comillas para CSV
      if (sep === ',' && l.includes('"')) {
        const out = []; let cur = ''; let inQ = false;
        for (let i = 0; i < l.length; i++) {
          const c = l[i];
          if (c === '"') { if (inQ && l[i+1] === '"') { cur += '"'; i++; } else inQ = !inQ; }
          else if (c === sep && !inQ) { out.push(cur); cur = ''; }
          else cur += c;
        }
        out.push(cur); return out;
      }
      return l.split(sep);
    };
    const headers = parseLine(lines[0]).map(h => h.trim());
    const rows = lines.slice(1).map(l => parseLine(l).map(v => {
      const t = v.trim();
      const num = Number(t.replace(',', '.'));
      return (t !== '' && !isNaN(num)) ? num : t;
    }));
    const newD = { id: uid(), name, description: 'Importado el ' + new Date().toLocaleDateString('es-CL'), columns: headers.map(h => ({ name: h })), rows };
    state.datasets.push(newD); vizSelectedDatasetId = newD.id;
    save(); closeModal(); renderVisualizaciones(); toast(`Importadas ${rows.length} filas`);
  };
}

