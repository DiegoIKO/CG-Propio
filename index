function renderProcessTree() {
  function nodes(parentId, depth = 0) {
    return state.processes.filter(p => p.parentId === parentId).map(p => {
      const children = state.processes.filter(c => c.parentId === p.id);
      const typeClr = p.type === 'Estratégico' ? 'purple' : p.type === 'Misional / Clave' ? 'blue' : 'gray';
      const linkedCount = getKPIsForProcess(p.id).length + getRisksForProcess(p.id).length + getFindingsForProcess(p.id).length + getDocumentsForProcess(p.id).length;
      return `<div>
        <div class="tree-node ${procesoSelectedId === p.id ? 'selected' : ''}" onclick="selectProcess('${p.id}')" style="padding-left: ${10 + depth * 12}px">
