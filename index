// Agrupa filas por valor de X y agrega los Y según función
// Devuelve { labels, ySeries } donde ySeries es array de arrays (uno por cada yIdx)
function aggregateChartData(ds, xIdx, yIdxs, aggFn) {
  aggFn = aggFn || 'sum';
  
  // Si X es fecha numérica única → no agrupar (preservar orden cronológico)
  const groups = new Map();
  const labelOrder = [];
  
  for (let i = 0; i < ds.rows.length; i++) {
    const row = ds.rows[i];
    const xVal = row[xIdx];
    const xKey = String(xVal === null || xVal === undefined ? '' : xVal);
    if (xKey === '') continue;
    
    if (!groups.has(xKey)) {
      groups.set(xKey, yIdxs.map(() => []));
      labelOrder.push(xKey);
    }
    const bucket = groups.get(xKey);
    yIdxs.forEach((yi, yIdxPos) => {
      bucket[yIdxPos].push(row[yi]);
    });
  }
  
  // Ordenar labels naturalmente
  const xCol = ds.columns[xIdx];
  if (xCol && xCol.type === 'date') {
    labelOrder.sort();
  } else if (xCol && xCol.type === 'number') {
    labelOrder.sort((a, b) => parseFloat(a) - parseFloat(b));
  } else {
    labelOrder.sort((a, b) => a.localeCompare(b, 'es', { numeric: true }));
  }
  
  // Aplicar agregación
  const aggregate = (values) => {
    const nums = values.map(v => parseFloat(v)).filter(v => !isNaN(v));
    const filled = values.filter(v => v !== '' && v != null);
    if (aggFn === 'count') return filled.length;
    if (aggFn === 'distinct') return new Set(filled.map(v => String(v))).size;
    if (!nums.length) return 0;
    if (aggFn === 'sum') return nums.reduce((a, b) => a + b, 0);
    if (aggFn === 'avg') return nums.reduce((a, b) => a + b, 0) / nums.length;
    if (aggFn === 'min') return Math.min(...nums);
    if (aggFn === 'max') return Math.max(...nums);
    return 0;
  };
  
  const ySeries = yIdxs.map((_, yIdxPos) => {
    return labelOrder.map(xKey => aggregate(groups.get(xKey)[yIdxPos]));
  });
  
  return { labels: labelOrder, ySeries };
}

