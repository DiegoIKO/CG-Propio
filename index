function generateReporteRiesgos() {
  const sorted = [...state.risks].sort((a, b) => (b.probability * b.impact) - (a.probability * a.impact));
  const rows = sorted.map(r => {
    const inh = r.probability * r.impact;
    const res = r.residualProb * r.residualImpact;
    return [
      `<strong>${escapeHtml(r.code)}</strong>`,
      escapeHtml(r.name),
      escapeHtml(r.category),
      `P${r.probability}·I${r.impact}<br>${repTag(inh.toString(), inh >= 15 ? 'red' : inh >= 8 ? 'yellow' : 'green')}`,
      `P${r.residualProb}·I${r.residualImpact}<br>${repTag(res.toString(), res >= 15 ? 'red' : res >= 8 ? 'yellow' : 'green')}`,
      escapeHtml((r.controls || '').slice(0, 100)),
      escapeHtml(r.treatment),
      escapeHtml(r.owner || '—'),
      fmtDate(r.dueDate)
    ];
  });
  return `${repCover('Matriz de Riesgos', 'Formato CAIGG · Probabilidad × Impacto (escala 1-5)')}
    
    <h2>Resumen</h2>
    ${repSummary(`El presente reporte contiene <strong>${state.risks.length} riesgos</strong> identificados, de los cuales <strong>${state.risks.filter(r => r.probability * r.impact >= 15).length} son críticos</strong> (P×I ≥ 15), <strong>${state.risks.filter(r => { const s = r.probability * r.impact; return s >= 8 && s < 15; }).length} moderados</strong> (8-14) y <strong>${state.risks.filter(r => r.probability * r.impact < 8).length} bajos</strong> (< 8). Los riesgos se ordenan por criticidad descendente.`)}
    
    <h2>Matriz de Riesgos</h2>
    ${repTable(['Código', 'Riesgo', 'Categoría', 'Inherente', 'Residual', 'Controles', 'Tratamiento', 'Responsable', 'Plazo'], rows)}
    
    <h2>Metodología</h2>
    <p>La identificación, evaluación y tratamiento de riesgos se realiza siguiendo los lineamientos del <strong>Consejo de Auditoría Interna General de Gobierno (CAIGG)</strong>. Cada riesgo se evalúa según su probabilidad de ocurrencia (1=muy baja, 5=muy alta) e impacto sobre los objetivos (1=insignificante, 5=catastrófico). El producto P×I determina la criticidad: ≥15 crítico, 8-14 moderado, &lt;8 bajo. El riesgo residual incorpora el efecto de los controles existentes.</p>`;
}

