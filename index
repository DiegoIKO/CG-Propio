.kpi-zoom-chart-wrap { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 10px; padding: 18px; min-height: 380px; position: relative; }
.kpi-zoom-side { display: flex; flex-direction: column; gap: 16px; }
.kpi-zoom-big-value { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 10px; padding: 22px; text-align: center; }
.kpi-zoom-big-value .label { font-size: 11px; text-transform: uppercase; letter-spacing: .07em; color: var(--ink-muted); font-weight: 600; margin-bottom: 6px; }
.kpi-zoom-big-value .value { font-family: 'Instrument Serif', serif; font-size: 48px; line-height: 1; }
.kpi-zoom-big-value .unit { font-size: 14px; color: var(--ink-muted); margin-left: 4px; }
.kpi-zoom-big-value .target-line { font-size: 11px; color: var(--ink-muted); margin-top: 6px; }
.kpi-zoom-mini-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.kpi-zoom-mini-stat { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px; padding: 10px 12px; }
