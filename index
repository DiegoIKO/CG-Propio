  else if (analisisTab === 'arbol') { body = renderExplicacionPanel('arbol') + renderArbol(); actions = `${explanationButton()}<button class="btn btn-primary" onclick="openArbolForm()">+ Nuevo árbol</button>`; }
  else if (analisisTab === 'impacto') { body = renderExplicacionPanel('impacto') + renderImpactoEsfuerzo(); actions = `${explanationButton()}${(state.impactEffort || []).length > 0 ? `<button class="btn btn-secondary" onclick="printImpactoEsfuerzo()" title="Imprimir matriz visualmente"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z"/></svg> Imprimir</button>` : ''}<button class="btn btn-primary" onclick="openImpactoItemForm()">+ Iniciativa</button>`; }
  else if (analisisTab === 'multi') { body = renderExplicacionPanel('multi') + renderMulticriterio(); actions = `${explanationButton()}${(state.multiCriteria || []).length > 0 ? `<button class="btn btn-secondary" onclick="printMulticriterioAll()" title="Imprimir matrices visualmente"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z"/></svg> Imprimir</button>` : ''}<button class="btn btn-primary" onclick="openMultiForm()">+ Nueva matriz</button>`; }
