function renderExplicacionPanel(key) {
  if (!analisisShowExplanation) return '';
  const exp = ANALISIS_EXPLICACIONES[key];
  if (!exp) return '';
  return `<div class="card p-5 mb-4" style="background:linear-gradient(180deg, #f7f4ee 0%, #ffffff 100%); border-left: 3px solid var(--accent)">
    <div class="flex items-start justify-between mb-3">
      <div class="font-serif text-2xl">${escapeHtml(exp.title)}</div>
      <button class="btn btn-ghost btn-icon" onclick="analisisShowExplanation=false; renderAnalisis()" title="Cerrar explicación"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
    </div>
    <div class="space-y-4">
      ${exp.sections.map(s => `<div>
        <div class="font-semibold text-sm mb-1" style="color:var(--accent)">${escapeHtml(s.h)}</div>
        <div class="text-sm leading-relaxed" style="color:var(--ink)">${s.p}</div>
      </div>`).join('')}
    </div>
  </div>`;
}

function explanationButton() {
  return `<button class="btn btn-secondary btn-sm" onclick="analisisShowExplanation=!analisisShowExplanation; renderAnalisis()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
