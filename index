function setupPivotDragDrop() {
  // Hacer drop-zones funcionales
  document.querySelectorAll('.pivot-dropzone[data-zone]').forEach(zone => {
    zone.addEventListener('dragover', e => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      zone.classList.add('drag-over');
    });
    zone.addEventListener('dragleave', e => {
      // Solo quitar la clase si realmente salimos del zone
      if (!zone.contains(e.relatedTarget)) {
        zone.classList.remove('drag-over');
      }
    });
    zone.addEventListener('drop', e => {
      e.preventDefault();
      zone.classList.remove('drag-over');
      const colIdx = parseInt(e.dataTransfer.getData('text/plain'));
      if (isNaN(colIdx)) return;
      pivotDropColumn(colIdx, zone.dataset.zone);
    });
  });
  
  // Hacer pivot-source draggable
  document.querySelectorAll('.pivot-source[draggable=true]').forEach(field => {
    field.addEventListener('dragstart', e => {
      const colIdx = field.dataset.fieldIdx;
      e.dataTransfer.setData('text/plain', String(colIdx));
      e.dataTransfer.effectAllowed = 'move';
      field.classList.add('dragging');
    });
    field.addEventListener('dragend', e => {
      field.classList.remove('dragging');
      document.querySelectorAll('.pivot-dropzone').forEach(z => z.classList.remove('drag-over'));
    });
  });
}

function pivotDropColumn(colIdx, area) {
  const ds = state.datasets.find(d => d.id === pivotState.datasetId);
  if (!ds || !ds.columns[colIdx]) return;
  
  // Quitar de cualquier zona donde esté
  pivotState.rows = pivotState.rows.filter(r => r.colIdx !== colIdx);
  pivotState.cols = pivotState.cols.filter(c => c.colIdx !== colIdx);
  pivotState.values = pivotState.values.filter(v => v.colIdx !== colIdx);
  pivotState.pivotFilters = pivotState.pivotFilters.filter(f => f.colIdx !== colIdx);
  
  const col = ds.columns[colIdx];
  if (area === 'values') {
    pivotState.values.push({ colIdx, agg: col.type === 'number' ? 'sum' : 'count' });
  } else if (area === 'pivotFilters') {
    const filterObj = { colIdx, type: col.type === 'number' ? 'number' : col.type === 'date' ? 'date' : 'text' };
    if (filterObj.type === 'text') {
      const allValues = [...new Set(ds.rows.map(r => String(r[colIdx] === null || r[colIdx] === undefined ? '(vacío)' : r[colIdx])))];
      filterObj.selected = allValues;
    } else if (filterObj.type === 'number') {
      filterObj.min = null;
      filterObj.max = null;
    } else {
      filterObj.from = null;
      filterObj.to = null;
    }
    pivotState.pivotFilters.push(filterObj);
    setTimeout(() => openPivotFilterConfig(pivotState.pivotFilters.length - 1), 50);
  } else {
    pivotState[area].push({ colIdx });
  }
  
  renderPivotBuilder_refresh();
}

function isFieldInPivot(colIdx) {
  return pivotState.rows.some(r => r.colIdx === colIdx) ||
    pivotState.cols.some(c => c.colIdx === colIdx) ||
    pivotState.values.some(v => v.colIdx === colIdx) ||
    pivotState.pivotFilters.some(f => f.colIdx === colIdx);
}

