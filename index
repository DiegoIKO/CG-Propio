function suggestChartType(ds, xField, yFields) {
  // Sugiere tipo de gráfico según los datos
  if (!ds || !xField || !yFields.length) return 'bar';
  const xCol = ds.columns.find(c => c.name === xField);
  if (!xCol) return 'bar';
  
  // Si X es fecha → línea
  if (xCol.type === 'date') return yFields.length >= 2 ? 'line' : 'line';
  // Si pocas categorías (≤8) y una sola serie → torta
  if (xCol.type === 'text' && ds.rows.length <= 8 && yFields.length === 1) return 'doughnut';
  // Si múltiples series con misma magnitud → barras apiladas o agrupadas
  if (yFields.length >= 3) return 'bar';
  return 'bar';
}

