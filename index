    });
    el.querySelectorAll('.pivot-table td.row-header').forEach(c => {
      c.style.background = '#ebe4d4';
      c.style.fontWeight = '500';
    });
    el.querySelectorAll('.pivot-table td.total-cell').forEach(c => {
      c.style.background = 'rgba(30,58,58,0.05)';
      c.style.fontWeight = '600';
    });
    el.querySelectorAll('.pivot-table tr.total-row td').forEach(c => {
      c.style.background = 'rgba(30,58,58,0.05)';
      c.style.fontWeight = '600';
      c.style.borderTop = '2px solid #b8af9f';
    });
    // Mapa de calor
    const heatColors = {
      'heat-1': 'rgba(74, 124, 74, 0.05)',
      'heat-2': 'rgba(74, 124, 74, 0.15)',
      'heat-3': 'rgba(74, 124, 74, 0.3)',
      'heat-4': 'rgba(74, 124, 74, 0.5)',
      'heat-5': 'rgba(74, 124, 74, 0.7)'
    };
    Object.entries(heatColors).forEach(([cls, color]) => {
      el.querySelectorAll(`.pivot-table td.${cls}`).forEach(c => {
        c.style.background = color;
        if (cls === 'heat-4' || cls === 'heat-5') c.style.color = 'white';
      });
    });
    el.querySelectorAll('.pivot-result-header').forEach(h => {
      h.style.marginBottom = '12px';
      h.style.paddingBottom = '12px';
      h.style.borderBottom = '1px solid #c9c1b3';
    });
    el.querySelectorAll('.pivot-result-title').forEach(t => {
      t.style.fontFamily = "'Instrument Serif', serif";
