.chart-zoom-close { width: 38px; height: 38px; border-radius: 50%; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: #f7f4ee; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 20px; transition: all .15s; padding: 0; flex-shrink: 0; }
.chart-zoom-close:hover { background: rgba(255,255,255,0.2); transform: rotate(90deg); }
.chart-zoom-canvas-wrap { flex: 1; background: #faf7ef; border-radius: 12px; padding: 24px; display: flex; align-items: center; justify-content: center; box-shadow: 0 12px 48px rgba(0,0,0,0.4); position: relative; min-height: 0; }
.chart-zoom-canvas-wrap canvas { max-width: 100%; max-height: 100%; }
.chart-zoom-footer { color: #a39a8c; font-size: 11px; text-align: center; margin-top: 12px; }
