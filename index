        <button class="btn btn-ghost btn-icon" onclick="moveStage('${project.id}', '${stage.id}', 1)" title="Mover abajo" ${idx === project.stages.length - 1 ? 'disabled' : ''}><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
        <button class="btn btn-ghost btn-icon" onclick="openStageForm('${project.id}', '${stage.id}')" title="Editar"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4v16h16v-7M18 2l4 4-12 12H6v-4z"/></svg></button>
        <button class="btn btn-ghost btn-icon" onclick="deleteStage('${project.id}', '${stage.id}')" title="Eliminar"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4h8v2M5 6l1 14h12l1-14"/></svg></button>
