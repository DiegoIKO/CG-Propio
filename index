        <button class="btn btn-ghost btn-icon" onclick="removeSubtask('${t.id}', '${s.id}')"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
      </div>`).join('') || '<div class="text-xs text-center py-3" style="color:var(--ink-muted)">Sin subtareas. Útil para dividir trabajo grande en pasos manejables.</div>'}</div>
