            <div class="kpi-zoom-mini-stat">
              <div class="label">Dirección</div>
              <div class="value" style="font-size: 12.5px; font-family: 'IBM Plex Sans', sans-serif">${k.direction === 'up' ? 'Mayor es mejor ↑' : 'Menor es mejor ↓'}</div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="kpi-zoom-history">
        <h3>Historial de mediciones</h3>
        ${measurements.length === 0 ? '<div class="text-sm" style="color:var(--ink-muted); padding: 12px; text-align: center">Sin mediciones registradas todavía. Usa el botón "+ Medición" para agregar la primera.</div>' : `
          <table>
            <thead><tr><th>Fecha</th><th>Valor</th><th>Variación</th><th>Comentario</th><th></th></tr></thead>
            <tbody>
              ${measurements.map((m, i, arr) => {
                const prev = arr[i + 1];
                const diff = prev ? Number(m.value) - Number(prev.value) : null;
                const diffStr = diff === null ? '—' : (diff > 0 ? '+' : '') + fmtNumber(diff);
                const diffColor = diff === null ? 'var(--ink-muted)' : (k.direction === 'up' ? (diff > 0 ? 'var(--green)' : diff < 0 ? 'var(--red)' : 'var(--ink-muted)') : (diff < 0 ? 'var(--green)' : diff > 0 ? 'var(--red)' : 'var(--ink-muted)'));
                const origIdx = k.measurements.findIndex(x => x === m);
                const commentText = m.comment || m.note || '';
                return `<tr style="cursor: pointer" onclick="openKPIMeasureForm('${k.id}', ${origIdx})" title="Clic para editar esta medición">
                  <td class="text-xs">${fmtDate(m.date)}</td>
                  <td class="font-mono"><strong>${fmtNumber(m.value)}</strong> <span class="text-xs" style="color:var(--ink-muted)">${escapeHtml(k.unit || '')}</span></td>
                  <td class="font-mono text-xs" style="color:${diffColor}">${diffStr}</td>
                  <td class="text-xs" style="max-width: 300px">${commentText ? `<span style="color:var(--ink); font-style: italic">${escapeHtml(commentText)}</span>` : '<span style="color:var(--ink-subtle)">—</span>'}</td>
                  <td class="text-right" onclick="event.stopPropagation()">
                    <button class="btn btn-ghost btn-icon" onclick="openKPIMeasureForm('${k.id}', ${origIdx})" title="Editar"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4v16h16v-7M18 2l4 4-12 12H6v-4z"/></svg></button>
                    <button class="btn btn-ghost btn-icon" onclick="deleteMeasure('${k.id}', ${origIdx})" title="Eliminar"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
                  </td>
                </tr>`;
              }).join('')}
            </tbody>
          </table>
        `}
      </div>
    </div>
  `;
  
  document.body.appendChild(overlay);
  document.addEventListener('keydown', kpiZoomKeyHandler);
  
  // Cerrar al hacer clic en el fondo (fuera del content)
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeKpiZoom();
  });
  
  // Renderizar el gráfico ampliado
  setTimeout(() => renderKpiZoomChart(k), 50);
}

function kpiZoomKeyHandler(e) {
  if (e.key === 'Escape') closeKpiZoom();
}

function closeKpiZoom() {
  const overlay = document.getElementById('kpi-zoom-overlay');
  if (overlay) {
    destroyChart('kpi-zoom-' + kpiZoomId);
    overlay.remove();
  }
  document.removeEventListener('keydown', kpiZoomKeyHandler);
  kpiZoomId = null;
}

function renderKpiZoomChart(k) {
  const canvas = document.getElementById('kpi-zoom-chart');
  if (!canvas || !window.Chart) return;
  const id = 'kpi-zoom-' + k.id;
  destroyChart(id);
  
  const measurements = (k.measurements || []).slice().sort((a, b) => (a.date || '').localeCompare(b.date || ''));
  const data = measurements.map(m => ({ x: m.date, y: Number(m.value) }));
  const s = kpiStatus(k);
  const colorMap = { green: '#4a7c4a', yellow: '#c89d2c', red: '#a83e3e', gray: '#a39a8c' };
  const color = colorMap[s];
  
  // Línea de meta si existe
  const datasets = [{
    label: k.name,
    data: data,
    borderColor: color,
    backgroundColor: hexToRgba(color, 0.15),
    borderWidth: 3,
    tension: 0.3,
    fill: true,
    pointBackgroundColor: color,
    pointBorderColor: '#ffffff',
    pointBorderWidth: 2,
    pointRadius: 6,
    pointHoverRadius: 9
  }];
  
  if (k.target !== undefined && k.target !== '' && data.length > 0) {
    datasets.push({
      label: 'Meta',
      data: data.map(d => ({ x: d.x, y: Number(k.target) })),
      borderColor: 'rgba(21,17,13,0.5)',
      borderWidth: 2,
      borderDash: [5, 5],
      fill: false,
      pointRadius: 0,
      tension: 0
    });
  }
  
  chartInstances[id] = new Chart(canvas, {
    type: 'line',
    data: { datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 600 },
      plugins: {
        legend: { display: true, position: 'top', align: 'end', labels: { font: { size: 12, family: "'IBM Plex Sans', sans-serif" }, usePointStyle: true, boxWidth: 10 } },
        tooltip: {
          backgroundColor: 'rgba(21, 17, 13, 0.95)',
          titleColor: '#f7f4ee',
          bodyColor: '#f7f4ee',
          padding: 10,
          cornerRadius: 6,
          callbacks: {
            label: function(ctx) { return ` ${ctx.dataset.label}: ${fmtNumber(ctx.parsed.y)} ${k.unit || ''}`; }
          }
        }
      },
      scales: {
        x: { type: 'time', time: { unit: 'month', displayFormats: { month: 'MMM yy' } }, grid: { display: false }, ticks: { font: { size: 11 }, color: '#6b6357' } },
        y: { beginAtZero: false, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { font: { size: 11 }, color: '#6b6357', callback: v => fmtNumber(v) } }
      }
    }
  });
}

