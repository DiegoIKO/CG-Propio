@keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
.project-detail-header .pd-progress-pct { font-family: 'JetBrains Mono', monospace; font-size: 20px; font-weight: 600; color: var(--ink); min-width: 56px; text-align: right; }
