function renderBPMNNode(pid, n) {
  const t = BPMN_NODE_TYPES[n.type]; if (!t) return '';
  const isSel = bpmnSelected && bpmnSelected.kind === 'node' && bpmnSelected.id === n.id;
  let shape = '';
  let labelDx = 0, labelDy = 0;
  let portX = 0, portY = 0; // posición del puerto de salida
  
  if (t.type === 'event') {
    const stroke = n.type === 'endEvent' ? `stroke="${t.color}" stroke-width="4"` : `stroke="rgba(0,0,0,.15)" stroke-width="1.5"`;
    const fill = n.type === 'endEvent' ? 'white' : t.color;
    shape = `<circle class="bpmn-node-shape" cx="${n.x}" cy="${n.y}" r="${t.radius}" fill="${fill}" ${stroke}/>`;
    labelDy = t.radius + 16;
    portX = n.x + t.radius; portY = n.y;
  } else if (t.type === 'rect') {
    shape = `<rect class="bpmn-node-shape" x="${n.x - t.width/2}" y="${n.y - t.height/2}" width="${t.width}" height="${t.height}" rx="6" fill="white" stroke="${t.color}" stroke-width="2"/>`;
    portX = n.x + t.width/2; portY = n.y;
  } else if (t.type === 'rect-double') {
    shape = `<rect class="bpmn-node-shape" x="${n.x - t.width/2}" y="${n.y - t.height/2}" width="${t.width}" height="${t.height}" rx="6" fill="white" stroke="${t.color}" stroke-width="2"/>
             <rect x="${n.x - t.width/2 + 4}" y="${n.y - t.height/2 + 4}" width="${t.width - 8}" height="${t.height - 8}" rx="4" fill="none" stroke="${t.color}" stroke-width="1" opacity="0.5"/>
             <text x="${n.x}" y="${n.y + t.height/2 - 8}" text-anchor="middle" font-size="14" fill="${t.color}">⊕</text>`;
    portX = n.x + t.width/2; portY = n.y;
  } else if (t.type === 'diamond') {
    const s = t.size;
    shape = `<polygon class="bpmn-node-shape" points="${n.x},${n.y-s} ${n.x+s},${n.y} ${n.x},${n.y+s} ${n.x-s},${n.y}" fill="white" stroke="${t.color}" stroke-width="2"/>
             <text x="${n.x}" y="${n.y + 4}" text-anchor="middle" font-size="18" fill="${t.color}" font-weight="bold">×</text>`;
    labelDy = s + 16;
    portX = n.x + s; portY = n.y;
  }
  
  const labelLines = wrapText(n.label || t.label, t.type === 'event' || t.type === 'diamond' ? 18 : 14);
  const labelY = (t.type === 'rect' || t.type === 'rect-double') ? n.y + 4 - ((labelLines.length - 1) * 7) : n.y + labelDy + ((labelLines.length - 1) * 6);
  const labelFill = (t.type === 'rect' || t.type === 'rect-double') ? '#15110d' : 'var(--ink-muted)';
  
  return `<g class="bpmn-node ${isSel ? 'selected' : ''}" data-id="${n.id}"
    onmousedown="bpmnStartDrag(event, '${pid}', '${n.id}')"
    onclick="event.stopPropagation(); bpmnSelectNode('${pid}', '${n.id}')"
    ondblclick="event.stopPropagation(); bpmnRenameNode('${pid}', '${n.id}')">
    ${shape}
    ${labelLines.map((l, i) => `<text x="${n.x}" y="${labelY + i * 14}" text-anchor="middle" fill="${labelFill}">${escapeHtml(l)}</text>`).join('')}
    <circle class="bpmn-port" cx="${portX}" cy="${portY}" r="6"
      onmousedown="event.stopPropagation(); bpmnStartConnection(event, '${pid}', '${n.id}')"/>
  </g>`;
}

function wrapText(text, maxChars) {
  if (!text) return [''];
  const words = text.split(' ');
  const lines = []; let cur = '';
  for (const w of words) {
    if ((cur + ' ' + w).trim().length <= maxChars) cur = (cur + ' ' + w).trim();
    else { if (cur) lines.push(cur); cur = w; }
  }
  if (cur) lines.push(cur);
  return lines.slice(0, 3);
}

function getNodeRightAnchor(node) {
  const t = BPMN_NODE_TYPES[node.type];
  if (t.type === 'event') return { x: node.x + t.radius, y: node.y };
  if (t.type === 'rect' || t.type === 'rect-double') return { x: node.x + t.width/2, y: node.y };
  if (t.type === 'diamond') return { x: node.x + t.size, y: node.y };
  return { x: node.x, y: node.y };
}
function getNodeLeftAnchor(node) {
  const t = BPMN_NODE_TYPES[node.type];
  if (t.type === 'event') return { x: node.x - t.radius, y: node.y };
  if (t.type === 'rect' || t.type === 'rect-double') return { x: node.x - t.width/2, y: node.y };
  if (t.type === 'diamond') return { x: node.x - t.size, y: node.y };
  return { x: node.x, y: node.y };
}

function renderBPMNConnection(pid, c, nodes) {
  const from = nodes.find(n => n.id === c.from);
  const to = nodes.find(n => n.id === c.to);
  if (!from || !to) return '';
  const a = getNodeRightAnchor(from);
  const b = getNodeLeftAnchor(to);
  const dx = (b.x - a.x) / 2;
  const path = `M ${a.x} ${a.y} C ${a.x + dx} ${a.y}, ${b.x - dx} ${b.y}, ${b.x} ${b.y}`;
  const isSel = bpmnSelected && bpmnSelected.kind === 'conn' && bpmnSelected.id === c.id;
  const labelX = (a.x + b.x) / 2;
  const labelY = (a.y + b.y) / 2 - 6;
  return `<g>
    <path class="bpmn-conn-hover" d="${path}" onclick="event.stopPropagation(); bpmnSelectConn('${pid}', '${c.id}')" ondblclick="event.stopPropagation(); bpmnRenameConnection('${pid}', '${c.id}')"/>
    <path class="bpmn-conn ${isSel ? 'selected' : ''}" d="${path}" marker-end="url(#bpmn-${isSel ? 'arrow-sel' : 'arrow'})"/>
    ${c.label ? `<rect x="${labelX - c.label.length * 3.2 - 4}" y="${labelY - 11}" width="${c.label.length * 6.4 + 8}" height="16" rx="3" fill="white" stroke="var(--line)" stroke-width="1"/><text x="${labelX}" y="${labelY + 1}" text-anchor="middle" font-size="11" fill="var(--ink)">${escapeHtml(c.label)}</text>` : ''}
  </g>`;
}

