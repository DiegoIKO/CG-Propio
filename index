    const q = quads.find(x => x.key === qk);
    const its = items.filter(x => x.quadrant === qk);
    gridHTML += `<div style="background: ${q.bg}; border: 2px solid ${q.border}; border-radius: 8px; padding: 14px; min-height: 240px">
      <div style="font-family: 'Instrument Serif', serif; font-size: 17px; font-weight: 600">${q.label}</div>
