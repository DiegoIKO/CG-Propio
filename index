function _printAnalysisShell(title, contentHTML) {
  return printContent({ title, htmlContent: contentHTML });
}

function printIshikawa(id) {
  const a = state.analyses.find(x => x.id === id);
  if (!a) return;
  
  // SVG espina de pescado horizontal
  const w = 1100, h = 580;
  const cx = w - 220, cy = h / 2;  // cabeza
  const tail = 60;  // cola izquierda
  const branches = [];
  
  // Distribución: 3 arriba, 3 abajo
  ISHIKAWA_CATS.forEach((cat, i) => {
    const isTop = i < 3;
    const xPos = tail + 100 + (i % 3) * 280;
    const yPos = isTop ? cy - 200 : cy + 200;
    const ySpine = cy;
    branches.push({ cat, x: xPos, y: yPos, ySpine, isTop, causes: (a.causes && a.causes[cat]) || [] });
  });
  
  // Generar SVG
  let svg = `<svg viewBox="0 0 ${w} ${h}" width="100%" style="max-width: 1100px; background: #fdfaf3; border: 1px solid #d8d2c4; border-radius: 8px">
    <defs>
      <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#15110d"/>
      </marker>
    </defs>
    <!-- Espina principal -->
    <line x1="${tail}" y1="${cy}" x2="${cx}" y2="${cy}" stroke="#15110d" stroke-width="3" marker-end="url(#arrow)"/>
    <!-- Cabeza con problema -->
    <rect x="${cx + 10}" y="${cy - 50}" width="200" height="100" rx="50" fill="#15110d"/>
    <foreignObject x="${cx + 20}" y="${cy - 45}" width="180" height="90">
      <div xmlns="http://www.w3.org/1999/xhtml" style="color: white; font-family: 'Instrument Serif', serif; font-size: 13px; text-align: center; display: flex; align-items: center; justify-content: center; height: 100%; padding: 4px; line-height: 1.3">
        ${escapeHtml(a.problem)}
      </div>
    </foreignObject>`;
  
  // Ramas (cada categoría)
  const colors = ['#3d5a80', '#a83e3e', '#4a7c4a', '#c89d2c', '#7d5b8e', '#a08570'];
  branches.forEach((b, i) => {
    const color = colors[i % colors.length];
    // Rama diagonal hacia la espina
    svg += `<line x1="${b.x}" y1="${b.y}" x2="${b.x + 100}" y2="${b.ySpine}" stroke="${color}" stroke-width="2.5"/>`;
    // Etiqueta de categoría
    svg += `<rect x="${b.x - 80}" y="${b.y - 14}" width="160" height="28" rx="14" fill="${color}"/>`;
    svg += `<text x="${b.x}" y="${b.y + 5}" fill="white" font-family="IBM Plex Sans, sans-serif" font-size="13" font-weight="600" text-anchor="middle">${escapeHtml(b.cat)}</text>`;
    // Causas debajo/arriba de la rama
    const visibleCauses = b.causes.slice(0, 5);
    visibleCauses.forEach((cause, ci) => {
      const offset = (ci + 1) * 22;
      const cy2 = b.isTop ? b.y - 14 - offset : b.y + 14 + offset;
      svg += `<text x="${b.x}" y="${cy2}" fill="#15110d" font-family="IBM Plex Sans, sans-serif" font-size="10.5" text-anchor="middle">• ${escapeHtml(cause.length > 30 ? cause.slice(0, 30) + '…' : cause)}</text>`;
    });
    if (b.causes.length > 5) {
      const cy2 = b.isTop ? b.y - 14 - 6 * 22 : b.y + 14 + 6 * 22;
      svg += `<text x="${b.x}" y="${cy2}" fill="#6b6357" font-family="IBM Plex Sans, sans-serif" font-size="10" text-anchor="middle" font-style="italic">+${b.causes.length - 5} más</text>`;
    }
  });
  
  svg += '</svg>';
  
  // Tabla de causas como soporte
  const tableHTML = `<table style="width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 12px">
    <thead><tr style="background: #f0ebe0">
      ${ISHIKAWA_CATS.map(c => `<th style="border: 1px solid #d8d2c4; padding: 8px; text-align: left; font-weight: 600">${escapeHtml(c)}</th>`).join('')}
    </tr></thead>
    <tbody><tr>
      ${ISHIKAWA_CATS.map(c => `<td style="border: 1px solid #d8d2c4; padding: 8px; vertical-align: top">${((a.causes && a.causes[c]) || []).map(x => `<div style="margin-bottom: 4px">• ${escapeHtml(x)}</div>`).join('') || '<span style="color: #b8ad99; font-style: italic">—</span>'}</td>`).join('')}
    </tr></tbody>
  </table>`;
  
  const content = `
    <div style="text-align: center; margin-bottom: 16px">
      <div style="font-family: 'Instrument Serif', serif; font-size: 22px; margin-bottom: 4px">${escapeHtml(a.problem)}</div>
      <div style="font-size: 11px; color: #6b6357; font-style: italic">Diagrama de Ishikawa · Análisis de causa raíz por categorías (6M)</div>
    </div>
    <div style="text-align: center">${svg}</div>
    <h3 style="font-family: 'Instrument Serif', serif; margin-top: 24px; font-size: 18px">Detalle de causas identificadas por categoría</h3>
    ${tableHTML}
  `;
  
  _printAnalysisShell('Análisis Ishikawa', content);
}

