.kpi-zoom-mini-stat .value { font-family: 'JetBrains Mono', monospace; font-size: 16px; font-weight: 600; }
.kpi-zoom-history { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 10px; padding: 18px; margin-top: 16px; }
