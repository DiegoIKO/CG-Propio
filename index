      <div>${field('Etiquetas (separadas por coma)', inputField('f-t-tags', (t?.tags || []).join(', '), 'text', 'urgente, revisión'))}</div>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>${field('Proyecto (opcional)', `<select class="select" id="f-t-project" onchange="updateTaskFormStages(this.value)">
        <option value="">— Sin proyecto —</option>
        ${state.projects.map(p => `<option value="${p.id}" ${p.id === initialProjectId ? 'selected' : ''}>${escapeHtml(p.code + ' · ' + p.name)}</option>`).join('')}
      </select>`)}</div>
      <div>${field('Etapa del proyecto (opcional)', `<select class="select" id="f-t-stage" ${!initialProjectId ? 'disabled' : ''}>
        <option value="">— Sin etapa —</option>
        ${stagesOfProject.map(s => `<option value="${s.id}" ${s.id === initialStageId ? 'selected' : ''}>${escapeHtml(s.name)}</option>`).join('')}
      </select>`)}</div>
    </div>
    <div class="text-xs p-2 rounded" style="background:var(--bg-sunken); color:var(--ink-muted); line-height: 1.5">
      <strong>Avance automático:</strong> el progreso de esta tarea contribuye al avance de su etapa (si tiene) y al avance del proyecto. Si marcas la tarea como "Completada", se considera 100% sin importar el slider.
    </div>
  </div>`;
  openModal({ title: isEdit ? 'Editar tarea' : 'Nueva tarea', body, footer: `<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-save-t">${isEdit ? 'Guardar' : 'Crear'}</button>`, width: 'wide' });
