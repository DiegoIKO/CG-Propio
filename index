/* ==================== TAREAS (Administrador) ==================== */
let tareasTab = 'lista'; // lista | tablero
let tareasFilter = { q: '', status: '', assignee: '', priority: '', tag: '', project: '' };
let tareasSort = { key: 'dueDate', dir: 'asc' }; // key: code|title|status|priority|assignee|dueDate|progress|project, dir: asc|desc

const TASK_STATUSES = [
  { key: 'todo', label: 'Por hacer', color: 'gray' },
  { key: 'inProgress', label: 'En curso', color: 'blue' },
  { key: 'review', label: 'En revisión', color: 'yellow' },
  { key: 'done', label: 'Completada', color: 'green' }
];
const TASK_PRIORITIES = [
  { key: 'urgente', label: 'Urgente', color: 'red' },
  { key: 'alta', label: 'Alta', color: 'warm' },
  { key: 'media', label: 'Media', color: 'yellow' },
  { key: 'baja', label: 'Baja', color: 'gray' }
];

function ensureTasks() { if (!state.tasks) state.tasks = []; return state.tasks; }
function priorityColor(p) { const obj = TASK_PRIORITIES.find(x => x.key === p); return obj ? `var(--${obj.color})` : 'var(--ink-subtle)'; }
function statusObj(s) { return TASK_STATUSES.find(x => x.key === s) || TASK_STATUSES[0]; }
function priorityObj(p) { return TASK_PRIORITIES.find(x => x.key === p) || TASK_PRIORITIES[2]; }
function getAllTaskTags() {
  const set = new Set();
  ensureTasks().forEach(t => (t.tags || []).forEach(tag => set.add(tag)));
  return Array.from(set).sort();
}
function getAllAssignees() {
  const set = new Set();
  ensureTasks().forEach(t => { if (t.assignee) set.add(t.assignee); });
  state.people.forEach(p => set.add(p.name));
  return Array.from(set).sort();
}

function applyTaskFilter(tasks) {
  const f = tareasFilter;
  return tasks.filter(t => {
    if (f.status && t.status !== f.status) return false;
    if (f.assignee && t.assignee !== f.assignee) return false;
    if (f.priority && t.priority !== f.priority) return false;
    if (f.tag && !(t.tags || []).includes(f.tag)) return false;
    if (f.project === '__none__' && t.projectId) return false;
    if (f.project && f.project !== '__none__' && t.projectId !== f.project) return false;
    if (f.q) {
      const q = f.q.toLowerCase();
      const blob = (t.code + ' ' + t.title + ' ' + (t.description || '') + ' ' + (t.tags || []).join(' ') + ' ' + (t.assignee || '')).toLowerCase();
      if (!blob.includes(q)) return false;
    }
    return true;
  });
}

// Aplica filtros excepto uno específico (para cálculo jerárquico)
function applyTaskFilterExcept(tasks, excludeKey) {
  const f = tareasFilter;
  return tasks.filter(t => {
    if (excludeKey !== 'status' && f.status && t.status !== f.status) return false;
    if (excludeKey !== 'assignee' && f.assignee && t.assignee !== f.assignee) return false;
    if (excludeKey !== 'priority' && f.priority && t.priority !== f.priority) return false;
    if (excludeKey !== 'tag' && f.tag && !(t.tags || []).includes(f.tag)) return false;
    if (excludeKey !== 'project') {
      if (f.project === '__none__' && t.projectId) return false;
      if (f.project && f.project !== '__none__' && t.projectId !== f.project) return false;
    }
    if (f.q) {
      const q = f.q.toLowerCase();
      const blob = (t.code + ' ' + t.title + ' ' + (t.description || '') + ' ' + (t.tags || []).join(' ') + ' ' + (t.assignee || '')).toLowerCase();
      if (!blob.includes(q)) return false;
    }
    return true;
  });
}

function renderTareas() {
  ensureTasks();
  const tasks = state.tasks;
  const counts = TASK_STATUSES.reduce((acc, s) => { acc[s.key] = tasks.filter(t => t.status === s.key).length; return acc; }, {});
  const overdueCount = tasks.filter(t => t.dueDate && new Date(t.dueDate) < new Date() && t.status !== 'done').length;
  const actions = `${printBtn('printTareas', 'Imprimir listado de tareas')}<button class="btn btn-primary" onclick="openTaskForm()">+ Nueva tarea</button>`;
  const tabs = `<div class="flex gap-2 px-6 py-3 border-b" style="border-color:var(--line); background:var(--bg)">
    <div class="pill-tab ${tareasTab === 'lista' ? 'active' : ''}" onclick="setTareasTab('lista')">Lista</div>
    <div class="pill-tab ${tareasTab === 'tablero' ? 'active' : ''}" onclick="setTareasTab('tablero')">Tablero</div>
  </div>`;
  const filters = renderTaskFilters();
  const body = tareasTab === 'lista' ? renderTasksList() : renderTasksBoard();
  document.getElementById('main-content').innerHTML = `${headerHTML('Tareas', `${tasks.length} tareas · ${counts.todo + counts.inProgress + counts.review} activas · ${overdueCount} vencidas`, actions)}${tabs}<div class="p-6 space-y-4">${filters}${body}</div>`;
