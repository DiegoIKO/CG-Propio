.stage-header .stage-status-badge.pending { background: var(--bg-sunken); color: var(--ink-muted); }
.stage-header .stage-status-badge.inProgress { background: rgba(61, 90, 128, 0.15); color: var(--blue); }
.stage-header .stage-status-badge.completed { background: rgba(74, 124, 74, 0.15); color: var(--green); }
.stage-header .stage-status-badge.overdue { background: rgba(168, 62, 62, 0.15); color: var(--red); }
.stage-header .stage-weight { font-size: 10px; color: var(--ink-subtle); font-family: 'JetBrains Mono', monospace; flex-shrink: 0; }
.stage-header .stage-progress-mini { width: 100px; flex-shrink: 0; display: flex; align-items: center; gap: 8px; }
.stage-header .stage-progress-mini .bar { flex: 1; height: 6px; background: var(--bg-sunken); border-radius: 3px; overflow: hidden; }
.stage-header .stage-progress-mini .fill { height: 100%; background: var(--ink); }
.stage-header .stage-progress-mini .pct { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted); min-width: 30px; text-align: right; }
.stage-header .stage-actions { display: flex; gap: 4px; flex-shrink: 0; opacity: 0; transition: opacity .15s; }
.stage-card:hover .stage-header .stage-actions { opacity: 1; }
.stage-body { padding: 12px 16px 16px; background: var(--bg); border-top: 1px solid var(--line); }
.stage-body .stage-desc { font-size: 12.5px; color: var(--ink-muted); line-height: 1.5; margin-bottom: 12px; padding: 8px 12px; background: var(--bg-elevated); border-radius: 6px; font-style: italic; }
.stage-body .stage-tasks-title { font-size: 10px; text-transform: uppercase; letter-spacing: .07em; color: var(--ink-muted); font-weight: 600; margin-bottom: 8px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
.stage-body .stage-tasks-list { display: flex; flex-direction: column; gap: 4px; }
.stage-task-row { display: flex; align-items: center; gap: 10px; padding: 7px 10px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; font-size: 12.5px; cursor: pointer; transition: all .12s; }
.stage-task-row:hover { background: var(--bg); border-color: var(--line-strong); }
.stage-task-row .task-status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.stage-task-row .task-status-dot.todo { background: var(--ink-subtle); }
.stage-task-row .task-status-dot.inProgress { background: var(--blue); }
