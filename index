  const footer = `<button class="btn btn-secondary" onclick="resetDashboardConfig()">Restaurar por defecto</button><button class="btn btn-primary" data-action="close-modal">Cerrar y ver dashboard</button>`;
  openModal({ title: 'Personalizar dashboard de Inicio', body, footer, width: 'wide' });
}

function renderDashBlockConfig(key, active, idx, total) {
  const b = DASHBOARD_BLOCKS[key]; if (!b) return '';
  if (active) {
    return `<div class="dash-block-config">
      <div class="order-controls">
        <button onclick="moveDashBlock('${key}', -1)" ${idx === 0 ? 'disabled' : ''} title="Subir">↑</button>
        <button onclick="moveDashBlock('${key}', 1)" ${idx === total - 1 ? 'disabled' : ''} title="Bajar">↓</button>
      </div>
      <div class="flex-1">
        <div class="dash-block-config-name">${escapeHtml(b.name)}</div>
        <div class="dash-block-config-desc">${escapeHtml(b.desc)}</div>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="toggleDashBlock('${key}')">Ocultar</button>
    </div>`;
  } else {
    return `<div class="dash-block-config disabled">
      <div class="flex-1">
        <div class="dash-block-config-name">${escapeHtml(b.name)}</div>
        <div class="dash-block-config-desc">${escapeHtml(b.desc)}</div>
      </div>
      <button class="btn btn-primary btn-sm" onclick="toggleDashBlock('${key}')">+ Activar</button>
    </div>`;
  }
}

function moveDashBlock(key, dir) {
  const cfg = getDashboardConfig();
  const idx = cfg.indexOf(key);
  if (idx === -1) return;
  const newIdx = idx + dir;
  if (newIdx < 0 || newIdx >= cfg.length) return;
  [cfg[idx], cfg[newIdx]] = [cfg[newIdx], cfg[idx]];
  save();
  openDashboardConfig();
}

function toggleDashBlock(key) {
  const cfg = getDashboardConfig();
  const idx = cfg.indexOf(key);
  if (idx === -1) cfg.push(key);
  else cfg.splice(idx, 1);
  save();
  openDashboardConfig();
}

function resetDashboardConfig() {
  if (!confirm('¿Restaurar la configuración por defecto del dashboard?')) return;
  state.meta.dashboardConfig = [...DEFAULT_DASHBOARD_CONFIG];
  save();
  openDashboardConfig();
  toast('Configuración restaurada');
}

function generateAlerts() {
  const alerts = [];
  state.kpis.forEach(k => {
    const s = kpiStatus(k);
    if (s === 'red') alerts.push({ level: 'red', title: `${k.code}: ${k.name}`, detail: `Indicador en zona crítica` });
    else if (s === 'yellow') alerts.push({ level: 'yellow', title: `${k.code}: ${k.name}`, detail: `Indicador en alerta` });
  });
  state.risks.filter(r => r.probability * r.impact >= 20).forEach(r => alerts.push({ level: 'red', title: `Riesgo extremo: ${r.code}`, detail: r.name }));
  state.findings.filter(f => f.status !== 'Cerrado' && f.dueDate && new Date(f.dueDate) < new Date()).forEach(f => alerts.push({ level: 'red', title: `Hallazgo vencido: ${f.code}`, detail: `Plazo: ${fmtDate(f.dueDate)}` }));
  state.commitments.filter(c => c.status !== 'Cumplido' && c.dueDate && new Date(c.dueDate) < new Date()).forEach(c => alerts.push({ level: 'red', title: `Compromiso vencido: ${c.code}`, detail: c.name }));
  (state.tasks || []).filter(t => t.status !== 'done' && t.dueDate && new Date(t.dueDate) < new Date() && (t.priority === 'urgente' || t.priority === 'alta')).forEach(t => alerts.push({ level: 'red', title: `Tarea vencida: ${t.code}`, detail: t.title }));
  state.milestones.filter(m => m.status !== 'Cumplido' && m.dueDate && new Date(m.dueDate) < new Date()).forEach(m => alerts.push({ level: 'yellow', title: `Hito vencido: ${m.code}`, detail: m.name }));
  return alerts.slice(0, 12);
}

