  }
  
  // Modo árbol normal
  function nodes(parentId, depth = 0) {
    return state.wikiPages.filter(p => p.parentId === parentId).map(p => {
      const children = state.wikiPages.filter(c => c.parentId === p.id);
      return `<div>
        <div class="tree-node ${wikiSelectedId === p.id ? 'selected' : ''}" onclick="selectWiki('${p.id}')" style="padding-left: ${10 + depth * 12}px">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
