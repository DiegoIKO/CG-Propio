function renderProjectsTimeline() {
  const filtered = applyProjectFilter(state.projects).filter(p => p.startDate || p.dueDate);
  
  if (state.projects.length === 0) {
    return `<div class="card p-8 text-center"><div class="text-sm" style="color:var(--ink-muted)">No hay proyectos para mostrar en timeline</div></div>`;
  }
  if (filtered.length === 0) {
    return `<div class="card p-8 text-center"><div class="text-sm" style="color:var(--ink-muted)">Ningún proyecto coincide con los filtros, o ninguno tiene fechas configuradas. Edita un proyecto para agregar fechas.</div></div>`;
  }
  
  // Calcular rango temporal global
  const allDates = [];
  filtered.forEach(p => {
    if (p.startDate) allDates.push(new Date(p.startDate));
    if (p.dueDate) allDates.push(new Date(p.dueDate));
    (p.stages || []).forEach(s => {
      if (s.startDate) allDates.push(new Date(s.startDate));
      if (s.dueDate) allDates.push(new Date(s.dueDate));
    });
  });
  if (allDates.length === 0) return '<div class="card p-8 text-center">Sin fechas disponibles</div>';
  
  const minDate = new Date(Math.min(...allDates));
  const maxDate = new Date(Math.max(...allDates));
  // Redondear a inicio de mes y fin de mes
  const rangeStart = new Date(minDate.getFullYear(), minDate.getMonth(), 1);
  const rangeEnd = new Date(maxDate.getFullYear(), maxDate.getMonth() + 1, 0);
  const totalDays = Math.ceil((rangeEnd - rangeStart) / (1000 * 60 * 60 * 24)) + 1;
  
  // Generar columnas de meses
  const months = [];
  let cur = new Date(rangeStart);
  while (cur <= rangeEnd) {
    months.push({
      label: cur.toLocaleDateString('es-CL', { month: 'short', year: '2-digit' }),
      year: cur.getFullYear(),
      month: cur.getMonth()
    });
    cur = new Date(cur.getFullYear(), cur.getMonth() + 1, 1);
  }
  
  const dayToPercent = (date) => {
    const days = (new Date(date) - rangeStart) / (1000 * 60 * 60 * 24);
    return (days / totalDays) * 100;
  };
  
  const today = new Date();
  const todayInRange = today >= rangeStart && today <= rangeEnd;
  const todayPct = todayInRange ? dayToPercent(today) : null;
  
  // Construir filas: cada proyecto + sus etapas debajo
  let rows = '';
  filtered.forEach(p => {
    syncProjectProgress(p);
    const pStart = p.startDate ? new Date(p.startDate) : null;
    const pEnd = p.dueDate ? new Date(p.dueDate) : null;
    const overdue = p.dueDate && new Date(p.dueDate) < today && p.status !== 'done';
    const barClass = p.status === 'done' ? 'completed' : overdue ? 'overdue' : p.status === 'backlog' ? 'pending' : '';
    
    let bar = '';
    if (pStart && pEnd) {
      const left = dayToPercent(pStart);
      const width = dayToPercent(pEnd) - left;
      bar = `<div class="gantt-bar ${barClass}" style="left: ${left}%; width: ${Math.max(width, 1)}%" onclick="openProjectDetail('${p.id}')" title="${escapeHtml(p.name)} · ${p.progress || 0}%">
        <div class="gantt-bar-fill" style="width: ${p.progress || 0}%"></div>
        <span class="gantt-bar-text">${escapeHtml(p.code)} · ${p.progress || 0}%</span>
      </div>`;
    }
    
    rows += `<div class="gantt-row" style="--gantt-months: ${months.length}">
      <div class="gantt-side" onclick="openProjectDetail('${p.id}')">
        <span class="name"><strong>${escapeHtml(p.code)}</strong> · ${escapeHtml(p.name)}</span>
        <span class="pct">${p.progress || 0}%</span>
      </div>
      <div class="gantt-timeline">
        ${bar}
        ${todayPct !== null ? `<div class="gantt-today-line" style="left: ${todayPct}%"></div>` : ''}
      </div>
    </div>`;
    
    // Sub-filas de etapas si hay
    (p.stages || []).forEach((stage, sIdx) => {
      if (!stage.startDate || !stage.dueDate) return;
      const stageTasks = getStageTasks(p.id, stage.id);
      const stageStatus = computeStageStatus(stage, stageTasks);
      const stageProgress = computeStageProgress(stage, stageTasks);
      const sLeft = dayToPercent(stage.startDate);
      const sWidth = dayToPercent(stage.dueDate) - sLeft;
      const sBarClass = stageStatus === 'completed' ? 'completed' : stageStatus === 'overdue' ? 'overdue' : stageStatus === 'pending' ? 'pending' : '';
      
      rows += `<div class="gantt-row" style="--gantt-months: ${months.length}; background: rgba(0,0,0,0.015)">
        <div class="gantt-side" onclick="openProjectDetail('${p.id}')" style="padding-left: 32px">
          <span class="name" style="font-size: 12px; color: var(--ink-muted)">└ ${escapeHtml(stage.name)}</span>
          <span class="pct">${stageProgress}%</span>
        </div>
        <div class="gantt-timeline">
          <div class="gantt-bar ${sBarClass}" style="left: ${sLeft}%; width: ${Math.max(sWidth, 1)}%; height: 18px; top: 13px; font-size: 10px; opacity: 0.85" onclick="openProjectDetail('${p.id}')" title="${escapeHtml(stage.name)} · ${stageProgress}%">
            <div class="gantt-bar-fill" style="width: ${stageProgress}%"></div>
            <span class="gantt-bar-text">${escapeHtml(stage.name)}</span>
          </div>
          ${todayPct !== null ? `<div class="gantt-today-line" style="left: ${todayPct}%"></div>` : ''}
        </div>
      </div>`;
    });
  });
  
  return `<div class="gantt-container">
    <div class="gantt-scroll">
      <div class="gantt-header" style="--gantt-months: ${months.length}">
        <div class="gantt-side">Proyecto / Etapa</div>
        <div class="gantt-timeline">
          ${months.map(m => `<div class="gantt-month">${m.label}</div>`).join('')}
        </div>
      </div>
      ${rows}
    </div>
  </div>
  <div class="text-xs mt-2" style="color:var(--ink-muted); padding: 0 4px">
    <strong>Leyenda:</strong> Barras azules = en curso · verdes = completadas · rojas = vencidas · grises = pendientes / backlog. Línea roja vertical = hoy. Clic en cualquier barra o nombre para abrir el proyecto.
  </div>`;
}

function duplicateProject(id) {
  const p = state.projects.find(x => x.id === id);
  if (!p) return;
  const copy = JSON.parse(JSON.stringify(p));
  copy.id = uid();
  copy.code = 'P-' + String(state.projects.length + 1).padStart(3, '0');
  copy.name = p.name + ' (copia)';
  state.projects.push(copy);
  save();
  renderProyectos();
  toast('Proyecto duplicado');
}

function deleteProject(id) {
  if (!confirm('¿Eliminar este proyecto? Las tareas vinculadas quedarán sin proyecto.')) return;
  state.projects = state.projects.filter(p => p.id !== id);
  // Desvincular tareas
  state.tasks.forEach(t => { if (t.projectId === id) { t.projectId = null; t.stageId = null; } });
  save();
  selectedProjectId = null;
  renderProyectos();
  toast('Proyecto eliminado');
}

