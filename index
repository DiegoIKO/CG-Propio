  openModal({ title: t.title, body, footer, width: 'wide' });
}

function addSubtaskPrompt(taskId) {
  const t = state.tasks.find(x => x.id === taskId); if (!t) return;
  const title = prompt('Título de la subtarea:');
  if (!title || !title.trim()) return;
  if (!t.subtasks) t.subtasks = [];
  t.subtasks.push({ id: uid(), title: title.trim(), done: false });
  save();
  openTaskDetail(taskId); // re-abrir el modal
}
function toggleSubtask(taskId, subId) {
  const t = state.tasks.find(x => x.id === taskId); if (!t) return;
  const s = t.subtasks.find(x => x.id === subId); if (!s) return;
  s.done = !s.done; save();
  openTaskDetail(taskId);
}
function removeSubtask(taskId, subId) {
  const t = state.tasks.find(x => x.id === taskId); if (!t) return;
  t.subtasks = t.subtasks.filter(s => s.id !== subId); save();
  openTaskDetail(taskId);
}

function duplicateTask(id) {
  const t = state.tasks.find(x => x.id === id); if (!t) return;
  const copy = JSON.parse(JSON.stringify(t));
  copy.id = uid();
  copy.code = 'T-' + String(state.tasks.length + 1).padStart(3, '0');
  copy.title = t.title + ' (copia)';
  copy.status = 'todo';
  if (copy.subtasks) copy.subtasks = copy.subtasks.map(s => ({ ...s, id: uid(), done: false }));
  state.tasks.push(copy);
  save(); renderTareas(); toast('Tarea duplicada');
}

function deleteTask(id) {
  if (!confirm('¿Eliminar esta tarea?')) return;
  state.tasks = state.tasks.filter(t => t.id !== id);
  save(); renderTareas(); toast('Tarea eliminada');
}

function goToTask(id) { navigate('tareas'); setTimeout(() => openTaskDetail(id), 100); }

/* ==================== IMPRESIÓN OPTIMIZADA POR MÓDULO ==================== */

// Función central robusta para imprimir cualquier contenido
function printContent(opts) {
  // opts: { title, htmlContent, showHeader (default true), withInstitution (default true) }
  const title = opts.title || 'Documento';
  const htmlContent = opts.htmlContent || '';
  const showHeader = opts.showHeader !== false;
  
  // Quitar print area previa si quedó
  document.querySelectorAll('#print-module-area, #print-module-style').forEach(el => el.remove());
  
  const printArea = document.createElement('div');
  printArea.id = 'print-module-area';
  
  const instName = (state.meta.institution || '').trim();
  const headerHTML = showHeader ? `<div class="report-preview"><div class="print-page-header" style="display:flex; align-items:flex-start; gap: 24px; border-bottom: 2px solid #15110d; padding-bottom: 12px; margin-bottom: 20px">
    <div style="flex: 1">
      <h1 style="font-family: 'Instrument Serif', serif; font-size: 26px; margin: 0; line-height: 1.1">${escapeHtml(title)}</h1>
      ${instName ? `<div style="font-size: 12px; color: #6b6357; margin-top: 4px">${escapeHtml(instName)}</div>` : ''}
    </div>
    <div class="meta" style="text-align: right; font-size: 11px; color: #6b6357; flex-shrink: 0">Documento generado<br>${fmtDate(new Date().toISOString())}</div>
  </div>${htmlContent}</div>` : htmlContent;
  
  printArea.innerHTML = headerHTML;
  document.body.appendChild(printArea);
  
  // CSS dinámico que oculta todo lo demás
  const style = document.createElement('style');
  style.id = 'print-module-style';
  style.textContent = `@media print {
    @page { size: A4; margin: 12mm; }
    html, body { background: white !important; height: auto !important; overflow: visible !important; }
    body * { visibility: hidden !important; }
    #print-module-area, #print-module-area * { visibility: visible !important; }
    #print-module-area { position: absolute !important; left: 0; top: 0; width: 100%; padding: 0; background: white !important; }
    #print-module-area svg, #print-module-area img { max-width: 100%; height: auto; }
    .no-print, .modal-overlay, .toast-container, .sidebar, .header, .header-actions, .kpi-zoom-overlay, .chart-zoom-overlay, .pivot-zoom-overlay, button { display: none !important; visibility: hidden !important; }
    /* Evitar scrollbars visibles */
    ::-webkit-scrollbar { display: none !important; }
    * { -ms-overflow-style: none !important; scrollbar-width: none !important; }
  }`;
  document.head.appendChild(style);
  
  setTimeout(() => {
    window.print();
    setTimeout(() => {
      printArea.remove();
      style.remove();
    }, 500);
  }, 150);
}

function printModule(htmlContent, title) {
  return printContent({ title, htmlContent });
}

function printRiesgos() {
  const sorted = [...state.risks].sort((a, b) => (b.residualProb * b.residualImpact) - (a.residualProb * a.residualImpact));
  const summary = repSummary(`Total: <strong>${state.risks.length}</strong> riesgos · <strong>${state.risks.filter(r => r.probability * r.impact >= 15).length}</strong> críticos (P×I ≥ 15) · <strong>${state.risks.filter(r => { const s = r.probability * r.impact; return s >= 8 && s < 15; }).length}</strong> moderados · <strong>${state.risks.filter(r => r.probability * r.impact < 8).length}</strong> bajos`);
  const html = `${summary}<h2>Matriz de Riesgos (ordenada por criticidad residual)</h2>${repTable(['Código', 'Riesgo', 'Categoría', 'Inherente', 'Residual', 'Tratamiento', 'Responsable', 'Estado'], sorted.map(r => {
    const inh = r.probability * r.impact;
    const res = r.residualProb * r.residualImpact;
    return [
      `<strong>${escapeHtml(r.code)}</strong>`,
      escapeHtml(r.name),
      escapeHtml(r.category),
      `${inh} ${repTag(inh >= 15 ? 'Alto' : inh >= 8 ? 'Med' : 'Bajo', inh >= 15 ? 'red' : inh >= 8 ? 'yellow' : 'green')}`,
      `${res} ${repTag(res >= 15 ? 'Alto' : res >= 8 ? 'Med' : 'Bajo', res >= 15 ? 'red' : res >= 8 ? 'yellow' : 'green')}`,
      escapeHtml(r.treatment),
      escapeHtml(r.owner || '—'),
      escapeHtml(r.status)
    ];
  }))}`;
  printModule(html, 'Matriz de Riesgos');
}

