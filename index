    }).join('');
  }
  return nodes(null) || '<div class="text-sm text-center py-4" style="color:var(--ink-muted)">Sin páginas</div>';
}

function selectWiki(id) { wikiSelectedId = id; wikiSearchQuery = ''; renderDocumental(); }

function extractWikiTOC(md) {
  const lines = (md || '').split('\n');
  const toc = [];
  lines.forEach((line, i) => {
    const m1 = line.match(/^# (.+)$/);
    const m2 = line.match(/^## (.+)$/);
    const m3 = line.match(/^### (.+)$/);
    if (m1) toc.push({ level: 1, text: m1[1], idx: i });
    else if (m2) toc.push({ level: 2, text: m2[1], idx: i });
    else if (m3) toc.push({ level: 3, text: m3[1], idx: i });
  });
  return toc;
}

function slugify(s) {
  return s.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').slice(0, 40);
}

