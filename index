const renderProyectosDebounced = debounce(renderProyectos, 220);

function sortProjects(projects) {
  const { key, dir } = proyectosSort;
  const mult = dir === 'asc' ? 1 : -1;
  return [...projects].sort((a, b) => {
    let va = a[key], vb = b[key];
    if (key === 'priority') {
      const ord = { alta: 0, media: 1, baja: 2 };
      va = ord[va] ?? 99; vb = ord[vb] ?? 99;
    }
    if (key === 'status') {
      const ord = { backlog: 0, inProgress: 1, review: 2, done: 3 };
      va = ord[va] ?? 99; vb = ord[vb] ?? 99;
    }
    if (va == null && vb == null) return 0;
    if (va == null) return mult;
    if (vb == null) return -mult;
    if (typeof va === 'number' && typeof vb === 'number') return (va - vb) * mult;
    return String(va).localeCompare(String(vb), 'es-CL', { numeric: true }) * mult;
  });
}

function setProyectosSort(key) {
  if (proyectosSort.key === key) {
    proyectosSort.dir = proyectosSort.dir === 'asc' ? 'desc' : 'asc';
  } else {
    proyectosSort.key = key;
    proyectosSort.dir = 'asc';
  }
  renderProyectos();
}

function proyectoSortHeader(key, label) {
  const active = proyectosSort.key === key;
