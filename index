function downloadReportAsWord(html, filename, title) {
  // Word .doc puede leer HTML perfectamente con este envoltorio MHTML simplificado
  const styles = `<style>
    body { font-family: Calibri, sans-serif; line-height: 1.5; color: #15110d; }
    h1 { font-family: 'Cambria', serif; font-size: 32pt; margin: 0 0 8pt; }
