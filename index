        <div class="bpmn-tool" onclick="addBPMNPhase('${p.id}')"><span class="bpmn-tool-shape"><svg width="24" height="24"><rect x="2" y="2" width="9" height="20" fill="none" stroke="var(--warm)" stroke-width="1.5"/><rect x="13" y="2" width="9" height="20" fill="var(--warm)"/></svg></span>+ Fase</div>
        
