function openDashboardConfig() {
  const cfg = getDashboardConfig();
  const hidden = getDashboardHidden();
  const body = `<div class="space-y-4">
    <div class="text-xs" style="color:var(--ink-muted); line-height: 1.55">Configura qué bloques aparecen en tu dashboard de Inicio y en qué orden. Los cambios se guardan automáticamente. Puedes restaurar la configuración por defecto cuando quieras.</div>
    
    <div>
      <div class="meta-label mb-2">Bloques activos (${cfg.length})</div>
      <div>
        ${cfg.map((key, i) => renderDashBlockConfig(key, true, i, cfg.length)).join('')}
        ${cfg.length === 0 ? '<div class="text-sm text-center py-4" style="color:var(--ink-muted)">Sin bloques activos</div>' : ''}
      </div>
    </div>
    
    ${hidden.length ? `<div>
      <div class="meta-label mb-2">Bloques disponibles para activar (${hidden.length})</div>
      <div>${hidden.map(key => renderDashBlockConfig(key, false)).join('')}</div>
