function renderProjectTaskRow(task, project) {
  const statusKey = task.status || 'todo';
  const titleClass = statusKey === 'done' ? 'done' : '';
  const progress = task.status === 'done' ? 100 : (task.progress || 0);
  return `<div class="stage-task-row" onclick="openTaskForm('${task.id}')" title="Clic para editar">
    <span class="task-status-dot ${statusKey}"></span>
    <span class="task-code">${escapeHtml(task.code || '')}</span>
    <span class="task-title ${titleClass}">${escapeHtml(task.title)}</span>
    ${task.assignee ? `<span class="task-assignee">${escapeHtml(task.assignee)}</span>` : ''}
    <span class="task-progress">${progress}%</span>
  </div>`;
}

/* === Modal: Agregar/Editar etapa === */
function openStageForm(projectId, stageId) {
  const project = state.projects.find(p => p.id === projectId);
  if (!project) return;
  ensureProjectStages(project);
  
  const stage = stageId ? project.stages.find(s => s.id === stageId) : null;
  const isEdit = !!stage;
  
  const body = `<div class="space-y-3">
    <div>${field('Nombre de la etapa', `<input class="input" id="f-stage-name" value="${stage ? escapeHtml(stage.name) : ''}" placeholder="Ej: Diagnóstico inicial">`)}</div>
    <div>${field('Descripción (opcional)', `<textarea class="input" id="f-stage-desc" rows="2" placeholder="Qué se hace en esta etapa...">${stage ? escapeHtml(stage.description || '') : ''}</textarea>`)}</div>
    <div class="grid grid-cols-2 gap-3">
      <div>${field('Fecha inicio', `<input type="date" class="input" id="f-stage-start" value="${stage?.startDate || ''}">`)}</div>
      <div>${field('Fecha término', `<input type="date" class="input" id="f-stage-end" value="${stage?.dueDate || ''}">`)}</div>
    </div>
    <div>${field('Peso (importancia relativa)', `<select class="select" id="f-stage-weight">
      <option value="1" ${(stage?.weight || 1) == 1 ? 'selected' : ''}>1 — Estándar</option>
      <option value="2" ${stage?.weight == 2 ? 'selected' : ''}>2 — Importante (cuenta el doble)</option>
      <option value="3" ${stage?.weight == 3 ? 'selected' : ''}>3 — Muy importante (cuenta el triple)</option>
      <option value="4" ${stage?.weight == 4 ? 'selected' : ''}>4 — Crítica (cuenta cuádruple)</option>
      <option value="5" ${stage?.weight == 5 ? 'selected' : ''}>5 — Esencial (cuenta quíntuple)</option>
    </select>`)}</div>
    <div class="text-xs p-3 rounded" style="background:var(--bg-sunken); color:var(--ink-muted); line-height: 1.55">
      <strong>¿Cómo se calcula el avance?</strong><br>
      El % de avance de la etapa se calcula automáticamente como el promedio del progreso de sus tareas vinculadas. Si una tarea está marcada como "completada", cuenta al 100%.<br>
      El peso determina cuánto influye esta etapa en el avance total del proyecto: una etapa con peso 3 cuenta el triple que una con peso 1.
    </div>
  </div>`;
  
  openModal({
    title: isEdit ? `Editar etapa: ${stage.name}` : 'Nueva etapa',
    body,
    footer: `<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-save-stage">${isEdit ? 'Guardar cambios' : 'Crear etapa'}</button>`
  });
  
  document.getElementById('btn-save-stage').onclick = () => {
    const name = document.getElementById('f-stage-name').value.trim();
    if (!name) { toast('El nombre es obligatorio'); return; }
    const data = {
      name,
      description: document.getElementById('f-stage-desc').value.trim(),
      startDate: document.getElementById('f-stage-start').value || null,
      dueDate: document.getElementById('f-stage-end').value || null,
      weight: parseInt(document.getElementById('f-stage-weight').value) || 1
    };
    
    if (isEdit) {
      Object.assign(stage, data);
    } else {
      project.stages.push({ id: uid(), ...data });
    }
    
    syncProjectProgress(project);
    save();
    closeModal();
    renderProyectos();
    toast(isEdit ? 'Etapa actualizada' : 'Etapa creada');
  };
}

function deleteStage(projectId, stageId) {
  const project = state.projects.find(p => p.id === projectId);
  if (!project) return;
  const stage = project.stages.find(s => s.id === stageId);
  if (!stage) return;
  const stageTasks = getStageTasks(projectId, stageId);
  const msg = stageTasks.length > 0
    ? `¿Eliminar la etapa "${stage.name}"? Sus ${stageTasks.length} tarea(s) quedarán como "sin etapa" pero seguirán vinculadas al proyecto.`
    : `¿Eliminar la etapa "${stage.name}"?`;
  if (!confirm(msg)) return;
  
  // Desvincular tareas de esta etapa
  state.tasks.forEach(t => { if (t.stageId === stageId) t.stageId = null; });
  project.stages = project.stages.filter(s => s.id !== stageId);
  syncProjectProgress(project);
  save();
  renderProyectos();
  toast('Etapa eliminada');
}

function moveStage(projectId, stageId, delta) {
  const project = state.projects.find(p => p.id === projectId);
  if (!project) return;
  const idx = project.stages.findIndex(s => s.id === stageId);
  if (idx === -1) return;
  const newIdx = idx + delta;
  if (newIdx < 0 || newIdx >= project.stages.length) return;
  const [moved] = project.stages.splice(idx, 1);
  project.stages.splice(newIdx, 0, moved);
  save();
  renderProyectos();
}

function openTaskFormForProject(projectId) {
  // Prerellenar el projectId al crear nueva tarea
  window._taskFormPrefill = { projectId, stageId: null };
  openTaskForm();
}

function openTaskFormForStage(projectId, stageId) {
  window._taskFormPrefill = { projectId, stageId };
  openTaskForm();
}

function printProjectDetail() {
  const p = state.projects.find(x => x.id === selectedProjectId);
  if (!p) { toast('No hay proyecto seleccionado'); return; }
  ensureProjectStages(p);
  syncProjectProgress(p);
  
  const statusInfo = PROJECT_STATUSES.find(x => x.key === p.status) || { label: '—' };
  const prio = PROJECT_PRIORITIES.find(x => x.key === p.priority) || { label: '—' };
  const allProjectTasks = state.tasks.filter(t => t.projectId === p.id);
  const tasksDone = allProjectTasks.filter(t => t.status === 'done').length;
  const today = new Date().toISOString().slice(0,10);
  const tasksOverdue = allProjectTasks.filter(t => t.dueDate && t.dueDate < today && t.status !== 'done').length;
  const obj = p.objectiveCode ? state.objectives.find(o => o.code === p.objectiveCode) : null;
  
  const tableStyle = 'width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 12px';
  const cellStyle = 'border: 1px solid #d8d2c4; padding: 8px; text-align: left';
  const thStyle = cellStyle + '; background: #f0ebe0; font-weight: 600';
  
  const stagesHTML = p.stages.length === 0 ? '<p style="color: #6b6357; font-style: italic">Sin etapas registradas.</p>' : `
    <table style="${tableStyle}">
      <thead><tr>
        <th style="${thStyle}">#</th>
        <th style="${thStyle}">Etapa</th>
        <th style="${thStyle}">Inicio</th>
        <th style="${thStyle}">Término</th>
        <th style="${thStyle}">Peso</th>
        <th style="${thStyle}">Avance</th>
        <th style="${thStyle}">Estado</th>
      </tr></thead>
      <tbody>
        ${p.stages.map((s, i) => {
          const stageTasks = getStageTasks(p.id, s.id);
          const stageStatus = computeStageStatus(s, stageTasks);
          const stageProgress = computeStageProgress(s, stageTasks);
          const labels = { pending: 'Pendiente', inProgress: 'En curso', completed: 'Completada', overdue: 'Vencida' };
          return `<tr>
            <td style="${cellStyle}">${i + 1}</td>
            <td style="${cellStyle}"><strong>${escapeHtml(s.name)}</strong>${s.description ? `<div style="font-size: 11px; color: #6b6357; margin-top: 4px">${escapeHtml(s.description)}</div>` : ''}</td>
            <td style="${cellStyle}">${s.startDate ? fmtDate(s.startDate) : '—'}</td>
            <td style="${cellStyle}">${s.dueDate ? fmtDate(s.dueDate) : '—'}</td>
            <td style="${cellStyle}; text-align: center">×${s.weight || 1}</td>
            <td style="${cellStyle}">${stageProgress}%</td>
            <td style="${cellStyle}">${labels[stageStatus]}</td>
          </tr>`;
        }).join('')}
      </tbody>
    </table>`;
  
  const tasksHTML = allProjectTasks.length === 0 ? '<p style="color: #6b6357; font-style: italic">Sin tareas vinculadas.</p>' : `
    <table style="${tableStyle}">
      <thead><tr>
        <th style="${thStyle}">Código</th>
        <th style="${thStyle}">Tarea</th>
        <th style="${thStyle}">Etapa</th>
        <th style="${thStyle}">Asignado</th>
        <th style="${thStyle}">Estado</th>
        <th style="${thStyle}">Plazo</th>
        <th style="${thStyle}">Avance</th>
      </tr></thead>
      <tbody>
        ${allProjectTasks.map(t => {
          const stage = t.stageId ? p.stages.find(s => s.id === t.stageId) : null;
          const statusObj = TASK_STATUSES.find(x => x.key === t.status) || { label: t.status };
          return `<tr>
            <td style="${cellStyle}">${escapeHtml(t.code || '')}</td>
            <td style="${cellStyle}">${escapeHtml(t.title)}</td>
            <td style="${cellStyle}">${stage ? escapeHtml(stage.name) : '<em style="color: #6b6357">Sin etapa</em>'}</td>
            <td style="${cellStyle}">${escapeHtml(t.assignee || '—')}</td>
            <td style="${cellStyle}">${escapeHtml(statusObj.label)}</td>
            <td style="${cellStyle}">${t.dueDate ? fmtDate(t.dueDate) : '—'}</td>
            <td style="${cellStyle}">${t.status === 'done' ? 100 : (t.progress || 0)}%</td>
          </tr>`;
        }).join('')}
      </tbody>
    </table>`;
  
  const content = `
    <div style="margin-bottom: 16px">
      <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #6b6357">${escapeHtml(p.code)}</div>
      <h2 style="font-family: 'Instrument Serif', serif; font-size: 26px; margin: 4px 0 10px">${escapeHtml(p.name)}</h2>
      ${p.description ? `<p style="line-height: 1.55; color: #3d3528">${escapeHtml(p.description)}</p>` : ''}
    </div>
    
    <table style="${tableStyle}">
      <thead><tr><th colspan="2" style="${thStyle}">Ficha del proyecto</th></tr></thead>
      <tbody>
        <tr><td style="${cellStyle}; width: 35%"><strong>Estado</strong></td><td style="${cellStyle}">${statusInfo.label}</td></tr>
        <tr><td style="${cellStyle}"><strong>Prioridad</strong></td><td style="${cellStyle}">${prio.label}</td></tr>
        <tr><td style="${cellStyle}"><strong>Responsable</strong></td><td style="${cellStyle}">${escapeHtml(p.owner || '—')}</td></tr>
        ${p.startDate ? `<tr><td style="${cellStyle}"><strong>Fecha inicio</strong></td><td style="${cellStyle}">${fmtDate(p.startDate)}</td></tr>` : ''}
        ${p.dueDate ? `<tr><td style="${cellStyle}"><strong>Fecha término</strong></td><td style="${cellStyle}">${fmtDate(p.dueDate)}</td></tr>` : ''}
        ${obj ? `<tr><td style="${cellStyle}"><strong>Objetivo estratégico</strong></td><td style="${cellStyle}">${escapeHtml(obj.code + ' · ' + obj.name)}</td></tr>` : ''}
        <tr><td style="${cellStyle}"><strong>Avance del proyecto</strong></td><td style="${cellStyle}"><strong>${p.progress || 0}%</strong> (calculado automáticamente)</td></tr>
        <tr><td style="${cellStyle}"><strong>Métricas</strong></td><td style="${cellStyle}">${p.stages.length} etapas · ${allProjectTasks.length} tareas · ${tasksDone} completadas · ${tasksOverdue} vencidas</td></tr>
      </tbody>
    </table>
    
    <h3 style="margin-top: 24px; font-family: 'Instrument Serif', serif; font-size: 18px">Etapas</h3>
    ${stagesHTML}
    
    <h3 style="margin-top: 24px; font-family: 'Instrument Serif', serif; font-size: 18px">Tareas del proyecto</h3>
    ${tasksHTML}
  `;
  
  printContent({ title: `Proyecto: ${p.code}`, htmlContent: content });
}

