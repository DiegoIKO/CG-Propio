function ensureBPMN(p) {
  if (!p.bpmn) p.bpmn = { nodes: [], connections: [], lanes: [], phases: [] };
  if (!p.bpmn.lanes) p.bpmn.lanes = [];
  if (!p.bpmn.phases) p.bpmn.phases = [];
  return p.bpmn;
}

// Constantes de layout
const BPMN_HEADER_W = 140; // ancho de encabezado de carriles a la izquierda
const BPMN_PHASE_H = 32; // alto de la barra de fases arriba
const BPMN_LANE_DEFAULT_H = 140;
const BPMN_CANVAS_W = 1200;

function bpmnLaneTopY(bpmn, laneIdx) {
  let y = BPMN_PHASE_H;
  for (let i = 0; i < laneIdx; i++) y += (bpmn.lanes[i].height || BPMN_LANE_DEFAULT_H);
  return y;
}
function bpmnCanvasHeight(bpmn) {
  if (!bpmn.lanes.length) return 520;
  return BPMN_PHASE_H + bpmn.lanes.reduce((s, l) => s + (l.height || BPMN_LANE_DEFAULT_H), 0) + 20;
}
function bpmnContentLeft() { return BPMN_HEADER_W; }
function bpmnContentRight(bpmn) {
  if (!bpmn.phases.length) return BPMN_CANVAS_W;
  return BPMN_HEADER_W + bpmn.phases.reduce((s, p) => s + (p.width || 240), 0);
}
function bpmnPhaseStartX(bpmn, phaseIdx) {
  let x = BPMN_HEADER_W;
  for (let i = 0; i < phaseIdx; i++) x += (bpmn.phases[i].width || 240);
  return x;
}

