    </div>
  </div>` : '';
  
  const viewTabs = state.kpis.length ? `<div class="flex gap-2 mb-4" style="border-bottom: 1px solid var(--line); padding-bottom: 6px">
    <div class="pill-tab ${kpisView === 'cards' ? 'active' : ''}" onclick="setKpisView('cards')">Tarjetas</div>
    <div class="pill-tab ${kpisView === 'list' ? 'active' : ''}" onclick="setKpisView('list')">Lista</div>
  </div>` : '';
  
  // Filtros jerárquicos
  const filterBar = state.kpis.length ? renderKpiFilterBar() : '';
  
  // Aplicar filtros
  const visibleKpis = applyKpiFilters(state.kpis);
  
  let body;
  if (visibleKpis.length === 0) {
    body = state.kpis.length 
      ? `<div class="card p-8 text-center"><div class="text-sm" style="color:var(--ink-muted)">Ningún indicador coincide con los filtros</div></div>`
      : `<div class="chart-empty-state">
          <div class="icon-wrap"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 12a9 9 0 1 1 18 0M12 12l4-3"/></svg></div>
          <div class="font-serif text-2xl mb-2">Sin indicadores aún</div>
          <div class="text-sm mb-5" style="color:var(--ink-muted); max-width: 460px; margin: 0 auto">Los indicadores te permiten medir el desempeño con semaforización automática según las metas y umbrales que definas.</div>
          <button class="btn btn-primary" onclick="openKPIForm()">+ Crear primer indicador</button>
        </div>`;
  } else if (kpisView === 'list') {
    body = renderKPIsList(visibleKpis);
  } else {
    body = `<div class="grid grid-cols-1 lg:grid-cols-2 gap-5">${visibleKpis.map(k => kpiCardHTML(k)).join('')}</div>`;
  }
  
  document.getElementById('main-content').innerHTML = `${headerHTML('Indicadores (KPI)', 'Catálogo de indicadores con seguimiento histórico y semaforización', actions)}<div class="p-6">${summary}${viewTabs}${filterBar}${body}</div>`;
  if (kpisView === 'cards') setTimeout(() => visibleKpis.forEach(k => renderKPIMiniChart(k)), 50);
}

function setKpisView(v) { kpisView = v; renderKPIs(); }

function applyKpiFilters(kpis) {
  return kpis.filter(k => {
    if (kpisFilter.status && kpiStatus(k) !== kpisFilter.status) return false;
    if (kpisFilter.owner && (k.owner || '') !== kpisFilter.owner) return false;
    if (kpisFilter.unit && (k.unitName || '') !== kpisFilter.unit) return false;
    if (kpisFilter.perspective && (k.perspective || '') !== kpisFilter.perspective) return false;
    return true;
  });
}

function applyKpiFiltersExcept(kpis, exceptKey) {
  return kpis.filter(k => {
    if (exceptKey !== 'status' && kpisFilter.status && kpiStatus(k) !== kpisFilter.status) return false;
    if (exceptKey !== 'owner' && kpisFilter.owner && (k.owner || '') !== kpisFilter.owner) return false;
    if (exceptKey !== 'unit' && kpisFilter.unit && (k.unitName || '') !== kpisFilter.unit) return false;
    if (exceptKey !== 'perspective' && kpisFilter.perspective && (k.perspective || '') !== kpisFilter.perspective) return false;
    return true;
  });
}

function renderKpiFilterBar() {
  const owners = [...new Set(state.kpis.map(k => k.owner).filter(Boolean))].sort();
  const units = [...new Set(state.kpis.map(k => k.unitName).filter(Boolean))].sort();
  const perspectives = [...new Set(state.kpis.map(k => k.perspective).filter(Boolean))].sort();
  
  // Cálculos jerárquicos
  const ctxStatus = applyKpiFiltersExcept(state.kpis, 'status');
  const ctxOwner = applyKpiFiltersExcept(state.kpis, 'owner');
  const ctxUnit = applyKpiFiltersExcept(state.kpis, 'unit');
  const ctxPersp = applyKpiFiltersExcept(state.kpis, 'perspective');
  
  const statusCounts = { green: 0, yellow: 0, red: 0, gray: 0 };
  ctxStatus.forEach(k => statusCounts[kpiStatus(k)]++);
  
  const availOwner = new Set(ctxOwner.map(k => k.owner).filter(Boolean));
  const availUnit = new Set(ctxUnit.map(k => k.unitName).filter(Boolean));
  const availPersp = new Set(ctxPersp.map(k => k.perspective).filter(Boolean));
  
  const hasAny = kpisFilter.status || kpisFilter.owner || kpisFilter.unit || kpisFilter.perspective;
  
  return `<div class="task-filters" style="margin-bottom: 14px">
    <select class="select input-sm" style="width:auto" onchange="setKpiFilterField('status', this.value)">
      <option value="">Estado: todos</option>
      <option value="green" ${kpisFilter.status === 'green' ? 'selected' : ''}${statusCounts.green === 0 && kpisFilter.status !== 'green' ? ' disabled' : ''}>En meta${statusCounts.green === 0 && kpisFilter.status !== 'green' ? ' (0)' : ` (${statusCounts.green})`}</option>
      <option value="yellow" ${kpisFilter.status === 'yellow' ? 'selected' : ''}${statusCounts.yellow === 0 && kpisFilter.status !== 'yellow' ? ' disabled' : ''}>En alerta${statusCounts.yellow === 0 && kpisFilter.status !== 'yellow' ? ' (0)' : ` (${statusCounts.yellow})`}</option>
      <option value="red" ${kpisFilter.status === 'red' ? 'selected' : ''}${statusCounts.red === 0 && kpisFilter.status !== 'red' ? ' disabled' : ''}>Críticos${statusCounts.red === 0 && kpisFilter.status !== 'red' ? ' (0)' : ` (${statusCounts.red})`}</option>
      <option value="gray" ${kpisFilter.status === 'gray' ? 'selected' : ''}${statusCounts.gray === 0 && kpisFilter.status !== 'gray' ? ' disabled' : ''}>Sin datos${statusCounts.gray === 0 && kpisFilter.status !== 'gray' ? ' (0)' : ` (${statusCounts.gray})`}</option>
    </select>
    ${perspectives.length ? `<select class="select input-sm" style="width:auto" onchange="setKpiFilterField('perspective', this.value)">
      <option value="">Perspectiva: todas</option>
      ${perspectives.map(p => {
        const sel = kpisFilter.perspective === p;
        const unavail = !sel && !availPersp.has(p);
        return `<option value="${escapeHtml(p)}" ${sel ? 'selected' : ''}${unavail ? ' disabled' : ''}>${escapeHtml(p)}${unavail ? ' (0)' : ''}</option>`;
      }).join('')}
    </select>` : ''}
    ${units.length ? `<select class="select input-sm" style="width:auto" onchange="setKpiFilterField('unit', this.value)">
      <option value="">Unidad: todas</option>
      ${units.map(u => {
        const sel = kpisFilter.unit === u;
        const unavail = !sel && !availUnit.has(u);
        return `<option value="${escapeHtml(u)}" ${sel ? 'selected' : ''}${unavail ? ' disabled' : ''}>${escapeHtml(u)}${unavail ? ' (0)' : ''}</option>`;
      }).join('')}
    </select>` : ''}
    ${owners.length ? `<select class="select input-sm" style="width:auto" onchange="setKpiFilterField('owner', this.value)">
      <option value="">Responsable: todos</option>
      ${owners.map(o => {
        const sel = kpisFilter.owner === o;
        const unavail = !sel && !availOwner.has(o);
        return `<option value="${escapeHtml(o)}" ${sel ? 'selected' : ''}${unavail ? ' disabled' : ''}>${escapeHtml(o)}${unavail ? ' (0)' : ''}</option>`;
      }).join('')}
    </select>` : ''}
    ${hasAny ? `<button class="btn btn-ghost btn-sm" onclick="kpisFilter={status:'',owner:'',unit:'',perspective:''}; renderKPIs()">Limpiar filtros</button>` : ''}
  </div>`;
}

function setKpiFilterField(field, value) {
  kpisFilter[field] = value;
  renderKPIs();
}

function renderKPIsList(kpis) {
  return `<div class="card" style="border-radius: 8px"><div class="overflow-x-auto"><table class="data-table">
    <thead><tr>
      <th>Código</th>
      <th>Indicador</th>
      <th>Perspectiva</th>
      <th>Responsable / Unidad</th>
      <th>Valor actual</th>
      <th>Meta</th>
      <th>Cumplimiento</th>
      <th>Tendencia</th>
      <th>Últ. medición</th>
      <th></th>
    </tr></thead>
    <tbody>
      ${kpis.map(k => {
        const v = kpiCurrentValue(k);
        const s = kpiStatus(k);
        const progress = kpiProgressVsTarget(k);
        const trend = kpiTrend(k);
        const lastDate = (k.measurements && k.measurements.length) ? k.measurements[k.measurements.length - 1].date : null;
        const statusLabels = { green: 'En meta', yellow: 'Alerta', red: 'Crítico', gray: 'Sin datos' };
        return `<tr class="kpi-table-row" onclick="openKpiZoom('${k.id}')" style="cursor: pointer">
          <td class="font-mono text-xs">${escapeHtml(k.code || '')}</td>
          <td><span class="kpi-status-dot ${s}" title="${statusLabels[s]}"></span><strong>${escapeHtml(k.name)}</strong></td>
          <td><span class="text-xs">${escapeHtml(k.perspective || '—')}</span></td>
          <td><div class="text-xs">${escapeHtml(k.owner || '—')}</div>${k.unitName ? `<div class="text-xs" style="color:var(--ink-muted)">${escapeHtml(k.unitName)}</div>` : ''}</td>
          <td class="font-mono">${v === null ? '<span style="color:var(--ink-subtle)">—</span>' : `<strong>${fmtNumber(v)}</strong> <span class="text-xs" style="color:var(--ink-muted)">${escapeHtml(k.unit || '')}</span>`}</td>
          <td class="font-mono text-xs">${k.target !== undefined && k.target !== '' ? fmtNumber(k.target) + ' ' + escapeHtml(k.unit || '') : '—'}</td>
          <td><span class="kpi-list-progress-bar"><span class="fill ${s}" style="width: ${Math.min(progress, 100)}%"></span></span><span class="font-mono text-xs">${progress}%</span></td>
          <td>${trend.direction === 'up' ? `<span class="kpi-trend-mini up">↑ ${fmtNumber(Math.abs(trend.diff))}</span>` : trend.direction === 'down' ? `<span class="kpi-trend-mini down">↓ ${fmtNumber(Math.abs(trend.diff))}</span>` : `<span class="kpi-trend-mini flat">→</span>`}</td>
          <td class="text-xs">${lastDate ? fmtDate(lastDate) : '—'}</td>
          <td onclick="event.stopPropagation()" style="white-space: nowrap">
            <button class="btn btn-ghost btn-icon" onclick="openKpiZoom('${k.id}')" title="Ampliar"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg></button>
            <button class="btn btn-ghost btn-icon" onclick="openMeasureForm('${k.id}')" title="+ Medición"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg></button>
            <button class="btn btn-ghost btn-icon" onclick="openKPIForm('${k.id}')" title="Editar"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4v16h16v-7M18 2l4 4-12 12H6v-4z"/></svg></button>
          </td>
        </tr>`;
      }).join('')}
    </tbody>
  </table></div></div>`;
}

function setKpiFilter(f) { kpisFilter.status = f === 'all' ? '' : f; renderKPIs(); }

function kpiTrend(k) {
  const measurements = (k.measurements || []).slice().sort((a, b) => (a.date || '').localeCompare(b.date || ''));
  if (measurements.length < 2) return { direction: 'flat', diff: 0, diffPct: 0 };
  const last = Number(measurements[measurements.length - 1].value);
  const prev = Number(measurements[measurements.length - 2].value);
  const diff = last - prev;
  const diffPct = prev !== 0 ? (diff / Math.abs(prev)) * 100 : 0;
  if (Math.abs(diff) < 0.0001) return { direction: 'flat', diff: 0, diffPct: 0 };
  return { direction: diff > 0 ? 'up' : 'down', diff, diffPct };
}

function kpiCardHTML(k) {
  const v = kpiCurrentValue(k);
  const s = kpiStatus(k);
  const progress = kpiProgressVsTarget(k);
  const cls = s === 'green' ? 'green' : s === 'yellow' ? 'yellow' : s === 'red' ? 'red' : 'gray';
  const direction = k.direction === 'up' ? '↑ Mayor mejor' : '↓ Menor mejor';
  const trend = kpiTrend(k);
  // Para "mayor mejor": subir es bueno; para "menor mejor": bajar es bueno
  const trendClass = trend.direction === 'flat' ? 'flat' : 
    (k.direction === 'up' ? (trend.direction === 'up' ? 'up-good' : 'down-bad') :
     (trend.direction === 'down' ? 'down-good' : 'up-bad'));
  const trendArrow = trend.direction === 'up' ? '↑' : trend.direction === 'down' ? '↓' : '→';
  
  return `<div class="kpi-card-new">
    <div class="status-stripe ${cls}"></div>
    <div class="kpi-header">
      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2">
          <span class="kpi-code">${escapeHtml(k.code)}</span>
          <span class="badge badge-${cls}">${cls === 'gray' ? 'sin datos' : cls === 'green' ? 'en meta' : cls === 'yellow' ? 'alerta' : 'crítico'}</span>
        </div>
        <div class="kpi-name">${escapeHtml(k.name)}</div>
        <div class="kpi-context">
          ${k.owner ? `<span>${escapeHtml(k.owner)}</span><span style="color:var(--ink-subtle)">·</span>` : ''}
          <span>${escapeHtml(k.frequency)}</span>
          <span style="color:var(--ink-subtle)">·</span>
          <span>${direction}</span>
        </div>
        ${(k.objective || k.processId) ? `<div class="flex gap-1 mt-2 flex-wrap">${objectiveBadge(k.objective)}${processBadge(k.processId)}</div>` : ''}
      </div>
      <div class="kpi-actions">
        <button class="btn btn-ghost btn-icon" onclick="openKpiZoom('${k.id}')" title="Ver en pantalla completa"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg></button>
        <button class="btn btn-ghost btn-icon" onclick="openKPIMeasureForm('${k.id}')" title="Registrar medición"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg></button>
        <button class="btn btn-ghost btn-icon" onclick="openKPIForm('${k.id}')" title="Editar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4v16h16v-7M18 2l4 4-12 12H6v-4z"/></svg></button>
        <button class="btn btn-ghost btn-icon" onclick="deleteKPI('${k.id}')" title="Eliminar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4h8v2M5 6l1 14h12l1-14"/></svg></button>
      </div>
    </div>
    
    <div class="kpi-main-value">
      <div class="kpi-current">
        <div class="label">Actual</div>
        <div class="value">${v === null ? '—' : fmtNumber(v)}<span class="unit">${escapeHtml(k.unit || '')}</span></div>
      </div>
      <div class="kpi-trend">
        <div class="kpi-trend-arrow ${trendClass}" title="${trend.direction === 'flat' ? 'Sin cambio respecto a la medición anterior' : `${trend.diff > 0 ? '+' : ''}${fmtNumber(trend.diff)} ${k.unit || ''} (${trend.diffPct > 0 ? '+' : ''}${trend.diffPct.toFixed(1)}%)`}">${trendArrow}</div>
      </div>
      <div class="kpi-target">
        <div class="label">Meta</div>
        <div class="value">${fmtNumber(k.target)}<span class="unit">${escapeHtml(k.unit || '')}</span></div>
      </div>
    </div>
    
    <div class="kpi-progress">
      <div class="kpi-progress-header">
        <span class="kpi-progress-label">Cumplimiento</span>
        <span class="kpi-progress-value">${Math.round(progress)}%</span>
      </div>
      <div class="kpi-progress-bar">
        <div class="kpi-progress-fill ${cls}" style="width: ${Math.min(100, Math.max(0, progress))}%"></div>
      </div>
    </div>
    
    <div class="kpi-chart-wrap"><canvas id="kpi-chart-${k.id}"></canvas></div>
    
    <div class="kpi-meta-row">
      <span><strong>${(k.measurements || []).length}</strong> ${(k.measurements || []).length === 1 ? 'medición' : 'mediciones'}</span>
      ${k.thresholdGreen !== undefined && k.thresholdGreen !== '' ? `<span style="color:var(--ink-subtle)">·</span><span>Verde ≥ <strong>${k.thresholdGreen}</strong></span>` : ''}
      ${k.thresholdYellow !== undefined && k.thresholdYellow !== '' ? `<span style="color:var(--ink-subtle)">·</span><span>Amarillo ≥ <strong>${k.thresholdYellow}</strong></span>` : ''}
    </div>
    
    <details class="action-collapse mt-3">
      <summary>Ver historial de mediciones</summary>
      <div class="p-3 mt-2" style="background:var(--bg-sunken); border-radius: 6px">
        ${(k.measurements || []).length ? `<table class="data-table" style="background:transparent"><thead><tr><th>Fecha</th><th>Valor</th><th>Variación</th><th>Comentario</th><th></th></tr></thead><tbody>${[...k.measurements].sort((a, b) => (b.date || '').localeCompare(a.date || '')).map((m, i, arr) => {
          const prev = arr[i + 1];
          const diff = prev ? Number(m.value) - Number(prev.value) : null;
          const diffStr = diff === null ? '—' : (diff > 0 ? '+' : '') + fmtNumber(diff);
          const diffColor = diff === null ? 'var(--ink-muted)' : (k.direction === 'up' ? (diff > 0 ? 'var(--green)' : diff < 0 ? 'var(--red)' : 'var(--ink-muted)') : (diff < 0 ? 'var(--green)' : diff > 0 ? 'var(--red)' : 'var(--ink-muted)'));
          const origIdx = k.measurements.findIndex(x => x === m);
          return `<tr><td class="text-xs">${fmtDate(m.date)}</td><td class="font-mono text-xs">${fmtNumber(m.value)} ${escapeHtml(k.unit || '')}</td><td class="font-mono text-xs" style="color:${diffColor}">${diffStr}</td><td class="text-xs" style="font-style: italic; color: var(--ink-muted); max-width: 200px">${m.comment ? escapeHtml(m.comment) : '<span style="color:var(--ink-subtle)">—</span>'}</td><td class="text-right"><button class="btn btn-ghost btn-icon" onclick="deleteMeasure('${k.id}', ${origIdx})"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button></td></tr>`;
        }).join('')}</tbody></table>` : '<div class="text-xs text-center py-4" style="color:var(--ink-muted)">Sin mediciones registradas. Usa el botón ＋ arriba para añadir la primera.</div>'}
      </div>
    </details>
  </div>`;
}

/* ==================== ZOOM DE KPI A PANTALLA COMPLETA ==================== */

