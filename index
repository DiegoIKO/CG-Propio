function setupDropZone() {
  const zone = document.getElementById('viz-drop-zone');
  if (!zone) return;
  ['dragenter', 'dragover'].forEach(evt => {
    zone.addEventListener(evt, e => { e.preventDefault(); e.stopPropagation(); zone.classList.add('drag-over'); });
  });
  ['dragleave', 'drop'].forEach(evt => {
    zone.addEventListener(evt, e => { e.preventDefault(); e.stopPropagation(); zone.classList.remove('drag-over'); });
  });
  zone.addEventListener('drop', e => {
    const files = e.dataTransfer.files;
    if (files.length) processImportFile(files[0]);
  });
}

function handleImportFile(event) {
  const file = event.target.files[0];
  if (file) processImportFile(file);
}

function processImportFile(file) {
  if (!window.XLSX) {
    toast('La librería de Excel no cargó. Verifica tu conexión y recarga la página.');
    return;
  }
  const ext = file.name.split('.').pop().toLowerCase();
  const fileSize = file.size < 1024 ? `${file.size} B` : file.size < 1024 * 1024 ? `${(file.size / 1024).toFixed(1)} KB` : `${(file.size / 1024 / 1024).toFixed(1)} MB`;
  
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      let workbook;
      const data = e.target.result;
      if (ext === 'csv' || ext === 'tsv' || ext === 'txt') {
        // Parsear como CSV/TSV
        const text = typeof data === 'string' ? data : new TextDecoder('utf-8').decode(new Uint8Array(data));
        const delim = ext === 'tsv' ? '\t' : detectDelimiter(text);
        workbook = XLSX.read(text, { type: 'string', FS: delim, raw: false });
      } else {
        workbook = XLSX.read(data, { type: 'array', cellDates: true, dateNF: 'yyyy-mm-dd' });
      }
      
      importStaging = {
        workbook,
        sheets: workbook.SheetNames,
        selectedSheet: workbook.SheetNames[0],
        fileName: file.name,
        fileSize,
        hasHeaders: true,
        skipRows: 0,
        datasetName: file.name.replace(/\.[^.]+$/, '')
      };
      
      renderImportPreview();
    } catch (err) {
      toast('Error al leer el archivo: ' + err.message);
      console.error(err);
    }
  };
  
  if (ext === 'csv' || ext === 'tsv' || ext === 'txt') {
    reader.readAsText(file);
  } else {
    reader.readAsArrayBuffer(file);
  }
}

function detectDelimiter(text) {
  const sample = text.split('\n').slice(0, 5).join('\n');
  const counts = { ',': 0, ';': 0, '\t': 0, '|': 0 };
  for (const c of sample) if (counts[c] !== undefined) counts[c]++;
  return Object.entries(counts).sort((a, b) => b[1] - a[1])[0][0];
}

function renderImportPreview() {
  if (!importStaging) return;
  
  const stage1 = document.getElementById('import-stage-1');
  const stage2 = document.getElementById('import-stage-2');
  if (stage1) stage1.style.display = 'none';
  if (stage2) stage2.style.display = 'block';
  
  const sheet = importStaging.workbook.Sheets[importStaging.selectedSheet];
  const allRows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: '', raw: false, blankrows: false });
  
  // Aplicar skipRows
  const dataRows = allRows.slice(importStaging.skipRows);
  let headers, rows;
  if (importStaging.hasHeaders && dataRows.length > 0) {
    headers = dataRows[0].map((h, i) => String(h || `Columna ${i + 1}`).trim());
    rows = dataRows.slice(1);
  } else {
    const maxCols = Math.max(0, ...dataRows.map(r => r.length));
    headers = Array.from({ length: maxCols }, (_, i) => `Columna ${i + 1}`);
    rows = dataRows;
  }
  
  // Limpiar columnas completamente vacías
  const colKeep = headers.map((_, i) => rows.some(r => r[i] !== '' && r[i] != null));
  if (colKeep.some(k => !k)) {
    headers = headers.filter((_, i) => colKeep[i]);
    rows = rows.map(r => r.filter((_, i) => colKeep[i]));
  }
  
  importStaging.previewHeaders = headers;
  importStaging.previewRows = rows;
  
  const previewLimit = 50;
  const previewRows = rows.slice(0, previewLimit);
  
  stage2.innerHTML = `<div class="space-y-4">
    <div class="viz-import-preview">
      <div class="viz-import-header">
        <div class="file-info">
          <div class="file-icon">${(importStaging.fileName.split('.').pop() || 'doc').toUpperCase().slice(0, 4)}</div>
          <div>
            <div class="file-name">${escapeHtml(importStaging.fileName)}</div>
            <div class="file-meta">${importStaging.fileSize} · ${importStaging.sheets.length} ${importStaging.sheets.length === 1 ? 'hoja' : 'hojas'}</div>
          </div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="resetImport()">← Elegir otro archivo</button>
      </div>
      
      ${importStaging.sheets.length > 1 ? `<div class="viz-sheets-tabs">
        ${importStaging.sheets.map(name => {
          const s = importStaging.workbook.Sheets[name];
          const ref = s['!ref'] ? XLSX.utils.decode_range(s['!ref']) : null;
          const cnt = ref ? `${ref.e.r - ref.s.r + 1} filas` : '';
          return `<div class="viz-sheet-tab ${name === importStaging.selectedSheet ? 'active' : ''}" onclick="selectImportSheet('${escapeHtml(name).replace(/'/g, "\\'")}')">${escapeHtml(name)}<span class="sheet-count">${cnt}</span></div>`;
        }).join('')}
      </div>` : ''}
      
      <div class="viz-import-options">
        <label><input type="checkbox" ${importStaging.hasHeaders ? 'checked' : ''} onchange="toggleImportHeaders(this.checked)"> Primera fila es encabezado</label>
        <label>Saltar filas: <input type="number" class="input-mini" value="${importStaging.skipRows}" min="0" style="width: 60px" onchange="updateImportSkip(this.value)"></label>
        <label>Nombre del dataset: <input type="text" class="input-mini" value="${escapeHtml(importStaging.datasetName)}" style="width: 220px" onchange="importStaging.datasetName = this.value"></label>
      </div>
      
      <div class="viz-import-table-wrap">
        <table class="viz-import-table">
          <thead>
            <tr>
              <th class="row-num">#</th>
              ${headers.map((h, i) => {
                // Detectar tipo de columna
                const type = detectColumnType(rows, i);
                const typeIcon = type === 'number' ? '123' : type === 'date' ? '📅' : 'Aa';
                return `<th><div>${escapeHtml(h)}</div><div style="font-size: 9px; color: var(--ink-subtle); font-weight: 500; text-transform: none; margin-top: 2px">${typeIcon} ${type}</div></th>`;
              }).join('')}
            </tr>
          </thead>
          <tbody>
            ${previewRows.map((row, ri) => `<tr>
              <td class="row-num">${ri + 1}</td>
              ${headers.map((_, ci) => `<td>${escapeHtml(String(row[ci] !== undefined && row[ci] !== null ? row[ci] : ''))}</td>`).join('')}
            </tr>`).join('')}
          </tbody>
        </table>
      </div>
      
      <div class="viz-import-actions">
        <div class="import-info"><strong>${rows.length}</strong> filas · <strong>${headers.length}</strong> columnas detectadas · mostrando primeras ${Math.min(previewLimit, rows.length)}</div>
      </div>
    </div>
  </div>`;
  
  document.getElementById('btn-import-confirm').style.display = '';
}

function detectColumnType(rows, colIdx) {
  const samples = rows.slice(0, 30).map(r => r[colIdx]).filter(v => v !== '' && v != null);
  if (!samples.length) return 'text';
  // ¿Fechas?
  if (samples.every(v => v instanceof Date || /^\d{4}-\d{2}-\d{2}/.test(String(v)) || /^\d{1,2}\/\d{1,2}\/\d{2,4}/.test(String(v)))) return 'date';
  // ¿Números?
  if (samples.every(v => {
    const s = String(v).replace(',', '.').replace(/[^\d.\-eE]/g, '');
    return s !== '' && !isNaN(parseFloat(s)) && isFinite(s);
  })) return 'number';
  return 'text';
}

function selectImportSheet(name) {
  importStaging.selectedSheet = name;
  renderImportPreview();
}

function toggleImportHeaders(checked) {
  importStaging.hasHeaders = checked;
  renderImportPreview();
}

function updateImportSkip(n) {
  importStaging.skipRows = parseInt(n) || 0;
  renderImportPreview();
}

function resetImport() {
  importStaging = null;
  document.getElementById('import-stage-1').style.display = '';
  document.getElementById('import-stage-2').style.display = 'none';
  document.getElementById('viz-file-input').value = '';
  document.getElementById('btn-import-confirm').style.display = 'none';
}

function confirmImport() {
  if (!importStaging || !importStaging.previewHeaders) return;
  const name = (importStaging.datasetName || importStaging.fileName.replace(/\.[^.]+$/, '')).trim();
  if (!name) { toast('Pon un nombre al dataset'); return; }
  
  // Convertir filas: detectar tipos y convertir
  const columns = importStaging.previewHeaders.map((h, i) => ({
    name: h,
    type: detectColumnType(importStaging.previewRows, i)
  }));
  
  const rows = importStaging.previewRows.map(r => 
    columns.map((c, ci) => {
      let v = r[ci];
      if (v === undefined || v === null) return '';
      if (v instanceof Date) return v.toISOString().slice(0, 10);
      if (c.type === 'number') {
        const num = parseFloat(String(v).replace(',', '.'));
        return isNaN(num) ? String(v) : num;
      }
      return String(v);
    })
  );
  
  const newDs = {
    id: uid(),
    name,
    description: `Importado el ${new Date().toLocaleDateString('es-CL')} desde ${importStaging.fileName}${importStaging.sheets.length > 1 ? ` (hoja "${importStaging.selectedSheet}")` : ''}`,
    columns,
    rows,
    importedAt: new Date().toISOString(),
    importedFrom: importStaging.fileName
  };
  
  state.datasets.push(newDs);
  vizSelectedDatasetId = newDs.id;
  vizTab = 'datasets';
  importStaging = null;
  save();
  closeModal();
  renderVisualizaciones();
  toast(`Dataset importado: ${rows.length} filas, ${columns.length} columnas`);
}

/* ==================== PROFILADO DE COLUMNAS ==================== */

function showColumnProfile(event, datasetId, colIdx) {
  event.stopPropagation();
  // Cerrar panel existente
  closeColumnProfile();
  
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  const col = ds.columns[colIdx];
  
  // Calcular estadísticas
  const values = (ds.rows || []).map(r => r[colIdx]);
  const total = values.length;
  const filled = values.filter(v => v !== '' && v != null).length;
  const empty = total - filled;
  const unique = new Set(values.filter(v => v !== '' && v != null).map(v => String(v))).size;
  const duplicates = filled - unique;
  
  let typeStats = '';
  let distribution = '';
  
  if (col.type === 'number') {
    const nums = values.map(v => parseFloat(v)).filter(v => !isNaN(v));
    if (nums.length) {
      const sum = nums.reduce((a, b) => a + b, 0);
      const avg = sum / nums.length;
      const sorted = [...nums].sort((a, b) => a - b);
      const median = sorted.length % 2 === 0 ? (sorted[sorted.length / 2 - 1] + sorted[sorted.length / 2]) / 2 : sorted[Math.floor(sorted.length / 2)];
      typeStats = `<div class="stat-box"><div class="stat-label">Mínimo</div><div class="stat-value">${fmtNumber(Math.min(...nums))}</div></div>
      <div class="stat-box"><div class="stat-label">Máximo</div><div class="stat-value">${fmtNumber(Math.max(...nums))}</div></div>
      <div class="stat-box"><div class="stat-label">Promedio</div><div class="stat-value">${fmtNumber(avg)}</div></div>
      <div class="stat-box"><div class="stat-label">Mediana</div><div class="stat-value">${fmtNumber(median)}</div></div>
      <div class="stat-box"><div class="stat-label">Suma</div><div class="stat-value">${fmtNumber(sum)}</div></div>
      <div class="stat-box"><div class="stat-label">Conteo</div><div class="stat-value">${nums.length}</div></div>`;
    }
  } else {
    // Distribución de valores más frecuentes para texto/fecha
    const counts = {};
    values.filter(v => v !== '' && v != null).forEach(v => {
      const k = String(v);
      counts[k] = (counts[k] || 0) + 1;
    });
    const topValues = Object.entries(counts).sort((a, b) => b[1] - a[1]).slice(0, 8);
    if (topValues.length) {
      const maxCount = topValues[0][1];
      distribution = `<div class="col-profile-distribution">
        <div class="dist-title">Valores más frecuentes</div>
        ${topValues.map(([val, cnt]) => `<div class="dist-row">
          <span class="dist-label" title="${escapeHtml(val)}">${escapeHtml(val.length > 30 ? val.slice(0, 28) + '…' : val)}</span>
          <div class="dist-bar-bg"><div class="dist-bar-fill" style="width: ${(cnt / maxCount * 100).toFixed(0)}%"></div></div>
          <span class="dist-count">${cnt}</span>
        </div>`).join('')}
      </div>`;
    }
  }
  
  // Acciones de limpieza disponibles según tipo
  const actions = [
    { label: 'Eliminar filas con valores vacíos', icon: '<path d="M3 6h18M8 6V4h8v2M5 6l1 14h12l1-14"/>', fn: `cleanColumnEmpty('${datasetId}', ${colIdx})` },
    empty > 0 && col.type === 'number' ? { label: `Rellenar ${empty} vacíos con 0`, icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>', fn: `cleanColumnFillZero('${datasetId}', ${colIdx})` } : null,
    empty > 0 && col.type === 'number' ? { label: `Rellenar ${empty} vacíos con promedio`, icon: '<path d="M3 12l4-4 6 6 8-8"/>', fn: `cleanColumnFillAvg('${datasetId}', ${colIdx})` } : null,
    duplicates > 0 ? { label: `Eliminar ${duplicates} duplicados`, icon: '<rect x="3" y="3" width="13" height="13"/><path d="M8 21h13V8"/>', fn: `cleanColumnDedupe('${datasetId}', ${colIdx})` } : null,
    col.type === 'text' ? { label: 'Limpiar espacios (TRIM)', icon: '<path d="M3 12h18"/>', fn: `cleanColumnTrim('${datasetId}', ${colIdx})` } : null,
    col.type === 'text' ? { label: 'Normalizar a minúsculas', icon: '<path d="M4 7h16M4 12h10M4 17h7"/>', fn: `cleanColumnLower('${datasetId}', ${colIdx})` } : null,
    col.type === 'text' ? { label: 'Convertir a número', icon: '<text x="3" y="18" font-size="16" font-family="monospace">123</text>', fn: `cleanColumnToNumber('${datasetId}', ${colIdx})` } : null,
    col.type === 'number' ? { label: 'Convertir a texto', icon: '<text x="3" y="18" font-size="16" font-family="monospace">Aa</text>', fn: `cleanColumnToText('${datasetId}', ${colIdx})` } : null,
  ].filter(Boolean);
  
  const panelHTML = `<div class="col-profile-panel" id="col-profile-panel" onclick="event.stopPropagation()">
    <button class="panel-close" onclick="closeColumnProfile()">×</button>
    <div class="panel-title">${escapeHtml(col.name)}</div>
    <div class="panel-type">Tipo: ${col.type === 'number' ? 'Numérico' : col.type === 'date' ? 'Fecha' : 'Texto'}</div>
    
    <div class="col-profile-stats">
      <div class="stat-box"><div class="stat-label">Total filas</div><div class="stat-value">${total}</div></div>
      <div class="stat-box"><div class="stat-label">Llenas</div><div class="stat-value">${filled}</div></div>
      <div class="stat-box"><div class="stat-label">Vacías</div><div class="stat-value ${empty > 0 ? 'warning' : ''}">${empty}</div></div>
      <div class="stat-box"><div class="stat-label">Únicos</div><div class="stat-value">${unique}</div></div>
      ${duplicates > 0 ? `<div class="stat-box"><div class="stat-label">Duplicados</div><div class="stat-value warning">${duplicates}</div></div>` : ''}
      ${typeStats}
    </div>
    
    <div class="col-profile-actions">
      <div style="font-size: 10px; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-muted); font-weight: 600; padding: 2px 0">Limpiar / transformar</div>
      ${actions.map(a => `<button onclick="${a.fn}"><svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${a.icon}</svg>${a.label}</button>`).join('')}
      <button class="danger" onclick="if(confirm('¿Eliminar columna ${col.name.replace(/'/g, "\\'")}?')) { removeDatasetColumn('${datasetId}', ${colIdx}); closeColumnProfile(); }"><svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4h8v2M5 6l1 14h12l1-14"/></svg>Eliminar columna</button>
    </div>
    
    ${distribution}
  </div>`;
  
  document.body.insertAdjacentHTML('beforeend', panelHTML);
  
  // Posicionar cerca del trigger
  const rect = event.target.closest('th').getBoundingClientRect();
  const panel = document.getElementById('col-profile-panel');
  let left = rect.left;
  if (left + 340 > window.innerWidth) left = window.innerWidth - 340 - 10;
  if (left < 10) left = 10;
  panel.style.left = left + 'px';
  panel.style.top = (rect.bottom + 6) + 'px';
  
  // Cerrar al hacer clic fuera
  setTimeout(() => {
    document.addEventListener('click', closeColumnProfileOnOutsideClick);
  }, 50);
}

function closeColumnProfileOnOutsideClick(e) {
  const panel = document.getElementById('col-profile-panel');
  if (panel && !panel.contains(e.target)) closeColumnProfile();
}

function closeColumnProfile() {
  const panel = document.getElementById('col-profile-panel');
  if (panel) panel.remove();
  document.removeEventListener('click', closeColumnProfileOnOutsideClick);
}

/* ==================== ACCIONES DE LIMPIEZA ==================== */

function cleanColumnEmpty(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  const before = ds.rows.length;
  ds.rows = ds.rows.filter(r => r[colIdx] !== '' && r[colIdx] != null);
  closeColumnProfile();
  save(); renderVisualizaciones();
  toast(`${before - ds.rows.length} filas eliminadas`);
}

function cleanColumnFillZero(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  let count = 0;
  ds.rows.forEach(r => {
    if (r[colIdx] === '' || r[colIdx] == null) { r[colIdx] = 0; count++; }
  });
  closeColumnProfile();
  save(); renderVisualizaciones();
  toast(`${count} celdas rellenas con 0`);
}

function cleanColumnFillAvg(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  const nums = ds.rows.map(r => parseFloat(r[colIdx])).filter(v => !isNaN(v));
  if (!nums.length) { toast('No hay números para calcular promedio'); return; }
  const avg = nums.reduce((a, b) => a + b, 0) / nums.length;
  let count = 0;
  ds.rows.forEach(r => {
    if (r[colIdx] === '' || r[colIdx] == null) { r[colIdx] = Math.round(avg * 100) / 100; count++; }
  });
  closeColumnProfile();
  save(); renderVisualizaciones();
  toast(`${count} celdas rellenas con el promedio (${fmtNumber(avg)})`);
}

function cleanColumnDedupe(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  const seen = new Set();
  const before = ds.rows.length;
  ds.rows = ds.rows.filter(r => {
    const v = String(r[colIdx]);
    if (seen.has(v)) return false;
    seen.add(v);
    return true;
  });
  closeColumnProfile();
  save(); renderVisualizaciones();
  toast(`${before - ds.rows.length} filas duplicadas eliminadas`);
}

function cleanColumnTrim(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  ds.rows.forEach(r => {
    if (typeof r[colIdx] === 'string') r[colIdx] = r[colIdx].trim().replace(/\s+/g, ' ');
  });
  closeColumnProfile();
  save(); renderVisualizaciones();
  toast('Espacios limpiados');
}

function cleanColumnLower(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  ds.rows.forEach(r => {
    if (typeof r[colIdx] === 'string') r[colIdx] = r[colIdx].toLowerCase();
  });
  closeColumnProfile();
  save(); renderVisualizaciones();
  toast('Texto normalizado a minúsculas');
}

function cleanColumnToNumber(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  let count = 0;
  ds.rows.forEach(r => {
    const num = parseFloat(String(r[colIdx]).replace(',', '.').replace(/[^\d.\-eE]/g, ''));
    if (!isNaN(num)) { r[colIdx] = num; count++; }
  });
  ds.columns[colIdx].type = 'number';
  closeColumnProfile();
  save(); renderVisualizaciones();
  toast(`${count} valores convertidos a número`);
}

function cleanColumnToText(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  ds.rows.forEach(r => { r[colIdx] = String(r[colIdx] !== null && r[colIdx] !== undefined ? r[colIdx] : ''); });
  ds.columns[colIdx].type = 'text';
  closeColumnProfile();
  save(); renderVisualizaciones();
  toast('Convertido a texto');
}

function cleanDatasetGlobal(datasetId) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  
  let report = [];
  
  // 1. Eliminar filas completamente vacías
  const beforeRows = ds.rows.length;
  ds.rows = ds.rows.filter(r => r.some(v => v !== '' && v != null));
  const removedEmptyRows = beforeRows - ds.rows.length;
  if (removedEmptyRows > 0) report.push(`${removedEmptyRows} filas vacías eliminadas`);
  
  // 2. Trim de todas las celdas de texto
  let trimmedCells = 0;
  ds.rows.forEach(r => {
    ds.columns.forEach((c, ci) => {
      if (typeof r[ci] === 'string') {
        const original = r[ci];
        r[ci] = r[ci].trim().replace(/\s+/g, ' ');
        if (original !== r[ci]) trimmedCells++;
      }
    });
  });
  if (trimmedCells > 0) report.push(`${trimmedCells} celdas con espacios normalizados`);
  
  // 3. Reinferir tipos de columna
  let typesChanged = 0;
  ds.columns.forEach((c, ci) => {
    const oldType = c.type;
    c.type = inferColumnType(ds, ci);
    if (oldType !== c.type) typesChanged++;
    // Si es número, convertir
    if (c.type === 'number') {
      ds.rows.forEach(r => {
        if (r[ci] !== '' && r[ci] != null) {
          const num = parseFloat(String(r[ci]).replace(',', '.'));
          if (!isNaN(num)) r[ci] = num;
        }
      });
    }
  });
  if (typesChanged > 0) report.push(`${typesChanged} columnas con tipo reajustado`);
  
  save();
  renderVisualizaciones();
  toast(report.length ? 'Limpieza completada: ' + report.join(' · ') : 'Dataset ya estaba limpio');
}

/* ==================== SISTEMA DE FILTROS DINÁMICOS ==================== */

// filterState[datasetId] = { filters: { colIdx: {type, ...config} }, expanded, propagate }
let filterState = {};

function getFilterState(datasetId) {
  if (!filterState[datasetId]) {
    filterState[datasetId] = { filters: {}, expanded: false, propagate: false };
  }
  return filterState[datasetId];
}

function persistFilterState() {
  try {
    const lite = {};
    Object.keys(filterState).forEach(k => {
      lite[k] = { filters: filterState[k].filters, expanded: filterState[k].expanded, propagate: filterState[k].propagate };
    });
    localStorage.setItem('gestio_os_filters_v1', JSON.stringify(lite));
  } catch(e) {}
}

function loadFilterState() {
  try {
    const raw = localStorage.getItem('gestio_os_filters_v1');
    if (raw) filterState = JSON.parse(raw);
  } catch(e) { filterState = {}; }
}
loadFilterState();

// Devuelve los índices de filas que pasan todos los filtros, excluyendo opcionalmente uno
function getFilteredRowIndices(datasetId, excludeColIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return [];
  const fs = getFilterState(datasetId);
  const activeFilters = Object.entries(fs.filters || {})
    .map(([k, v]) => [parseInt(k), v])
    .filter(([colIdx, f]) => colIdx !== excludeColIdx && filterHasValue(f));
  
  if (!activeFilters.length) return ds.rows.map((_, i) => i);
  
  // Pre-convertir filtros de texto a Set para búsqueda O(1)
  const optimizedFilters = activeFilters.map(([colIdx, f]) => {
    if (f.type === 'text') {
      return [colIdx, { ...f, _selectedSet: new Set(f.selected) }];
    }
    return [colIdx, f];
  });
  
  const result = [];
  for (let i = 0; i < ds.rows.length; i++) {
    let pass = true;
    for (let j = 0; j < optimizedFilters.length; j++) {
      const [colIdx, f] = optimizedFilters[j];
      const v = ds.rows[i][colIdx];
      if (!rowMatchesFilterFast(v, f)) { pass = false; break; }
    }
    if (pass) result.push(i);
  }
  return result;
}

// Versión rápida que usa _selectedSet si está presente
function rowMatchesFilterFast(value, f) {
  if (f.type === 'text') {
    const v = String(value === null || value === undefined ? '(vacío)' : value);
    if (f._selectedSet) return f._selectedSet.has(v);
    return f.selected.includes(v);
  }
  return rowMatchesFilter(value, f);
}

function filterHasValue(f) {
  if (!f) return false;
  if (f.type === 'text') return f.selected && f.selected.length > 0;
  if (f.type === 'number') return (f.min !== null && f.min !== undefined && f.min !== '') || (f.max !== null && f.max !== undefined && f.max !== '');
  if (f.type === 'date') return (f.from !== null && f.from !== '') || (f.to !== null && f.to !== '');
  return false;
}

function rowMatchesFilter(value, f) {
  if (f.type === 'text') {
    const v = String(value === null || value === undefined ? '' : value);
    return f.selected.includes(v);
  }
  if (f.type === 'number') {
    const n = parseFloat(value);
    if (isNaN(n)) return false;
    if (f.min !== null && f.min !== undefined && f.min !== '' && n < parseFloat(f.min)) return false;
    if (f.max !== null && f.max !== undefined && f.max !== '' && n > parseFloat(f.max)) return false;
    return true;
  }
  if (f.type === 'date') {
    if (!value) return false;
    const v = String(value).slice(0, 10);
    if (f.from && v < f.from) return false;
    if (f.to && v > f.to) return false;
    return true;
  }
  return true;
}

function summarizeFilter(ds, colIdx, f) {
  const col = ds.columns[colIdx];
  if (!col) return '';
  if (f.type === 'text') {
    if (!f.selected || f.selected.length === 0) return '';
    if (f.selected.length === 1) return f.selected[0];
    if (f.selected.length <= 3) return f.selected.join(', ');
    return `${f.selected.length} valores`;
  }
  if (f.type === 'number') {
    const parts = [];
    if (f.min !== null && f.min !== undefined && f.min !== '') parts.push(`≥ ${fmtNumber(f.min)}`);
    if (f.max !== null && f.max !== undefined && f.max !== '') parts.push(`≤ ${fmtNumber(f.max)}`);
    return parts.join(' y ');
  }
  if (f.type === 'date') {
    const parts = [];
    if (f.from) parts.push(`desde ${f.from}`);
    if (f.to) parts.push(`hasta ${f.to}`);
    return parts.join(' ');
  }
  return '';
}

function renderFiltersPanel(datasetId) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return '';
  const fs = getFilterState(datasetId);
  const totalRows = ds.rows.length;
  const filteredIdx = getFilteredRowIndices(datasetId);
  const visibleRows = filteredIdx.length;
  
  // Chips de filtros activos
  const activeChips = [];
  Object.entries(fs.filters || {}).forEach(([colIdx, f]) => {
    if (filterHasValue(f)) {
      const idx = parseInt(colIdx);
      const col = ds.columns[idx];
      if (col) {
        activeChips.push(`<div class="viz-filters-chip">
          <span class="chip-col">${escapeHtml(col.name)}</span>
          <span class="chip-val">${escapeHtml(summarizeFilter(ds, idx, f))}</span>
          <span class="chip-remove" onclick="event.stopPropagation(); clearFilter('${datasetId}', ${idx})">×</span>
        </div>`);
      }
    }
  });
  
  return `<div class="viz-filters-panel">
    <div class="viz-filters-header ${fs.expanded ? 'open' : ''}" onclick="toggleFiltersPanel('${datasetId}')">
      <span class="toggle-icon">▶</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--ink-muted)"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
      <span class="title">Filtros</span>
      <span class="row-count"><strong>${fmtNumber(visibleRows)}</strong> de ${fmtNumber(totalRows)} filas${visibleRows < totalRows ? ' visibles' : ''}</span>
    </div>
    
    <div class="viz-filters-chips">
      <span class="chips-label">Activos:</span>
      ${activeChips.length ? activeChips.join('') + `<button class="viz-filters-chip" style="background: var(--bg-sunken); color: var(--ink-muted); border: 1px solid var(--line); cursor: pointer" onclick="clearAllFilters('${datasetId}')">Limpiar todos</button>` : '<span class="viz-filters-empty">Sin filtros aplicados — todas las filas visibles</span>'}
    </div>
    
    ${fs.expanded ? `<div class="viz-filters-body">
      <div class="viz-filters-grid">
        ${ds.columns.map((col, i) => renderFilterCard(datasetId, i)).join('')}
      </div>
    </div>
    
    <div class="viz-filters-toolbar">
      <label class="propagate-switch" title="Si está activo, los filtros también se aplican a la pestaña Análisis y a los Gráficos">
        <input type="checkbox" ${fs.propagate ? 'checked' : ''} onchange="toggleFilterPropagation('${datasetId}', this.checked)">
        Propagar filtros a Análisis y Gráficos
      </label>
      <span class="toolbar-spacer"></span>
      ${activeChips.length ? `<button class="btn btn-secondary btn-sm" onclick="createDatasetFromFilter('${datasetId}')" title="Crear un nuevo dataset con solo las filas filtradas">Crear dataset desde filtro</button>` : ''}
    </div>` : ''}
  </div>`;
}

function renderFilterCard(datasetId, colIdx) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return '';
  const col = ds.columns[colIdx];
  const fs = getFilterState(datasetId);
  const f = fs.filters[colIdx];
  const isActive = filterHasValue(f);
  
  // Tipo de filtro según el tipo de columna
  if (col.type === 'number') return renderFilterNumberCard(datasetId, colIdx, f);
  if (col.type === 'date') return renderFilterDateCard(datasetId, colIdx, f);
  return renderFilterTextCard(datasetId, colIdx, f);
}

// Mapa global para guardar referencias a valores de filtro (evita problemas con strings con comillas/HTML)
const _filterValueRegistry = {};

function renderFilterTextCard(datasetId, colIdx, f) {
  const ds = state.datasets.find(d => d.id === datasetId);
  const col = ds.columns[colIdx];
  const isActive = f && f.selected && f.selected.length > 0;
  
  // Valores disponibles en el contexto (usando Set para O(1))
  const idxsInContext = getFilteredRowIndices(datasetId, colIdx);
  const idxsInContextSet = new Set(idxsInContext);
  const allValues = new Set();
  const valueCountsInContext = {};
  
  for (let i = 0; i < ds.rows.length; i++) {
    const raw = ds.rows[i][colIdx];
    const v = String(raw === null || raw === undefined ? '(vacío)' : raw);
    allValues.add(v);
    if (idxsInContextSet.has(i)) {
      valueCountsInContext[v] = (valueCountsInContext[v] || 0) + 1;
    }
  }
  
  const searchKey = `filter-search-${datasetId}-${colIdx}`;
  const searchValue = (window._filterSearches || {})[searchKey] || '';
  const sortedValues = [...allValues].sort((a, b) => a.localeCompare(b, 'es', { numeric: true }));
  
  // Si hay demasiados valores únicos, advertir
  const TOO_MANY_THRESHOLD = 500;
  const tooMany = sortedValues.length > TOO_MANY_THRESHOLD;
  
  const visibleValues = searchValue ? sortedValues.filter(v => v.toLowerCase().includes(searchValue.toLowerCase())) : sortedValues;
  const showSearch = sortedValues.length > 8;
  
  // Mostrar máximo 200 valores en la lista (con búsqueda puede acceder a todos)
  const MAX_DISPLAYED = 200;
  const displayedValues = visibleValues.slice(0, MAX_DISPLAYED);
  const moreCount = visibleValues.length - displayedValues.length;
  
  // Registrar valores en el registro global
  const regKey = `${datasetId}__${colIdx}`;
  _filterValueRegistry[regKey] = sortedValues;
  
  const isValueSelected = (v) => {
    if (!isActive) return true;
    return f.selected.includes(v);
  };
  
  // Selected como Set para lookup rápido
  const selectedSet = isActive ? new Set(f.selected) : null;
  const isValueSelectedFast = (v) => selectedSet ? selectedSet.has(v) : true;
  
  return `<div class="viz-filter-card ${isActive ? 'active' : ''}" data-col-idx="${colIdx}">
    <div class="filter-card-header">
      <div class="filter-card-name">
        <span class="col-type-mini">Aa</span>
        <span class="col-name-text">${escapeHtml(col.name)}</span>
      </div>
      ${isActive ? `<button class="filter-clear-btn" onclick="clearFilter('${datasetId}', ${colIdx})">Limpiar</button>` : ''}
    </div>
    
    ${tooMany ? `<div style="font-size: 10.5px; color: var(--warm); padding: 4px 6px; background: rgba(200,157,44,0.1); border-radius: 4px; margin-bottom: 6px"><strong>${sortedValues.length}</strong> valores únicos · usa buscar</div>` : ''}
    
    ${showSearch ? `<input class="filter-search" placeholder="Buscar..." value="${escapeHtml(searchValue)}" oninput="updateFilterSearch('${datasetId}', ${colIdx}, this.value)">` : ''}
    
    <div class="filter-toggle-all">
      <button onclick="filterTextSelectAll('${datasetId}', ${colIdx}, true)" title="Marca todos los valores">Todos</button>
      <span style="color:var(--ink-subtle)">·</span>
      <button onclick="filterTextSelectAll('${datasetId}', ${colIdx}, false)" title="Desmarca todos los valores">Ninguno</button>
      ${searchValue ? `<span style="color:var(--ink-subtle)">·</span><button onclick="filterTextSelectOnlyVisible('${datasetId}', ${colIdx})" title="Solo los valores visibles en la búsqueda">Solo visibles</button>` : ''}
    </div>
    
    <div class="filter-values-list">
      ${displayedValues.length === 0 ? '<div style="font-size:11px;color:var(--ink-muted);padding:8px;text-align:center">Sin coincidencias</div>' : displayedValues.map(v => {
        const inContext = valueCountsInContext[v] !== undefined;
        const isSelected = isValueSelectedFast(v);
        const valIdx = sortedValues.indexOf(v);
        return `<label class="filter-value-row ${!inContext ? 'unavailable' : ''}">
          <input type="checkbox" ${isSelected ? 'checked' : ''} onchange="toggleFilterTextValueByIdx('${datasetId}', ${colIdx}, ${valIdx}, this.checked)">
          <span class="val-label" title="${escapeHtml(v)}">${escapeHtml(v)}</span>
          <span class="val-count">${inContext ? valueCountsInContext[v] : 0}</span>
        </label>`;
      }).join('')}
      ${moreCount > 0 ? `<div style="font-size:10.5px; color:var(--ink-subtle); padding:6px; text-align:center; font-style:italic">+${moreCount} valores más · usa el buscador para encontrarlos</div>` : ''}
    </div>
  </div>`;
}

function renderFilterNumberCard(datasetId, colIdx, f) {
  const ds = state.datasets.find(d => d.id === datasetId);
  const col = ds.columns[colIdx];
  const isActive = f && filterHasValue(f);
  
  // Calcular min/max en contexto filtrado
  const idxsInContext = getFilteredRowIndices(datasetId, colIdx);
  const valuesInContext = idxsInContext.map(i => parseFloat(ds.rows[i][colIdx])).filter(v => !isNaN(v));
  const minVal = valuesInContext.length ? Math.min(...valuesInContext) : 0;
  const maxVal = valuesInContext.length ? Math.max(...valuesInContext) : 0;
  
  return `<div class="viz-filter-card ${isActive ? 'active' : ''}" data-col-idx="${colIdx}">
    <div class="filter-card-header">
      <div class="filter-card-name">
        <span class="col-type-mini">123</span>
        <span class="col-name-text">${escapeHtml(col.name)}</span>
      </div>
      ${isActive ? `<button class="filter-clear-btn" onclick="clearFilter('${datasetId}', ${colIdx})">Limpiar</button>` : ''}
    </div>
    
    <div class="filter-range-inputs">
      <input type="number" step="any" placeholder="Mín" value="${f?.min ?? ''}" oninput="updateFilterNumber('${datasetId}', ${colIdx}, 'min', this.value)">
      <span style="color:var(--ink-muted); font-size: 12px">a</span>
      <input type="number" step="any" placeholder="Máx" value="${f?.max ?? ''}" oninput="updateFilterNumber('${datasetId}', ${colIdx}, 'max', this.value)">
    </div>
    
    <div class="filter-range-stats">
      <span>Mín en datos: <strong>${fmtNumber(minVal)}</strong></span>
      <span>Máx: <strong>${fmtNumber(maxVal)}</strong></span>
    </div>
  </div>`;
}

function renderFilterDateCard(datasetId, colIdx, f) {
  const ds = state.datasets.find(d => d.id === datasetId);
  const col = ds.columns[colIdx];
  const isActive = f && filterHasValue(f);
  
  const idxsInContext = getFilteredRowIndices(datasetId, colIdx);
  const datesInContext = idxsInContext.map(i => String(ds.rows[i][colIdx] || '').slice(0, 10)).filter(v => v && /^\d{4}-\d{2}-\d{2}/.test(v));
  const minDate = datesInContext.length ? datesInContext.reduce((a, b) => a < b ? a : b) : '';
  const maxDate = datesInContext.length ? datesInContext.reduce((a, b) => a > b ? a : b) : '';
  
  return `<div class="viz-filter-card ${isActive ? 'active' : ''}" data-col-idx="${colIdx}">
    <div class="filter-card-header">
      <div class="filter-card-name">
        <span class="col-type-mini">📅</span>
        <span class="col-name-text">${escapeHtml(col.name)}</span>
      </div>
      ${isActive ? `<button class="filter-clear-btn" onclick="clearFilter('${datasetId}', ${colIdx})">Limpiar</button>` : ''}
    </div>
    
    <div class="filter-range-inputs">
      <input type="date" value="${f?.from || ''}" oninput="updateFilterDate('${datasetId}', ${colIdx}, 'from', this.value)">
      <span style="color:var(--ink-muted); font-size: 12px">a</span>
      <input type="date" value="${f?.to || ''}" oninput="updateFilterDate('${datasetId}', ${colIdx}, 'to', this.value)">
    </div>
    
    <div class="filter-range-stats">
      <span>Desde: <strong>${minDate || '—'}</strong></span>
      <span>Hasta: <strong>${maxDate || '—'}</strong></span>
    </div>
    
    <div class="filter-presets">
      <button class="filter-preset-btn" onclick="applyDatePreset('${datasetId}', ${colIdx}, 'last30')">Últ. 30 días</button>
      <button class="filter-preset-btn" onclick="applyDatePreset('${datasetId}', ${colIdx}, 'last90')">Últ. 90 días</button>
      <button class="filter-preset-btn" onclick="applyDatePreset('${datasetId}', ${colIdx}, 'thisYear')">Este año</button>
      <button class="filter-preset-btn" onclick="applyDatePreset('${datasetId}', ${colIdx}, 'lastYear')">Año pasado</button>
    </div>
  </div>`;
}

function toggleFiltersPanel(datasetId) {
  const fs = getFilterState(datasetId);
  fs.expanded = !fs.expanded;
  persistFilterState();
  refreshFiltersUI(datasetId);
}

function toggleFilterPropagation(datasetId, value) {
  const fs = getFilterState(datasetId);
  fs.propagate = value;
  persistFilterState();
}

function clearFilter(datasetId, colIdx) {
  const fs = getFilterState(datasetId);
  delete fs.filters[colIdx];
  persistFilterState();
  refreshFiltersUI(datasetId);
  refreshDatasetTable(datasetId);
}

function clearAllFilters(datasetId) {
  const fs = getFilterState(datasetId);
  fs.filters = {};
  persistFilterState();
  refreshFiltersUI(datasetId);
  refreshDatasetTable(datasetId);
}

function updateFilterSearch(datasetId, colIdx, value) {
  if (!window._filterSearches) window._filterSearches = {};
  window._filterSearches[`filter-search-${datasetId}-${colIdx}`] = value;
  // Solo actualizar esa card
  const cards = document.querySelectorAll('.viz-filter-card');
  // Buscar la card específica
  refreshOneFilterCard(datasetId, colIdx);
}

function refreshOneFilterCard(datasetId, colIdx) {
  // Encontrar la card en el DOM y reemplazarla
  const grid = document.querySelector('.viz-filters-grid');
  if (!grid) return;
  const cards = grid.children;
  if (cards[colIdx]) {
    const wrapper = document.createElement('div');
    wrapper.innerHTML = renderFilterCard(datasetId, colIdx);
    if (wrapper.firstElementChild) {
      // Preservar foco si estaba en el search
      const focusEl = document.activeElement;
      const wasSearchFocused = focusEl && focusEl.classList && focusEl.classList.contains('filter-search') && cards[colIdx].contains(focusEl);
      const focusValue = wasSearchFocused ? focusEl.value : null;
      cards[colIdx].replaceWith(wrapper.firstElementChild);
      if (wasSearchFocused) {
        const newCard = grid.children[colIdx];
        const newSearch = newCard.querySelector('.filter-search');
        if (newSearch) { newSearch.focus(); newSearch.setSelectionRange((focusValue || '').length, (focusValue || '').length); }
      }
    }
  }
}

function toggleFilterTextValueByIdx(datasetId, colIdx, valIdx, checked) {
  const regKey = `${datasetId}__${colIdx}`;
  const allValues = _filterValueRegistry[regKey];
  if (!allValues) return;
  const value = allValues[valIdx];
  if (value === undefined) return;
  
  const fs = getFilterState(datasetId);
  
  // Si no hay filtro, currentSelected = TODOS los valores
  let currentSelected;
  if (!fs.filters[colIdx]) {
    currentSelected = [...allValues];
  } else {
    currentSelected = [...fs.filters[colIdx].selected];
  }
  
  if (checked) {
    if (!currentSelected.includes(value)) currentSelected.push(value);
  } else {
    currentSelected = currentSelected.filter(v => v !== value);
  }
  
  // Aplicar nuevo estado
  if (currentSelected.length === allValues.length) {
    // Todos seleccionados = sin filtro
    delete fs.filters[colIdx];
  } else {
    fs.filters[colIdx] = { type: 'text', selected: currentSelected };
  }
  
  persistFilterState();
  refreshOtherFilterCards(datasetId, colIdx);
  refreshFilterChips(datasetId);
  refreshDatasetTable(datasetId);
}

function filterTextSelectAll(datasetId, colIdx, all) {
  const fs = getFilterState(datasetId);
  const regKey = `${datasetId}__${colIdx}`;
  const allValues = _filterValueRegistry[regKey];
  if (!allValues) return;
  
  if (all) {
    // "Todos" = sin filtro
    delete fs.filters[colIdx];
  } else {
    // "Ninguno" = array vacío explícito (oculta TODAS las filas)
    fs.filters[colIdx] = { type: 'text', selected: [] };
  }
  
  persistFilterState();
  // Re-render esta card también (los checkboxes deben actualizarse)
  refreshFiltersUI(datasetId);
  refreshDatasetTable(datasetId);
}

function filterTextSelectOnlyVisible(datasetId, colIdx) {
  const fs = getFilterState(datasetId);
  const regKey = `${datasetId}__${colIdx}`;
  const allValues = _filterValueRegistry[regKey];
  if (!allValues) return;
  
  const searchKey = `filter-search-${datasetId}-${colIdx}`;
  const searchValue = (window._filterSearches || {})[searchKey] || '';
  
  if (!searchValue) {
    // Sin búsqueda, "Solo visibles" no tiene sentido — equivale a "Todos"
    delete fs.filters[colIdx];
  } else {
    const visible = allValues.filter(v => v.toLowerCase().includes(searchValue.toLowerCase()));
    if (visible.length === allValues.length) {
      delete fs.filters[colIdx];
    } else if (visible.length === 0) {
      fs.filters[colIdx] = { type: 'text', selected: [] };
    } else {
      fs.filters[colIdx] = { type: 'text', selected: visible };
    }
  }
  
  persistFilterState();
  refreshFiltersUI(datasetId);
  refreshDatasetTable(datasetId);
}

// Refrescar todas las cards EXCEPTO una específica (para no perder foco/scroll en la que el usuario está editando)
function refreshOtherFilterCards(datasetId, exceptColIdx) {
  const grid = document.querySelector('.viz-filters-grid');
  if (!grid) return;
  Array.from(grid.children).forEach((card, idx) => {
    const cardColIdx = parseInt(card.dataset.colIdx);
    if (cardColIdx === exceptColIdx) return; // saltar la card actual
    if (isNaN(cardColIdx)) return;
    
    const wrapper = document.createElement('div');
    wrapper.innerHTML = renderFilterCard(datasetId, cardColIdx);
    if (wrapper.firstElementChild) {
      card.replaceWith(wrapper.firstElementChild);
    }
  });
}

// Refrescar solo los chips de filtros activos y el contador
function refreshFilterChips(datasetId) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  const fs = getFilterState(datasetId);
  const filteredIdx = getFilteredRowIndices(datasetId);
  
  // Actualizar contador en el header
  const countEl = document.querySelector('.viz-filters-header .row-count');
  if (countEl) {
    countEl.innerHTML = `<strong>${fmtNumber(filteredIdx.length)}</strong> de ${fmtNumber(ds.rows.length)} filas${filteredIdx.length < ds.rows.length ? ' visibles' : ''}`;
  }
  
  // Actualizar chips
  const chipsContainer = document.querySelector('.viz-filters-chips');
  if (chipsContainer) {
    const activeChips = [];
    Object.entries(fs.filters || {}).forEach(([colIdx, f]) => {
      if (filterHasValue(f)) {
        const idx = parseInt(colIdx);
        const col = ds.columns[idx];
        if (col) {
          activeChips.push(`<div class="viz-filters-chip">
            <span class="chip-col">${escapeHtml(col.name)}</span>
            <span class="chip-val">${escapeHtml(summarizeFilter(ds, idx, f))}</span>
            <span class="chip-remove" data-action="clear-filter" data-dsid="${datasetId}" data-col="${idx}">×</span>
          </div>`);
        }
      }
    });
    chipsContainer.innerHTML = `<span class="chips-label">Activos:</span>${activeChips.length ? activeChips.join('') + `<button class="viz-filters-chip" style="background: var(--bg-sunken); color: var(--ink-muted); border: 1px solid var(--line); cursor: pointer" data-action="clear-all" data-dsid="${datasetId}">Limpiar todos</button>` : '<span class="viz-filters-empty">Sin filtros aplicados — todas las filas visibles</span>'}`;
  }
}

// (Event delegation eliminado: ahora se usa onclick/onchange/oninput inline, más confiable)

function updateFilterNumber(datasetId, colIdx, which, value) {
  const fs = getFilterState(datasetId);
  if (!fs.filters[colIdx] || fs.filters[colIdx].type !== 'number') {
    fs.filters[colIdx] = { type: 'number', min: null, max: null };
  }
  fs.filters[colIdx][which] = value === '' ? null : parseFloat(value);
  if (!filterHasValue(fs.filters[colIdx])) delete fs.filters[colIdx];
  persistFilterState();
  // Debounced para no rerender en cada tecla
  if (!window._filterNumberDebounce) window._filterNumberDebounce = {};
  clearTimeout(window._filterNumberDebounce[datasetId]);
  window._filterNumberDebounce[datasetId] = setTimeout(() => {
    refreshFiltersUI(datasetId);
    refreshDatasetTable(datasetId);
  }, 400);
}

function updateFilterDate(datasetId, colIdx, which, value) {
  const fs = getFilterState(datasetId);
  if (!fs.filters[colIdx] || fs.filters[colIdx].type !== 'date') {
    fs.filters[colIdx] = { type: 'date', from: null, to: null };
  }
  fs.filters[colIdx][which] = value || null;
  if (!filterHasValue(fs.filters[colIdx])) delete fs.filters[colIdx];
  persistFilterState();
  refreshFiltersUI(datasetId);
  refreshDatasetTable(datasetId);
}

function applyDatePreset(datasetId, colIdx, preset) {
  const fs = getFilterState(datasetId);
  const today = new Date();
  const fmt = d => d.toISOString().slice(0, 10);
  let from, to;
  if (preset === 'last30') {
    from = new Date(today); from.setDate(today.getDate() - 30);
    to = today;
  } else if (preset === 'last90') {
    from = new Date(today); from.setDate(today.getDate() - 90);
    to = today;
  } else if (preset === 'thisYear') {
    from = new Date(today.getFullYear(), 0, 1);
    to = new Date(today.getFullYear(), 11, 31);
  } else if (preset === 'lastYear') {
    from = new Date(today.getFullYear() - 1, 0, 1);
    to = new Date(today.getFullYear() - 1, 11, 31);
  }
  fs.filters[colIdx] = { type: 'date', from: fmt(from), to: fmt(to) };
  persistFilterState();
  refreshFiltersUI(datasetId);
  refreshDatasetTable(datasetId);
}

function refreshFiltersUI(datasetId) {
  // Refrescar todo el panel de filtros sin re-render completo del dataset
  const panel = document.querySelector('.viz-filters-panel');
  if (panel) {
    const wrapper = document.createElement('div');
    wrapper.innerHTML = renderFiltersPanel(datasetId);
    if (wrapper.firstElementChild) {
      panel.replaceWith(wrapper.firstElementChild);
    }
  }
}

function refreshDatasetTable(datasetId) {
  // Re-renderiza el detalle completo del dataset, manteniendo el scroll
  const scroll = document.getElementById('main-content')?.scrollTop || 0;
  if (vizSelectedDatasetId === datasetId && vizTab === 'datasets') {
    renderVisualizaciones();
    setTimeout(() => {
      const mc = document.getElementById('main-content');
      if (mc) mc.scrollTop = scroll;
    }, 10);
  }
}

function createDatasetFromFilter(datasetId) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  const idxs = getFilteredRowIndices(datasetId);
  if (idxs.length === 0) { toast('No hay filas que cumplan los filtros'); return; }
  
  const newDs = {
    id: uid(),
    name: ds.name + ' (filtrado)',
    description: `Dataset filtrado desde "${ds.name}" el ${new Date().toLocaleDateString('es-CL')} · ${idxs.length} de ${ds.rows.length} filas`,
    columns: JSON.parse(JSON.stringify(ds.columns)),
    rows: idxs.map(i => [...ds.rows[i]])
  };
  state.datasets.push(newDs);
  vizSelectedDatasetId = newDs.id;
  save();
  renderVisualizaciones();
  toast(`Dataset creado con ${idxs.length} filas`);
}

// Helper para que otras funciones obtengan datos filtrados según el switch
function getDatasetEffectiveRows(datasetId, forceFilter) {
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return { rows: [], indices: [] };
  const fs = getFilterState(datasetId);
  const shouldFilter = forceFilter || fs.propagate;
  if (!shouldFilter) return { rows: ds.rows, indices: ds.rows.map((_, i) => i) };
  const indices = getFilteredRowIndices(datasetId);
  return { rows: indices.map(i => ds.rows[i]), indices };
}

function exportDatasetXLSX(datasetId) {
  if (!window.XLSX) { toast('Librería de Excel no disponible'); return; }
  const ds = state.datasets.find(d => d.id === datasetId);
  if (!ds) return;
  
  // Respetar búsqueda activa si la hay
  const vs = datasetViewState[datasetId];
  let rowsToExport = ds.rows;
  let hasSearch = false;
  if (vs && vs.search && vs.search.trim()) {
    const q = vs.search.trim().toLowerCase();
    rowsToExport = ds.rows.filter(row => row.some(v => String(v == null ? '' : v).toLowerCase().includes(q)));
    hasSearch = true;
  }
  
  const aoa = [
    ds.columns.map(c => c.name),
    ...rowsToExport
  ];
  
  const ws = XLSX.utils.aoa_to_sheet(aoa);
  
  const colWidths = ds.columns.map((c, i) => {
    const maxLen = Math.max(c.name.length, ...rowsToExport.map(r => String(r[i] || '').length));
    return { wch: Math.min(50, Math.max(10, maxLen + 2)) };
  });
  ws['!cols'] = colWidths;
  
  const wb = XLSX.utils.book_new();
  const sheetName = ds.name.slice(0, 31).replace(/[\\\/\?\*\[\]:]/g, '_');
  XLSX.utils.book_append_sheet(wb, ws, sheetName);
  
  const suffix = hasSearch ? '_busqueda' : '';
  XLSX.writeFile(wb, `${ds.name.replace(/[^a-zA-Z0-9_\-]/g, '_')}${suffix}.xlsx`);
  toast(hasSearch ? `Excel descargado (${rowsToExport.length} filas coinciden)` : 'Excel descargado');
}

