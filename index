function addBPMNNode(pid, type) {
  const p = state.processes.find(x => x.id === pid);
  const bpmn = ensureBPMN(p);
  // Determinar posición inicial razonable
  const minX = bpmn.lanes.length || bpmn.phases.length ? BPMN_HEADER_W + 60 : 100;
  const minY = bpmn.phases.length ? BPMN_PHASE_H + 50 : 80;
  let x, y;
  if (bpmn.nodes.length > 0) {
    const last = bpmn.nodes[bpmn.nodes.length - 1];
    x = last.x + 160; y = last.y;
    const rightLimit = bpmn.phases.length ? bpmnContentRight(bpmn) - 60 : 1060;
    if (x > rightLimit) { x = minX; y = last.y + 110; }
  } else {
    x = minX + 40; y = minY + (bpmn.lanes.length ? (bpmn.lanes[0].height || BPMN_LANE_DEFAULT_H) / 2 : 100);
  }
  bpmn.nodes.push({ id: uid(), type, x, y, label: '' });
  save(); renderProcesos();
}

