    <h2>4. Indicadores Institucionales</h2>
    ${kpiRows.length ? repTable(['Indicador', 'Actual', 'Meta', 'Cumplimiento', 'Estado'], kpiRows) : '<p>Sin indicadores.</p>'}
    
