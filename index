.project-detail-header .pd-title { font-family: 'Instrument Serif', serif; font-size: 34px; line-height: 1.1; margin-bottom: 6px; }
.project-detail-header .pd-meta { display: flex; gap: 18px; flex-wrap: wrap; font-size: 12.5px; color: var(--ink-muted); margin-bottom: 16px; }
