    return [
      `<strong>${escapeHtml(k.code)}</strong> ${escapeHtml(k.name)}`,
      v === null ? '—' : `${fmtNumber(v)} ${escapeHtml(k.unit || '')}`,
      `${fmtNumber(k.target)}`,
      `${Math.round(progress)}%`,
      repTag(s === 'green' ? 'En meta' : s === 'yellow' ? 'En alerta' : s === 'red' ? 'Crítico' : 'Sin datos', kpiTagColor(k))
    ];
  });
  
  const milestoneRows = state.milestones.map(m => [
    `<strong>${escapeHtml(m.code)}</strong>`,
