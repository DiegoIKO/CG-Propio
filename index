    .rep-tag { padding: 1pt 6pt; font-size: 8pt; font-weight: bold; text-transform: uppercase; }
    .rep-tag-green { background: #e8f0e3; color: #4a7c4a; }
    .rep-tag-yellow { background: #f5ecd0; color: #8a6a1a; }
    .rep-tag-red { background: #f0dede; color: #a83e3e; }
    .rep-tag-blue { background: #e0e7ef; color: #3d5a80; }
    .rep-tag-gray { background: #efeae0; color: #6b6357; }
    .rep-cover { text-align: center; padding: 60pt 20pt; border-bottom: 2pt solid #15110d; margin-bottom: 20pt; }
    .rep-cover h1 { font-size: 42pt; }
    .rep-cover .institution { font-size: 10pt; text-transform: uppercase; letter-spacing: 2pt; }
    .rep-cover .subtitle { font-size: 14pt; color: #6b6357; font-style: italic; }
