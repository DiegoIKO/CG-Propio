/* ----- Priorización multicriterio ----- */
function renderMulticriterio() {
  const list = state.multicriteria || [];
  if (analisisSelectedId) {
    const m = list.find(x => x.id === analisisSelectedId);
    if (m) return renderMultiDetail(m);
  }
  if (!list.length) return emptyState('Sin matrices de priorización', 'Crea la primera. Permite comparar alternativas usando criterios ponderados.');
  return `<div class="grid grid-cols-1 md:grid-cols-2 gap-4">${list.map(m => `
    <div class="card p-4 cursor-pointer" onclick="selectAnalisis('${m.id}')">
      <div class="meta-label mb-1">Priorización Multicriterio</div>
      <div class="font-serif text-xl mb-2">${escapeHtml(m.name)}</div>
      <div class="text-xs" style="color:var(--ink-muted)">${(m.criteria || []).length} criterios · ${(m.alternatives || []).length} alternativas</div>
    </div>`).join('')}</div>`;
}
function renderMultiDetail(m) {
  if (!m.criteria) m.criteria = [];
  if (!m.alternatives) m.alternatives = [];
  if (!m.scores) m.scores = {};
  // Calcular puntaje
  const totalWeight = m.criteria.reduce((s, c) => s + (Number(c.weight) || 0), 0) || 1;
  const scoresArr = m.alternatives.map(a => {
    let total = 0;
    m.criteria.forEach(c => {
      const v = Number((m.scores[a.id] || {})[c.id]) || 0;
      total += v * (Number(c.weight) || 0);
    });
    return { id: a.id, name: a.name, score: total / totalWeight };
  }).sort((x, y) => y.score - x.score);
  
  return `<div class="space-y-4">
    <div class="flex items-center justify-between">
      <div><div class="meta-label">Priorización Multicriterio</div><div class="font-serif text-3xl">${escapeHtml(m.name)}</div></div>
      <div class="flex gap-2">
        <button class="btn btn-secondary" onclick="analisisSelectedId=null; renderAnalisis()">← Volver</button>
        <button class="btn btn-danger" onclick="deleteMulti('${m.id}')">Eliminar</button>
      </div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="card p-4">
        <div class="flex items-center justify-between mb-3"><div class="meta-label">Criterios</div><button class="btn btn-secondary btn-sm" onclick="addMultiCriterion('${m.id}')">+ Criterio</button></div>
        <table class="data-table" style="font-size:12px">
          <thead><tr><th>Criterio</th><th style="width:80px">Peso</th><th></th></tr></thead>
          <tbody>${m.criteria.map(c => `<tr>
            <td><input class="input input-sm" value="${escapeHtml(c.name)}" onchange="updateMultiCriterion('${m.id}', '${c.id}', 'name', this.value)"></td>
            <td><input class="input input-sm" type="number" value="${c.weight}" onchange="updateMultiCriterion('${m.id}', '${c.id}', 'weight', this.value)"></td>
            <td><button class="btn btn-ghost btn-icon" onclick="removeMultiCriterion('${m.id}', '${c.id}')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button></td>
          </tr>`).join('') || `<tr><td colspan="3" class="text-center py-3 text-xs" style="color:var(--ink-muted)">Sin criterios</td></tr>`}</tbody>
        </table>
      </div>
      <div class="card p-4">
        <div class="flex items-center justify-between mb-3"><div class="meta-label">Alternativas</div><button class="btn btn-secondary btn-sm" onclick="addMultiAlternative('${m.id}')">+ Alternativa</button></div>
        <table class="data-table" style="font-size:12px">
          <thead><tr><th>Alternativa</th><th></th></tr></thead>
          <tbody>${m.alternatives.map(a => `<tr>
            <td><input class="input input-sm" value="${escapeHtml(a.name)}" onchange="updateMultiAlternative('${m.id}', '${a.id}', this.value)"></td>
            <td><button class="btn btn-ghost btn-icon" onclick="removeMultiAlternative('${m.id}', '${a.id}')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button></td>
          </tr>`).join('') || `<tr><td colspan="2" class="text-center py-3 text-xs" style="color:var(--ink-muted)">Sin alternativas</td></tr>`}</tbody>
        </table>
      </div>
    </div>
    
    ${m.criteria.length && m.alternatives.length ? `
    <div class="card p-4">
      <div class="meta-label mb-3">Matriz de evaluación · escala 1-5</div>
      <div class="overflow-x-auto">
        <table class="data-table" style="font-size:12px">
          <thead><tr><th>Alternativa</th>${m.criteria.map(c => `<th>${escapeHtml(c.name)}<br><span style="font-weight:400">(peso ${c.weight})</span></th>`).join('')}<th>Puntaje</th></tr></thead>
          <tbody>${m.alternatives.map(a => {
            const sc = scoresArr.find(s => s.id === a.id);
            return `<tr>
              <td><strong>${escapeHtml(a.name)}</strong></td>
              ${m.criteria.map(c => `<td><input class="input input-sm" type="number" min="1" max="5" value="${((m.scores[a.id] || {})[c.id]) || ''}" placeholder="1-5" onchange="updateMultiScore('${m.id}', '${a.id}', '${c.id}', this.value)" style="width:60px"></td>`).join('')}
              <td><span class="badge badge-${sc.score >= 4 ? 'green' : sc.score >= 3 ? 'yellow' : 'red'}">${sc.score.toFixed(2)}</span></td>
            </tr>`;
          }).join('')}</tbody>
        </table>
      </div>
    </div>
    <div class="card p-4">
      <div class="meta-label mb-3">Ranking</div>
      <div class="space-y-2">${scoresArr.map((s, i) => `<div class="flex items-center gap-3 p-2" style="background:var(--bg-sunken); border-radius:6px">
        <span class="font-serif text-2xl" style="width:40px">${i + 1}</span>
        <div class="flex-1"><div class="font-medium">${escapeHtml(s.name)}</div></div>
        <div class="font-mono text-lg font-semibold">${s.score.toFixed(2)}</div>
      </div>`).join('')}</div>
    </div>` : ''}
  </div>`;
}
function addMultiCriterion(id) {
  const m = state.multicriteria.find(x => x.id === id);
  if (!m.criteria) m.criteria = [];
  m.criteria.push({ id: uid(), name: 'Nuevo criterio', weight: 1 });
  save(); renderAnalisis();
}
function updateMultiCriterion(mid, cid, f, v) {
  const m = state.multicriteria.find(x => x.id === mid);
  const c = m.criteria.find(x => x.id === cid);
  c[f] = f === 'weight' ? Number(v) : v; save();
}
function removeMultiCriterion(mid, cid) {
  const m = state.multicriteria.find(x => x.id === mid);
  m.criteria = m.criteria.filter(c => c.id !== cid);
  Object.values(m.scores || {}).forEach(sc => delete sc[cid]);
  save(); renderAnalisis();
}
function addMultiAlternative(id) {
  const m = state.multicriteria.find(x => x.id === id);
  if (!m.alternatives) m.alternatives = [];
  m.alternatives.push({ id: uid(), name: 'Nueva alternativa' });
  save(); renderAnalisis();
}
function updateMultiAlternative(mid, aid, v) {
  const m = state.multicriteria.find(x => x.id === mid);
  const a = m.alternatives.find(x => x.id === aid); a.name = v; save();
}
function removeMultiAlternative(mid, aid) {
  const m = state.multicriteria.find(x => x.id === mid);
  m.alternatives = m.alternatives.filter(a => a.id !== aid);
  delete (m.scores || {})[aid];
  save(); renderAnalisis();
}
function updateMultiScore(mid, aid, cid, v) {
  const m = state.multicriteria.find(x => x.id === mid);
  if (!m.scores) m.scores = {};
  if (!m.scores[aid]) m.scores[aid] = {};
  m.scores[aid][cid] = Math.max(1, Math.min(5, Number(v) || 0));
  save(); renderAnalisis();
}
function openMultiForm() {
  const body = `<div class="space-y-3">${field('Nombre de la matriz', inputField('f-mc-name', '', 'text', 'Ej: Selección de proveedor sistema documental'))}</div>`;
  openModal({ title: 'Nueva matriz multicriterio', body, footer: `<button class="btn btn-secondary" data-action="close-modal">Cancelar</button><button class="btn btn-primary" id="btn-save-mc">Crear</button>` });
  document.getElementById('btn-save-mc').onclick = () => {
    const name = document.getElementById('f-mc-name').value.trim();
    if (!name) { toast('Nombre obligatorio'); return; }
    const m = { id: uid(), name, criteria: [{ id: uid(), name: 'Costo', weight: 3 }, { id: uid(), name: 'Impacto', weight: 5 }, { id: uid(), name: 'Tiempo', weight: 2 }], alternatives: [], scores: {} };
    state.multicriteria.push(m); analisisSelectedId = m.id;
    save(); closeModal(); renderAnalisis(); toast('Matriz creada');
  };
}
function deleteMulti(id) {
  if (!confirm('¿Eliminar?')) return;
  state.multicriteria = state.multicriteria.filter(m => m.id !== id);
  analisisSelectedId = null; save(); renderAnalisis(); toast('Eliminada');
}


