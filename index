<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GESTIO·OS — Sistema Integral de Control de Gestión</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/date-fns@2.30.0/index.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f7f4ee; --bg-elevated: #ffffff; --bg-sunken: #efeae0;
  --ink: #15110d; --ink-muted: #6b6357; --ink-subtle: #a39a8c;
  --line: #e3ddd0; --line-strong: #c9c0ae;
  --accent: #1e3a3a; --warm: #b85c2e;
  --green: #4a7c4a; --green-soft: #e8f0e3;
  --yellow: #c89d2c; --yellow-soft: #f5ecd0;
  --red: #a83e3e; --red-soft: #f0dede;
  --blue: #3d5a80; --blue-soft: #e0e7ef;
  --purple: #6b4d8a; --purple-soft: #ece3f0;
}
* { box-sizing: border-box; }
html, body { height: 100%; }
body { margin: 0; font-family: 'IBM Plex Sans', system-ui, sans-serif; background: var(--bg); color: var(--ink); -webkit-font-smoothing: antialiased; }
.font-serif { font-family: 'Instrument Serif', Georgia, serif; font-weight: 400; }
.font-mono { font-family: 'JetBrains Mono', monospace; }
body::before { content: ''; position: fixed; inset: 0; background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.015) 1px, transparent 0); background-size: 3px 3px; pointer-events: none; z-index: 1; }
.app-shell { position: relative; z-index: 2; }

.sidebar { background: var(--bg-sunken); border-right: 1px solid var(--line); }
.nav-item { display: flex; align-items: center; gap: 10px; padding: 7px 12px; margin: 1px 8px; border-radius: 6px; color: var(--ink-muted); font-size: 13px; font-weight: 500; cursor: pointer; transition: all .15s ease; user-select: none; }
.nav-item:hover { background: rgba(0,0,0,.04); color: var(--ink); }
.nav-item.active { background: var(--ink); color: var(--bg); }
.nav-item .nav-icon { width: 15px; height: 15px; flex-shrink: 0; opacity: .85; }
.nav-section { font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-subtle); padding: 12px 20px 4px; font-weight: 600; }

.card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px; }
.card-soft { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; }

.btn { display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer; transition: all .15s ease; border: 1px solid transparent; white-space: nowrap; }
.btn-primary { background: var(--ink); color: var(--bg); }
.btn-primary:hover { background: var(--accent); }
.btn-secondary { background: var(--bg-elevated); color: var(--ink); border-color: var(--line-strong); }
.btn-secondary:hover { background: var(--bg-sunken); }
.btn-ghost { background: transparent; color: var(--ink-muted); }
.btn-ghost:hover { background: var(--bg-sunken); color: var(--ink); }
.btn-danger { background: var(--red); color: white; }
.btn-danger:hover { background: #8a3232; }
.btn-icon { padding: 6px; width: 30px; height: 30px; justify-content: center; }
.btn-sm { padding: 4px 10px; font-size: 12px; }

.input, .select, .textarea { width: 100%; padding: 8px 12px; border: 1px solid var(--line-strong); border-radius: 6px; background: var(--bg-elevated); font-family: inherit; font-size: 13.5px; color: var(--ink); transition: border-color .15s ease; }
.input:focus, .select:focus, .textarea:focus { outline: none; border-color: var(--ink); box-shadow: 0 0 0 3px rgba(0,0,0,.05); }
.textarea { resize: vertical; min-height: 80px; font-family: inherit; }
.input-sm { padding: 5px 8px; font-size: 12.5px; }
label.form-label { display: block; font-size: 11px; font-weight: 600; color: var(--ink-muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .04em; }

.badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
.badge-green { background: var(--green-soft); color: var(--green); }
.badge-yellow { background: var(--yellow-soft); color: #8a6a1a; }
.badge-red { background: var(--red-soft); color: var(--red); }
.badge-blue { background: var(--blue-soft); color: var(--blue); }
.badge-purple { background: var(--purple-soft); color: var(--purple); }
.badge-gray { background: var(--bg-sunken); color: var(--ink-muted); }
.badge-dark { background: var(--ink); color: var(--bg); }

.dot { width: 8px; height: 8px; border-radius: 999px; display: inline-block; }
.dot-green { background: var(--green); } .dot-yellow { background: var(--yellow); }
.dot-red { background: var(--red); } .dot-blue { background: var(--blue); }
.dot-gray { background: var(--ink-subtle); } .dot-purple { background: var(--purple); }

table.data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
table.data-table th { text-align: left; padding: 10px 12px; font-weight: 600; color: var(--ink-muted); border-bottom: 1px solid var(--line); font-size: 11px; text-transform: uppercase; letter-spacing: .05em; background: var(--bg-sunken); }
table.data-table td { padding: 10px 12px; border-bottom: 1px solid var(--line); vertical-align: middle; }
table.data-table tr:hover td { background: rgba(0,0,0,.015); }
table.data-table tr:last-child td { border-bottom: none; }

.modal-backdrop { position: fixed; inset: 0; background: rgba(15, 11, 7, 0.5); backdrop-filter: blur(4px); z-index: 100; display: flex; align-items: flex-start; justify-content: center; padding-top: 5vh; animation: fadeIn .15s ease; }
.modal { background: var(--bg-elevated); border-radius: 10px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,.2); animation: slideUp .2s ease; }
.modal-wide { max-width: 900px; }
.modal-xwide { max-width: 1200px; }
.modal-narrow { max-width: 440px; }
.modal-header { padding: 16px 24px; border-bottom: 1px solid var(--line); display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: var(--bg-elevated); z-index: 5; }
.modal-body { padding: 20px 24px; }
.modal-footer { padding: 14px 24px; border-top: 1px solid var(--line); display: flex; justify-content: flex-end; gap: 8px; background: var(--bg-sunken); border-radius: 0 0 10px 10px; position: sticky; bottom: 0; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

.kpi-card { padding: 18px; }
.kpi-label { font-size: 11px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }
.kpi-value { font-size: 30px; font-weight: 600; line-height: 1; }
.kpi-delta { font-size: 12px; color: var(--ink-muted); margin-top: 6px; }

.kanban-board { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; min-height: 500px; }
.kanban-col { background: var(--bg-sunken); border-radius: 8px; padding: 10px; display: flex; flex-direction: column; gap: 8px; }
.kanban-col-header { display: flex; align-items: center; justify-content: space-between; padding: 4px 8px 8px; font-size: 11.5px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .04em; }
.kanban-card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; padding: 10px; cursor: grab; transition: all .15s ease; }
.kanban-card:active { cursor: grabbing; }
.kanban-card:hover { border-color: var(--line-strong); transform: translateY(-1px); }
.kanban-card.dragging { opacity: .4; }
.kanban-col.drag-over { background: rgba(30,58,58,.06); }

.risk-matrix { display: grid; grid-template-columns: 60px repeat(5, 1fr); gap: 4px; }
.risk-cell { aspect-ratio: 1.4; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: rgba(0,0,0,.4); cursor: pointer; transition: all .15s ease; position: relative; background: var(--bg-sunken); }
.risk-cell:hover { transform: scale(1.04); z-index: 2; }
.risk-cell .count { position: absolute; background: var(--ink); color: var(--bg); border-radius: 999px; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 11.5px; font-weight: 600; }
.risk-axis-label { font-size: 10px; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .05em; font-weight: 600; display: flex; align-items: center; justify-content: center; }

.ishikawa-cause { background: var(--bg-sunken); padding: 6px 10px; border-radius: 4px; margin: 4px 0; font-size: 13px; display: flex; align-items: center; justify-content: space-between; gap: 8px; }

.toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 200; display: flex; flex-direction: column; gap: 8px; }
.toast { background: var(--ink); color: var(--bg); padding: 10px 16px; border-radius: 6px; font-size: 13px; box-shadow: 0 8px 24px rgba(0,0,0,.2); animation: slideInRight .2s ease; min-width: 240px; }
@keyframes slideInRight { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

.scroll-area::-webkit-scrollbar { width: 8px; height: 8px; }
.scroll-area::-webkit-scrollbar-track { background: transparent; }
.scroll-area::-webkit-scrollbar-thumb { background: var(--line-strong); border-radius: 4px; }
.scroll-area::-webkit-scrollbar-thumb:hover { background: var(--ink-subtle); }

.meta-label { font-size: 11px; color: var(--ink-subtle); text-transform: uppercase; letter-spacing: .05em; font-weight: 600; }
.empty-state { padding: 60px 20px; text-align: center; color: var(--ink-muted); }
.empty-state .empty-icon { width: 48px; height: 48px; margin: 0 auto 16px; opacity: .3; }

.pill-tab { padding: 6px 14px; border-radius: 999px; font-size: 13px; font-weight: 500; color: var(--ink-muted); cursor: pointer; transition: all .15s ease; }
.pill-tab.active { background: var(--ink); color: var(--bg); }
.pill-tab:not(.active):hover { background: var(--bg-sunken); }

details.action-collapse > summary { cursor: pointer; list-style: none; padding: 8px 12px; background: var(--bg-sunken); border-radius: 6px; font-size: 13px; font-weight: 500; }
details.action-collapse > summary::-webkit-details-marker { display: none; }
details.action-collapse[open] > summary { border-radius: 6px 6px 0 0; }

.bsc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.bsc-quadrant { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px; padding: 16px; min-height: 200px; }
.bsc-quadrant.persp-financial { border-top: 3px solid var(--warm); }
.bsc-quadrant.persp-customer { border-top: 3px solid var(--blue); }
.bsc-quadrant.persp-process { border-top: 3px solid var(--green); }
.bsc-quadrant.persp-learning { border-top: 3px solid var(--purple); }

.tree-node { padding: 6px 10px; border-radius: 4px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 6px; }
.tree-node:hover { background: var(--bg-sunken); }
.tree-node.selected { background: var(--ink); color: var(--bg); }
.tree-children { margin-left: 18px; border-left: 1px dashed var(--line-strong); padding-left: 8px; }

.sipoc-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; }
.sipoc-col { background: var(--bg-sunken); border-radius: 6px; padding: 10px; min-height: 200px; }
.sipoc-col-header { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-muted); margin-bottom: 8px; text-align: center; }
.sipoc-item { background: var(--bg-elevated); padding: 6px 8px; border-radius: 4px; font-size: 12.5px; margin-bottom: 4px; display: flex; align-items: center; justify-content: space-between; gap: 4px; border: 1px solid var(--line); }

.ei-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.ei-quadrant { background: var(--bg-sunken); border-radius: 6px; padding: 12px; min-height: 200px; }
.ei-quadrant-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: var(--ink-muted); margin-bottom: 8px; }
.ei-item { background: var(--bg-elevated); padding: 6px 8px; border-radius: 4px; font-size: 12px; margin-bottom: 4px; cursor: grab; border: 1px solid var(--line); display: flex; align-items: center; justify-content: space-between; gap: 4px; }
.ei-item:active { cursor: grabbing; }
.ei-item.dragging { opacity: .4; }
.ei-quadrant.drag-over { background: rgba(30,58,58,.1); }

.ss-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 6px; background: var(--bg-elevated); }
.ss-table { border-collapse: collapse; width: 100%; font-size: 13px; }
.ss-table th, .ss-table td { border: 1px solid var(--line); padding: 0; min-width: 120px; position: relative; }
.ss-table th { background: var(--bg-sunken); padding: 0; text-align: left; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; color: var(--ink-muted); }
.ss-table th .ss-th-inner { display: flex; align-items: center; gap: 4px; padding: 6px 8px; }
.ss-table th .ss-col-name { border: 1px solid transparent; background: transparent; padding: 3px 6px; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; color: var(--ink-muted); border-radius: 4px; flex: 1; min-width: 0; }
.ss-table th .ss-col-name:hover { background: var(--bg-elevated); border-color: var(--line); }
.ss-table th .ss-col-name:focus { outline: none; background: var(--bg-elevated); border-color: var(--ink); color: var(--ink); }
.ss-table th .ss-col-type { font-size: 10px; padding: 2px 5px; background: var(--bg-elevated); border-radius: 3px; cursor: pointer; color: var(--ink-muted); border: 1px solid var(--line); }
.ss-table th .ss-col-type:hover { background: var(--ink); color: var(--bg); }
.ss-table td { background: var(--bg-elevated); }
.ss-table td input { border: 1px solid transparent; width: 100%; padding: 8px 10px; background: transparent; font-family: inherit; font-size: 13px; color: var(--ink); }
.ss-table td input:hover { background: var(--bg-sunken); }
.ss-table td input:focus { outline: none; background: var(--bg); border: 1.5px solid var(--ink); padding: 7px 9px; }
.ss-table td.cell-number input { text-align: right; font-variant-numeric: tabular-nums; font-family: 'JetBrains Mono', monospace; font-size: 12px; }
.ss-table td.cell-date input { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink-muted); }
.ss-table tr:nth-child(even) td { background: rgba(0,0,0,.015); }
.ss-table tr:hover td { background: rgba(30,58,58,.04); }
.ss-row-num { text-align: center !important; background: var(--bg-sunken) !important; font-size: 11px; color: var(--ink-subtle); padding: 0 !important; min-width: 44px !important; max-width: 44px; }
.ss-row-num .row-num-inner { display: flex; align-items: center; justify-content: center; gap: 2px; padding: 4px 2px; }
.ss-row-num button { opacity: 0; transition: opacity .15s; }
.ss-table tr:hover .ss-row-num button { opacity: 1; }
.ss-empty-msg { padding: 32px 16px; text-align: center; color: var(--ink-muted); font-size: 13px; }

/* Gráficos mejorados */
.chart-card { background: linear-gradient(180deg, var(--bg-elevated) 0%, var(--bg) 100%); border: 1px solid var(--line); border-radius: 10px; padding: 20px; transition: all .25s ease; position: relative; overflow: hidden; }
.chart-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(21, 17, 13, 0.08); border-color: var(--line-strong); }
.chart-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--accent) 0%, var(--blue) 50%, var(--purple) 100%); opacity: 0.7; }
.chart-card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 14px; padding-bottom: 14px; border-bottom: 1px dashed var(--line); }
.chart-card-title { font-family: 'Instrument Serif', serif; font-size: 22px; line-height: 1.1; color: var(--ink); margin-bottom: 4px; }
.chart-card-meta { font-size: 11px; color: var(--ink-muted); display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
.chart-card-canvas-wrap { background: var(--bg); border-radius: 6px; padding: 12px 8px 8px; height: 320px; }
.chart-card-actions { display: flex; gap: 4px; }
.chart-type-badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; background: var(--bg-sunken); border-radius: 12px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-muted); }
.chart-type-badge svg { width: 11px; height: 11px; }
.chart-empty-state { background: var(--bg-elevated); border: 2px dashed var(--line-strong); border-radius: 12px; padding: 60px 40px; text-align: center; }
.chart-empty-state .icon-wrap { width: 64px; height: 64px; margin: 0 auto 16px; background: var(--bg-sunken); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--ink-muted); }

/* Dataset cards mejoradas */
.dataset-card { background: linear-gradient(135deg, var(--bg-elevated) 0%, #faf7ef 100%); border: 1px solid var(--line); border-radius: 10px; padding: 18px; cursor: pointer; transition: all .2s ease; position: relative; overflow: hidden; }
.dataset-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(21, 17, 13, 0.07); border-color: var(--line-strong); }
.dataset-card::after { content: ''; position: absolute; right: -30px; bottom: -30px; width: 100px; height: 100px; background: radial-gradient(circle, var(--accent) 0%, transparent 70%); opacity: 0.08; }
.dataset-card .ds-icon { width: 40px; height: 40px; background: var(--accent); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }

/* KPI Cards rediseñadas */
.kpi-card-new { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 12px; padding: 20px; transition: all .25s ease; position: relative; overflow: hidden; }
.kpi-card-new:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(21, 17, 13, 0.08); }
.kpi-card-new .status-stripe { position: absolute; top: 0; left: 0; right: 0; height: 4px; }
.kpi-card-new .status-stripe.green { background: linear-gradient(90deg, #4a7c4a 0%, #6fa86f 100%); }
.kpi-card-new .status-stripe.yellow { background: linear-gradient(90deg, #c89d2c 0%, #e0bb5a 100%); }
.kpi-card-new .status-stripe.red { background: linear-gradient(90deg, #a83e3e 0%, #cc6b6b 100%); }
.kpi-card-new .status-stripe.gray { background: linear-gradient(90deg, #a39a8c 0%, #c4bbac 100%); }
.kpi-card-new .kpi-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 16px; }
.kpi-card-new .kpi-code { font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 2px 8px; background: var(--bg-sunken); border-radius: 4px; color: var(--ink-muted); }
.kpi-card-new .kpi-name { font-family: 'Instrument Serif', serif; font-size: 22px; line-height: 1.15; color: var(--ink); margin-top: 6px; margin-bottom: 4px; }
.kpi-card-new .kpi-context { font-size: 11.5px; color: var(--ink-muted); display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
.kpi-card-new .kpi-actions { display: flex; gap: 2px; flex-shrink: 0; }
.kpi-card-new .kpi-main-value { background: linear-gradient(135deg, var(--bg-sunken) 0%, var(--bg) 100%); border-radius: 8px; padding: 16px; margin-bottom: 12px; display: grid; grid-template-columns: 1fr auto 1fr; gap: 12px; align-items: center; }
.kpi-card-new .kpi-current { text-align: left; }
.kpi-card-new .kpi-current .label { font-size: 10px; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-subtle); font-weight: 600; margin-bottom: 4px; }
.kpi-card-new .kpi-current .value { font-family: 'Instrument Serif', serif; font-size: 36px; line-height: 1; color: var(--ink); }
.kpi-card-new .kpi-current .unit { font-size: 14px; color: var(--ink-muted); margin-left: 4px; }
.kpi-card-new .kpi-trend { display: flex; align-items: center; justify-content: center; }
.kpi-card-new .kpi-trend-arrow { font-size: 24px; padding: 8px; border-radius: 50%; }
.kpi-card-new .kpi-trend-arrow.up-good { color: var(--green); background: var(--green-soft); }
.kpi-card-new .kpi-trend-arrow.up-bad { color: var(--red); background: var(--red-soft); }
.kpi-card-new .kpi-trend-arrow.down-good { color: var(--green); background: var(--green-soft); }
.kpi-card-new .kpi-trend-arrow.down-bad { color: var(--red); background: var(--red-soft); }
.kpi-card-new .kpi-trend-arrow.flat { color: var(--ink-muted); background: var(--bg-sunken); }
.kpi-card-new .kpi-target { text-align: right; }
.kpi-card-new .kpi-target .label { font-size: 10px; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-subtle); font-weight: 600; margin-bottom: 4px; }
.kpi-card-new .kpi-target .value { font-family: 'Instrument Serif', serif; font-size: 24px; line-height: 1; color: var(--ink-muted); }
.kpi-card-new .kpi-progress { margin-bottom: 14px; }
.kpi-card-new .kpi-progress-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; }
.kpi-card-new .kpi-progress-label { font-size: 11px; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .06em; font-weight: 600; }
.kpi-card-new .kpi-progress-value { font-family: 'Instrument Serif', serif; font-size: 18px; color: var(--ink); }
.kpi-card-new .kpi-progress-bar { height: 8px; background: var(--bg-sunken); border-radius: 4px; overflow: hidden; position: relative; }
.kpi-card-new .kpi-progress-fill { height: 100%; border-radius: 4px; transition: width .5s ease; }
.kpi-card-new .kpi-progress-fill.green { background: linear-gradient(90deg, #4a7c4a, #6fa86f); }
.kpi-card-new .kpi-progress-fill.yellow { background: linear-gradient(90deg, #c89d2c, #e0bb5a); }
.kpi-card-new .kpi-progress-fill.red { background: linear-gradient(90deg, #a83e3e, #cc6b6b); }
.kpi-card-new .kpi-progress-fill.gray { background: linear-gradient(90deg, #a39a8c, #c4bbac); }
.kpi-card-new .kpi-chart-wrap { height: 90px; margin-bottom: 8px; }
.kpi-card-new .kpi-meta-row { display: flex; gap: 12px; flex-wrap: wrap; font-size: 11px; color: var(--ink-muted); padding-top: 12px; border-top: 1px solid var(--line); }
.kpi-card-new .kpi-meta-row strong { color: var(--ink); font-weight: 500; }

.kpi-summary-bar { background: linear-gradient(135deg, var(--bg-elevated) 0%, #faf7ef 100%); border: 1px solid var(--line); border-radius: 12px; padding: 16px 20px; margin-bottom: 20px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
.kpi-summary-item { text-align: center; padding: 8px 4px; border-right: 1px solid var(--line); }
.kpi-summary-item:last-child { border-right: none; }
.kpi-summary-item .ks-value { font-family: 'Instrument Serif', serif; font-size: 32px; line-height: 1; }
.kpi-summary-item .ks-label { font-size: 10.5px; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .08em; font-weight: 600; margin-top: 4px; }
.kpi-summary-item.green .ks-value { color: var(--green); }
.kpi-summary-item.yellow .ks-value { color: #8a6a1a; }
.kpi-summary-item.red .ks-value { color: var(--red); }
.kpi-summary-item.gray .ks-value { color: var(--ink-muted); }

.kpi-filter-bar { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
.kpi-filter-pill { padding: 6px 14px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 999px; font-size: 12px; cursor: pointer; transition: all .15s; display: inline-flex; align-items: center; gap: 6px; }
.kpi-filter-pill:hover { border-color: var(--line-strong); }
.kpi-filter-pill.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }
.kpi-filter-pill .count { font-family: 'JetBrains Mono', monospace; font-size: 11px; opacity: 0.7; }

/* Gestión Documental mejorada */
.doc-view-toggle { display: inline-flex; background: var(--bg-sunken); border-radius: 6px; padding: 2px; }
.doc-view-toggle button { padding: 5px 12px; background: transparent; border: none; border-radius: 4px; font-size: 11.5px; cursor: pointer; color: var(--ink-muted); display: inline-flex; align-items: center; gap: 6px; }
.doc-view-toggle button.active { background: var(--bg-elevated); color: var(--ink); box-shadow: 0 1px 3px rgba(0,0,0,.06); }

.doc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
.doc-card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 10px; padding: 18px; transition: all .2s; cursor: pointer; position: relative; }
.doc-card:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,.07); }
.doc-card-icon { width: 44px; height: 52px; border-radius: 4px 8px 4px 4px; position: relative; margin-bottom: 12px; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 8px; font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 700; color: white; letter-spacing: .05em; }
.doc-card-icon::before { content: ''; position: absolute; top: 0; right: 0; width: 12px; height: 12px; background: rgba(255,255,255,0.3); clip-path: polygon(0 0, 100% 0, 100% 100%); }
.doc-card-icon.type-procedimiento { background: linear-gradient(135deg, #3d5a80 0%, #5a7d9c 100%); }
.doc-card-icon.type-manual { background: linear-gradient(135deg, #6b4d8a 0%, #8a6fa8 100%); }
.doc-card-icon.type-instructivo { background: linear-gradient(135deg, #2d5454 0%, #4a7474 100%); }
.doc-card-icon.type-politica { background: linear-gradient(135deg, #a83e3e 0%, #c66262 100%); }
.doc-card-icon.type-formato { background: linear-gradient(135deg, #c89d2c 0%, #e0bb5a 100%); color: #4a3a10; }
.doc-card-icon.type-otro { background: linear-gradient(135deg, #6b6357 0%, #8a8275 100%); }
.doc-card-code { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted); margin-bottom: 4px; }
.doc-card-title { font-family: 'Instrument Serif', serif; font-size: 18px; line-height: 1.2; margin-bottom: 6px; color: var(--ink); }
.doc-card-desc { font-size: 11.5px; color: var(--ink-muted); line-height: 1.4; margin-bottom: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 32px; }
.doc-card-meta { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; padding-top: 10px; border-top: 1px solid var(--line); font-size: 10.5px; color: var(--ink-muted); }
.doc-card-version { font-family: 'JetBrains Mono', monospace; }
.doc-card-actions { position: absolute; top: 12px; right: 12px; display: flex; gap: 2px; opacity: 0; transition: opacity .15s; }
.doc-card:hover .doc-card-actions { opacity: 1; }
.doc-card-tags { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 8px; }

/* Wiki mejorada */
.wiki-search { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; padding: 8px 12px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.wiki-search input { border: none; outline: none; background: transparent; flex: 1; font-size: 12.5px; }
.wiki-search svg { color: var(--ink-muted); }
.wiki-toc { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px; padding: 14px 16px; margin-bottom: 20px; }
.wiki-toc-title { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-muted); font-weight: 600; margin-bottom: 8px; }
.wiki-toc-list { list-style: none; padding: 0; margin: 0; }
.wiki-toc-list li { margin: 4px 0; font-size: 13px; }
.wiki-toc-list a { color: var(--ink); text-decoration: none; padding: 2px 6px; border-radius: 3px; display: block; transition: background .15s; }
.wiki-toc-list a:hover { background: var(--bg-sunken); }
.wiki-toc-list li.lvl-2 { padding-left: 14px; }
.wiki-toc-list li.lvl-3 { padding-left: 28px; font-size: 12px; color: var(--ink-muted); }
.wiki-content h1, .wiki-content h2, .wiki-content h3 { scroll-margin-top: 16px; }
.wiki-stats-bar { display: flex; gap: 16px; padding: 6px 0; font-size: 11px; color: var(--ink-muted); margin-bottom: 8px; }
.wiki-stats-bar strong { color: var(--ink); font-weight: 500; }

.org-node { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; padding: 10px; margin: 4px 0; display: flex; align-items: center; gap: 10px; }
.org-children { margin-left: 24px; padding-left: 12px; border-left: 2px solid var(--line); }

.wiki-content { font-size: 14px; line-height: 1.65; max-width: 720px; }
.wiki-content h1 { font-family: 'Instrument Serif', serif; font-size: 32px; margin: 24px 0 12px; }
.wiki-content h2 { font-family: 'Instrument Serif', serif; font-size: 24px; margin: 20px 0 10px; }
.wiki-content h3 { font-size: 18px; font-weight: 600; margin: 16px 0 8px; }
.wiki-content p { margin: 8px 0; }
.wiki-content ul, .wiki-content ol { margin: 8px 0; padding-left: 24px; }
.wiki-content li { margin: 4px 0; }
.wiki-content code { background: var(--bg-sunken); padding: 1px 6px; border-radius: 3px; font-family: 'JetBrains Mono', monospace; font-size: 13px; }
.wiki-content strong { font-weight: 600; }
.wiki-content em { font-style: italic; }
.wiki-content blockquote { border-left: 3px solid var(--ink); padding: 6px 14px; margin: 12px 0; color: var(--ink-muted); background: var(--bg-sunken); }

.problem-tree-canvas { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px; padding: 20px; }
.pt-node { background: var(--bg-sunken); padding: 8px 12px; border-radius: 6px; font-size: 13px; margin: 4px 0; display: flex; justify-content: space-between; align-items: center; gap: 8px; }
.pt-node.central { background: var(--ink); color: var(--bg); font-weight: 600; padding: 14px; }
.pt-node.causa { border-left: 3px solid var(--red); }
.pt-node.efecto { border-left: 3px solid var(--blue); }

/* Calendario */
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
.cal-day-header { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-muted); text-align: center; padding: 8px 4px; }
.cal-cell { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 4px; min-height: 88px; padding: 4px 6px; display: flex; flex-direction: column; gap: 2px; transition: background .15s; }
.cal-cell.other-month { background: var(--bg-sunken); opacity: 0.5; }
.cal-cell.today { border: 2px solid var(--ink); }
.cal-cell:hover { background: var(--bg-sunken); }
.cal-day-num { font-size: 12px; font-weight: 600; color: var(--ink-muted); }
.cal-cell.today .cal-day-num { color: var(--ink); }
.cal-event { font-size: 10.5px; padding: 2px 5px; border-radius: 3px; cursor: pointer; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.cal-event:hover { filter: brightness(0.92); }
.cal-event.ev-milestone { background: var(--purple-soft); color: var(--purple); border-left: 2px solid var(--purple); }
.cal-event.ev-project { background: var(--blue-soft); color: var(--blue); border-left: 2px solid var(--blue); }
.cal-event.ev-finding { background: var(--red-soft); color: var(--red); border-left: 2px solid var(--red); }
.cal-event.ev-commitment { background: var(--yellow-soft); color: #8a6a1a; border-left: 2px solid var(--yellow); }
.cal-event.ev-risk { background: #f5e6e0; color: var(--warm); border-left: 2px solid var(--warm); }
.cal-event.ev-task { background: #e8e9ed; color: var(--accent); border-left: 2px solid var(--accent); }
.cal-event.ev-meeting { background: #e8f0e3; color: var(--green); border-left: 2px solid var(--green); }
.cal-event.overdue { font-weight: 600; }

/* Timeline */
.timeline-wrap { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px; padding: 20px; overflow-x: auto; }
.timeline-row { display: grid; grid-template-columns: 220px 1fr; gap: 12px; margin-bottom: 8px; align-items: center; min-height: 32px; }
.timeline-row-label { font-size: 12px; color: var(--ink); }
.timeline-row-label .meta-code { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted); }
.timeline-track { background: var(--bg-sunken); border-radius: 4px; height: 24px; position: relative; }
.timeline-bar { position: absolute; top: 2px; bottom: 2px; border-radius: 3px; padding: 0 6px; font-size: 10.5px; color: white; display: flex; align-items: center; cursor: pointer; min-width: 4px; }
.timeline-bar:hover { filter: brightness(1.1); }
.timeline-bar.tl-milestone { background: var(--purple); }
.timeline-bar.tl-project { background: var(--blue); }
.timeline-bar.tl-finding { background: var(--red); }
.timeline-bar.tl-commitment { background: var(--yellow); color: #4a3a10; }
.timeline-bar.tl-risk { background: var(--warm); }
.timeline-bar.tl-task { background: var(--accent); }
.timeline-bar.tl-meeting { background: var(--green); }
.timeline-header-row { display: grid; grid-template-columns: 220px 1fr; gap: 12px; margin-bottom: 12px; }
.timeline-months { display: grid; grid-auto-flow: column; grid-auto-columns: 1fr; gap: 1px; }
.timeline-month { background: var(--bg-sunken); padding: 4px 6px; font-size: 10.5px; font-weight: 600; text-transform: uppercase; color: var(--ink-muted); text-align: center; border-radius: 3px; }
.timeline-today-marker { position: absolute; top: -4px; bottom: -4px; width: 2px; background: var(--ink); z-index: 2; }

/* BPMN editor */
.bpmn-wrap { display: grid; grid-template-columns: 200px 1fr; gap: 12px; min-height: 520px; }
.bpmn-toolbar { background: var(--bg-sunken); border-radius: 6px; padding: 12px; display: flex; flex-direction: column; gap: 8px; }
.bpmn-tool { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; padding: 10px; font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all .15s; }
.bpmn-tool:hover { border-color: var(--ink); transform: translateY(-1px); }
.bpmn-tool .bpmn-tool-shape { width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
.bpmn-canvas-wrap { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; overflow: auto; position: relative; }
.bpmn-canvas { background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.06) 1px, transparent 0); background-size: 20px 20px; cursor: default; }
.bpmn-node { cursor: move; }
.bpmn-node.selected .bpmn-node-shape { stroke: var(--accent) !important; stroke-width: 3 !important; }
.bpmn-node text { user-select: none; font-family: 'IBM Plex Sans', sans-serif; font-size: 12px; pointer-events: none; }
.bpmn-conn { stroke: var(--ink); stroke-width: 1.5; fill: none; }
.bpmn-conn.selected { stroke: var(--accent); stroke-width: 2.5; }
.bpmn-conn-hover { stroke: transparent; stroke-width: 12; fill: none; cursor: pointer; }
.bpmn-port { fill: var(--bg-elevated); stroke: var(--accent); stroke-width: 2; cursor: crosshair; opacity: 0; transition: opacity .15s; }
.bpmn-node:hover .bpmn-port { opacity: 1; }
.bpmn-canvas.connecting { cursor: crosshair; }
.bpmn-empty { padding: 60px 20px; text-align: center; color: var(--ink-muted); }
.bpmn-lane-bg { fill: white; stroke: var(--line-strong); stroke-width: 1; }
.bpmn-lane-bg.alt { fill: rgba(239, 234, 224, 0.4); }
.bpmn-lane-header-bg { fill: var(--bg-sunken); stroke: var(--line-strong); stroke-width: 1; }
.bpmn-lane-label { font-size: 11px; font-weight: 600; fill: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.04em; }
.bpmn-lane-divider { stroke: var(--line-strong); stroke-width: 1; stroke-dasharray: 4,4; }
.bpmn-lane-controls { position: absolute; right: 8px; display: flex; gap: 2px; opacity: 0; transition: opacity .15s; }
.bpmn-lane-row:hover .bpmn-lane-controls { opacity: 1; }
.bpmn-lane-handle { stroke: var(--line-strong); stroke-width: 1; fill: var(--bg-sunken); cursor: ns-resize; }
.bpmn-lane-handle:hover { fill: var(--line-strong); }

/* Tareas */
.task-row { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; padding: 10px 14px; display: grid; grid-template-columns: auto 28px 1fr auto auto auto auto auto; gap: 12px; align-items: center; transition: all .15s; cursor: pointer; }
.task-row:hover { border-color: var(--line-strong); background: var(--bg-sunken); }
.task-row.done { opacity: 0.55; }
.task-row.done .task-title { text-decoration: line-through; }
.task-check { width: 18px; height: 18px; border: 2px solid var(--line-strong); border-radius: 4px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; background: var(--bg-elevated); }
.task-check.checked { background: var(--green); border-color: var(--green); }
.task-check.checked svg { stroke: white; }
.task-prio-dot { width: 8px; height: 8px; border-radius: 999px; flex-shrink: 0; }
.task-title { font-size: 13.5px; font-weight: 500; }
.task-meta { font-size: 11.5px; color: var(--ink-muted); }
.task-tag { background: var(--bg-sunken); color: var(--ink-muted); font-size: 10.5px; padding: 1px 6px; border-radius: 3px; font-weight: 500; }
.tasks-kanban { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.tasks-col { background: var(--bg-sunken); border-radius: 8px; padding: 10px; display: flex; flex-direction: column; gap: 8px; min-height: 400px; }
.tasks-col-header { display: flex; align-items: center; justify-content: space-between; padding: 4px 8px 8px; font-size: 11.5px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .04em; }
.task-kcard { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; padding: 10px; cursor: grab; transition: all .15s; }
.task-kcard:active { cursor: grabbing; }
.task-kcard:hover { border-color: var(--line-strong); transform: translateY(-1px); }
.task-kcard.dragging { opacity: .4; }
.tasks-col.drag-over { background: rgba(30,58,58,.06); }
.subtask-row { display: flex; align-items: center; gap: 8px; padding: 6px 10px; border-radius: 4px; background: var(--bg-sunken); margin-bottom: 4px; }
.subtask-row.done { opacity: 0.55; }
.subtask-row.done .subtask-title { text-decoration: line-through; }
.subtask-title { font-size: 13px; flex: 1; }
.subtask-check { width: 16px; height: 16px; border: 2px solid var(--line-strong); border-radius: 4px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; background: var(--bg-elevated); flex-shrink: 0; }
.subtask-check.checked { background: var(--green); border-color: var(--green); }
.subtask-check.checked svg { stroke: white; }
.task-filters { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; padding: 10px 14px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
.task-filters .search-input { flex: 1; min-width: 200px; }

/* Informes */
.report-card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px; padding: 20px; cursor: pointer; transition: all .15s; }
.report-card:hover { border-color: var(--ink); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,.05); }
.report-icon { width: 44px; height: 44px; background: var(--bg-sunken); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--accent); margin-bottom: 12px; }
.report-preview { background: #ffffff; color: #15110d; padding: 60px 70px; min-height: 60vh; font-family: 'IBM Plex Sans', sans-serif; line-height: 1.55; }
.report-preview h1 { font-family: 'Instrument Serif', Georgia, serif; font-size: 36px; font-weight: 400; margin: 0 0 8px; color: #15110d; }
.report-preview h2 { font-family: 'Instrument Serif', Georgia, serif; font-size: 24px; font-weight: 400; margin: 28px 0 12px; padding-bottom: 6px; border-bottom: 1px solid #c9c0ae; color: #15110d; }
.report-preview h3 { font-size: 15px; font-weight: 600; margin: 18px 0 8px; color: #15110d; text-transform: uppercase; letter-spacing: .04em; }
.report-preview p { margin: 8px 0; font-size: 13px; }
.report-preview table.rep-table { width: 100%; border-collapse: collapse; margin: 12px 0; font-size: 12px; }
.report-preview table.rep-table th { text-align: left; padding: 8px 10px; background: #efeae0; font-weight: 600; border-bottom: 2px solid #15110d; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
.report-preview table.rep-table td { padding: 8px 10px; border-bottom: 1px solid #e3ddd0; vertical-align: top; }
.report-preview .rep-meta { color: #6b6357; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; font-weight: 600; }
.report-preview .rep-summary { background: #efeae0; border-left: 3px solid #15110d; padding: 14px 18px; margin: 16px 0; font-size: 13px; }
.report-preview .rep-kpi-card { background: #f7f4ee; border: 1px solid #e3ddd0; border-radius: 6px; padding: 12px; }
.report-preview .rep-kpi-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin: 12px 0; }
.report-preview .rep-tag { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
.report-preview .rep-tag-green { background: #e8f0e3; color: #4a7c4a; }
.report-preview .rep-tag-yellow { background: #f5ecd0; color: #8a6a1a; }
.report-preview .rep-tag-red { background: #f0dede; color: #a83e3e; }
.report-preview .rep-tag-blue { background: #e0e7ef; color: #3d5a80; }
.report-preview .rep-tag-gray { background: #efeae0; color: #6b6357; }
.report-preview .rep-cover { text-align: center; padding: 80px 40px 60px; border-bottom: 2px solid #15110d; margin-bottom: 30px; }
.report-preview .rep-cover .institution { font-size: 12px; text-transform: uppercase; letter-spacing: .15em; color: #6b6357; margin-bottom: 32px; }
.report-preview .rep-cover h1 { font-size: 48px; margin-bottom: 8px; }
.report-preview .rep-cover .subtitle { font-size: 18px; color: #6b6357; font-style: italic; }
.report-preview .rep-cover .date { margin-top: 40px; font-size: 13px; color: #6b6357; }
.report-preview ul { margin: 8px 0; padding-left: 22px; }
.report-preview li { margin: 3px 0; font-size: 13px; }
.report-preview .page-break { page-break-after: always; height: 0; }

@media print {
  body * { visibility: hidden; }
  #report-print-area, #report-print-area * { visibility: visible; }
  #report-print-area { position: absolute; left: 0; top: 0; width: 100%; }
  #report-print-area .no-print { display: none !important; }
  .report-preview { padding: 30px 40px; }
}

/* Búsqueda global */
.gs-backdrop { position: fixed; inset: 0; background: rgba(15, 11, 7, 0.55); backdrop-filter: blur(6px); z-index: 300; display: flex; align-items: flex-start; justify-content: center; padding-top: 12vh; animation: fadeIn .15s ease; }
.gs-panel { background: var(--bg-elevated); border-radius: 12px; width: 100%; max-width: 640px; max-height: 70vh; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,.3); animation: slideUp .2s ease; }
.gs-input-wrap { padding: 14px 18px; border-bottom: 1px solid var(--line); display: flex; align-items: center; gap: 12px; }
.gs-input-wrap svg { color: var(--ink-muted); flex-shrink: 0; }
.gs-input { flex: 1; border: none; outline: none; background: transparent; font-size: 15px; font-family: inherit; color: var(--ink); }
.gs-input::placeholder { color: var(--ink-subtle); }
.gs-hint { font-size: 11px; color: var(--ink-subtle); padding: 2px 6px; background: var(--bg-sunken); border-radius: 4px; font-family: 'JetBrains Mono', monospace; }
.gs-results { flex: 1; overflow-y: auto; padding: 6px 0; }
.gs-section-header { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-subtle); padding: 10px 18px 4px; }
.gs-item { display: flex; align-items: center; gap: 12px; padding: 10px 18px; cursor: pointer; transition: background .1s; }
.gs-item:hover, .gs-item.active { background: var(--bg-sunken); }
.gs-item-icon { width: 32px; height: 32px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: white; font-size: 14px; }
.gs-item-body { flex: 1; min-width: 0; }
.gs-item-title { font-size: 13.5px; font-weight: 500; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.gs-item-meta { font-size: 11.5px; color: var(--ink-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 1px; }
.gs-item .gs-code { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted); padding: 1px 5px; background: var(--bg-sunken); border-radius: 3px; }
.gs-empty { padding: 40px 20px; text-align: center; color: var(--ink-muted); font-size: 13px; }
.gs-footer { padding: 8px 18px; border-top: 1px solid var(--line); display: flex; justify-content: space-between; align-items: center; font-size: 11px; color: var(--ink-subtle); }
.gs-footer-key { font-family: 'JetBrains Mono', monospace; background: var(--bg-sunken); padding: 1px 5px; border-radius: 3px; margin: 0 3px; }
.gs-trigger { display: flex; align-items: center; gap: 8px; padding: 6px 10px; margin: 0 8px 6px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 6px; cursor: pointer; transition: all .15s; }
.gs-trigger:hover { border-color: var(--line-strong); background: var(--bg-sunken); }
.gs-trigger svg { color: var(--ink-muted); flex-shrink: 0; }
.gs-trigger-text { flex: 1; font-size: 12px; color: var(--ink-muted); }
.gs-trigger-kbd { font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 1px 5px; background: var(--bg-sunken); border-radius: 3px; color: var(--ink-muted); }

/* Modo presentación */
body.present-mode .sidebar { display: none; }
body.present-mode #modal-root { display: none; }
body.present-mode main { background: var(--bg); }
body.present-mode .present-header { display: flex !important; }
body.present-mode .present-hide { display: none !important; }
body.present-mode .kpi-value { font-size: 42px; }
body.present-mode .kpi-label { font-size: 13px; }
body.present-mode .font-serif.text-2xl { font-size: 36px; }
body.present-mode .font-serif.text-xl { font-size: 28px; }
body.present-mode .font-serif.text-4xl { font-size: 64px; }
body.present-mode .card { padding: 24px; }
body.present-mode .card.kpi-card { padding: 24px; }
body.present-mode .text-sm, body.present-mode .text-xs { font-size: 14px; }
.present-bar { display: none; position: fixed; top: 0; left: 0; right: 0; background: var(--ink); color: var(--bg); padding: 10px 20px; z-index: 90; align-items: center; justify-content: space-between; }
body.present-mode .present-bar { display: flex; }
.present-bar .present-title { font-family: 'Instrument Serif', serif; font-size: 20px; }
.present-bar button { background: rgba(255,255,255,.1); color: var(--bg); padding: 6px 14px; border-radius: 6px; font-size: 12px; border: 1px solid rgba(255,255,255,.2); cursor: pointer; }
.present-bar button:hover { background: rgba(255,255,255,.18); }
body.present-mode main { padding-top: 50px; }

/* Vista de impresión generalizada */
@media print {
  @page { margin: 1.5cm; size: A4 portrait; }
  body { background: white !important; color: black; }
  body::before { display: none; }
  .sidebar, .present-bar, .modal-backdrop:not(#report-print-area), .toast-container, #gs-root, .no-print { display: none !important; }
  main { overflow: visible !important; height: auto !important; }
  .card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
  .kanban-board, .bsc-grid, .tasks-kanban, .sipoc-grid { display: block !important; }
  .kanban-col, .bsc-quadrant, .sipoc-col { page-break-inside: avoid; margin-bottom: 12px; }
}

/* Filtros/ordenamiento en tablas */
table.data-table th.sortable { cursor: pointer; user-select: none; position: relative; padding-right: 22px; }
table.data-table th.sortable:hover { background: var(--line); }
table.data-table th.sortable .sort-ind { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); opacity: 0.4; font-size: 10px; }
table.data-table th.sortable.sorted .sort-ind { opacity: 1; color: var(--ink); }
.table-toolbar { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px 8px 0 0; padding: 10px 14px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; border-bottom: none; }
.table-toolbar .search-mini { flex: 1; min-width: 180px; }
.table-toolbar .table-info { font-size: 11.5px; color: var(--ink-muted); margin-left: auto; }
.table-toolbar + .card, .table-toolbar + table, .table-toolbar + .overflow-x-auto { border-top-left-radius: 0; border-top-right-radius: 0; }

/* Dashboard personalizable */
.dash-block-config { display: flex; align-items: center; gap: 10px; padding: 8px 10px; background: var(--bg-sunken); border-radius: 6px; margin-bottom: 6px; }
.dash-block-config.disabled { opacity: 0.55; }
.dash-block-config-name { flex: 1; font-size: 13px; }
.dash-block-config-desc { font-size: 11px; color: var(--ink-muted); }
.dash-block-config .order-controls { display: flex; gap: 2px; }
.dash-block-config .order-controls button { width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 4px; cursor: pointer; font-size: 12px; color: var(--ink-muted); }
.dash-block-config .order-controls button:hover { background: var(--bg); color: var(--ink); }
.dash-block-config .order-controls button:disabled { opacity: 0.3; cursor: not-allowed; }

/* Vistas impresas por módulo */
.print-only { display: none; }
@media print {
  .print-only { display: block !important; }
  .print-hide { display: none !important; }
  .print-list-item { page-break-inside: avoid; border: 1px solid #ddd !important; padding: 12px !important; margin-bottom: 10px !important; background: white !important; }
  .print-page-header { display: flex !important; justify-content: space-between; padding-bottom: 12px; margin-bottom: 16px; border-bottom: 2px solid #15110d; }
  .print-page-header h1 { font-family: 'Instrument Serif', serif; font-size: 24pt; margin: 0; }
  .print-page-header .meta { font-size: 10pt; color: #6b6357; text-align: right; }
}

@media (max-width: 900px) {
  .sidebar { display: none; }
  .kanban-board { grid-template-columns: 1fr; }
  .tasks-kanban { grid-template-columns: 1fr; }
  .bsc-grid { grid-template-columns: 1fr; }
  .sipoc-grid { grid-template-columns: 1fr; }
  .ei-grid { grid-template-columns: 1fr; }
}

/* ============ Módulo Datos (importación, profilado, limpieza) ============ */

/* Drop zone para importar archivos */
.viz-drop-zone { border: 2px dashed var(--line-strong); border-radius: 12px; padding: 40px 24px; text-align: center; background: var(--bg-elevated); cursor: pointer; transition: all .2s; }
.viz-drop-zone:hover, .viz-drop-zone.drag-over { border-color: var(--ink); background: var(--bg-sunken); transform: translateY(-1px); }
.viz-drop-zone .drop-icon { width: 56px; height: 56px; margin: 0 auto 14px; background: var(--ink); color: var(--bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.viz-drop-zone .drop-title { font-family: 'Instrument Serif', serif; font-size: 22px; margin-bottom: 6px; color: var(--ink); }
.viz-drop-zone .drop-subtitle { font-size: 12.5px; color: var(--ink-muted); line-height: 1.5; max-width: 480px; margin: 0 auto 12px; }
.viz-drop-zone .drop-formats { font-size: 11px; color: var(--ink-subtle); margin-top: 10px; font-family: 'JetBrains Mono', monospace; }
.viz-drop-zone input[type=file] { display: none; }

/* Vista previa de importación */
.viz-import-preview { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 10px; overflow: hidden; }
.viz-import-header { padding: 14px 18px; border-bottom: 1px solid var(--line); background: var(--bg-sunken); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
.viz-import-header .file-info { display: flex; align-items: center; gap: 12px; }
.viz-import-header .file-icon { width: 36px; height: 36px; background: linear-gradient(135deg, #2d5454, #4a7474); color: white; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700; }
.viz-import-header .file-name { font-family: 'Instrument Serif', serif; font-size: 18px; line-height: 1; }
.viz-import-header .file-meta { font-size: 11px; color: var(--ink-muted); margin-top: 3px; }
.viz-sheets-tabs { display: flex; gap: 4px; padding: 8px 14px; background: var(--bg-elevated); border-bottom: 1px solid var(--line); overflow-x: auto; }
.viz-sheet-tab { padding: 6px 14px; border: 1px solid var(--line); background: var(--bg-elevated); border-radius: 6px; font-size: 12px; cursor: pointer; white-space: nowrap; transition: all .15s; }
.viz-sheet-tab:hover { background: var(--bg-sunken); }
.viz-sheet-tab.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }
.viz-sheet-tab .sheet-count { opacity: 0.6; font-family: 'JetBrains Mono', monospace; font-size: 10px; margin-left: 4px; }
.viz-import-options { padding: 12px 18px; background: var(--bg); display: flex; gap: 16px; align-items: center; flex-wrap: wrap; font-size: 12.5px; border-bottom: 1px solid var(--line); }
.viz-import-options label { display: flex; align-items: center; gap: 6px; cursor: pointer; color: var(--ink-muted); }
.viz-import-options label:hover { color: var(--ink); }
.viz-import-options input[type=checkbox] { cursor: pointer; }
.viz-import-options .input-mini { padding: 3px 8px; border: 1px solid var(--line); border-radius: 4px; font-size: 12px; background: var(--bg-elevated); }
.viz-import-table-wrap { max-height: 360px; overflow: auto; background: var(--bg-elevated); }
.viz-import-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.viz-import-table th, .viz-import-table td { border: 1px solid var(--line); padding: 6px 10px; text-align: left; white-space: nowrap; }
.viz-import-table th { background: var(--bg-sunken); position: sticky; top: 0; z-index: 2; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; color: var(--ink-muted); }
.viz-import-table tbody tr:nth-child(even) td { background: rgba(0,0,0,.012); }
.viz-import-table .row-num { background: var(--bg-sunken); text-align: center; color: var(--ink-subtle); font-family: 'JetBrains Mono', monospace; font-size: 10.5px; min-width: 36px; }
.viz-import-actions { padding: 14px 18px; background: var(--bg-sunken); border-top: 1px solid var(--line); display: flex; gap: 10px; justify-content: flex-end; align-items: center; }
.viz-import-actions .import-info { margin-right: auto; font-size: 12px; color: var(--ink-muted); }

/* Panel de profilado de columnas */
.col-profile-trigger { cursor: pointer; transition: color .15s; }
.col-profile-trigger:hover { color: var(--ink) !important; }
.col-profile-panel { position: absolute; background: var(--bg-elevated); border: 1px solid var(--line-strong); border-radius: 10px; box-shadow: 0 8px 32px rgba(0,0,0,.12); padding: 16px; width: 320px; z-index: 100; max-height: 480px; overflow-y: auto; }
.col-profile-panel .panel-close { position: absolute; top: 10px; right: 10px; width: 22px; height: 22px; border-radius: 50%; background: var(--bg-sunken); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--ink-muted); }
.col-profile-panel .panel-close:hover { background: var(--ink); color: var(--bg); }
.col-profile-panel .panel-title { font-family: 'Instrument Serif', serif; font-size: 20px; margin-bottom: 4px; color: var(--ink); padding-right: 30px; }
.col-profile-panel .panel-type { font-size: 10px; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-muted); margin-bottom: 12px; font-weight: 600; }
.col-profile-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--line); }
.col-profile-stats .stat-box { background: var(--bg-sunken); padding: 8px 10px; border-radius: 6px; }
.col-profile-stats .stat-label { font-size: 9.5px; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-muted); font-weight: 600; margin-bottom: 2px; }
.col-profile-stats .stat-value { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--ink); }
.col-profile-stats .stat-value.warning { color: var(--warm); }
.col-profile-stats .stat-value.error { color: var(--red); }
.col-profile-actions { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--line); }
.col-profile-actions button { padding: 7px 10px; background: var(--bg-sunken); border: 1px solid var(--line); border-radius: 5px; font-size: 12px; text-align: left; cursor: pointer; transition: all .15s; color: var(--ink); display: flex; align-items: center; gap: 8px; }
.col-profile-actions button:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }
.col-profile-actions button .action-icon { width: 14px; height: 14px; flex-shrink: 0; opacity: 0.7; }
.col-profile-actions button:hover .action-icon { opacity: 1; }
.col-profile-actions button.danger { color: var(--red); }
.col-profile-actions button.danger:hover { background: var(--red); color: white; border-color: var(--red); }
.col-profile-distribution { font-size: 11.5px; }
.col-profile-distribution .dist-title { font-size: 10px; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-muted); font-weight: 600; margin-bottom: 6px; }
.col-profile-distribution .dist-row { display: flex; align-items: center; gap: 8px; padding: 3px 0; }
.col-profile-distribution .dist-label { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.col-profile-distribution .dist-bar-bg { width: 80px; height: 4px; background: var(--bg-sunken); border-radius: 2px; overflow: hidden; flex-shrink: 0; }
.col-profile-distribution .dist-bar-fill { height: 100%; background: var(--accent); border-radius: 2px; }
.col-profile-distribution .dist-count { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; color: var(--ink-muted); min-width: 32px; text-align: right; }

/* Indicadores de tipo en header de columna del dataset */
.ss-table th .ss-col-stats { font-size: 9px; color: var(--ink-subtle); font-weight: 500; text-transform: none; letter-spacing: 0; margin-top: 1px; }

/* Banner de limpieza aplicada */
.viz-action-banner { background: linear-gradient(135deg, var(--blue) 0%, #5a7d9c 100%); color: white; padding: 10px 14px; border-radius: 8px; font-size: 12.5px; display: flex; align-items: center; gap: 10px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(61, 90, 128, 0.25); }
.viz-action-banner button { background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); padding: 3px 10px; border-radius: 4px; cursor: pointer; font-size: 11px; }
.viz-action-banner button:hover { background: rgba(255,255,255,0.3); }

/* ============ Constructor de tabla pivote ============ */
.pivot-builder { display: grid; grid-template-columns: 280px 1fr; gap: 16px; height: calc(100vh - 220px); }
.pivot-fields-panel { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 10px; padding: 14px; overflow-y: auto; }
.pivot-fields-title { font-size: 10px; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-muted); font-weight: 600; margin-bottom: 8px; }
.pivot-available-fields { display: flex; flex-direction: column; gap: 4px; margin-bottom: 18px; }
.pivot-field { background: var(--bg-sunken); border: 1px solid var(--line); padding: 7px 10px; border-radius: 5px; cursor: grab; font-size: 12px; display: flex; align-items: center; gap: 8px; transition: all .15s; }
.pivot-field:hover { background: var(--bg-elevated); border-color: var(--line-strong); }
.pivot-field.dragging { opacity: 0.4; }
.pivot-field-icon { font-family: 'JetBrains Mono', monospace; font-size: 9px; padding: 2px 5px; background: var(--bg-elevated); border-radius: 3px; color: var(--ink-muted); flex-shrink: 0; }
.pivot-field-icon.number { background: var(--green); color: white; }
.pivot-field-icon.date { background: var(--blue); color: white; }
.pivot-field-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.pivot-dropzone { background: var(--bg-sunken); border: 1.5px dashed var(--line-strong); border-radius: 6px; padding: 10px; min-height: 48px; transition: all .15s; }
.pivot-dropzone-label { font-size: 10px; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-muted); font-weight: 600; margin-bottom: 6px; display: block; }
.pivot-dropzone.drag-over { border-color: var(--ink); background: var(--bg-elevated); }
.pivot-dropzone .pivot-field { background: var(--ink); color: var(--bg); border-color: var(--ink); }
.pivot-dropzone .pivot-field-icon { background: rgba(255,255,255,0.15); color: white; }
.pivot-dropzone-empty { text-align: center; color: var(--ink-subtle); font-size: 11.5px; padding: 8px; font-style: italic; }
.pivot-dropzone .field-remove { background: rgba(255,255,255,0.15); color: white; border: none; width: 18px; height: 18px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 12px; }
.pivot-dropzone .field-remove:hover { background: rgba(255,255,255,0.3); }

.pivot-agg-select { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; font-size: 10px; padding: 2px 4px; border-radius: 3px; cursor: pointer; }
.pivot-agg-select option { background: var(--bg-elevated); color: var(--ink); }

.pivot-result-panel { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 10px; padding: 16px; overflow: auto; display: flex; flex-direction: column; }
.pivot-result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--line); }
.pivot-result-title { font-family: 'Instrument Serif', serif; font-size: 20px; }
.pivot-result-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; padding: 40px; text-align: center; color: var(--ink-muted); }
.pivot-result-empty .icon-wrap { width: 56px; height: 56px; background: var(--bg-sunken); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; color: var(--ink-subtle); }
.pivot-result-empty .empty-title { font-family: 'Instrument Serif', serif; font-size: 22px; color: var(--ink); margin-bottom: 8px; }
.pivot-result-empty .empty-text { font-size: 13px; line-height: 1.5; max-width: 360px; }
.pivot-table-wrap { flex: 1; overflow: auto; border: 1px solid var(--line); border-radius: 6px; }
.pivot-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.pivot-table th, .pivot-table td { border: 1px solid var(--line); padding: 7px 10px; text-align: left; }
.pivot-table th { background: var(--bg-sunken); font-size: 11px; text-transform: uppercase; letter-spacing: .04em; color: var(--ink-muted); position: sticky; top: 0; z-index: 2; }
.pivot-table th.col-header { text-align: center; }
.pivot-table td.value-cell { font-family: 'JetBrains Mono', monospace; text-align: right; font-variant-numeric: tabular-nums; }
.pivot-table td.row-header { background: var(--bg-sunken); font-weight: 500; color: var(--ink); }
.pivot-table tr.total-row td { background: rgba(30,58,58,0.05); font-weight: 600; border-top: 2px solid var(--line-strong); }
.pivot-table td.total-cell { background: rgba(30,58,58,0.05); font-weight: 600; }
.pivot-table tr:hover td:not(.row-header):not(.total-cell) { background: rgba(0,0,0,.02); }
.pivot-table td.value-cell.heat-1 { background: rgba(74, 124, 74, 0.05); }
.pivot-table td.value-cell.heat-2 { background: rgba(74, 124, 74, 0.15); }
.pivot-table td.value-cell.heat-3 { background: rgba(74, 124, 74, 0.3); }
.pivot-table td.value-cell.heat-4 { background: rgba(74, 124, 74, 0.5); color: white; }
.pivot-table td.value-cell.heat-5 { background: rgba(74, 124, 74, 0.7); color: white; }

.pivot-dataset-selector { padding: 10px 14px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 8px; margin-bottom: 14px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

@media (max-width: 1024px) {
  .pivot-builder { grid-template-columns: 1fr; height: auto; }
}

/* ============ KPIs: vista Lista y zoom de indicador ============ */
.kpi-table-row .kpi-status-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; vertical-align: middle; margin-right: 6px; }
.kpi-status-dot.green { background: var(--green); }
.kpi-status-dot.yellow { background: var(--warm); }
.kpi-status-dot.red { background: var(--red); }
.kpi-status-dot.gray { background: var(--ink-subtle); }
.kpi-list-progress-bar { display: inline-block; width: 80px; height: 6px; background: var(--bg-sunken); border-radius: 3px; overflow: hidden; vertical-align: middle; margin-right: 6px; }
