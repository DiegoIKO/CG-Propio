  const st = window._chartFormState;
  const ds = state.datasets.find(d => d.id === st.datasetId);
  if (!ds) return '<div class="text-sm" style="color:var(--ink-muted)">Selecciona un dataset</div>';
  
  const cols = ds.columns.map(c => c.name);
  const suggestedType = suggestChartType(ds, st.xField, st.yFields);
  
  return `<div class="grid grid-cols-3 gap-3 mb-3">
    <div>${field('Eje X (categorías)', `<select class="select" id="f-ch-x" onchange="window._chartFormState.xField=this.value; refreshChartFormConfig()">${cols.map(col => {
      const c = ds.columns.find(cc => cc.name === col);
      const typeLabel = c?.type === 'number' ? '(123)' : c?.type === 'date' ? '(📅)' : '(Aa)';
      return `<option value="${escapeHtml(col)}" ${col === st.xField ? 'selected' : ''}>${escapeHtml(col)} ${typeLabel}</option>`;
    }).join('')}</select>`)}</div>
    <div>${field('Agregar Y por X', `<select class="select" onchange="window._chartFormState.aggregation=this.value">
      <option value="sum" ${(st.aggregation || 'sum') === 'sum' ? 'selected' : ''}>Suma</option>
      <option value="avg" ${st.aggregation === 'avg' ? 'selected' : ''}>Promedio</option>
      <option value="count" ${st.aggregation === 'count' ? 'selected' : ''}>Conteo</option>
      <option value="distinct" ${st.aggregation === 'distinct' ? 'selected' : ''}>Únicos</option>
      <option value="min" ${st.aggregation === 'min' ? 'selected' : ''}>Mínimo</option>
      <option value="max" ${st.aggregation === 'max' ? 'selected' : ''}>Máximo</option>
      <option value="none" ${st.aggregation === 'none' ? 'selected' : ''}>Sin agrupar</option>
    </select>`)}</div>
    <div>
      <label class="form-label">Series Y (valores a medir)</label>
      <div class="space-y-1 p-2 border rounded" style="border-color:var(--line-strong); max-height:140px; overflow-y:auto">
        ${cols.map(col => {
          const c = ds.columns.find(cc => cc.name === col);
          const typeIcon = c?.type === 'number' ? '123' : c?.type === 'date' ? '📅' : 'Aa';
          const isNumber = c?.type === 'number';
          return `<label class="flex items-center gap-2 text-sm py-1" style="${!isNumber ? 'opacity:0.6' : ''}"><input type="checkbox" value="${escapeHtml(col)}" ${st.yFields.includes(col) ? 'checked' : ''} onchange="toggleChartYField('${escapeHtml(col).replace(/'/g, "\\'")}', this.checked)"><span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-muted)">${typeIcon}</span><span>${escapeHtml(col)}</span></label>`;
        }).join('')}
      </div>
    </div>
  </div>
  
  <div>
    <label class="form-label">Tipo de gráfico</label>
    <div class="chart-type-gallery">
      ${CHART_TYPES.map(t => {
        const isSelected = st.type === t.value;
        const isSuggested = t.value === suggestedType;
        const isDisabled = st.yFields.length < (t.minSeries || 1);
        const cls = `chart-type-card ${isSelected ? 'selected' : ''} ${isSuggested && !isSelected ? 'recommended' : ''} ${isDisabled ? 'disabled' : ''}`;
        return `<div class="${cls}" onclick="${isDisabled ? '' : `selectChartFormType('${t.value}')`}" title="${escapeHtml(t.desc)}${isDisabled ? ' · Requiere al menos ' + t.minSeries + ' series' : ''}">
          <div class="chart-type-icon">${CHART_TYPE_ICONS[t.icon] || ''}</div>
          <div class="chart-type-label">${escapeHtml(t.label)}</div>
          <div class="chart-type-desc">${escapeHtml(t.desc)}</div>
        </div>`;
      }).join('')}
    </div>
  </div>
  
  <div class="text-xs mt-3 p-2 rounded" style="background:var(--bg-sunken); color:var(--ink-muted); line-height: 1.5">
    <strong>Tip:</strong> Los gráficos de torta y dona funcionan mejor con una sola serie. Las barras apiladas y áreas apiladas requieren dos o más. La dispersión necesita que el eje X sea numérico.
  </div>`;
}

function onChartFormDsChange(dsId) {
  const ds = state.datasets.find(d => d.id === dsId);
  if (!ds) return;
  window._chartFormState.datasetId = dsId;
  window._chartFormState.xField = ds.columns[0]?.name || '';
  window._chartFormState.yFields = [];
  refreshChartFormConfig();
}

function selectChartFormType(type) {
  window._chartFormState.type = type;
  refreshChartFormConfig();
}

function toggleChartYField(field, checked) {
  const st = window._chartFormState;
  if (checked) {
    if (!st.yFields.includes(field)) st.yFields.push(field);
  } else {
    st.yFields = st.yFields.filter(f => f !== field);
  }
  refreshChartFormConfig();
}

function refreshChartFormConfig() {
  const el = document.getElementById('f-ch-config');
  if (el) el.innerHTML = renderChartFormConfig();
}

function deleteChart(id) {
  if (!confirm('¿Eliminar gráfico?')) return;
  state.charts = state.charts.filter(c => c.id !== id);
  save(); renderVisualizaciones(); toast('Eliminado');
}


