.kpi-zoom-history table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
.kpi-zoom-history th, .kpi-zoom-history td { border-bottom: 1px solid var(--line); padding: 8px 10px; text-align: left; }
.kpi-zoom-history th { font-size: 10px; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-muted); font-weight: 600; }
.kpi-zoom-history .measure-comment { font-style: italic; color: var(--ink-muted); font-size: 11.5px; padding: 4px 12px 8px 28px; background: rgba(0,0,0,0.015); border-left: 2px solid var(--line-strong); }
